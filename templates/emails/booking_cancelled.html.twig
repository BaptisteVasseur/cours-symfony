<!DOCTYPE html>
<html lang="fr">
<body style="font-family: sans-serif; color: #333; max-width: 600px; margin: 0 auto; padding: 24px;">

<div style="background: #dc2626; padding: 20px 24px; border-radius: 8px 8px 0 0;">
    <h1 style="color: white; margin: 0; font-size: 20px;">Réservation annulée</h1>
</div>

<div style="background: #f9f9f9; padding: 24px; border: 1px solid #e5e5e5; border-top: 0;">
    <p>La réservation pour le logement <strong>{{ booking.listing.title }}</strong> a été annulée
        {% if cancelledBy == 'host' %}par l'hôte{% else %}par le voyageur{% endif %}.
    </p>

    <div style="background: #fff3cd; border: 1px solid #ffc107; border-radius: 6px; padding: 12px 16px; margin: 16px 0;">
        <strong>Motif :</strong> {{ reason }}
    </div>

    <table style="width: 100%; border-collapse: collapse; margin: 16px 0;">
        <tr>
            <td style="padding: 8px; border-bottom: 1px solid #eee; color: #666;">Logement</td>
            <td style="padding: 8px; border-bottom: 1px solid #eee;">{{ booking.listing.title }}</td>
        </tr>
        <tr>
            <td style="padding: 8px; border-bottom: 1px solid #eee; color: #666;">Arrivée prévue</td>
            <td style="padding: 8px; border-bottom: 1px solid #eee;">{{ booking.startDate|date('d/m/Y') }}</td>
        </tr>
        <tr>
            <td style="padding: 8px; color: #666;">Départ prévu</td>
            <td style="padding: 8px;">{{ booking.endDate|date('d/m/Y') }}</td>
        </tr>
    </table>

    <p style="margin-top: 24px; color: #999; font-size: 12px;">Airbnb Clone — Cet email a été envoyé automatiquement.</p>
</div>

</body>
</html>
