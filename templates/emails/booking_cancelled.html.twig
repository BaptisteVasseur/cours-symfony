{% extends 'emails/_base.html.twig' %}

{% block body %}
    <h1 style="font-size:18px;margin:0 0 16px;">Réservation annulée</h1>
    <p style="margin:0 0 12px;">Bonjour {{ recipient.firstName }},</p>
    <p style="margin:0 0 16px;">
        La réservation concernant <strong>{{ booking.listing.title }}</strong>
        ({{ booking.checkIn|date('d/m/Y') }} → {{ booking.checkOut|date('d/m/Y') }}) a été annulée.
        Les dates correspondantes sont de nouveau disponibles.
    </p>

    {% if booking.cancellationReason %}
        <div style="background:#fafafa;border-left:4px solid #71717a;padding:12px 16px;margin:16px 0;font-size:14px;">
            <strong>Motif :</strong> {{ booking.cancellationReason }}
            {% if booking.cancelledBy %}<br><span style="color:#71717a;">À l'initiative de {{ booking.cancelledBy.firstName }} {{ booking.cancelledBy.lastName }}.</span>{% endif %}
        </div>
    {% endif %}

    <a href="http://localhost:8089/my-bookings" style="display:inline-block;background:#FF385C;color:#ffffff;text-decoration:none;padding:12px 22px;border-radius:8px;font-weight:bold;">
        Voir mes réservations
    </a>
{% endblock %}
