<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Réservation annulée par le voyageur</title>
</head>
<body style="font-family: Arial, sans-serif; color: #333; max-width: 600px; margin: 0 auto; padding: 20px;">
    <h1 style="color: #e74c3c;">Réservation annulée</h1>

    <p>Bonjour {% if reservation.property.host.profile %}{{ reservation.property.host.profile.firstName }}{% else %}{{ reservation.property.host.email }}{% endif %},</p>

    <p>Le voyageur <strong>
        {% if reservation.guest.profile %}
            {{ reservation.guest.profile.firstName }} {{ reservation.guest.profile.lastName }}
        {% else %}
            {{ reservation.guest.email }}
        {% endif %}
    </strong> a annulé sa réservation pour le logement <strong>{{ reservation.property.title }}</strong>.</p>

    <table style="width: 100%; border-collapse: collapse; margin: 20px 0;">
        <tr>
            <td style="padding: 8px; border: 1px solid #ddd; background: #f9f9f9;"><strong>Arrivée prévue</strong></td>
            <td style="padding: 8px; border: 1px solid #ddd;">{{ reservation.checkinDate|date('d/m/Y') }}</td>
        </tr>
        <tr>
            <td style="padding: 8px; border: 1px solid #ddd; background: #f9f9f9;"><strong>Départ prévu</strong></td>
            <td style="padding: 8px; border: 1px solid #ddd;">{{ reservation.checkoutDate|date('d/m/Y') }}</td>
        </tr>
        <tr>
            <td style="padding: 8px; border: 1px solid #ddd; background: #f9f9f9;"><strong>Motif</strong></td>
            <td style="padding: 8px; border: 1px solid #ddd;">{{ reservation.cancellationReason }}</td>
        </tr>
    </table>

    <p style="background: #fff3cd; padding: 12px; border-left: 4px solid #ffc107;">
        Ces dates sont à nouveau disponibles pour de nouvelles réservations.
    </p>
</body>
</html>
