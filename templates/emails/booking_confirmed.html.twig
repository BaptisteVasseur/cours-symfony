{% extends 'emails/_base.html.twig' %}

{% block body %}
    <h1 style="font-size:18px;margin:0 0 16px;">Réservation confirmée ✅</h1>
    <p style="margin:0 0 12px;">Bonjour {{ recipient.firstName }},</p>
    <p style="margin:0 0 16px;">
        {% if isHost %}
            La réservation de {{ booking.guest.firstName }} {{ booking.guest.lastName }} pour votre logement
            <strong>{{ booking.listing.title }}</strong> est confirmée.
        {% else %}
            Votre séjour à <strong>{{ booking.listing.title }}</strong> est confirmé. Bon voyage !
        {% endif %}
    </p>

    <table cellpadding="0" cellspacing="0" style="width:100%;font-size:14px;border-collapse:collapse;margin:16px 0;">
        <tr><td style="padding:6px 0;color:#71717a;">Arrivée</td><td style="padding:6px 0;text-align:right;">{{ booking.checkIn|date('d/m/Y') }}</td></tr>
        <tr><td style="padding:6px 0;color:#71717a;">Départ</td><td style="padding:6px 0;text-align:right;">{{ booking.checkOut|date('d/m/Y') }}</td></tr>
        <tr><td style="padding:6px 0;color:#71717a;">Nuits</td><td style="padding:6px 0;text-align:right;">{{ booking.nightsCount }}</td></tr>
        <tr><td style="padding:6px 0;color:#71717a;">Voyageurs</td><td style="padding:6px 0;text-align:right;">{{ booking.guestsCount }}</td></tr>
        {% if isHost %}
            <tr><td style="padding:6px 0;color:#71717a;">Contact voyageur</td><td style="padding:6px 0;text-align:right;">{{ booking.guest.email }}</td></tr>
        {% endif %}
        <tr><td style="padding:6px 0;color:#71717a;border-top:1px solid #e4e4e7;">Total</td><td style="padding:6px 0;text-align:right;font-weight:bold;border-top:1px solid #e4e4e7;">{{ booking.totalAmount }} {{ booking.currency }}</td></tr>
    </table>

    <a href="http://localhost:8089/my-bookings" style="display:inline-block;background:#FF385C;color:#ffffff;text-decoration:none;padding:12px 22px;border-radius:8px;font-weight:bold;">
        Voir la réservation
    </a>
{% endblock %}
