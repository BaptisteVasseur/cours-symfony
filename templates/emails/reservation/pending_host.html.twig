<!DOCTYPE html>
<html lang="fr">
<body style="font-family: sans-serif; color: #222;">
    <h1>Nouvelle demande de réservation</h1>
    <p>Bonjour {{ host.profile ? host.profile.firstName : host.email }},</p>
    <p>
        <strong>{{ guest.profile ? (guest.profile.firstName ~ ' ' ~ guest.profile.lastName)|trim : guest.email }}</strong>
        souhaite réserver <strong>{{ property.title }}</strong>.
    </p>
    <ul>
        <li>Arrivée : {{ reservation.checkinDate|date('d/m/Y') }}</li>
        <li>Départ : {{ reservation.checkoutDate|date('d/m/Y') }}</li>
        <li>Voyageurs : {{ reservation.guestsCount }}</li>
        <li>Total : {{ reservation.totalPrice }} {{ reservation.currency }}</li>
    </ul>
    <p><a href="{{ manageUrl }}">Gérer les demandes en attente</a></p>
</body>
</html>
