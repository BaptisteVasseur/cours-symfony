{% extends 'emails/layout.html.twig' %}

{% set guestName = guest.profile and (guest.profile.firstName or guest.profile.lastName)
    ? (guest.profile.firstName ~ ' ' ~ guest.profile.lastName)|trim
    : guest.email %}

{% block content %}
    <h1 style="font-size:20px;margin:0 0 16px;">Demande de réservation refusée</h1>
    <p style="margin:0 0 16px;line-height:1.5;">
        Bonjour {{ guestName }}, l'hôte a malheureusement refusé votre demande de réservation pour
        <strong>{{ property.title }}</strong>.
    </p>

    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:0 0 24px;font-size:14px;">
        <tr><td style="padding:6px 0;color:#6b7280;width:160px;">Référence</td><td style="padding:6px 0;font-family:monospace;">{{ reservation.id }}</td></tr>
        <tr><td style="padding:6px 0;color:#6b7280;">Logement</td><td style="padding:6px 0;font-weight:bold;">{{ property.title }}</td></tr>
        <tr><td style="padding:6px 0;color:#6b7280;">Arrivée</td><td style="padding:6px 0;">{{ reservation.checkinDate|date('d/m/Y') }}</td></tr>
        <tr><td style="padding:6px 0;color:#6b7280;">Départ</td><td style="padding:6px 0;">{{ reservation.checkoutDate|date('d/m/Y') }}</td></tr>
    </table>

    <h2 style="font-size:16px;margin:0 0 8px;">Motif communiqué par l'hôte</h2>
    <div style="background-color:#fef2f2;border:1px solid #fecaca;border-radius:8px;padding:16px;margin-bottom:24px;font-size:14px;color:#991b1b;line-height:1.5;">
        {{ reason|nl2br }}
    </div>

    <p style="margin:0 0 16px;line-height:1.5;font-size:14px;">
        Vous n'avez pas été débité. Vous pouvez chercher d'autres logements disponibles sur la même période.
    </p>

    <a href="{{ reservationUrl }}" style="display:inline-block;background-color:#e11d48;color:#ffffff;text-decoration:none;font-weight:bold;padding:12px 24px;border-radius:8px;">
        Voir le détail
    </a>
{% endblock %}
