<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Confirmation de réservation</title>
</head>
<body style="font-family: sans-serif; color: #374151; background: #f9fafb; margin: 0; padding: 0;">
<table width="100%" cellpadding="0" cellspacing="0" style="background:#f9fafb; padding: 40px 0;">
    <tr>
        <td align="center">
            <table width="600" cellpadding="0" cellspacing="0" style="background:#ffffff; border-radius: 12px; overflow: hidden; box-shadow: 0 1px 3px rgba(0,0,0,.1);">
                <tr>
                    <td style="background:#FF385C; padding: 24px 32px;">
                        <h1 style="margin:0; color:#ffffff; font-size: 22px;">StayEasy</h1>
                    </td>
                </tr>
                <tr>
                    <td style="padding: 32px;">
                        <h2 style="margin: 0 0 8px; font-size: 20px;">Bonjour {{ guestName }},</h2>
                        {% if reservation.status == 'confirmed' %}
                            <p style="color:#059669; font-weight: 600; font-size: 16px; margin: 0 0 24px;">
                                ✅ Votre réservation est <strong>confirmée</strong> !
                            </p>
                        {% else %}
                            <p style="color:#d97706; font-weight: 600; font-size: 16px; margin: 0 0 24px;">
                                ⏳ Votre demande de réservation est <strong>en attente</strong> de confirmation par l'hôte.
                            </p>
                        {% endif %}
                        <table width="100%" cellpadding="0" cellspacing="0" style="background:#f3f4f6; border-radius: 8px; margin-bottom: 24px;">
                            <tr>
                                <td style="padding: 20px;">
                                    <p style="margin: 0 0 6px; font-size: 15px;"><strong>Logement :</strong> {{ property.title }}</p>
                                    <p style="margin: 0 0 6px; font-size: 15px;"><strong>Arrivée :</strong> {{ reservation.checkinDate|date('d/m/Y') }}</p>
                                    <p style="margin: 0 0 6px; font-size: 15px;"><strong>Départ :</strong> {{ reservation.checkoutDate|date('d/m/Y') }}</p>
                                    <p style="margin: 0 0 6px; font-size: 15px;"><strong>Voyageurs :</strong> {{ reservation.guestsCount }}</p>
                                    <p style="margin: 0; font-size: 15px;"><strong>Total :</strong> {{ reservation.totalPrice|number_format(2, ',', ' ') }} {{ reservation.currency }}</p>
                                </td>
                            </tr>
                        </table>
                        <p style="font-size: 13px; color: #6b7280; margin: 0;">
                            Vous pouvez suivre votre réservation depuis votre espace personnel.
                        </p>
                    </td>
                </tr>
                <tr>
                    <td style="padding: 16px 32px; background: #f9fafb; text-align: center;">
                        <p style="margin: 0; font-size: 12px; color: #9ca3af;">© {{ "now"|date("Y") }} StayEasy — plateforme de location entre particuliers</p>
                    </td>
                </tr>
            </table>
        </td>
    </tr>
</table>
</body>
</html>
