<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Réservation confirmée</title>
</head>
<body style="font-family: Arial, sans-serif; padding: 20px;">
    <h1 style="color: #27ae60;"> Réservation confirmée</h1>
    
    <p>Bonjour <strong>{{ reservation.property.host.profile.firstName|default('Hôte') }}</strong>,</p>
    
    <p>La réservation suivante a été confirmée :</p>
    
    <div style="background: #f5f5f5; padding: 15px; border-radius: 10px; margin: 20px 0;">
        <h2 style="margin: 0 0 10px 0;">{{ reservation.property.title }}</h2>
        <p><strong> Dates :</strong> {{ reservation.checkinDate|date('d/m/Y') }} → {{ reservation.checkoutDate|date('d/m/Y') }}</p>
        <p><strong> Voyageur :</strong> {{ reservation.guest.profile.firstName|default('') }} {{ reservation.guest.profile.lastName|default('') }}</p>
        <p><strong> Nombre de voyageurs :</strong> {{ reservation.guestsCount }}</p>
    </div>
    
    <p style="color: #666; font-size: 12px; margin-top: 30px;">Cet email a été envoyé automatiquement, merci de ne pas y répondre.</p>
</body>
</html>