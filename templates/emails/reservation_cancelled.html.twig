<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Annulation de réservation</title>
    <style>
        body { font-family: Arial, sans-serif; color: #333; margin: 0; padding: 0; background: #f5f5f5; }
        .container { max-width: 600px; margin: 30px auto; background: #fff; border-radius: 8px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
        .header { background: #6c757d; color: #fff; padding: 28px 32px; }
        .header h1 { margin: 0; font-size: 22px; }
        .body { padding: 28px 32px; }
        .info-box { background: #f8f8f8; border-left: 4px solid #6c757d; padding: 16px 20px; border-radius: 4px; margin: 20px 0; }
        .reason-box { background: #fff3cd; border-left: 4px solid #ffc107; padding: 16px 20px; border-radius: 4px; margin: 20px 0; }
        .info-row { display: flex; justify-content: space-between; margin-bottom: 8px; }
        .info-row:last-child { margin-bottom: 0; }
        .label { color: #666; font-size: 13px; }
        .value { font-weight: bold; font-size: 14px; }
        .footer { background: #f0f0f0; padding: 16px 32px; font-size: 12px; color: #888; text-align: center; }
    </style>
</head>
<body>
<div class="container">
    <div class="header">
        <h1>Réservation annulée</h1>
    </div>
    <div class="body">
        {% if recipient == 'guest' %}
            <p>Bonjour {% if reservation.guest.profile %}{{ reservation.guest.profile.firstName }}{% else %}{{ reservation.guest.email }}{% endif %},</p>
            <p>Votre réservation pour le logement <strong>{{ reservation.property.title }}</strong> a été annulée.</p>
        {% else %}
            <p>Bonjour {% if reservation.property.host.profile %}{{ reservation.property.host.profile.firstName }}{% else %}{{ reservation.property.host.email }}{% endif %},</p>
            <p>La réservation pour votre logement <strong>{{ reservation.property.title }}</strong> a été annulée.</p>
        {% endif %}

        <div class="info-box">
            <div class="info-row">
                <span class="label">Logement</span>
                <span class="value">{{ reservation.property.title }}</span>
            </div>
            <div class="info-row">
                <span class="label">Voyageur</span>
                <span class="value">
                    {% if reservation.guest.profile %}
                        {{ reservation.guest.profile.firstName }} {{ reservation.guest.profile.lastName }}
                    {% else %}
                        {{ reservation.guest.email }}
                    {% endif %}
                </span>
            </div>
            <div class="info-row">
                <span class="label">Arrivée prévue</span>
                <span class="value">{{ reservation.checkinDate|date('d/m/Y') }}</span>
            </div>
            <div class="info-row">
                <span class="label">Départ prévu</span>
                <span class="value">{{ reservation.checkoutDate|date('d/m/Y') }}</span>
            </div>
            <div class="info-row">
                <span class="label">Montant</span>
                <span class="value">{{ reservation.totalPrice }} {{ reservation.currency }}</span>
            </div>
        </div>

        {% if reservation.cancellationReason %}
        <div class="reason-box">
            <p style="margin: 0 0 6px; font-weight: bold;">Motif de l'annulation :</p>
            <p style="margin: 0;">{{ reservation.cancellationReason }}</p>
        </div>
        {% endif %}
    </div>
    <div class="footer">
        Cet email a été envoyé automatiquement. Merci de ne pas y répondre directement.
    </div>
</div>
</body>
</html>