<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Demande de réservation refusée</title>
</head>
<body style="margin:0;padding:0;background:#f4f4f5;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">

<table width="100%" cellpadding="0" cellspacing="0" style="background:#f4f4f5;padding:32px 16px;">
<tr><td align="center">
<table width="600" cellpadding="0" cellspacing="0" style="background:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,.08);">

  <!-- Header -->
  <tr>
    <td style="background:#dc2626;padding:28px 32px;">
      <p style="margin:0;color:#ffffff;font-size:22px;font-weight:700;letter-spacing:-0.3px;">
        ❌ Demande refusée
      </p>
      <p style="margin:6px 0 0;color:#fca5a5;font-size:13px;">Votre demande de réservation n'a pas été acceptée.</p>
    </td>
  </tr>

  <!-- Body -->
  <tr>
    <td style="padding:32px;">

      <p style="margin:0 0 24px;font-size:15px;color:#374151;line-height:1.6;">
        Nous sommes désolés de vous informer que votre demande de réservation pour
        <strong>{{ reservation.property.title }}</strong> a été refusée.
      </p>

      <!-- Property + dates recap -->
      <table width="100%" cellpadding="0" cellspacing="0" style="background:#fef2f2;border:1px solid #fecaca;border-radius:10px;margin-bottom:24px;">
        <tr>
          <td style="padding:20px 24px;">
            <p style="margin:0 0 4px;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.08em;color:#dc2626;">Logement concerné</p>
            <p style="margin:0;font-size:17px;font-weight:700;color:#111827;">{{ reservation.property.title }}</p>
            {% if reservation.property.address %}
              <p style="margin:4px 0 0;font-size:13px;color:#6b7280;">
                📍 {{ reservation.property.address.city }}{% if reservation.property.address.country %}, {{ reservation.property.address.country }}{% endif %}
              </p>
            {% endif %}
            <table width="100%" cellpadding="0" cellspacing="0" style="margin-top:16px;">
              <tr>
                <td style="font-size:13px;color:#6b7280;">Arrivée prévue :</td>
                <td align="right" style="font-size:13px;color:#111827;font-weight:600;">{{ reservation.checkinDate|date('d/m/Y') }}</td>
              </tr>
              <tr>
                <td style="font-size:13px;color:#6b7280;padding-top:4px;">Départ prévu :</td>
                <td align="right" style="font-size:13px;color:#111827;font-weight:600;padding-top:4px;">{{ reservation.checkoutDate|date('d/m/Y') }}</td>
              </tr>
            </table>
          </td>
        </tr>
      </table>

      <!-- Reason -->
      {% if reservation.cancellationReason %}
      <table width="100%" cellpadding="0" cellspacing="0" style="background:#fff7ed;border:1px solid #fed7aa;border-radius:10px;margin-bottom:32px;">
        <tr>
          <td style="padding:20px 24px;">
            <p style="margin:0 0 8px;font-size:13px;font-weight:700;color:#92400e;">ℹ️ Motif communiqué par l'hôte</p>
            <p style="margin:0;font-size:14px;color:#78350f;line-height:1.6;">{{ reservation.cancellationReason }}</p>
          </td>
        </tr>
      </table>
      {% endif %}

      <p style="margin:0 0 32px;font-size:14px;color:#6b7280;line-height:1.6;">
        Nous vous encourageons à rechercher d'autres logements disponibles pour ces dates.
        N'hésitez pas à relancer une recherche sur notre plateforme.
      </p>

      <!-- CTA -->
      <table width="100%" cellpadding="0" cellspacing="0">
        <tr>
          <td align="center">
            <a href="{{ homeUrl }}"
               style="display:inline-block;background:#111827;color:#ffffff;font-size:14px;font-weight:600;text-decoration:none;padding:14px 32px;border-radius:8px;">
              Rechercher un autre logement →
            </a>
          </td>
        </tr>
      </table>

    </td>
  </tr>

  <!-- Footer -->
  <tr>
    <td style="padding:20px 32px;border-top:1px solid #f3f4f6;text-align:center;">
      <p style="margin:0;font-size:11px;color:#9ca3af;">
        Cet email a été envoyé automatiquement. Ne pas répondre directement à ce message.
      </p>
    </td>
  </tr>

</table>
</td></tr>
</table>

</body>
</html>
