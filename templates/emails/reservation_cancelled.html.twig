{% extends 'emails/base.html.twig' %}

{% block subject %}Réservation annulée{% endblock %}

{% block content %}
    <h1 style="font-size:20px; margin:0 0 12px;">Réservation annulée</h1>
    <p style="font-size:14px; line-height:1.6; color:#444;">
        {% if recipientRole|default('guest') == 'host' %}
            Une réservation de votre logement a été annulée. Les dates correspondantes sont de nouveau disponibles.
        {% else %}
            Votre réservation a bien été annulée. Les dates sont à nouveau libres.
        {% endif %}
    </p>

    {{ include('emails/partials/_summary.html.twig') }}

    {% if reservation.cancellationReason %}
        <p style="font-size:14px; line-height:1.6; color:#444;">
            <strong>Motif :</strong> {{ reservation.cancellationReason }}
        </p>
    {% endif %}
{% endblock %}
