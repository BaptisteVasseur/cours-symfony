<!DOCTYPE html>
<html lang="fr">
<head><meta charset="UTF-8"></head>
<body style="font-family: Arial, Helvetica, sans-serif; background:#f5f5f5; padding:24px; color:#222; margin:0;">
    <div style="max-width:560px; margin:0 auto; background:#fff; border-radius:12px; overflow:hidden; border:1px solid #eee;">
        <div style="background:#FF385C; color:#fff; padding:20px 24px; font-size:18px; font-weight:bold;">
            {% block heading %}{% endblock %}
        </div>
        <div style="padding:24px; line-height:1.6;">
            {% block body %}{% endblock %}
        </div>
        <div style="padding:16px 24px; color:#999; font-size:12px; border-top:1px solid #eee;">
            Airbnb Clone — email automatique, merci de ne pas répondre.
        </div>
    </div>
</body>
</html>
