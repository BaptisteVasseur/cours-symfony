<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body style="margin:0;font-family:Arial,Helvetica,sans-serif;color:#222222;background:#f6f6f6;padding:24px;">
    <div style="max-width:560px;margin:0 auto;background:#ffffff;border:1px solid #eeeeee;border-radius:12px;overflow:hidden;">
        <div style="background:#ff385c;color:#ffffff;padding:16px 24px;font-size:18px;font-weight:bold;">Clone Airbnb</div>
        <div style="padding:24px;line-height:1.5;">
            {% block body %}{% endblock %}
        </div>
        <div style="padding:16px 24px;border-top:1px solid #eeeeee;color:#999999;font-size:12px;">
            Cet email vous est envoyé automatiquement par Clone Airbnb.
        </div>
    </div>
</body>
</html>
