<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Airbnb Clone{% endblock %}</title>
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f9fafb; margin: 0; padding: 0; color: #111827; }
        .container { max-width: 600px; margin: 32px auto; background: #fff; border-radius: 12px; border: 1px solid #e5e7eb; overflow: hidden; }
        .header { background: #FF385C; padding: 24px 32px; }
        .header h1 { color: #fff; margin: 0; font-size: 20px; font-weight: 700; }
        .body { padding: 32px; }
        .body h2 { font-size: 18px; font-weight: 600; margin: 0 0 16px; }
        .summary-box { background: #f3f4f6; border-radius: 8px; padding: 16px 20px; margin: 20px 0; font-size: 14px; }
        .summary-box dt { color: #6b7280; font-weight: 500; display: inline-block; width: 120px; }
        .summary-box dd { display: inline-block; font-weight: 600; margin: 4px 0; }
        .cta { display: inline-block; margin-top: 20px; padding: 12px 24px; background: #FF385C; color: #fff; text-decoration: none; border-radius: 8px; font-weight: 600; font-size: 14px; }
        .footer { padding: 20px 32px; border-top: 1px solid #e5e7eb; font-size: 12px; color: #9ca3af; }
        .reason-box { background: #fef2f2; border: 1px solid #fecaca; border-radius: 8px; padding: 12px 16px; margin: 16px 0; font-size: 14px; color: #b91c1c; }
    </style>
</head>
<body>
<div class="container">
    <div class="header">
        <h1>✈️ Airbnb Clone</h1>
    </div>
    <div class="body">
        {% block content %}{% endblock %}
    </div>
    <div class="footer">
        Vous recevez cet email en raison de votre activité sur Airbnb Clone.<br>
        © {{ 'now'|date('Y') }} Airbnb Clone
    </div>
</div>
</body>
</html>
