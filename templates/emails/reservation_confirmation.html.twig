<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Réservation</title>
</head>
<body style="margin:0; padding:0; background-color:#f4f4f5; font-family:Arial, Helvetica, sans-serif; color:#222;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#f4f4f5; padding:24px 0;">
        <tr>
            <td align="center">
                <table role="presentation" width="600" cellpadding="0" cellspacing="0" style="background-color:#ffffff; border-radius:16px; overflow:hidden; max-width:600px; width:100%;">
                    <tr>
                        <td style="background-color:#FF385C; padding:28px 32px;">
                            <span style="color:#ffffff; font-size:22px; font-weight:bold;">Airbnb Clone</span>
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:32px;">
                            {% set forHost = recipientRole|default('guest') == 'host' %}
                            <h1 style="margin:0 0 8px; font-size:22px; color:#111;">
                                {% if status == 'confirmed' %}
                                    Votre réservation est confirmée 🎉
                                {% elseif status == 'cancelled' %}
                                    Réservation annulée
                                {% else %}
                                    Demande de réservation reçue
                                {% endif %}
                            </h1>
                            <p style="margin:0 0 24px; font-size:15px; color:#555; line-height:1.5;">
                                {% if forHost %}
                                    Bonjour,
                                    {% if status == 'cancelled' %}
                                        une réservation sur votre logement a été annulée. Les dates concernées sont de nouveau disponibles. Voici le récapitulatif :
                                    {% endif %}
                                {% else %}
                                    Bonjour{% if guest.profile and guest.profile.firstName %} {{ guest.profile.firstName }}{% endif %},
                                    {% if status == 'confirmed' %}
                                        votre séjour est bien confirmé. Voici le récapitulatif :
                                    {% elseif status == 'cancelled' %}
                                        votre réservation a été annulée. Voici le récapitulatif :
                                    {% else %}
                                        votre demande a bien été enregistrée et est en attente de validation par l'hôte. Voici le récapitulatif :
                                    {% endif %}
                                {% endif %}
                            </p>

                            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="border:1px solid #eee; border-radius:12px;">
                                <tr>
                                    <td style="padding:16px 20px; border-bottom:1px solid #f0f0f0;">
                                        <span style="display:block; font-size:12px; color:#888; text-transform:uppercase;">Logement</span>
                                        <span style="font-size:16px; font-weight:bold; color:#111;">{{ property.title }}</span>
                                        {% if property.address %}
                                            <span style="display:block; font-size:13px; color:#777;">{{ property.address.city }}{% if property.address.country %}, {{ property.address.country }}{% endif %}</span>
                                        {% endif %}
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding:16px 20px; border-bottom:1px solid #f0f0f0;">
                                        <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                                            <tr>
                                                <td style="font-size:13px; color:#888; text-transform:uppercase;">Arrivée</td>
                                                <td style="font-size:13px; color:#888; text-transform:uppercase;">Départ</td>
                                            </tr>
                                            <tr>
                                                <td style="font-size:15px; font-weight:bold; color:#111;">{{ reservation.checkinDate|date('d/m/Y') }}</td>
                                                <td style="font-size:15px; font-weight:bold; color:#111;">{{ reservation.checkoutDate|date('d/m/Y') }}</td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding:16px 20px; border-bottom:1px solid #f0f0f0;">
                                        <span style="font-size:14px; color:#555;">Voyageurs : <strong>{{ reservation.guestsCount }}</strong></span>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding:16px 20px;">
                                        <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                                            <tr>
                                                <td style="font-size:16px; color:#111;">Total</td>
                                                <td align="right" style="font-size:18px; font-weight:bold; color:#FF385C;">{{ reservation.totalPrice|number_format(2, ',', ' ') }} {{ reservation.currency }}</td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>
                            </table>

                            {% set statusColor = { 'confirmed': '#0a7d33', 'cancelled': '#c0392b', 'pending': '#b26a00' } %}
                            {% set statusText = { 'confirmed': 'Confirmée', 'cancelled': 'Annulée', 'pending': 'En attente' } %}
                            <p style="margin:24px 0 0; font-size:13px; color:#999; line-height:1.5;">
                                Statut de la réservation :
                                <strong style="color:{{ statusColor[status] ?? '#999' }};">
                                    {{ statusText[status] ?? status }}
                                </strong>
                            </p>
                            {% if status == 'cancelled' and reservation.cancellationReason %}
                                <p style="margin:8px 0 0; font-size:13px; color:#999;">Motif : {{ reservation.cancellationReason }}</p>
                            {% endif %}
                        </td>
                    </tr>
                    <tr>
                        <td style="padding:20px 32px; background-color:#fafafa; border-top:1px solid #eee;">
                            <p style="margin:0; font-size:12px; color:#aaa;">Cet email vous est envoyé automatiquement par Airbnb Clone. Merci de ne pas y répondre.</p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>
