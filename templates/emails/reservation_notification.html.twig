<!DOCTYPE html>
<html>
<head><meta charset="UTF-8"></head>
<body style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; background: #f5f5f5; margin: 0; padding: 0;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
        <tr>
            <td align="center" style="padding: 24px 16px;">
                <table role="presentation" width="480" cellpadding="0" cellspacing="0" style="background: #ffffff; border-radius: 12px; overflow: hidden;">

                    <!-- Header -->
                    <tr>
                        <td style="padding: 32px 24px 24px; text-align: center; background: #f9fafb; border-bottom: 1px solid #e5e7eb;">
                            <h1 style="margin: 0 0 4px; font-size: 20px; font-weight: 700; color: #111827;">
                                {% if event == 'pending' %}
                                    Nouvelle demande de réservation
                                {% elseif event == 'confirmed' %}
                                    {% if isHost %}
                                        Réservation confirmée
                                    {% else %}
                                        Votre réservation est confirmée !
                                    {% endif %}
                                {% elseif event == 'cancelled' %}
                                    Réservation annulée
                                {% else %}
                                    Mise à jour de réservation
                                {% endif %}
                            </h1>
                            <p style="margin: 0; font-size: 14px; color: #6b7280;">{{ reservation.property.title }}</p>
                        </td>
                    </tr>

                    <!-- Body -->
                    <tr>
                        <td style="padding: 24px;">

                            {% if isHost and (event == 'pending' or event == 'confirmed') %}
                                <!-- Guest info (shown to host) -->
                                <h2 style="font-size: 14px; font-weight: 600; color: #111827; margin: 0 0 12px;">Voyageur</h2>
                                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-bottom: 20px;">
                                    <tr><td style="padding: 8px 0; font-size: 14px; border-bottom: 1px solid #f3f4f6;"><strong style="color: #6b7280;">Nom :</strong> {{ guestName }}</td></tr>
                                    <tr><td style="padding: 8px 0; font-size: 14px; border-bottom: 1px solid #f3f4f6;"><strong style="color: #6b7280;">Email :</strong> {{ guestEmail }}</td></tr>
                                </table>
                            {% endif %}

                            {% if isGuest and event == 'confirmed' %}
                                <!-- Host info (shown to guest on confirmed) -->
                                <h2 style="font-size: 14px; font-weight: 600; color: #111827; margin: 0 0 12px;">Votre hôte</h2>
                                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-bottom: 20px;">
                                    <tr><td style="padding: 8px 0; font-size: 14px; border-bottom: 1px solid #f3f4f6;"><strong style="color: #6b7280;">Nom :</strong> {{ hostName }}</td></tr>
                                    <tr><td style="padding: 8px 0; font-size: 14px; border-bottom: 1px solid #f3f4f6;"><strong style="color: #6b7280;">Email :</strong> {{ hostEmail }}</td></tr>
                                    {% if hostPhone is not null %}<tr><td style="padding: 8px 0; font-size: 14px; border-bottom: 1px solid #f3f4f6;"><strong style="color: #6b7280;">Téléphone :</strong> {{ hostPhone }}</td></tr>{% endif %}
                                </table>
                            {% endif %}

                            <!-- Property address (shown to guest on confirmed) -->
                            {% if isGuest and event == 'confirmed' and propertyAddress is not null %}
                                <h2 style="font-size: 14px; font-weight: 600; color: #111827; margin: 0 0 12px;">Adresse du logement</h2>
                                <p style="font-size: 14px; color: #374151; margin: 0 0 20px;">
                                    {{ propertyAddress.addressLine1 }}<br>
                                    {% if propertyAddress.addressLine2 is not null %}{{ propertyAddress.addressLine2 }}<br>{% endif %}
                                    {{ propertyAddress.postalCode }} {{ propertyAddress.city }}<br>
                                    {{ propertyAddress.country }}
                                </p>
                            {% endif %}

                            <!-- Trip details -->
                            <h2 style="font-size: 14px; font-weight: 600; color: #111827; margin: 0 0 12px;">Détails du séjour</h2>
                            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-bottom: 20px;">
                                <tr><td style="padding: 8px 0; font-size: 14px; border-bottom: 1px solid #f3f4f6;"><strong style="color: #6b7280;">Arrivée :</strong> {{ reservation.checkinDate|date('d/m/Y') }}</td></tr>
                                <tr><td style="padding: 8px 0; font-size: 14px; border-bottom: 1px solid #f3f4f6;"><strong style="color: #6b7280;">Départ :</strong> {{ reservation.checkoutDate|date('d/m/Y') }}</td></tr>
                                <tr><td style="padding: 8px 0; font-size: 14px; border-bottom: 1px solid #f3f4f6;"><strong style="color: #6b7280;">Voyageurs :</strong> {{ reservation.guestsCount }}</td></tr>
                            </table>

                            <!-- Price summary (shown on confirmed + cancelled, and to host for pending) -->
                            {% if event != 'pending' or isHost %}
                                <h2 style="font-size: 14px; font-weight: 600; color: #111827; margin: 0 0 12px;">Prix</h2>
                                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-bottom: 20px;">
                                    {% if reservation.cleaningFee is not null and reservation.cleaningFee > 0 %}
                                    <tr><td style="padding: 8px 0; font-size: 14px; border-bottom: 1px solid #f3f4f6;"><strong style="color: #6b7280;">Frais de ménage :</strong> {{ reservation.cleaningFee|number_format(2, ',', ' ') }} {{ reservation.currency|default('EUR') }}</td></tr>
                                    {% endif %}
                                    {% if reservation.serviceFee is not null and reservation.serviceFee > 0 %}
                                    <tr><td style="padding: 8px 0; font-size: 14px; border-bottom: 1px solid #f3f4f6;"><strong style="color: #6b7280;">Frais de service :</strong> {{ reservation.serviceFee|number_format(2, ',', ' ') }} {{ reservation.currency|default('EUR') }}</td></tr>
                                    {% endif %}
                                    <tr><td style="padding: 8px 0; font-size: 14px;"><strong style="color: #6b7280;">Total :</strong> <strong style="color: #111827;">{{ reservation.totalPrice|number_format(2, ',', ' ') }} {{ reservation.currency|default('EUR') }}</strong></td></tr>
                                </table>
                            {% endif %}

                            <!-- Cancellation reason -->
                            {% if event == 'cancelled' and reservation.cancellationReason is not null %}
                                <div style="background: #fef2f2; border: 1px solid #fecaca; border-radius: 8px; padding: 12px; margin-bottom: 20px;">
                                    <p style="font-size: 13px; color: #991b1b; margin: 0;"><strong>Motif d'annulation :</strong> {{ reservation.cancellationReason }}</p>
                                </div>
                            {% endif %}

                            <!-- CTA Button -->
                            <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                                <tr>
                                    <td align="center" style="padding: 8px 0 0;">
                                        <a href="{{ reservationUrl }}" style="display: inline-block; background: #111827; color: #ffffff; font-size: 14px; font-weight: 600; text-decoration: none; padding: 12px 32px; border-radius: 8px;">
                                            {% if event == 'pending' %}
                                                Voir la demande
                                            {% elseif event == 'confirmed' %}
                                                Voir la réservation
                                            {% elseif event == 'cancelled' %}
                                                Voir le détail
                                            {% else %}
                                                Voir la réservation
                                            {% endif %}
                                        </a>
                                    </td>
                                </tr>
                            </table>

                        </td>
                    </tr>

                    <tr>
                        <td style="padding: 24px; text-align: center; border-top: 1px solid #e5e7eb; background: #f9fafb;">
                            <p style="margin: 0; font-size: 12px; color: #9ca3af;">
                                Cet email a été envoyé automatiquement depuis l'application de réservation.<br>
                                Merci de ne pas répondre à cet email.
                            </p>
                        </td>
                    </tr>

                </table>
            </td>
        </tr>
    </table>
</body>
</html>
