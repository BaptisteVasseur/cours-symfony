{# @var \App\Entity\Reservation reservation #}
{# @var \App\Entity\Property property #}
{# @var string recipientName #}
{# @var bool isGuest #}
{# For: guest AND host #}
{% extends 'layout/base.html.twig' %}

{% block body %}
<body style="font-family: system-ui, sans-serif; background: #f9fafb; padding: 40px 0;">
    <div style="max-width: 560px; margin: 0 auto; background: #fff; border-radius: 16px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,0.06);">
        <div style="background: #059669; padding: 28px 32px;">
            <h1 style="color: #fff; font-size: 22px; margin: 0;">Réservation confirmée ✓</h1>
        </div>
        <div style="padding: 32px;">
            <p style="font-size: 16px; color: #1f2937; margin: 0 0 16px;">
                Bonjour <strong>{{ recipientName }}</strong>,<br>
                {% if isGuest %}
                    Votre réservation pour <strong>{{ property.title }}</strong> est confirmée.
                {% else %}
                    <strong>{{ reservation.guest.profile.firstName ?? reservation.guest.email }}</strong> a réservé <strong>{{ property.title }}</strong>.
                {% endif %}
            </p>

            <table style="width: 100%; border-collapse: collapse; margin: 20px 0; font-size: 14px;">
                <tr>
                    <td style="padding: 10px 0; color: #6b7280;">Logement</td>
                    <td style="padding: 10px 0; text-align: right; font-weight: 600;">{{ property.title }}</td>
                </tr>
                {% if property.address %}
                <tr>
                    <td style="padding: 10px 0; color: #6b7280;">Adresse</td>
                    <td style="padding: 10px 0; text-align: right; font-weight: 600;">{{ property.address.city }}{% if property.address.country %}, {{ property.address.country }}{% endif %}</td>
                </tr>
                {% endif %}
                <tr>
                    <td style="padding: 10px 0; color: #6b7280;">Arrivée</td>
                    <td style="padding: 10px 0; text-align: right; font-weight: 600;">{{ reservation.checkinDate|date('d/m/Y') }}</td>
                </tr>
                <tr>
                    <td style="padding: 10px 0; color: #6b7280;">Départ</td>
                    <td style="padding: 10px 0; text-align: right; font-weight: 600;">{{ reservation.checkoutDate|date('d/m/Y') }}</td>
                </tr>
                <tr>
                    <td style="padding: 10px 0; color: #6b7280;">Voyageurs</td>
                    <td style="padding: 10px 0; text-align: right; font-weight: 600;">{{ reservation.guestsCount }}</td>
                </tr>
                <tr>
                    <td style="padding: 10px 0; color: #6b7280; border-top: 1px solid #e5e7eb;">Total</td>
                    <td style="padding: 10px 0; text-align: right; font-weight: 700; font-size: 16px; border-top: 1px solid #e5e7eb;">{{ reservation.totalPrice|number_format(2, ',', ' ') }} €</td>
                </tr>
            </table>

            <a href="{{ reservationUrl }}" style="display: inline-block; background: #059669; color: #fff; text-decoration: none; padding: 14px 32px; border-radius: 8px; font-weight: 600; font-size: 15px; margin-top: 12px;">
                Voir la réservation
            </a>

            <p style="margin-top: 28px; font-size: 12px; color: #9ca3af;">
                Cet email a été envoyé automatiquement par Clone Airbnb.
            </p>
        </div>
    </div>
</body>
{% endblock %}
