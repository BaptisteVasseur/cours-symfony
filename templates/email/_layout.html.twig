{% set property = reservation.property %}
{% set guest = reservation.guest %}
{% set guestProfile = guest ? guest.profile : null %}
{% set guestName = guestProfile ? guestProfile.firstName ~ ' ' ~ guestProfile.lastName : (guest ? guest.email : 'Voyageur') %}

<div style="font-family: Arial, sans-serif; color: #1f2937; max-width: 560px; margin: 0 auto;">
    <div style="background: #FF385C; color: #ffffff; padding: 20px 24px; border-radius: 12px 12px 0 0;">
        <h1 style="margin: 0; font-size: 20px;">{% block heading %}{% endblock %}</h1>
    </div>
    <div style="border: 1px solid #e5e7eb; border-top: none; padding: 24px; border-radius: 0 0 12px 12px;">
        {% block intro %}{% endblock %}

        <table style="width: 100%; font-size: 14px; border-collapse: collapse; margin: 16px 0;">
            <tr><td style="padding: 6px 0; color: #6b7280;">Logement</td><td style="padding: 6px 0; text-align: right; font-weight: bold;">{{ property ? property.title : '-' }}</td></tr>
            <tr><td style="padding: 6px 0; color: #6b7280;">Voyageur</td><td style="padding: 6px 0; text-align: right;">{{ guestName }}{% if guest %} ({{ guest.email }}){% endif %}</td></tr>
            <tr><td style="padding: 6px 0; color: #6b7280;">Arrivée</td><td style="padding: 6px 0; text-align: right;">{{ reservation.checkinDate|date('d/m/Y') }}</td></tr>
            <tr><td style="padding: 6px 0; color: #6b7280;">Départ</td><td style="padding: 6px 0; text-align: right;">{{ reservation.checkoutDate|date('d/m/Y') }}</td></tr>
            <tr><td style="padding: 6px 0; color: #6b7280;">Voyageurs</td><td style="padding: 6px 0; text-align: right;">{{ reservation.guestsCount }}</td></tr>
            <tr><td style="padding: 6px 0; color: #6b7280;">Total</td><td style="padding: 6px 0; text-align: right; font-weight: bold;">{{ reservation.totalPrice|number_format(2, ',', ' ') }} {{ reservation.currency }}</td></tr>
        </table>

        {% block extra %}{% endblock %}
    </div>
</div>
