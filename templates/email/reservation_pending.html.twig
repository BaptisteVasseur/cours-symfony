{# @var \App\Entity\Reservation reservation #}
{# @var \App\Entity\Property property #}
{# For: property host #}
{% extends 'layout/base.html.twig' %}

{% block body %}
<body style="font-family: system-ui, sans-serif; background: #f9fafb; padding: 40px 0;">
    <div style="max-width: 560px; margin: 0 auto; background: #fff; border-radius: 16px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,0.06);">
        <div style="background: #FF385C; padding: 28px 32px;">
            <h1 style="color: #fff; font-size: 22px; margin: 0;">Nouvelle demande de réservation</h1>
        </div>
        <div style="padding: 32px;">
            <p style="font-size: 16px; color: #1f2937; margin: 0 0 16px;">
                <strong>{{ guestName }}</strong> souhaite réserver <strong>{{ property.title }}</strong>.
            </p>

            <table style="width: 100%; border-collapse: collapse; margin: 20px 0; font-size: 14px;">
                <tr>
                    <td style="padding: 10px 0; color: #6b7280;">Arrivée</td>
                    <td style="padding: 10px 0; text-align: right; font-weight: 600;">{{ reservation.checkinDate|date('d/m/Y') }}</td>
                </tr>
                <tr>
                    <td style="padding: 10px 0; color: #6b7280;">Départ</td>
                    <td style="padding: 10px 0; text-align: right; font-weight: 600;">{{ reservation.checkoutDate|date('d/m/Y') }}</td>
                </tr>
                <tr>
                    <td style="padding: 10px 0; color: #6b7280;">Voyageurs</td>
                    <td style="padding: 10px 0; text-align: right; font-weight: 600;">{{ reservation.guestsCount }}</td>
                </tr>
                <tr>
                    <td style="padding: 10px 0; color: #6b7280;">Total</td>
                    <td style="padding: 10px 0; text-align: right; font-weight: 600;">{{ reservation.totalPrice|number_format(2, ',', ' ') }} €</td>
                </tr>
            </table>

            <a href="{{ dashboardUrl }}" style="display: inline-block; background: #FF385C; color: #fff; text-decoration: none; padding: 14px 32px; border-radius: 8px; font-weight: 600; font-size: 15px; margin-top: 12px;">
                Voir les demandes en attente
            </a>

            <p style="margin-top: 28px; font-size: 12px; color: #9ca3af;">
                Cet email a été envoyé automatiquement par Clone Airbnb. Merci de répondre dans les 24 heures.
            </p>
        </div>
    </div>
</body>
{% endblock %}
