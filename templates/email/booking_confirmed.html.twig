<!DOCTYPE html>
<html lang="fr">
<head><meta charset="UTF-8"><style>body{font-family:sans-serif;color:#374151;margin:0;padding:0;} .container{max-width:600px;margin:0 auto;padding:32px 24px;} .card{background:#fff;border:1px solid #e5e7eb;border-radius:16px;padding:24px;margin-top:16px;} .badge{display:inline-block;padding:4px 12px;border-radius:999px;font-size:13px;font-weight:600;} .badge-green{background:#d1fae5;color:#065f46;}</style></head>
<body>
<div class="container">
    <h2 style="color:#10b981;margin-bottom:4px;">✅ Réservation confirmée !</h2>
    <p style="color:#6b7280;font-size:15px;">Bonne nouvelle ! La réservation suivante est maintenant confirmée.</p>

    <div class="card">
        <h3 style="margin-top:0;">{{ booking.property.title }}</h3>
        <p style="color:#6b7280;">{{ booking.property.city }}, {{ booking.property.country }}</p>

        <table style="width:100%;margin-top:16px;border-collapse:collapse;">
            <tr><td style="padding:6px 0;color:#9ca3af;font-size:13px;">Voyageur</td><td style="font-weight:600;">{{ booking.traveler.firstName }} {{ booking.traveler.lastName }}</td></tr>
            <tr><td style="padding:6px 0;color:#9ca3af;font-size:13px;">Hôte</td><td>{{ booking.property.host.firstName }} {{ booking.property.host.lastName }}</td></tr>
            <tr><td style="padding:6px 0;color:#9ca3af;font-size:13px;">Arrivée</td><td style="font-weight:600;">{{ booking.checkIn|date('D d M Y') }}</td></tr>
            <tr><td style="padding:6px 0;color:#9ca3af;font-size:13px;">Départ</td><td style="font-weight:600;">{{ booking.checkOut|date('D d M Y') }}</td></tr>
            <tr><td style="padding:6px 0;color:#9ca3af;font-size:13px;">Durée</td><td>{{ booking.nights }} nuit(s)</td></tr>
            <tr><td style="padding:6px 0;color:#9ca3af;font-size:13px;">Voyageurs</td><td>{{ booking.guestsCount }}</td></tr>
            <tr><td style="padding:6px 0;color:#9ca3af;font-size:13px;">Total</td><td style="font-weight:700;font-size:18px;color:#111827;">{{ booking.totalPrice }} €</td></tr>
        </table>

        <span class="badge badge-green">Confirmée</span>
    </div>

    <p style="margin-top:24px;font-size:14px;color:#6b7280;">Adresse du logement : {{ booking.property.address }}, {{ booking.property.city }}</p>
    <p style="font-size:13px;color:#9ca3af;">Pour toute question, utilisez la messagerie de la plateforme.</p>
</div>
</body>
</html>
