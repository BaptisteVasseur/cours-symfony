<!DOCTYPE html>
<html lang="fr">
<head><meta charset="UTF-8"><title>Rappel check-in demain</title></head>
<body style="font-family: Arial, sans-serif; background:#f4f4f4; margin:0; padding:20px;">
<div style="max-width:600px; margin:0 auto; background:#fff; border-radius:8px; overflow:hidden;">
    <div style="background:#f97316; padding:24px 32px;">
        <h1 style="color:#fff; margin:0; font-size:22px;">Votre séjour commence demain 🏠</h1>
    </div>
    <div style="padding:32px;">
        {% set property = reservation.property %}
        {% set guestProfile = reservation.guest ? reservation.guest.profile : null %}
        {% set hostProfile  = property and property.host ? property.host.profile : null %}

        <p>Bonjour {{ guestProfile ? guestProfile.firstName : 'cher voyageur' }},</p>
        <p>Votre séjour à <strong>{{ property ? property.title : '—' }}</strong> commence <strong>demain</strong>. Voici un récapitulatif pour préparer votre arrivée.</p>

        <table style="width:100%; border-collapse:collapse; margin:24px 0;">
            <tr style="background:#fff7ed;">
                <td style="padding:12px; font-weight:bold;">Logement</td>
                <td style="padding:12px;">{{ property ? property.title : '—' }}</td>
            </tr>
            {% if property and property.address %}
            <tr>
                <td style="padding:12px; font-weight:bold;">Adresse</td>
                <td style="padding:12px;">
                    {{ property.address.addressLine1 }}<br>
                    {{ property.address.postalCode }} {{ property.address.city }}, {{ property.address.country }}
                </td>
            </tr>
            {% endif %}
            <tr style="background:#fff7ed;">
                <td style="padding:12px; font-weight:bold;">Arrivée</td>
                <td style="padding:12px;">
                    {{ reservation.checkinDate|date('d/m/Y') }}
                    {% if property and property.checkinTime %}
                        à partir de {{ property.checkinTime|date('H:i') }}
                    {% endif %}
                </td>
            </tr>
            <tr>
                <td style="padding:12px; font-weight:bold;">Départ</td>
                <td style="padding:12px;">
                    {{ reservation.checkoutDate|date('d/m/Y') }}
                    {% if property and property.checkoutTime %}
                        avant {{ property.checkoutTime|date('H:i') }}
                    {% endif %}
                </td>
            </tr>
            <tr style="background:#fff7ed;">
                <td style="padding:12px; font-weight:bold;">Voyageurs</td>
                <td style="padding:12px;">{{ reservation.guestsCount }}</td>
            </tr>
            {% if hostProfile %}
            <tr>
                <td style="padding:12px; font-weight:bold;">Votre hôte</td>
                <td style="padding:12px;">{{ hostProfile.firstName }} {{ hostProfile.lastName }}</td>
            </tr>
            {% endif %}
        </table>

        <p style="color:#666; font-size:13px;">Bon séjour ! N'hésitez pas à contacter votre hôte en cas de besoin.</p>
    </div>
    <div style="background:#f8f8f8; padding:16px 32px; text-align:center; color:#999; font-size:12px;">
        © {{ "now"|date("Y") }} StayHub — Ce message est automatique, merci de ne pas y répondre.
    </div>
</div>
</body>
</html>
