{# @var \App\Entity\Reservation reservation #}
{# @var \App\Entity\Property property #}
{# @var string recipientName #}
{# @var string cancellationReason #}
{# For: guest AND host #}
{% extends 'layout/base.html.twig' %}

{% block body %}
<body style="font-family: system-ui, sans-serif; background: #f9fafb; padding: 40px 0;">
    <div style="max-width: 560px; margin: 0 auto; background: #fff; border-radius: 16px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,0.06);">
        <div style="background: #dc2626; padding: 28px 32px;">
            <h1 style="color: #fff; font-size: 22px; margin: 0;">Réservation annulée</h1>
        </div>
        <div style="padding: 32px;">
            <p style="font-size: 16px; color: #1f2937; margin: 0 0 16px;">
                Bonjour <strong>{{ recipientName }}</strong>,<br>
                La réservation pour <strong>{{ property.title }}</strong> a été annulée.
            </p>

            <table style="width: 100%; border-collapse: collapse; margin: 20px 0; font-size: 14px;">
                <tr>
                    <td style="padding: 10px 0; color: #6b7280;">Logement</td>
                    <td style="padding: 10px 0; text-align: right; font-weight: 600;">{{ property.title }}</td>
                </tr>
                <tr>
                    <td style="padding: 10px 0; color: #6b7280;">Arrivée (annulée)</td>
                    <td style="padding: 10px 0; text-align: right; font-weight: 600;">{{ reservation.checkinDate|date('d/m/Y') }}</td>
                </tr>
                <tr>
                    <td style="padding: 10px 0; color: #6b7280;">Départ (annulé)</td>
                    <td style="padding: 10px 0; text-align: right; font-weight: 600;">{{ reservation.checkoutDate|date('d/m/Y') }}</td>
                </tr>
            </table>

            <div style="background: #fef2f2; border-left: 4px solid #dc2626; padding: 16px; margin: 20px 0; border-radius: 4px;">
                <p style="margin: 0; font-size: 14px; color: #991b1b;">
                    <strong>Motif d'annulation :</strong><br>
                    {{ cancellationReason }}
                </p>
            </div>

            <a href="{{ reservationUrl }}" style="display: inline-block; background: #374151; color: #fff; text-decoration: none; padding: 14px 32px; border-radius: 8px; font-weight: 600; font-size: 15px; margin-top: 12px;">
                Voir le détail
            </a>

            <p style="margin-top: 28px; font-size: 12px; color: #9ca3af;">
                Cet email a été envoyé automatiquement par Clone Airbnb.
            </p>
        </div>
    </div>
</body>
{% endblock %}
