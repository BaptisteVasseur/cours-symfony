{% extends 'layout/base.html.twig' %}

{% block title %}Logements — Airbnb{% endblock %}

{% block body %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
        <h1 class="text-2xl font-semibold text-gray-900">
            {% if city %}Logements à {{ city }}{% else %}Tous les logements{% endif %}
            <span class="text-gray-400 text-base font-normal ml-2">{{ properties|length }} résultat(s)</span>
        </h1>

        <form method="GET" class="flex items-center gap-2">
            <input type="text" name="city" value="{{ city }}" placeholder="Ville" class="border border-gray-300 rounded-lg px-3 py-2 text-sm outline-none focus:ring-2 focus:ring-rose-400">
            <input type="number" name="guests" value="{{ guests }}" placeholder="Voyageurs" min="1" class="border border-gray-300 rounded-lg px-3 py-2 text-sm w-28 outline-none focus:ring-2 focus:ring-rose-400">
            <button type="submit" class="bg-rose-500 text-white px-4 py-2 rounded-lg text-sm hover:bg-rose-600 transition">Filtrer</button>
        </form>
    </div>

    {% if properties is empty %}
        <div class="text-center py-20">
            <p class="text-xl text-gray-400">Aucun logement disponible</p>
        </div>
    {% else %}
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
            {% for property in properties %}
                {% include 'property/_card.html.twig' with { property: property } %}
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}
