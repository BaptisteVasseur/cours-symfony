{% extends 'layout/user.html.twig' %}

{% block title %}{{ property.title }}{% endblock %}

{% block body %}
<div class="max-w-7xl mx-auto px-6 py-8">

    {# Breadcrumb #}
    <nav class="flex items-center gap-2 text-sm text-gray-500 mb-6">
        <a href="{{ path('app_home') }}" class="hover:underline">Accueil</a>
        <span>·</span>
        <a href="{{ path('app_home') }}" class="hover:underline">{{ property.address ? property.address.city : '' }}</a>
        <span>·</span>
        <span class="text-gray-900 font-medium truncate">{{ property.title }}</span>
    </nav>

    {# Titre #}
    <div class="flex items-start justify-between gap-4 mb-6">
        <h1 class="text-2xl font-bold text-gray-900">{{ property.title }}</h1>
        <div class="flex items-center gap-3 flex-shrink-0">
            <button class="flex items-center gap-2 text-sm font-semibold underline hover:text-gray-600 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M7.217 10.907a2.25 2.25 0 100 2.186m0-2.186c.18.324.283.696.283 1.093s-.103.77-.283 1.093m0-2.186l9.566-5.314m-9.566 7.5l9.566 5.314m0 0a2.25 2.25 0 103.935 2.186 2.25 2.25 0 00-3.935-2.186zm0-12.814a2.25 2.25 0 103.933-2.185 2.25 2.25 0 00-3.933 2.185z"/>
                </svg>
                Partager
            </button>
            <button class="flex items-center gap-2 text-sm font-semibold underline hover:text-gray-600 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/>
                </svg>
                Sauvegarder
            </button>
        </div>
    </div>

  {# Galerie photos #}
<div class="grid grid-cols-4 grid-rows-2 gap-2 rounded-2xl overflow-hidden mb-8 h-96">

    {# Cover #}
    <div class="col-span-2 row-span-2 bg-gray-200">
        {% set cover = property.media|filter(m => m.isCover)|first %}
        {% if cover %}
            <img src="{{ cover.fileUrl }}" alt="{{ property.title }}" class="w-full h-full object-cover">
        {% else %}
            <div class="w-full h-full flex items-center justify-center">
                <svg class="w-16 h-16 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 19.5h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5z"/>
                </svg>
            </div>
        {% endif %}
    </div>

    {# 4 autres images #}
    {% set others = property.media|filter(m => not m.isCover)|slice(0, 4) %}
    {% for media in others %}
    <div class="bg-gray-100">
        <img src="{{ media.fileUrl }}" alt="{{ property.title }}" class="w-full h-full object-cover">
    </div>
    {% else %}
        {% for i in 1..4 %}
        <div class="bg-gray-{% if i is odd %}100{% else %}200{% endif %}"></div>
        {% endfor %}
    {% endfor %}

</div>
    {# Contenu principal + sidebar réservation #}
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">

        {# Colonne gauche #}
        <div class="lg:col-span-2 space-y-8">

            {# Infos hote + meta #}
            <div class="flex items-start justify-between pb-6 border-b border-gray-200">
                <div>
                    <h2 class="text-xl font-semibold text-gray-900 mb-1">
                        {{ property.propertyType|capitalize }} · {{ property.address ? property.address.city : '' }}
                    </h2>
                    <p class="text-gray-500 text-sm">
                        {{ property.maxGuests }} voyageur{{ property.maxGuests > 1 ? 's' : '' }}
                        · {{ property.bedrooms }} chambre{{ property.bedrooms > 1 ? 's' : '' }}
                        · {{ property.beds }} lit{{ property.beds > 1 ? 's' : '' }}
                        · {{ property.bathrooms }} salle{{ property.bathrooms > 1 ? 's' : '' }} de bain
                    </p>
                </div>
                <div class="w-12 h-12 rounded-full bg-gray-300 flex-shrink-0 flex items-center justify-center text-gray-600 font-bold text-lg">
                    {{ property.host.profile ? property.host.profile.firstName|first|upper : '?' }}
                </div>
            </div>

            {# Badges #}
            <div class="space-y-5 pb-6 border-b border-gray-200">
                {% if property.instantBooking %}
                <div class="flex items-start gap-4">
                    <svg class="w-6 h-6 text-gray-700 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/>
                    </svg>
                    <div>
                        <p class="font-semibold text-gray-900 text-sm">Reservation instantanee</p>
                        <p class="text-gray-500 text-sm">Reservez sans attendre la confirmation de l'hote.</p>
                    </div>
                </div>
                {% endif %}
                <div class="flex items-start gap-4">
                    <svg class="w-6 h-6 text-gray-700 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/>
                    </svg>
                    <div>
                        <p class="font-semibold text-gray-900 text-sm">
                            Arrivee :
                            {% if property.checkinTime %}{{ property.checkinTime|date('H:i') }}{% else %}flexible{% endif %}
                            · Depart :
                            {% if property.checkoutTime %}{{ property.checkoutTime|date('H:i') }}{% else %}flexible{% endif %}
                        </p>
                        <p class="text-gray-500 text-sm">Horaires de check-in et check-out.</p>
                    </div>
                </div>
                <div class="flex items-start gap-4">
                    <svg class="w-6 h-6 text-gray-700 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/>
                    </svg>
                    <div>
                        <p class="font-semibold text-gray-900 text-sm">Politique d'annulation : {{ property.cancellationPolicy.label }}</p>
                        <p class="text-gray-500 text-sm">{{ property.cancellationPolicy.description }}</p>
                    </div>
                </div>
            </div>

            {# Description #}
            {% if property.description %}
            <div class="pb-6 border-b border-gray-200">
                <h3 class="text-lg font-semibold text-gray-900 mb-3">Description</h3>
                <p class="text-gray-600 leading-relaxed whitespace-pre-line">{{ property.description }}</p>
            </div>
            {% endif %}

            {# Equipements #}
            {% if property.propertyAmenities is not empty %}
            <div class="pb-6 border-b border-gray-200">
                <h3 class="text-lg font-semibold text-gray-900 mb-4">Ce que propose ce logement</h3>
                <div class="grid grid-cols-2 gap-3">
                    {% for amenity in property.propertyAmenities %}
                    <div class="flex items-center gap-3 text-sm text-gray-700">
                        <svg class="w-5 h-5 text-gray-500 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
                        </svg>
                        {{ amenity.amenity.name ?? amenity }}
                    </div>
                    {% endfor %}
                </div>
            </div>
            {% endif %}

            {# Adresse #}
            {% if property.address %}
            <div class="pb-6">
                <h3 class="text-lg font-semibold text-gray-900 mb-2">Ou se trouve ce logement</h3>
                <p class="text-gray-500 text-sm mb-4">
                    {{ property.address.city }}{% if property.address.postalCode %}, {{ property.address.postalCode }}{% endif %} · {{ property.address.country }}
                </p>
                <div class="w-full h-48 bg-gray-100 rounded-2xl flex items-center justify-center text-gray-400 text-sm border border-gray-200">
                    Carte non disponible
                </div>
            </div>
            {% endif %}

        </div>

        {# Sidebar reservation #}
        <div class="lg:col-span-1">
            <div class="sticky top-24">
                <div class="border border-gray-200 rounded-2xl shadow-lg p-6 space-y-5">

                    {# Prix #}
                    <div class="flex items-end gap-2">
                        <span class="text-2xl font-bold text-gray-900">{{ property.pricePerNight }} €</span>
                        <span class="text-gray-500 text-sm mb-0.5">/ nuit</span>
                    </div>

                    {# Dates #}
                    <div class="grid grid-cols-2 border border-gray-300 rounded-xl overflow-hidden text-sm">
                        <div class="px-4 py-3 border-r border-gray-300">
                            <p class="text-xs font-semibold text-gray-700 uppercase mb-1">Arrivee</p>
                            <input type="date" class="w-full text-gray-900 focus:outline-none bg-transparent text-sm">
                        </div>
                        <div class="px-4 py-3">
                            <p class="text-xs font-semibold text-gray-700 uppercase mb-1">Depart</p>
                            <input type="date" class="w-full text-gray-900 focus:outline-none bg-transparent text-sm">
                        </div>
                    </div>

                    {# Voyageurs #}
                    <div class="border border-gray-300 rounded-xl px-4 py-3 text-sm">
                        <p class="text-xs font-semibold text-gray-700 uppercase mb-1">Voyageurs</p>
                        <select class="w-full text-gray-900 focus:outline-none bg-transparent">
                            {% for i in 1..property.maxGuests %}
                                <option value="{{ i }}">{{ i }} voyageur{{ i > 1 ? 's' : '' }}</option>
                            {% endfor %}
                        </select>
                    </div>

                    {# Bouton reserver #}
                    <button class="w-full bg-[#FF385C] hover:bg-[#E31C5F] text-white font-semibold py-3.5 rounded-xl transition-colors text-sm">
                        Reserver
                    </button>

                    <p class="text-center text-xs text-gray-400">Aucun montant ne sera debite pour l'instant</p>

                    {# Recapitulatif prix #}
                    <div class="space-y-3 pt-2 border-t border-gray-100 text-sm">
                        <div class="flex justify-between text-gray-600">
                            <span>{{ property.pricePerNight }} € x nuits</span>
                            <span>—</span>
                        </div>
                        {% if property.cleaningFee %}
                        <div class="flex justify-between text-gray-600">
                            <span>Frais de menage</span>
                            <span>{{ property.cleaningFee }} €</span>
                        </div>
                        {% endif %}
                        {% if property.securityDeposit %}
                        <div class="flex justify-between text-gray-600">
                            <span>Caution</span>
                            <span>{{ property.securityDeposit }} €</span>
                        </div>
                        {% endif %}
                        <div class="flex justify-between font-semibold text-gray-900 pt-3 border-t border-gray-100">
                            <span>Total</span>
                            <span>—</span>
                        </div>
                    </div>

                </div>
            </div>
        </div>

    </div>
</div>
{% endblock %}