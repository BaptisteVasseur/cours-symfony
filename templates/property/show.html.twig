{% extends 'layout/app.html.twig' %}

{% block title %}{{ property.title }} - Airbnb{% endblock %}



{% block content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    {# Breadcrumb #}
    <nav class="flex items-center gap-2 text-sm text-gray-500 mb-4">
        <a href="{{ path('app_property_index') }}" class="hover:underline">Logements</a>
        <span>/</span>
        <span class="text-gray-900">{{ property.title }}</span>
    </nav>

    <h1 class="text-2xl md:text-3xl font-bold text-gray-900 mb-2">{{ property.title }}</h1>

    <div class="flex items-center gap-4 text-sm text-gray-600 mb-6">
        {% if property.reviews|length > 0 %}
        <span class="flex items-center gap-1">
            <svg class="w-4 h-4 text-gray-900" fill="currentColor" viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
            <strong class="text-gray-900">{{ property.reviews|length }} avis</strong>
        </span>
        <span>·</span>
        {% endif %}
        {% if property.address %}
        <span>{{ property.address.city }}, {{ property.address.country }}</span>
        {% endif %}
        {% if property.instantBooking %}
        <span>· ⚡ Réservation instantanée</span>
        {% endif %}
    </div>

    {# Photo gallery #}
    {% set mediaList = property.media|filter(m => m.mediaType == 'image') %}
    <div class="grid grid-cols-4 grid-rows-2 gap-2 rounded-2xl overflow-hidden mb-8 h-80 md:h-[28rem]">
        {% if mediaList|length > 0 %}
            {% for media in mediaList|slice(0, 5) %}
                <div class="{{ loop.first ? 'col-span-2 row-span-2' : 'col-span-1 row-span-1' }} bg-gray-100 overflow-hidden">
                    <img src="{{ media.fileUrl }}" alt="{{ property.title }}" class="w-full h-full object-cover hover:scale-105 transition-transform duration-300 cursor-pointer">
                </div>
            {% endfor %}
            {% if mediaList|length < 5 %}
                {% for i in 1..(5 - mediaList|length) %}
                <div class="bg-gray-100 col-span-1 row-span-1"></div>
                {% endfor %}
            {% endif %}
        {% else %}
            <div class="col-span-4 row-span-2 bg-gradient-to-br from-gray-100 to-gray-200 flex items-center justify-center">
                <svg class="w-24 h-24 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                </svg>
            </div>
        {% endif %}
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">

        {# Left: details #}
        <div class="lg:col-span-2 space-y-8">

            {# Host + capacity #}
            <div class="flex items-start justify-between border-b border-gray-200 pb-6">
                <div>
                    <h2 class="text-xl font-semibold text-gray-900">
                        {{ property.propertyType|capitalize }} hébergé par
                        {{ property.host.profile ? property.host.profile.firstName : property.host.email }}
                    </h2>
                    <p class="text-gray-500 mt-1">
                        {{ property.maxGuests }} voyageur{{ property.maxGuests > 1 ? 's' : '' }} ·
                        {{ property.bedrooms }} chambre{{ property.bedrooms > 1 ? 's' : '' }} ·
                        {{ property.beds }} lit{{ property.beds > 1 ? 's' : '' }} ·
                        {{ property.bathrooms }} salle{{ property.bathrooms > 1 ? 's' : '' }} de bain
                    </p>
                </div>
                <div class="w-12 h-12 bg-gray-200 rounded-full flex items-center justify-center shrink-0">
                    <svg class="w-7 h-7 text-gray-500" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/>
                    </svg>
                </div>
            </div>

            {# Description #}
            {% if property.description %}
            <div class="border-b border-gray-200 pb-6">
                <h3 class="text-lg font-semibold text-gray-900 mb-3">Description</h3>
                <p class="text-gray-700 leading-relaxed whitespace-pre-line">{{ property.description }}</p>
            </div>
            {% endif %}

            {# Amenities #}
            {% if property.propertyAmenities|length > 0 %}
            <div class="border-b border-gray-200 pb-6">
                <h3 class="text-lg font-semibold text-gray-900 mb-4">Ce que propose ce logement</h3>
                <div class="grid grid-cols-2 gap-3">
                    {% for propertyAmenity in property.propertyAmenities|slice(0, 10) %}
                    <div class="flex items-center gap-3 text-gray-700">
                        <svg class="w-5 h-5 text-gray-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                        </svg>
                        <span>{{ propertyAmenity.amenity.label }}</span>
                    </div>
                    {% endfor %}
                </div>
            </div>
            {% endif %}

            {# Check-in/out times #}
            {% if property.checkinTime or property.checkoutTime %}
            <div class="border-b border-gray-200 pb-6">
                <h3 class="text-lg font-semibold text-gray-900 mb-4">Arrivée et départ</h3>
                <div class="grid grid-cols-2 gap-4">
                    {% if property.checkinTime %}
                    <div class="bg-gray-50 rounded-xl p-4">
                        <p class="text-sm text-gray-500 mb-1">Arrivée</p>
                        <p class="font-semibold text-gray-900">Après {{ property.checkinTime|date('H:i') }}</p>
                    </div>
                    {% endif %}
                    {% if property.checkoutTime %}
                    <div class="bg-gray-50 rounded-xl p-4">
                        <p class="text-sm text-gray-500 mb-1">Départ</p>
                        <p class="font-semibold text-gray-900">Avant {{ property.checkoutTime|date('H:i') }}</p>
                    </div>
                    {% endif %}
                </div>
            </div>
            {% endif %}

        </div>

        {# Right: booking card #}
        <div class="lg:col-span-1">
            <div class="sticky top-24 border border-gray-200 rounded-2xl shadow-xl p-6 bg-white">
                <div class="flex items-baseline gap-1 mb-4">
                    <span class="text-2xl font-bold text-gray-900">{{ property.pricePerNight|number_format(0, ',', ' ') }} €</span>
                    <span class="text-gray-500">/ nuit</span>
                </div>

                <a href="{{ path('app_reservation_book', {id: property.id}) }}"
                   class="block w-full bg-[#FF385C] hover:bg-[#E0284F] text-white font-semibold py-3 px-6 rounded-xl text-center transition-colors">
                    Réserver
                </a>

                <p class="text-center text-sm text-gray-400 mt-3">Aucun frais ne vous sera débité pour le moment</p>

                {% if property.cleaningFee or property.securityDeposit %}
                <div class="mt-4 space-y-2 pt-4 border-t border-gray-100">
                    {% if property.cleaningFee %}
                    <div class="flex justify-between text-sm text-gray-600">
                        <span>Frais de ménage</span>
                        <span>{{ property.cleaningFee|number_format(0, ',', ' ') }} €</span>
                    </div>
                    {% endif %}
                    {% if property.securityDeposit %}
                    <div class="flex justify-between text-sm text-gray-600">
                        <span>Dépôt de garantie</span>
                        <span>{{ property.securityDeposit|number_format(0, ',', ' ') }} €</span>
                    </div>
                    {% endif %}
                </div>
                {% endif %}
            </div>
        </div>
    </div>

</div>
{% endblock %}
