{% extends 'layout/base.html.twig' %}

{% block title %}{{ property.title }} — Airbnb{% endblock %}

{% block body %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-4">
        <a href="{{ path('app_property_index') }}" class="text-sm text-gray-500 hover:underline">&larr; Retour aux logements</a>
    </div>

    <h1 class="text-3xl font-bold text-gray-900 mb-2">{{ property.title }}</h1>
    <div class="flex items-center gap-4 text-sm text-gray-600 mb-6">
        {% if property.averageRating %}
            <span class="flex items-center gap-1">
                <svg class="w-4 h-4 text-gray-800" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                {{ property.averageRating }} ({{ property.reviews|length }} avis)
            </span>
        {% endif %}
        <span>{{ property.city }}, {{ property.country }}</span>
    </div>

    <div class="grid grid-cols-2 gap-2 rounded-2xl overflow-hidden mb-8 h-80">
        {% if property.images.first %}
            <img src="{{ property.images.first.imageUrl }}" alt="{{ property.title }}" class="col-span-2 w-full h-full object-cover">
        {% else %}
            <div class="col-span-2 bg-gray-100 flex items-center justify-center">
                <p class="text-gray-400">Aucune photo disponible</p>
            </div>
        {% endif %}
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        <div class="lg:col-span-2">
            <div class="flex items-center justify-between pb-6 border-b border-gray-200">
                <div>
                    <h2 class="text-xl font-semibold text-gray-900">Hébergé par {{ property.host.firstName }}</h2>
                    <p class="text-gray-500 text-sm mt-1">Jusqu'à {{ property.maxGuests }} voyageurs</p>
                </div>
                <div class="w-12 h-12 bg-rose-500 rounded-full flex items-center justify-center text-white font-bold text-lg">
                    {{ property.host.firstName|first|upper }}
                </div>
            </div>

            <div class="py-6 border-b border-gray-200">
                <p class="text-gray-700 leading-relaxed">{{ property.description }}</p>
            </div>

            <div class="py-6 border-b border-gray-200">
                <h3 class="font-semibold text-gray-900 mb-3">Localisation</h3>
                <p class="text-gray-600">{{ property.address }}</p>
                <p class="text-gray-600">{{ property.city }}, {{ property.country }}</p>
            </div>

            {% if property.reviews is not empty %}
                <div class="py-6">
                    <h3 class="font-semibold text-gray-900 mb-4 flex items-center gap-2">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                        {{ property.averageRating }} · {{ property.reviews|length }} avis
                    </h3>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        {% for review in property.reviews %}
                            <div class="p-4 bg-gray-50 rounded-xl">
                                <div class="flex items-center gap-2 mb-2">
                                    <div class="w-8 h-8 bg-gray-400 rounded-full flex items-center justify-center text-white text-sm font-medium">
                                        {{ review.reviewer.firstName|first|upper }}
                                    </div>
                                    <div>
                                        <p class="font-medium text-sm text-gray-800">{{ review.reviewer.firstName }}</p>
                                        <p class="text-xs text-gray-500">{{ review.createdAt|date('M Y') }}</p>
                                    </div>
                                </div>
                                <p class="text-sm text-gray-700">{{ review.comment }}</p>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}
        </div>

        <div class="lg:col-span-1">
            <div class="sticky top-24 border border-gray-200 rounded-2xl p-6 shadow-md">
                <div class="flex items-baseline gap-1 mb-6">
                    <span class="text-2xl font-bold text-gray-900">{{ property.pricePerNight }} €</span>
                    <span class="text-gray-500">/ nuit</span>
                </div>

                {% if is_granted('ROLE_USER') %}
                    {{ form_start(bookingForm, { action: path('app_booking_new', { id: property.id }), method: 'POST', attr: { class: 'space-y-4' } }) }}
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Arrivée</label>
                            {{ form_widget(bookingForm.checkIn) }}
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Départ</label>
                            {{ form_widget(bookingForm.checkOut) }}
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">Voyageurs</label>
                            {{ form_widget(bookingForm.guestsCount, { attr: { max: property.maxGuests } }) }}
                        </div>
                        <button type="submit" class="w-full bg-rose-500 hover:bg-rose-600 text-white font-semibold py-3 rounded-xl transition">
                            Réserver
                        </button>
                    {{ form_end(bookingForm) }}
                {% else %}
                    <a href="{{ path('app_login') }}" class="block w-full text-center bg-rose-500 hover:bg-rose-600 text-white font-semibold py-3 rounded-xl transition">
                        Connectez-vous pour réserver
                    </a>
                {% endif %}

                {% if is_granted('ROLE_HOST') and property.host == app.user %}
                    <div class="mt-4 pt-4 border-t border-gray-100 flex gap-2">
                        <a href="{{ path('app_property_edit', { id: property.id }) }}" class="flex-1 text-center border border-gray-300 text-sm py-2 rounded-lg hover:bg-gray-50 transition">Modifier</a>
                        <form method="POST" action="{{ path('app_property_delete', { id: property.id }) }}" onsubmit="return confirm('Supprimer ce logement ?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ property.id) }}">
                            <button type="submit" class="text-sm text-rose-500 border border-rose-200 py-2 px-3 rounded-lg hover:bg-rose-50 transition">Supprimer</button>
                        </form>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
