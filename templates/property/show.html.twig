{% extends 'layout/user.html.twig' %}

{% set hostProfile = property.host ? property.host.profile : null %}
{% set placeholderImage = 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=1200&q=80' %}

{% block title %}{{ property.title }}{% endblock %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-6xl mx-auto w-full">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 px-4 py-3 rounded-lg text-sm font-medium {{ label == 'success' ? 'bg-emerald-50 text-emerald-800 border border-emerald-200' : 'bg-red-50 text-red-800 border border-red-200' }}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        <div class="mb-6">
            <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">{{ property.title }}</h1>
            {% if property.address %}
                <p class="text-sm text-gray-600 mt-2">{{ property.address.city }}, {{ property.address.country }}</p>
            {% endif %}
        </div>

        <div class="mb-10 overflow-hidden rounded-xl bg-gray-100" data-controller="gallery">
            {% if property.media is not empty %}
                {% for medium in property.media %}
                    <img
                        data-gallery-target="slide"
                        src="{{ asset(medium.fileUrl) }}"
                        alt="{{ property.title }}"
                        class="h-[320px] md:h-[520px] w-full object-cover"
                        {% if not loop.first %}hidden{% endif %}
                    >
                {% endfor %}
                {% if property.media|length > 1 %}
                    <div class="flex items-center justify-between bg-white border-x border-b border-gray-200 px-4 py-3">
                        <button type="button" data-action="click->gallery#previous" class="h-10 w-10 rounded-full border border-gray-200 hover:bg-gray-50 transition" aria-label="Image précédente">
                            <i class="fa-solid fa-chevron-left"></i>
                        </button>
                        <span data-gallery-target="counter" class="text-sm font-semibold text-gray-700">1 / {{ property.media|length }}</span>
                        <button type="button" data-action="click->gallery#next" class="h-10 w-10 rounded-full border border-gray-200 hover:bg-gray-50 transition" aria-label="Image suivante">
                            <i class="fa-solid fa-chevron-right"></i>
                        </button>
                    </div>
                {% endif %}
            {% else %}
                <img src="{{ placeholderImage }}" alt="{{ property.title }}" class="h-[320px] md:h-[520px] w-full object-cover">
            {% endif %}
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
            <div class="lg:col-span-2 space-y-8">
                <section class="pb-8 border-b border-gray-200">
                    <h2 class="text-xl font-semibold text-gray-900">
                        Logement proposé par {{ hostProfile ? hostProfile.firstName : property.host.firstName|default('un hôte') }}
                    </h2>
                    <p class="text-gray-500 mt-1">
                        {{ property.maxGuests }} voyageur{{ property.maxGuests > 1 ? 's' : '' }}
                        · {{ property.bedrooms }} chambre{{ property.bedrooms > 1 ? 's' : '' }}
                        · {{ property.beds }} lit{{ property.beds > 1 ? 's' : '' }}
                        · {{ property.bathrooms }} salle{{ property.bathrooms > 1 ? 's' : '' }} de bain
                    </p>
                </section>

                <section class="pb-8 border-b border-gray-200">
                    <h2 class="text-xl font-semibold text-gray-900 mb-4">À propos de ce logement</h2>
                    <p class="text-gray-700 leading-relaxed whitespace-pre-line">{{ property.description }}</p>
                </section>

                {% if property.propertyAmenities|length > 0 %}
                    <section>
                        <h2 class="text-xl font-semibold text-gray-900 mb-4">Équipements</h2>
                        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                            {% for propertyAmenity in property.propertyAmenities %}
                                {% if propertyAmenity.amenity %}
                                    <li class="flex items-center gap-3 text-gray-700">
                                        <i class="fa-solid fa-check text-gray-900"></i>
                                        {{ propertyAmenity.amenity.label }}
                                    </li>
                                {% endif %}
                            {% endfor %}
                        </ul>
                    </section>
                {% endif %}
            </div>

            <aside class="lg:col-span-1">
                <section class="sticky top-28 border border-gray-200 rounded-xl shadow-lg p-6">
                    <p class="text-2xl font-semibold mb-4">
                        <span class="font-bold">{{ property.pricePerNight|number_format(0, ',', ' ') }} €</span>
                        <span class="text-base font-normal text-gray-600"> / nuit</span>
                    </p>

                    {% if app.user %}
                        {% if is_granted('BOOK_PROPERTY', property) %}
                            <form method="post" action="{{ path('app_booking_create', {id: property.id}) }}" class="space-y-4">
                                <input type="hidden" name="_token" value="{{ csrf_token('book-' ~ property.id) }}">

                                <div>
                                    <label for="startDate" class="block text-xs font-bold uppercase text-gray-800 mb-1">Arrivée</label>
                                    <input type="date" id="startDate" name="startDate" min="{{ 'now'|date('Y-m-d') }}" required class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
                                </div>

                                <div>
                                    <label for="endDate" class="block text-xs font-bold uppercase text-gray-800 mb-1">Départ</label>
                                    <input type="date" id="endDate" name="endDate" min="{{ 'now'|date('Y-m-d') }}" required class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
                                </div>

                                <button type="submit" class="w-full bg-brand hover:bg-brandHover text-white font-semibold py-3 rounded-lg transition">
                                    Réserver
                                </button>
                            </form>
                        {% else %}
                            <div class="bg-gray-50 border border-gray-200 rounded-lg p-4 text-center text-sm text-gray-600">
                                <i class="fa-solid fa-circle-info mr-2"></i>
                                Vous ne pouvez pas réserver votre propre logement.
                            </div>
                        {% endif %}
                    {% else %}
                        <a href="{{ path('app_login') }}" class="block w-full text-center bg-brand hover:bg-brandHover text-white font-semibold py-3 rounded-lg transition">
                            Se connecter pour réserver
                        </a>
                    {% endif %}
                </section>
            </aside>
        </div>
    </main>
{% endblock %}
