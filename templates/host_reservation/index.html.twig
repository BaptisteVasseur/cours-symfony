{% extends 'layout/user.html.twig' %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-6xl mx-auto w-full">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 px-4 py-3 rounded-lg text-sm font-medium {{ label == 'success' ? 'bg-emerald-50 text-emerald-800 border border-emerald-200' : 'bg-red-50 text-red-800 border border-red-200' }}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        <div class="mb-8 flex flex-col md:flex-row md:items-end md:justify-between gap-4">
            <div>
                <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">Demandes de réservation</h1>
                <p class="text-gray-500 mt-1">Validez ou refusez les demandes en attente sur vos logements.</p>
            </div>
            <div class="text-sm text-gray-500">
                {{ reservations|length }} demande{{ reservations|length > 1 ? 's' : '' }} en attente
            </div>
        </div>

        <div class="space-y-5">
            {% for reservation in reservations %}
                {% set property = reservation.property %}
                {% set cover = property ? property.coverMedia : null %}
                {% set guestProfile = reservation.guest ? reservation.guest.profile : null %}

                <article class="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm">
                    <div class="grid grid-cols-1 lg:grid-cols-[220px_1fr]">
                        <div class="h-48 lg:h-full bg-gray-100">
                            {% if cover %}
                                <img src="{{ cover.fileUrl }}" alt="{{ property.title }}" class="w-full h-full object-cover">
                            {% else %}
                                <div class="w-full h-full flex items-center justify-center text-gray-300">
                                    <i class="fa-solid fa-house text-4xl"></i>
                                </div>
                            {% endif %}
                        </div>

                        <div class="p-5">
                            <div class="flex flex-col xl:flex-row xl:items-start xl:justify-between gap-4">
                                <div>
                                    <div class="flex flex-wrap items-center gap-2 mb-2">
                                        <span class="text-xs font-semibold px-2.5 py-1 rounded-full bg-yellow-100 text-yellow-800">En attente</span>
                                        <span class="text-xs text-gray-400">Demandée le {{ reservation.createdAt|date('d/m/Y à H:i') }}</span>
                                    </div>
                                    <h2 class="text-lg font-semibold text-gray-900">{{ property ? property.title : 'Logement supprimé' }}</h2>
                                    {% if property and property.address %}
                                        <p class="text-sm text-gray-500 mt-1">{{ property.address.city }}, {{ property.address.country }}</p>
                                    {% endif %}
                                </div>
                                <div class="text-left xl:text-right">
                                    <p class="font-semibold text-gray-900">{{ reservation.totalPrice|number_format(2, ',', ' ') }} {{ reservation.currency }}</p>
                                    <p class="text-xs text-gray-400">Réf. {{ reservation.id }}</p>
                                </div>
                            </div>

                            <dl class="grid grid-cols-1 sm:grid-cols-4 gap-4 mt-5 text-sm">
                                <div>
                                    <dt class="text-gray-500 mb-1">Voyageur</dt>
                                    <dd class="font-semibold text-gray-900">
                                        {% if guestProfile %}
                                            {{ guestProfile.firstName }} {{ guestProfile.lastName }}
                                        {% elseif reservation.guest %}
                                            {{ reservation.guest.email }}
                                        {% else %}
                                            Voyageur inconnu
                                        {% endif %}
                                    </dd>
                                </div>
                                <div>
                                    <dt class="text-gray-500 mb-1">Arrivée</dt>
                                    <dd class="font-semibold text-gray-900">{{ reservation.checkinDate|date('d/m/Y') }}</dd>
                                </div>
                                <div>
                                    <dt class="text-gray-500 mb-1">Départ</dt>
                                    <dd class="font-semibold text-gray-900">{{ reservation.checkoutDate|date('d/m/Y') }}</dd>
                                </div>
                                <div>
                                    <dt class="text-gray-500 mb-1">Voyageurs</dt>
                                    <dd class="font-semibold text-gray-900">{{ reservation.guestsCount }}</dd>
                                </div>
                            </dl>

                            <div class="mt-5 pt-5 border-t border-gray-100 grid grid-cols-1 xl:grid-cols-[auto_1fr] gap-3">
                                <form method="post" action="{{ path('app_host_reservation_accept', { id: reservation.id }) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('host_accept' ~ reservation.id) }}">
                                    <button type="submit" class="w-full xl:w-auto inline-flex justify-center items-center gap-2 bg-emerald-600 hover:bg-emerald-700 text-white font-semibold text-sm px-5 py-3 rounded-lg transition">
                                        <i class="fa-solid fa-check"></i>
                                        Accepter
                                    </button>
                                </form>

                                <form method="post" action="{{ path('app_host_reservation_reject', { id: reservation.id }) }}" class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-3">
                                    <input type="hidden" name="_token" value="{{ csrf_token('host_reject' ~ reservation.id) }}">
                                    <input
                                        type="text"
                                        name="reason"
                                        required
                                        placeholder="Motif du refus"
                                        class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand/20 focus:border-brand"
                                    >
                                    <button type="submit" class="inline-flex justify-center items-center gap-2 border border-red-200 text-red-700 hover:bg-red-50 font-semibold text-sm px-5 py-3 rounded-lg transition">
                                        <i class="fa-solid fa-xmark"></i>
                                        Refuser
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </article>
            {% else %}
                <div class="text-center py-16 border border-dashed border-gray-200 rounded-xl bg-white">
                    <i class="fa-solid fa-calendar-check text-4xl text-gray-300 mb-4"></i>
                    <p class="font-semibold text-gray-900">Aucune demande en attente</p>
                    <p class="text-sm text-gray-500 mt-1">Les nouvelles demandes de réservation apparaîtront ici.</p>
                </div>
            {% endfor %}
        </div>
    </main>
{% endblock %}
