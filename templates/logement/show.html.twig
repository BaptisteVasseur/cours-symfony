{% extends 'layout/base.html.twig' %}

{% block title %}{{ logement.titre }} - StayShare{% endblock %}

{% block body %}
    {% set photo = logement.photos|first %}
    <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
        <a href="{{ path('app_logement_index') }}" class="text-sm font-semibold text-rose-600 hover:text-rose-700">Retour aux logements</a>

        <section class="mt-5">
            <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
                <div>
                    <h1 class="text-3xl font-bold text-gray-950">{{ logement.titre }}</h1>
                    <p class="mt-2 text-sm text-gray-600">
                        {{ logement.adresse ? logement.adresse.ville ~ ', ' ~ logement.adresse.pays : 'Adresse a confirmer' }}
                        - {{ logement.noteMoyenne|number_format(2, '.', ' ') }} sur {{ logement.nombreAvis }} avis
                    </p>
                </div>
                <p class="text-sm text-gray-600">Hote : <strong class="text-gray-950">{{ logement.hote.prenom }}</strong></p>
            </div>

            <img src="{{ photo ? photo.url : 'https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?auto=format&fit=crop&w=1200&q=80' }}" alt="{{ logement.titre }}" class="mt-6 h-[30rem] w-full rounded-lg object-cover">
        </section>

        <div class="mt-10 grid gap-10 lg:grid-cols-[1fr_360px]">
            <section>
                <div class="border-b border-gray-100 pb-8">
                    <h2 class="text-xl font-semibold text-gray-950">{{ logement.typeLogement.value|replace({'_': ' '})|title }} - {{ logement.categorie.value|replace({'_': ' '})|title }}</h2>
                    <p class="mt-2 text-sm text-gray-600">{{ logement.capaciteVoyageurs }} voyageurs - {{ logement.nombreChambres }} chambres - {{ logement.nombreLits }} lits - {{ logement.nombreSallesBain }} salle{{ logement.nombreSallesBain > 1 ? 's' : '' }} de bain</p>
                    <p class="mt-6 leading-7 text-gray-700">{{ logement.description }}</p>
                </div>

                <div class="border-b border-gray-100 py-8">
                    <h2 class="text-xl font-semibold text-gray-950">Equipements</h2>
                    <div class="mt-5 grid gap-3 sm:grid-cols-2">
                        {% for equipement in logement.equipements %}
                            <div class="rounded-md border border-gray-100 px-4 py-3 text-sm text-gray-700">{{ equipement.nom }}</div>
                        {% else %}
                            <p class="text-sm text-gray-600">Aucun equipement renseigne pour le moment.</p>
                        {% endfor %}
                    </div>
                </div>

                <div class="border-b border-gray-100 py-8">
                    <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
                        <div>
                            <h2 class="text-xl font-semibold text-gray-950">Disponibilites</h2>
                            <p class="mt-2 text-sm text-gray-600">Les dates ouvertes a la reservation sur les 60 prochains jours.</p>
                        </div>
                        <div class="flex flex-wrap gap-2 text-xs font-medium">
                            <span class="rounded-full bg-emerald-50 px-3 py-1 text-emerald-700">Disponible</span>
                            <span class="rounded-full bg-rose-50 px-3 py-1 text-rose-700">Reservee</span>
                            <span class="rounded-full bg-gray-100 px-3 py-1 text-gray-600">Bloquee</span>
                            <span class="rounded-full bg-slate-50 px-3 py-1 text-slate-500">Non ouverte</span>
                        </div>
                    </div>

                    <div class="mt-5 grid grid-cols-7 gap-2 text-center text-xs font-semibold uppercase text-gray-400">
                        <span>Lun</span>
                        <span>Mar</span>
                        <span>Mer</span>
                        <span>Jeu</span>
                        <span>Ven</span>
                        <span>Sam</span>
                        <span>Dim</span>
                    </div>
                    <div class="mt-2 space-y-2">
                        {% for semaine in calendrier_disponibilites %}
                            <div class="grid grid-cols-7 gap-2">
                                {% for jour in semaine %}
                                    {% if jour.date %}
                                        {% set disponibilite = jour.disponibilite %}
                                        {% set statut = disponibilite ? disponibilite.statut.value : 'non_ouverte' %}
                                        {% set libelle = {
                                            disponible: 'Dispo',
                                            reservee: 'Reservee',
                                            bloquee: 'Bloquee',
                                            non_ouverte: 'Non ouverte'
                                        }[statut] %}
                                        {% set style = {
                                            disponible: 'border-emerald-200 bg-emerald-50 text-emerald-800',
                                            reservee: 'border-rose-200 bg-rose-50 text-rose-800',
                                            bloquee: 'border-gray-200 bg-gray-100 text-gray-600',
                                            non_ouverte: 'border-slate-100 bg-slate-50 text-slate-400'
                                        }[statut] %}
                                        <div class="min-h-16 rounded-md border px-1.5 py-2 text-center {{ style }}">
                                            <p class="text-sm font-bold">{{ jour.date|date('d/m') }}</p>
                                            <p class="mt-1 text-[0.65rem] font-semibold leading-tight">{{ libelle }}</p>
                                        </div>
                                    {% else %}
                                        <div class="min-h-16"></div>
                                    {% endif %}
                                {% endfor %}
                            </div>
                        {% endfor %}
                    </div>
                    <p class="mt-4 text-xs text-gray-500">La date de depart correspond au lendemain de la derniere nuit reservee.</p>
                </div>

                <div class="grid gap-8 py-8 md:grid-cols-2">
                    <section>
                        <h2 class="text-xl font-semibold text-gray-950">Reglement</h2>
                        {% if logement.reglementInterieur %}
                            <ul class="mt-4 space-y-2 text-sm text-gray-700">
                                <li>Animaux : {{ logement.reglementInterieur.animauxAcceptes ? 'acceptes' : 'non acceptes' }}</li>
                                <li>Fumeurs : {{ logement.reglementInterieur.fumeursAcceptes ? 'acceptes' : 'non acceptes' }}</li>
                                <li>Fetes : {{ logement.reglementInterieur.fetesAutorisees ? 'autorisees' : 'non autorisees' }}</li>
                                {% if logement.reglementInterieur.reglesSupplementaires %}<li>{{ logement.reglementInterieur.reglesSupplementaires }}</li>{% endif %}
                            </ul>
                        {% endif %}
                    </section>
                    <section>
                        <h2 class="text-xl font-semibold text-gray-950">Annulation</h2>
                        <p class="mt-4 text-sm text-gray-700">{{ logement.politiqueAnnulation ? logement.politiqueAnnulation.nom : 'Politique a confirmer' }}.</p>
                    </section>
                </div>
            </section>

            <aside class="h-fit rounded-lg border border-gray-100 bg-white p-5 shadow-lg">
                <div class="flex items-end justify-between">
                    <p><strong class="text-2xl text-gray-950">{{ logement.tarif ? logement.tarif.prixNuit : '0.00' }} EUR</strong> <span class="text-sm text-gray-600">/ nuit</span></p>
                    <span class="text-sm font-semibold text-gray-900">{{ logement.noteMoyenne|number_format(2, '.', ' ') }}</span>
                </div>

                <form class="mt-6 space-y-4" action="{{ path('app_reservation_request', { id: logement.id }) }}" method="post">
                    <div class="grid grid-cols-2 gap-3">
                        <label>
                            <span class="text-xs font-semibold uppercase text-gray-500">Arrivee</span>
                            <input name="date_arrivee" type="date" min="{{ date_min|date('Y-m-d') }}" max="{{ date_max|date('Y-m-d') }}" required class="mt-1 w-full rounded-md border border-gray-200 px-3 py-2 text-sm focus:border-rose-500 focus:outline-none focus:ring-2 focus:ring-rose-200">
                        </label>
                        <label>
                            <span class="text-xs font-semibold uppercase text-gray-500">Depart</span>
                            <input name="date_depart" type="date" min="{{ date_min|date('Y-m-d') }}" max="{{ date_max|date('Y-m-d') }}" required class="mt-1 w-full rounded-md border border-gray-200 px-3 py-2 text-sm focus:border-rose-500 focus:outline-none focus:ring-2 focus:ring-rose-200">
                        </label>
                    </div>
                    <label>
                        <span class="text-xs font-semibold uppercase text-gray-500">Voyageurs</span>
                        <input name="voyageurs" type="number" min="1" max="{{ logement.capaciteVoyageurs }}" value="1" required class="mt-1 w-full rounded-md border border-gray-200 px-3 py-2 text-sm focus:border-rose-500 focus:outline-none focus:ring-2 focus:ring-rose-200">
                    </label>
                    <label>
                        <span class="text-xs font-semibold uppercase text-gray-500">Message</span>
                        <textarea name="message_voyageur" rows="3" class="mt-1 w-full rounded-md border border-gray-200 px-3 py-2 text-sm focus:border-rose-500 focus:outline-none focus:ring-2 focus:ring-rose-200"></textarea>
                    </label>
                    <input type="hidden" name="_token" value="{{ csrf_token('reservation_request_' ~ logement.id) }}">
                    <button type="submit" class="w-full rounded-md bg-rose-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-rose-700">Demander a reserver</button>
                </form>
            </aside>
        </div>
    </main>
{% endblock %}
