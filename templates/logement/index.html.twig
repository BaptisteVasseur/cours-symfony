{% extends 'layout/base.html.twig' %}

{% block title %}Recherche de logements - StayShare{% endblock %}

{% block body %}
    <main class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
            <div>
                <h1 class="text-3xl font-bold text-gray-950">Explorer les logements</h1>
                <p class="mt-2 text-sm text-gray-600">{{ logements|length }} resultat{{ logements|length > 1 ? 's' : '' }} disponible{{ logements|length > 1 ? 's' : '' }}</p>
            </div>
        </div>

        {% if erreurs is defined and erreurs is not empty %}
            <div class="mt-6 rounded-lg bg-amber-50 p-4 text-sm text-amber-800">
                {% for erreur in erreurs %}
                    <p>{{ erreur }}</p>
                {% endfor %}
            </div>
        {% endif %}

        <form method="get" action="{{ path('app_search') }}" class="mt-8 grid gap-3 rounded-lg border border-gray-100 bg-white p-4 shadow-sm md:grid-cols-7">
            <label>
                <span class="text-xs font-semibold uppercase text-gray-500">Destination</span>
                <input name="destination" value="{{ criteres.destination }}" type="text" class="mt-1 w-full rounded-md border border-gray-200 px-3 py-2 focus:border-rose-500 focus:outline-none focus:ring-2 focus:ring-rose-200">
            </label>
            <label>
                <span class="text-xs font-semibold uppercase text-gray-500">Arrivee</span>
                <input name="checkin" value="{{ criteres.checkin }}" type="date" class="mt-1 w-full rounded-md border border-gray-200 px-3 py-2 focus:border-rose-500 focus:outline-none focus:ring-2 focus:ring-rose-200">
            </label>
            <label>
                <span class="text-xs font-semibold uppercase text-gray-500">Depart</span>
                <input name="checkout" value="{{ criteres.checkout }}" type="date" class="mt-1 w-full rounded-md border border-gray-200 px-3 py-2 focus:border-rose-500 focus:outline-none focus:ring-2 focus:ring-rose-200">
            </label>
            <label>
                <span class="text-xs font-semibold uppercase text-gray-500">Voyageurs</span>
                <input name="guests" value="{{ criteres.guests }}" type="number" min="1" class="mt-1 w-full rounded-md border border-gray-200 px-3 py-2 focus:border-rose-500 focus:outline-none focus:ring-2 focus:ring-rose-200">
            </label>
            <label>
                <span class="text-xs font-semibold uppercase text-gray-500">Prix max</span>
                <input name="prix_max" value="{{ criteres.prix_max }}" type="number" min="1" class="mt-1 w-full rounded-md border border-gray-200 px-3 py-2 focus:border-rose-500 focus:outline-none focus:ring-2 focus:ring-rose-200">
            </label>
            <label>
                <span class="text-xs font-semibold uppercase text-gray-500">Type</span>
                <select name="type" class="mt-1 w-full rounded-md border border-gray-200 px-3 py-2 focus:border-rose-500 focus:outline-none focus:ring-2 focus:ring-rose-200">
                    <option value="">Tous</option>
                    {% for value, label in {
                        appartement: 'Appartement', maison: 'Maison', chambre_privee: 'Chambre privee', chambre_partagee: 'Chambre partagee', villa: 'Villa', studio: 'Studio', autre: 'Autre'
                    } %}
                        <option value="{{ value }}" {{ criteres.type == value ? 'selected' : '' }}>{{ label }}</option>
                    {% endfor %}
                </select>
            </label>
            <button type="submit" class="self-end rounded-md bg-rose-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-rose-700">Filtrer</button>
        </form>

        <div class="mt-8 grid gap-6 lg:grid-cols-[1fr_360px]">
            <section class="grid gap-5">
                {% for logement in logements %}
                    {% set photo = logement.photos|first %}
                    <article class="grid overflow-hidden rounded-lg border border-gray-100 bg-white shadow-sm sm:grid-cols-[260px_1fr]">
                        <a href="{{ path('app_logement_show', { id: logement.id }) }}">
                            <img src="{{ photo ? photo.url : 'https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?auto=format&fit=crop&w=900&q=80' }}" alt="{{ logement.titre }}" class="h-64 w-full object-cover sm:h-full">
                        </a>
                        <div class="flex flex-col p-5">
                            <div class="flex items-start justify-between gap-4">
                                <div>
                                    <p class="text-sm text-gray-500">{{ logement.typeLogement.value|replace({'_': ' '})|title }} - {{ logement.categorie.value|replace({'_': ' '})|title }}</p>
                                    <h2 class="mt-1 text-xl font-semibold text-gray-950">
                                        <a href="{{ path('app_logement_show', { id: logement.id }) }}" class="hover:text-rose-600">{{ logement.titre }}</a>
                                    </h2>
                                    <p class="mt-1 text-sm text-gray-600">{{ logement.adresse ? logement.adresse.ville ~ ', ' ~ logement.adresse.pays : 'Adresse a confirmer' }}</p>
                                </div>
                                <span class="shrink-0 text-sm font-semibold text-gray-900">{{ logement.noteMoyenne|number_format(2, '.', ' ') }}</span>
                            </div>

                            <p class="mt-4 text-sm text-gray-700">{{ logement.description }}</p>
                            <p class="mt-4 text-sm text-gray-600">{{ logement.capaciteVoyageurs }} voyageurs - {{ logement.nombreChambres }} chambres - {{ logement.nombreLits }} lits</p>

                            <div class="mt-auto flex items-center justify-between pt-5">
                                <p class="text-sm text-gray-700"><strong class="text-lg text-gray-950">{{ logement.tarif ? logement.tarif.prixNuit : '0.00' }} EUR</strong> / nuit</p>
                                <a href="{{ path('app_logement_show', { id: logement.id }) }}" class="rounded-md border border-gray-200 px-4 py-2 text-sm font-semibold text-gray-900 hover:border-rose-300 hover:text-rose-600">Voir</a>
                            </div>
                        </div>
                    </article>
                {% else %}
                    <div class="rounded-lg border border-gray-100 bg-white p-8 text-center shadow-sm">
                        <h2 class="text-xl font-semibold text-gray-950">Aucun logement trouve</h2>
                        <p class="mt-2 text-sm text-gray-600">Ajoutez des fixtures ou publiez une annonce pour alimenter la recherche.</p>
                    </div>
                {% endfor %}
            </section>

            <aside class="hidden rounded-lg border border-gray-100 bg-gray-50 p-5 lg:block">
                <h2 class="text-sm font-semibold uppercase text-gray-500">Carte</h2>
                <div class="mt-4 flex aspect-square items-center justify-center rounded-md bg-white text-sm text-gray-500">
                    Carte interactive a brancher
                </div>
            </aside>
        </div>
    </main>
{% endblock %}
