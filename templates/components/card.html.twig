{% set cover = property.coverMedia %}
{% set averageRating = property.averageRating %}
{% set placeholderImage = 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=800&q=80' %}

<div class="group block cursor-pointer"
     onclick="window.location.href='{{ path('app_logement_detail', { id: property.id }) }}'">

    <div class="relative aspect-square w-full overflow-hidden rounded-xl mb-3">
        <img
            class="h-full w-full object-cover group-hover:scale-105 transition duration-300"
            src="{{ cover ? cover.fileUrl : placeholderImage }}"
            alt="{{ property.title }}"
        >

        <button type="button"
                class="absolute top-3 right-3 text-white text-xl drop-shadow-md hover:scale-110 transition"
                aria-label="Ajouter aux favoris"
                onclick="event.stopPropagation()">
            <i class="fa-regular fa-heart"></i>
        </button>
    </div>

    <div class="flex justify-between items-start gap-2">
        <h3 class="font-bold text-sm text-gray-900 line-clamp-1">
            {{ property.title }}
        </h3>

        {% if averageRating %}
            <div class="flex items-center space-x-1 text-sm shrink-0">
                <i class="fa-solid fa-star text-xs"></i>
                <span>{{ averageRating|number_format(2, ',') }}</span>
            </div>
        {% endif %}
    </div>

    {% if property.address %}
        <p class="text-gray-500 text-sm">
            {{ property.address.city }}
            {% if property.address.country %}, {{ property.address.country }}{% endif %}
        </p>
    {% endif %}

    {% if checkin is defined and checkout is defined and checkin and checkout %}
        <p class="text-gray-500 text-sm mb-1">
            {{ checkin|date('d') }}–{{ checkout|date('d/m') }}
        </p>
    {% endif %}

    <p class="text-sm font-semibold">
        <span class="font-bold">{{ property.pricePerNight|number_format(0, ',', ' ') }} €</span> nuit
    </p>

    {% if showCalendarButton is defined and showCalendarButton %}
        <button type="button"
                onclick="event.stopPropagation(); window.location.href='{{ path('app_availability_index', { id: property.id }) }}'"
                class="inline-flex bg-red-500 items-center gap-2 p-2 rounded-md text-sm text-white hover:bg-red-600 mt-2">
            <i class="fa-solid fa-calendar-days"></i>
            Voir le calendrier
        </button>
    {% endif %}

    {% if showIcalButton is defined and showIcalButton %}
    <div class="mt-3 pt-3 border-t border-gray-100" onclick="event.stopPropagation()">
        {% if property.icalToken %}
            <div class="space-y-2">
                {# Bouton de copie d'URL #}
                <div class="flex items-center gap-2">
                    <button onclick="copyToClipboard('{{ url('app_ical_export', { id: property.id, token: property.icalToken }) }}')"
                            class="text-xs bg-gray-100 hover:bg-gray-200 text-gray-700 px-2 py-1 rounded transition">
                        <i class="fa-regular fa-copy"></i> Copier l'URL iCal
                    </button>
                    <a href="{{ path('app_ical_export', { id: property.id, token: property.icalToken }) }}" 
                       target="_blank" 
                       class="text-xs text-blue-600 hover:text-blue-800">
                        <i class="fa-regular fa-calendar-alt"></i> Télécharger
                    </a>
                    <form method="POST" action="{{ path('app_property_generate_ical_token', { id: property.id }) }}" class="inline">
                        <button type="submit" class="text-xs text-gray-500 hover:text-gray-700">
                            <i class="fa-solid fa-rotate"></i>
                        </button>
                    </form>
                </div>
            </div>
        {% else %}
            <form method="POST" action="{{ path('app_property_generate_ical_token', { id: property.id }) }}" class="inline">
                <button type="submit" class="text-xs text-gray-500 hover:text-gray-700">
                    <i class="fa-solid fa-key"></i> Générer token iCal
                </button>
            </form>
        {% endif %}
    </div>
{% endif %}
</div>

<script>
function copyToClipboard(text) {
    if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(text).then(function() {
            alert('URL iCal copiée dans le presse-papier !');
        }).catch(function(err) {
            console.error('Erreur de copie: ', err);
            fallbackCopyToClipboard(text);
        });
    } else {
        fallbackCopyToClipboard(text);
    }
}

function fallbackCopyToClipboard(text) {
    const textarea = document.createElement('textarea');
    textarea.value = text;
    textarea.style.position = 'fixed';
    textarea.style.opacity = '0';
    document.body.appendChild(textarea);
    textarea.select();
    try {
        document.execCommand('copy');
        alert('URL iCal copiée dans le presse-papier !');
    } catch (err) {
        console.error('Erreur de copie: ', err);
        alert('Impossible de copier. Veuillez copier manuellement.');
    }
    document.body.removeChild(textarea);
}
</script>