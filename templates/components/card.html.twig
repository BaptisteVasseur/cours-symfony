{% set cover = property.coverMedia %}
{% set averageRating = property.averageRating %}
{% set placeholder = 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=800&q=80' %}

<a href="{{ hostUrl is defined and hostUrl ? hostUrl : path('app_logement_detail', { id: property.id }) }}" class="property-card group block">

    {# Image #}
    <div class="relative aspect-photo w-full overflow-hidden rounded-2xl mb-3 bg-ink/10">
        <img
            src="{{ cover ? cover.fileUrl : placeholder }}"
            alt="{{ property.title }}"
            class="absolute inset-0 w-full h-full object-cover group-hover:scale-[1.06] transition-transform duration-700 ease-out"
            loading="lazy"
        >

        {# Dark editorial overlay on hover #}
        <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500"
             style="background: linear-gradient(180deg, rgba(13,17,23,0) 40%, rgba(13,17,23,0.55) 100%);"></div>

        {# Wishlist button #}
        <button type="button"
            class="absolute top-3 right-3 w-8 h-8 flex items-center justify-center rounded-full bg-black/20 backdrop-blur-sm text-white hover:bg-black/40 hover:scale-110 transition"
            aria-label="Sauvegarder"
            onclick="event.preventDefault()">
            <i class="fa-regular fa-heart text-sm"></i>
        </button>

        {# Instant booking badge #}
        {% if property.instantBooking %}
            <span class="absolute top-3 left-3 flex items-center gap-1.5 bg-ink/70 backdrop-blur-sm text-[10px] font-semibold uppercase tracking-wide px-3 py-1 rounded-full" style="color: #FCA5A5;">
                <i class="fa-solid fa-bolt" style="color: #E63946;"></i>Instant
            </span>
        {% endif %}

        {# Rating badge — bottom right, visible on hover #}
        {% if averageRating %}
            <span class="absolute bottom-3 right-3 flex items-center gap-1 bg-ink/70 backdrop-blur-sm text-white text-xs font-semibold px-2.5 py-1 rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                <i class="fa-solid fa-star text-[9px]" style="color: #E63946;"></i>
                {{ averageRating|number_format(1, ',') }}
            </span>
        {% endif %}
    </div>

    {# Info #}
    <div class="space-y-0.5 px-0.5">
        <div class="flex items-start justify-between gap-2">
            <h3 class="font-medium text-ink text-sm leading-snug line-clamp-1 group-hover:text-gold transition-colors duration-200">{{ property.title }}</h3>
            {% if averageRating %}
                <span class="flex items-center gap-1 text-xs font-semibold text-ink/60 shrink-0">
                    <i class="fa-solid fa-star text-[9px]" style="color: #E63946;"></i>
                    {{ averageRating|number_format(1, ',') }}
                </span>
            {% endif %}
        </div>

        {% if property.address %}
            <p class="text-ink/40 text-xs">{{ property.address.city }}{% if property.address.country %}, {{ property.address.country }}{% endif %}</p>
        {% endif %}

        {% if checkin is defined and checkout is defined and checkin and checkout %}
            <p class="text-ink/35 text-xs">{{ checkin|date('d') }}–{{ checkout|date('d/m') }}</p>
        {% else %}
            <p class="text-ink/35 text-xs">
                {{ property.maxGuests }} voyageur{{ property.maxGuests > 1 ? 's' : '' }}
                · {{ property.bedrooms }} chambre{{ property.bedrooms > 1 ? 's' : '' }}
            </p>
        {% endif %}

        <p class="text-sm pt-1">
            <span class="font-semibold text-ink">{{ property.pricePerNight|number_format(0, ',', ' ') }} €</span>
            <span class="text-ink/40 font-normal text-xs"> / nuit</span>
        </p>
    </div>
</a>
