{% set cover = property.coverMedia %}
{% set averageRating = property.averageRating %}
{% set placeholder = 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=800&q=80' %}

<a href="{{ hostUrl is defined and hostUrl ? hostUrl : path('app_logement_detail', { id: property.id }) }}" class="group block">

    {# Image   #}
    <div class="relative aspect-photo w-full overflow-hidden rounded-2xl mb-3 bg-gray-100">
        <img
            src="{{ cover ? cover.fileUrl : placeholder }}"
            alt="{{ property.title }}"
            class="absolute inset-0 w-full h-full object-cover group-hover:scale-[1.04] transition-transform duration-500 ease-out"
            loading="lazy"
        >
        {# Gradient overlay for bottom info   #}
        <div class="absolute inset-0 bg-gradient-to-t from-black/30 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>

        {# Favourite button   #}
        <button type="button"
            class="absolute top-3 right-3 w-8 h-8 flex items-center justify-center text-white drop-shadow hover:scale-110 transition"
            aria-label="Sauvegarder"
            onclick="event.preventDefault()">
            <i class="fa-regular fa-heart text-lg"></i>
        </button>

        {# Instant booking badge   #}
        {% if property.instantBooking %}
            <span class="absolute top-3 left-3 bg-white/90 backdrop-blur-sm text-gray-800 text-[10px] font-bold uppercase tracking-wide px-2.5 py-1 rounded-full shadow-sm">
                <i class="fa-solid fa-bolt text-amber-400 mr-1"></i>Instant
            </span>
        {% endif %}
    </div>

    {# Info   #}
    <div class="space-y-0.5">
        <div class="flex items-start justify-between gap-2">
            <h3 class="font-semibold text-gray-900 text-sm leading-snug line-clamp-1">{{ property.title }}</h3>
            {% if averageRating %}
                <span class="flex items-center gap-1 text-xs font-semibold text-gray-800 shrink-0">
                    <i class="fa-solid fa-star text-[10px]"></i>
                    {{ averageRating|number_format(1, ',') }}
                </span>
            {% endif %}
        </div>

        {% if property.address %}
            <p class="text-gray-500 text-xs">{{ property.address.city }}{% if property.address.country %}, {{ property.address.country }}{% endif %}</p>
        {% endif %}

        {% if checkin is defined and checkout is defined and checkin and checkout %}
            <p class="text-gray-400 text-xs">{{ checkin|date('d') }}–{{ checkout|date('d/m') }}</p>
        {% else %}
            <p class="text-gray-400 text-xs">
                {{ property.maxGuests }} voyageur{{ property.maxGuests > 1 ? 's' : '' }}
                · {{ property.bedrooms }} chambre{{ property.bedrooms > 1 ? 's' : '' }}
            </p>
        {% endif %}

        <p class="text-sm pt-0.5">
            <span class="font-bold text-gray-900">{{ property.pricePerNight|number_format(0, ',', ' ') }} €</span>
            <span class="text-gray-500 font-normal"> / nuit</span>
        </p>
    </div>
</a>
