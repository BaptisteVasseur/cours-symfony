{% set variant = variant|default('hero') %}
{% set destination = destination|default('') %}
{% set checkin = checkin|default('') %}
{% set checkout = checkout|default('') %}
{% set guests = guests|default(1) %}

{% if variant == 'hero' %}
    <div class="mb-10 w-full max-w-4xl mx-auto" data-controller="search" data-search-guests-value="{{ guests }}">
        <form action="{{ path('app_search') }}" method="get" class="hidden md:block">
            <div class="bg-white/[0.07] backdrop-blur-md border border-white/20 rounded-full shadow-[0_8px_32px_rgba(0,0,0,0.4)] hover:border-gold/40 transition-all flex items-center divide-x divide-white/10">
                <div class="flex-1 px-7 py-3.5 rounded-full cursor-pointer" data-search-target="field" data-action="click->search#selectField">
                    <label class="block text-[10px] font-semibold uppercase tracking-widest text-gold/80 mb-0.5">Où</label>
                    <input type="text" name="destination" value="{{ destination }}" placeholder="Destination" class="w-full text-sm text-white placeholder-white/40 focus:outline-none bg-transparent" data-action="focus->search#selectField">
                </div>
                <div class="flex-1 px-7 py-3.5 cursor-pointer" data-search-target="field" data-action="click->search#selectField">
                    <label class="block text-[10px] font-semibold uppercase tracking-widest text-gold/80 mb-0.5">Arrivée</label>
                    <input type="date" name="checkin" value="{{ checkin }}" class="w-full text-sm text-white/80 focus:outline-none bg-transparent" data-action="focus->search#selectField">
                </div>
                <div class="flex-1 px-7 py-3.5 cursor-pointer" data-search-target="field" data-action="click->search#selectField">
                    <label class="block text-[10px] font-semibold uppercase tracking-widest text-gold/80 mb-0.5">Départ</label>
                    <input type="date" name="checkout" value="{{ checkout }}" class="w-full text-sm text-white/80 focus:outline-none bg-transparent" data-action="focus->search#selectField">
                </div>
                <div class="flex-1 px-7 py-3.5 cursor-pointer relative" data-search-target="field" data-action="click->search#toggleGuests">
                    <label class="block text-[10px] font-semibold uppercase tracking-widest text-gold/80 mb-0.5">Voyageurs</label>
                    <span class="text-sm text-white/80" data-search-target="guestsLabel">{{ guests }} voyageur{{ guests > 1 ? 's' : '' }}</span>
                    <input type="hidden" name="guests" value="{{ guests }}" data-search-target="guestsInput">
                    <div class="hidden absolute top-full right-0 mt-3 bg-navy border border-white/10 rounded-2xl shadow-popup p-6 w-72 z-50" data-search-target="guestsPanel" data-action="click->search#stopPropagation">
                        <div class="flex items-center justify-between">
                            <div>
                                <p class="font-medium text-white text-sm">Voyageurs</p>
                                <p class="text-xs text-white/40 mt-0.5">Nombre total</p>
                            </div>
                            <div class="flex items-center space-x-3">
                                <button type="button" class="w-8 h-8 rounded-full border border-white/20 flex items-center justify-center text-white/60 hover:border-gold hover:text-gold disabled:opacity-30 transition" data-action="search#decrementGuests" data-search-target="decrementBtn">
                                    <i class="fa-solid fa-minus text-xs"></i>
                                </button>
                                <span class="w-6 text-center font-semibold text-sm text-white" data-search-target="guestsCount">{{ guests }}</span>
                                <button type="button" class="w-8 h-8 rounded-full border border-white/20 flex items-center justify-center text-white/60 hover:border-gold hover:text-gold transition" data-action="search#incrementGuests">
                                    <i class="fa-solid fa-plus text-xs"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="pr-2 py-2">
                    <button type="submit" class="rounded-full px-6 py-3 flex items-center space-x-2 transition font-semibold text-sm text-ink" style="background: linear-gradient(135deg, #C9922A, #F0D080);">
                        <i class="fa-solid fa-magnifying-glass"></i>
                        <span>Rechercher</span>
                    </button>
                </div>
            </div>
        </form>

        <form action="{{ path('app_search') }}" method="get" class="md:hidden">
            <button type="button" class="w-full bg-white/10 backdrop-blur border border-white/20 rounded-full px-6 py-4 flex items-center justify-between hover:border-gold/40 transition" data-action="click->search#openMobile">
                <div class="flex items-center space-x-3 text-left">
                    <i class="fa-solid fa-magnifying-glass text-gold"></i>
                    <div>
                        <p class="font-semibold text-sm text-white">Où allez-vous ?</p>
                        <p class="text-xs text-white/50">Dates · Voyageurs</p>
                    </div>
                </div>
            </button>

            <div class="hidden fixed inset-0 z-[60] bg-navy" data-search-target="mobilePanel">
                <div class="flex items-center justify-between px-6 py-4 border-b border-white/10">
                    <button type="button" class="text-sm font-medium text-white/60 hover:text-white transition" data-action="search#closeMobile">Fermer</button>
                    <span class="font-display font-semibold text-white">Rechercher</span>
                    <span class="w-12"></span>
                </div>
                <div class="p-6 space-y-4">
                    <div>
                        <label class="block text-[10px] font-semibold uppercase tracking-widest text-gold/80 mb-2">Où</label>
                        <input type="text" name="destination" value="{{ destination }}" placeholder="Destination" class="w-full bg-white/[0.07] border border-white/10 text-white placeholder-white/30 rounded-xl px-4 py-3 text-sm focus:border-gold/50">
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-[10px] font-semibold uppercase tracking-widest text-gold/80 mb-2">Arrivée</label>
                            <input type="date" name="checkin" value="{{ checkin }}" class="w-full bg-white/[0.07] border border-white/10 text-white rounded-xl px-4 py-3 text-sm focus:border-gold/50">
                        </div>
                        <div>
                            <label class="block text-[10px] font-semibold uppercase tracking-widest text-gold/80 mb-2">Départ</label>
                            <input type="date" name="checkout" value="{{ checkout }}" class="w-full bg-white/[0.07] border border-white/10 text-white rounded-xl px-4 py-3 text-sm focus:border-gold/50">
                        </div>
                    </div>
                    <div>
                        <label class="block text-[10px] font-semibold uppercase tracking-widest text-gold/80 mb-2">Voyageurs</label>
                        <input type="number" name="guests" value="{{ guests }}" min="1" max="16" class="w-full bg-white/[0.07] border border-white/10 text-white rounded-xl px-4 py-3 text-sm focus:border-gold/50">
                    </div>
                    <button type="submit" class="w-full rounded-xl py-4 font-semibold text-sm text-ink transition" style="background: linear-gradient(135deg, #C9922A, #F0D080);">
                        <i class="fa-solid fa-magnifying-glass mr-2"></i>Rechercher
                    </button>
                </div>
            </div>
        </form>
    </div>
{% else %}
    <form action="{{ path('app_search') }}" method="get" class="hidden md:flex items-center bg-white/[0.07] border border-white/15 rounded-full py-1.5 pl-5 pr-1.5 hover:border-gold/30 transition max-w-sm w-full mx-4">
        <div class="flex space-x-3 text-sm flex-1 min-w-0">
            <input type="text" name="destination" value="{{ destination }}" placeholder="Destination" class="border-r border-white/10 pr-3 w-24 truncate focus:outline-none bg-transparent placeholder-white/50 text-white text-xs font-medium">
            <input type="date" name="checkin" value="{{ checkin }}" class="border-r border-white/10 pr-3 w-24 text-white/60 focus:outline-none bg-transparent text-xs">
            <input type="number" name="guests" value="{{ guests }}" min="1" max="16" class="w-14 text-white/60 focus:outline-none bg-transparent text-xs" title="Voyageurs">
        </div>
        <button type="submit" class="p-2 rounded-full shrink-0 text-ink" style="background: linear-gradient(135deg, #C9922A, #F0D080);">
            <i class="fa-solid fa-magnifying-glass text-xs"></i>
        </button>
    </form>
{% endif %}
