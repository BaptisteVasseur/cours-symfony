{% set category = category|default(null) %}
{% set filterRoute = filter_route|default('app_home') %}
{% set filterBaseQuery = filter_base_query|default({}) %}
{% set categoryFilters = [
    { slug: 'seaside', label: 'Bord de mer', icon: 'fa-umbrella-beach' },
    { slug: 'iconic', label: 'Iconiques', icon: 'fa-mountain-city' },
    { slug: 'trending', label: 'Tendances', icon: 'fa-fire' },
    { slug: 'camping', label: 'Campings', icon: 'fa-campground' },
] %}

<div class="flex items-center space-x-8 overflow-x-auto pb-4 mb-8 no-scrollbar border-b border-gray-100">
    {% for filter in categoryFilters %}
        {% set isActive = category == filter.slug %}
        {% set query = isActive ? filterBaseQuery : filterBaseQuery|merge({ category: filter.slug }) %}
        <a
            href="{{ path(filterRoute, query) }}"
            class="flex flex-col items-center space-y-2 border-b-2 pb-2 transition min-w-[56px] {{ isActive ? 'text-black border-black' : 'text-gray-500 hover:text-black border-transparent hover:border-black' }}"
            {% if isActive %}aria-current="page"{% endif %}
        >
            <i class="fa-solid {{ filter.icon }} text-xl"></i>
            <span class="text-xs font-semibold whitespace-nowrap">{{ filter.label }}</span>
        </a>
    {% endfor %}
</div>
