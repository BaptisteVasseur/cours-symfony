{% set property = reservation.property %}
{% set cover = property ? property.coverMedia : null %}
{% set guestProfile = reservation.guest ? reservation.guest.profile : null %}
{% set placeholderImage = 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=400&q=80' %}

<a href="{{ path('app_reservation_show', { id: reservation.id }) }}" class="flex flex-col sm:flex-row gap-4 p-4 border border-gray-200 rounded-xl hover:shadow-md transition bg-white">
    <div class="w-full sm:w-40 h-32 sm:h-28 shrink-0 rounded-lg overflow-hidden">
        <img
            src="{{ cover ? cover.fileUrl : placeholderImage }}"
            alt="{{ property ? property.title : 'Logement' }}"
            class="w-full h-full object-cover"
        >
    </div>
    <div class="flex-grow min-w-0">
        <div class="flex flex-wrap items-start justify-between gap-2 mb-2">
            <h2 class="font-semibold text-gray-900 truncate">
                {{ property ? property.title : 'Logement supprimé' }}
            </h2>
            {% include 'components/status_badge.html.twig' with { status: reservation.status } %}
            
        </div>
        {% if property and property.address %}
            <p class="text-sm text-gray-500 mb-2">{{ property.address.city }}, {{ property.address.country }}</p>
        {% endif %}
        <p class="text-sm text-gray-700">
            {{ reservation.checkinDate|date('d/m/Y') }} → {{ reservation.checkoutDate|date('d/m/Y') }}
            · {{ reservation.guestsCount }} voyageur{{ reservation.guestsCount > 1 ? 's' : '' }}
        </p>
        {% if guestProfile %}
            <p class="text-xs text-gray-400 mt-1">Voyageur : {{ guestProfile.firstName }} {{ guestProfile.lastName }}</p>
        {% endif %}
    </div>
    <div class="sm:text-right shrink-0">
        <p class="font-semibold text-gray-900">{{ reservation.totalPrice|number_format(0, ',', ' ') }} {{ reservation.currency|default('EUR') }}</p>
        <p class="text-xs text-gray-400 mt-1">Réf. {{ reservation.id }}</p>
    </div>
</a>
