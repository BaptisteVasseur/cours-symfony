{% set typeLabels = {
    'apartment': 'Appartement entier',
    'house':     'Maison entière',
    'villa':     'Villa entière',
    'studio':    'Studio entier',
    'loft':      'Loft entier',
    'chalet':    'Chalet entier',
    'cottage':   'Cottage entier',
} %}

{# Note moyenne calculée depuis les avis #}
{% set totalRating = 0 %}
{% for review in listings.reviews %}
    {% set totalRating = totalRating + review.rating %}
{% endfor %}
{% set reviewCount = listings.reviews|length %}
{% set avgRating = reviewCount > 0 ? (totalRating / reviewCount)|round(2) : null %}

{# Photo de couverture : position 0, sinon la première disponible #}
{% set coverPhoto = null %}
{% for photo in listings.photos %}
    {% if coverPhoto is null and photo.position == 0 %}
        {% set coverPhoto = photo %}
    {% endif %}
{% endfor %}
{% if coverPhoto is null %}
    {% set coverPhoto = listings.photos|first %}
{% endif %}

{# Badge "Nouveau" si annonce créée il y a moins de 30 jours #}
{% set isNew = listings.createdAt > date('-30 days') %}

<a href="{{ path('app_listing_details', { id: listings.id }) }}" class="block group cursor-pointer">
<article>

    {# ── Photo ── #}
    <div class="relative overflow-hidden rounded-2xl aspect-square bg-gray-100 mb-3">
        {% if coverPhoto %}
            <img
                src="{{ coverPhoto.url }}"
                alt="{{ listings.title }}"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                loading="lazy"
            >
        {% else %}
            <div class="w-full h-full flex items-center justify-center bg-gray-200">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 22V12h6v10"/>
                </svg>
            </div>
        {% endif %}

        {# Badge Nouveau #}
        {% if isNew %}
            <span class="absolute top-3 left-3 bg-white text-gray-900 text-xs font-semibold px-2.5 py-1 rounded-full shadow">
                Nouveau
            </span>
        {% endif %}

        {# Bouton favori #}
        <button
            class="absolute top-3 right-3 p-1.5 rounded-full hover:scale-110 transition-transform"
            aria-label="Ajouter aux favoris"
        >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 fill-transparent stroke-white stroke-2 drop-shadow" viewBox="0 0 24 24">
                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
            </svg>
        </button>

        {# Points de navigation entre photos #}
        {% set photoCount = listings.photos|length %}
        {% if photoCount > 1 %}
            <div class="absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                {% for i in 1..([photoCount, 5]|length) %}
                    <span class="w-1.5 h-1.5 rounded-full {{ loop.first ? 'bg-white' : 'bg-white/50' }}"></span>
                {% endfor %}
            </div>
        {% endif %}
    </div>

    {# ── Infos ── #}
    <div class="flex justify-between items-start gap-2">
        <div class="min-w-0">
            <h2 class="font-semibold text-gray-900 text-sm truncate">
                {{ listings.city }}, {{ listings.country }}
            </h2>
            <p class="text-sm text-gray-500 truncate">
                {{ typeLabels[listings.propertyType] ?? listings.propertyType|capitalize }}
            </p>
            <p class="text-sm text-gray-500">
                {{ listings.maxGuests }} voyageur{{ listings.maxGuests > 1 ? 's' }} ·
                {{ listings.bedrooms }} chambre{{ listings.bedrooms > 1 ? 's' }}
            </p>
            <p class="text-sm mt-1">
                <span class="font-semibold text-gray-900">
                    {{ listings.pricePerNight|number_format(0, ',', '\u{00A0}') }} €
                </span>
                <span class="text-gray-500"> / nuit</span>
            </p>
        </div>

        {# Note #}
        <div class="flex items-center gap-1 shrink-0">
            {% if avgRating %}
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 fill-gray-900" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
                <span class="text-sm font-medium text-gray-900">{{ avgRating }}</span>
                <span class="text-sm text-gray-400">({{ reviewCount }})</span>
            {% else %}
                <span class="text-xs text-gray-400">Aucun avis</span>
            {% endif %}
        </div>
    </div>

</article>
</a>
