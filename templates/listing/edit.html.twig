{% extends 'admin/base.html.twig' %}

{% block page_title %}Modifier #{{ listing.id }}{% endblock %}
{% block page_title_display %}Modifier le logement{% endblock %}

{% block breadcrumb %}
    <nav class="flex items-center gap-1.5 text-xs text-gray-400 mt-0.5">
        <a href="{{ path('app_listing_index') }}" class="hover:text-gray-600">Logements</a>
        <span>›</span>
        <a href="{{ path('app_listing_show', {'id': listing.id}) }}" class="hover:text-gray-600 truncate max-w-xs">{{ listing.title }}</a>
        <span>›</span>
        <span class="text-gray-600">Modifier</span>
    </nav>
{% endblock %}

{% block body %}

<div class="flex items-center justify-between mb-6">
    <a href="{{ path('app_listing_show', {'id': listing.id}) }}" class="flex items-center gap-1.5 text-sm text-gray-500 hover:text-gray-900 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
        </svg>
        Retour au détail
    </a>
    <form method="post" action="{{ path('app_listing_delete', {'id': listing.id}) }}"
          onsubmit="return confirm('Supprimer ce logement définitivement ?');">
        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ listing.id) }}">
        <button type="submit"
                class="flex items-center gap-2 bg-red-50 text-red-600 border border-red-200 text-sm font-medium px-4 py-2 rounded-lg hover:bg-red-100 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
            </svg>
            Supprimer
        </button>
    </form>
</div>

<div class="max-w-3xl">
    <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100">
            <h2 class="text-sm font-semibold text-gray-700">Modifier : {{ listing.title }}</h2>
        </div>
        <div class="px-6 py-6">
            {{ include('listing/_form.html.twig', {'button_label': 'Enregistrer les modifications'}) }}
        </div>
    </div>
</div>

{% endblock %}
