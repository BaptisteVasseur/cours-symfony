{{ form_start(form) }}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {% for child in form %}
            {% if child.vars.name not in ['_token'] %}
                <div class="{{ child.vars.name in ['title', 'description', 'amenities'] ? 'md:col-span-2' : '' }}">
                    {{ form_label(child, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(child, {'attr': {'class': child.vars.checked is defined ? '' : 'w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#FF385C]'}}) }}
                    {{ form_errors(child) }}
                </div>
            {% endif %}
        {% endfor %}
    </div>

    <div class="mt-6 flex gap-3">
        <button type="submit" class="px-5 py-2.5 bg-[#FF385C] text-white font-semibold rounded-lg hover:bg-[#E11D48] transition">
            {{ button_label|default('Enregistrer') }}
        </button>
        <a href="{{ path('app_listing_index') }}" class="px-5 py-2.5 border border-gray-300 text-gray-700 font-medium rounded-lg hover:bg-gray-50 transition">Annuler</a>
    </div>
{{ form_end(form) }}
