{% extends 'layout/base.html.twig' %}

{% block title %}Mes reservations - StayShare{% endblock %}

{% block body %}
    <main class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
            <div>
                <p class="text-sm font-semibold uppercase text-rose-600">Voyageur</p>
                <h1 class="mt-2 text-3xl font-bold text-gray-950">Mes reservations</h1>
                <p class="mt-2 text-sm text-gray-600">Suivez vos demandes, confirmations et annulations.</p>
            </div>
            <a href="{{ path('app_logement_index') }}" class="rounded-md bg-rose-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-rose-700">Rechercher un logement</a>
        </div>

        <section class="mt-8 grid gap-5">
            {% for reservation in reservations %}
                {% set photo = reservation.logement.photos|first %}
                <article class="grid overflow-hidden rounded-lg border border-gray-100 bg-white shadow-sm sm:grid-cols-[220px_1fr]">
                    <img src="{{ photo ? photo.url : 'https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?auto=format&fit=crop&w=900&q=80' }}" alt="{{ reservation.logement.titre }}" class="h-48 w-full object-cover sm:h-full">
                    <div class="p-5">
                        <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                            <div>
                                <p class="text-sm text-gray-500">{{ reservation.logement.adresse ? reservation.logement.adresse.ville ~ ', ' ~ reservation.logement.adresse.pays : 'Adresse a confirmer' }}</p>
                                <h2 class="mt-1 text-xl font-semibold text-gray-950">
                                    <a href="{{ path('app_reservation_show', { id: reservation.id }) }}" class="hover:text-rose-600">{{ reservation.logement.titre }}</a>
                                </h2>
                            </div>
                            <span class="rounded-md bg-gray-100 px-3 py-2 text-sm font-semibold text-gray-700">{{ reservation.statut.value }}</span>
                        </div>

                        <div class="mt-5 grid gap-3 text-sm text-gray-700 sm:grid-cols-3">
                            <p>Arrivee : <strong>{{ reservation.dateArrivee|date('d/m/Y') }}</strong></p>
                            <p>Depart : <strong>{{ reservation.dateDepart|date('d/m/Y') }}</strong></p>
                            <p>Total : <strong>{{ reservation.montantTotal }} EUR</strong></p>
                        </div>

                        <a href="{{ path('app_reservation_show', { id: reservation.id }) }}" class="mt-5 inline-flex rounded-md border border-gray-200 px-4 py-2 text-sm font-semibold text-gray-900 hover:border-rose-300 hover:text-rose-600">Voir le detail</a>
                    </div>
                </article>
            {% else %}
                <div class="rounded-lg border border-gray-100 bg-white p-8 text-center shadow-sm">
                    <h2 class="text-xl font-semibold text-gray-950">Aucune reservation</h2>
                    <p class="mt-2 text-sm text-gray-600">Vos futures demandes apparaitront ici.</p>
                    <a href="{{ path('app_logement_index') }}" class="mt-5 inline-flex rounded-md bg-rose-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-rose-700">Explorer les logements</a>
                </div>
            {% endfor %}
        </section>
    </main>
{% endblock %}
