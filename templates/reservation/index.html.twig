{% extends 'layout/base.html.twig' %}

{% block title %}Mes réservations - Airbnb{% endblock %}

{% block stylesheets %}
    <script src="https://cdn.tailwindcss.com"></script>
{% endblock %}

{% block body %}
<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    <h1 class="text-3xl font-bold text-gray-900 mb-8">Mes réservations</h1>

    {% if reservations is empty %}
        <div class="text-center py-24">
            <div class="text-7xl mb-6">🗓️</div>
            <h2 class="text-xl font-semibold text-gray-800 mb-2">Aucune réservation pour le moment</h2>
            <p class="text-gray-500 mb-6">Commencez à explorer des logements exceptionnels.</p>
            <a href="{{ path('app_property_index') }}"
               class="inline-block bg-[#FF385C] hover:bg-[#E0284F] text-white font-semibold py-3 px-8 rounded-xl transition-colors">
                Explorer les logements
            </a>
        </div>
    {% else %}

        {# Tabs by status #}
        {% set statusGroups = {
            'upcoming': reservations|filter(r => r.status in ['pending', 'confirmed'] and r.checkinDate >= date()),
            'past':     reservations|filter(r => r.checkoutDate < date() or r.status == 'completed'),
            'cancelled': reservations|filter(r => r.status == 'cancelled')
        } %}

        <div class="space-y-6">
            {% for reservation in reservations %}
            {% set property = reservation.property %}
            {% set nights = reservation.checkinDate.diff(reservation.checkoutDate).days %}

            {% set coverMedia = null %}
            {% for media in property.media %}
                {% if media.isCover and coverMedia is null %}{% set coverMedia = media %}{% endif %}
            {% endfor %}

            <div class="flex flex-col sm:flex-row gap-4 border border-gray-200 rounded-2xl overflow-hidden hover:shadow-md transition-shadow bg-white">

                {# Image #}
                <a href="{{ path('app_property_show', {id: property.id}) }}" class="sm:w-56 shrink-0">
                    {% if coverMedia %}
                        <img src="{{ coverMedia.fileUrl }}" alt="{{ property.title }}" class="w-full h-48 sm:h-full object-cover">
                    {% else %}
                        <div class="w-full h-48 sm:h-full bg-gradient-to-br from-gray-100 to-gray-200 flex items-center justify-center">
                            <svg class="w-14 h-14 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                            </svg>
                        </div>
                    {% endif %}
                </a>

                {# Content #}
                <div class="flex-1 p-5 flex flex-col justify-between">
                    <div>
                        <div class="flex items-start justify-between gap-3">
                            <div>
                                <a href="{{ path('app_property_show', {id: property.id}) }}"
                                   class="text-lg font-semibold text-gray-900 hover:underline">{{ property.title }}</a>
                                {% if property.address %}
                                <p class="text-sm text-gray-500">{{ property.address.city }}, {{ property.address.country }}</p>
                                {% endif %}
                            </div>

                            {# Status badge #}
                            {% set statusMap = {
                                'pending':   {label: 'En attente',  color: 'bg-yellow-100 text-yellow-800'},
                                'confirmed': {label: 'Confirmée',   color: 'bg-green-100 text-green-800'},
                                'completed': {label: 'Terminée',    color: 'bg-gray-100 text-gray-700'},
                                'cancelled': {label: 'Annulée',     color: 'bg-red-100 text-red-700'},
                            } %}
                            {% set badge = statusMap[reservation.status] ?? {label: reservation.status, color: 'bg-gray-100 text-gray-700'} %}
                            <span class="shrink-0 inline-flex items-center px-3 py-1 rounded-full text-xs font-medium {{ badge.color }}">
                                {{ badge.label }}
                            </span>
                        </div>

                        <div class="mt-3 flex flex-wrap gap-4 text-sm text-gray-600">
                            <span>
                                <strong class="text-gray-800">Arrivée :</strong>
                                {{ reservation.checkinDate|date('d/m/Y') }}
                            </span>
                            <span>
                                <strong class="text-gray-800">Départ :</strong>
                                {{ reservation.checkoutDate|date('d/m/Y') }}
                            </span>
                            <span>
                                <strong class="text-gray-800">{{ nights }} nuit{{ nights > 1 ? 's' : '' }}</strong>
                            </span>
                            <span>
                                <strong class="text-gray-800">{{ reservation.guestsCount }} voyageur{{ reservation.guestsCount > 1 ? 's' : '' }}</strong>
                            </span>
                        </div>
                    </div>

                    <div class="mt-4 flex items-center justify-between">
                        <span class="font-bold text-gray-900 text-lg">{{ reservation.totalPrice|number_format(2, ',', ' ') }} {{ reservation.currency }}</span>
                        <a href="{{ path('app_reservation_confirm', {id: reservation.id}) }}"
                           class="text-sm font-medium text-[#FF385C] hover:underline">
                            Voir le détail →
                        </a>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    {% endif %}

</div>
{% endblock %}
