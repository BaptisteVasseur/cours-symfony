{% extends 'layout/base.html.twig' %}

{% block title %}Réserver - {{ property.title }}{% endblock %}

{% block stylesheets %}
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/themes/airbnb.css">
{% endblock %}

{% block body %}
<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    <nav class="flex items-center gap-2 text-sm text-gray-500 mb-6">
        <a href="{{ path('app_property_index') }}" class="hover:underline">Logements</a>
        <span>/</span>
        <a href="{{ path('app_property_show', {id: property.id}) }}" class="hover:underline">{{ property.title }}</a>
        <span>/</span>
        <span class="text-gray-900">Réserver</span>
    </nav>

    <h1 class="text-2xl font-bold text-gray-900 mb-8">Votre réservation</h1>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

        {# Booking form #}
        <div>
            <form method="POST" class="space-y-5">

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Date d'arrivée</label>
                    <input type="text" id="checkinDate" name="checkinDate" required placeholder="jj/mm/aaaa"
                           class="w-full border border-gray-300 rounded-xl px-4 py-3 text-gray-900 focus:outline-none focus:ring-2 focus:ring-[#FF385C] focus:border-transparent">
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Date de départ</label>
                    <input type="text" id="checkoutDate" name="checkoutDate" required placeholder="jj/mm/aaaa"
                           class="w-full border border-gray-300 rounded-xl px-4 py-3 text-gray-900 focus:outline-none focus:ring-2 focus:ring-[#FF385C] focus:border-transparent">
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Nombre de voyageurs</label>
                    <select name="guestsCount"
                            class="w-full border border-gray-300 rounded-xl px-4 py-3 text-gray-900 focus:outline-none focus:ring-2 focus:ring-[#FF385C] focus:border-transparent">
                        {% for i in 1..property.maxGuests %}
                        <option value="{{ i }}">{{ i }} voyageur{{ i > 1 ? 's' : '' }}</option>
                        {% endfor %}
                    </select>
                </div>

                <button type="submit"
                        class="w-full bg-[#FF385C] hover:bg-[#E0284F] text-white font-semibold py-3 px-6 rounded-xl transition-colors text-center">
                    Confirmer la réservation
                </button>

                <p class="text-center text-xs text-gray-400">
                    Aucun montant ne sera prélevé immédiatement.
                </p>
            </form>
        </div>

        {# Property summary #}
        <div class="border border-gray-200 rounded-2xl p-5 h-fit">
            {% set coverMedia = null %}
            {% for media in property.media %}
                {% if media.isCover and coverMedia is null %}{% set coverMedia = media %}{% endif %}
            {% endfor %}

            {% if coverMedia %}
                <img src="{{ coverMedia.fileUrl }}" alt="{{ property.title }}" class="w-full h-44 object-cover rounded-xl mb-4">
            {% else %}
                <div class="w-full h-44 bg-gray-100 rounded-xl mb-4 flex items-center justify-center">
                    <svg class="w-12 h-12 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                    </svg>
                </div>
            {% endif %}

            <h3 class="font-semibold text-gray-900">{{ property.title }}</h3>
            {% if property.address %}
            <p class="text-sm text-gray-500">{{ property.address.city }}, {{ property.address.country }}</p>
            {% endif %}

            <div class="mt-4 pt-4 border-t border-gray-100 space-y-2">
                <div class="flex justify-between text-sm">
                    <span class="text-gray-600">Prix par nuit</span>
                    <span class="font-medium text-gray-900">{{ property.pricePerNight|number_format(2, ',', ' ') }} €</span>
                </div>
                {% if property.cleaningFee %}
                <div class="flex justify-between text-sm">
                    <span class="text-gray-600">Frais de ménage</span>
                    <span class="font-medium text-gray-900">{{ property.cleaningFee|number_format(2, ',', ' ') }} €</span>
                </div>
                {% endif %}
                <div class="flex justify-between text-sm">
                    <span class="text-gray-600">Frais de service (12%)</span>
                    <span class="font-medium text-gray-900">calculé selon les dates</span>
                </div>
            </div>
        </div>
    </div>

</div>
{% endblock %}

{% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/fr.js"></script>
<script>
    const bookedRanges = {{ bookedRanges|json_encode|raw }};

    const disabledDates = [];
    bookedRanges.forEach(function(range) {
        disabledDates.push({ from: range.checkin, to: range.checkout });
    });

    const today = new Date().toISOString().split('T')[0];

    const checkinPicker = flatpickr('#checkinDate', {
        locale: 'fr',
        dateFormat: 'Y-m-d',
        altInput: true,
        altFormat: 'd/m/Y',
        minDate: today,
        disable: disabledDates,
        onChange: function(selectedDates) {
            if (selectedDates[0]) {
                const nextDay = new Date(selectedDates[0]);
                nextDay.setDate(nextDay.getDate() + 1);
                checkoutPicker.set('minDate', nextDay);
                checkoutPicker.clear();
            }
        }
    });

    const checkoutPicker = flatpickr('#checkoutDate', {
        locale: 'fr',
        dateFormat: 'Y-m-d',
        altInput: true,
        altFormat: 'd/m/Y',
        minDate: today,
        disable: disabledDates,
    });
</script>
{% endblock %}
