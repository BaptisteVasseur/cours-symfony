{% extends 'layout/user.html.twig' %}

{% block title %}Mes réservations{% endblock %}

{% block body %}
<div class="max-w-4xl mx-auto px-6 py-10">

    <h1 class="text-2xl font-bold text-gray-900 mb-2">Mes réservations</h1>
    <p class="text-gray-500 text-sm mb-8">Historique de tous vos séjours</p>

    {# Filtres par statut #}
    <div class="flex items-center gap-2 mb-6 flex-wrap">
        {% set statuses = ['all', 'pending', 'confirmed', 'cancelled', 'completed'] %}
        {% for s in statuses %}
        <a href="{{ path('app_reservation_history', s != 'all' ? { status: s } : {}) }}"
           class="px-4 py-2 rounded-full text-sm font-medium border transition-colors
               {% if (currentStatus ?? 'all') == s %}
                   bg-gray-900 text-white border-gray-900
               {% else %}
                   bg-white text-gray-600 border-gray-300 hover:border-gray-400
               {% endif %}">
            {% if s == 'all' %}Toutes
            {% elseif s == 'pending' %}En attente
            {% elseif s == 'confirmed' %}Confirmées
            {% elseif s == 'cancelled' %}Annulées
            {% elseif s == 'completed' %}Terminées
            {% endif %}
        </a>
        {% endfor %}
    </div>

    {# Liste des réservations #}
    {% if reservations is empty %}
        <div class="text-center py-20 bg-white rounded-2xl border border-gray-200">
            <svg class="w-12 h-12 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/>
            </svg>
            <p class="text-gray-500 font-medium">Aucune réservation trouvée</p>
            <a href="{{ path('app_home') }}" class="mt-4 inline-block text-sm text-[#FF385C] font-semibold hover:underline">
                Découvrir des logements →
            </a>
        </div>
    {% else %}
        <div class="space-y-4">
            {% for reservation in reservations %}
            <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden hover:shadow-md transition-shadow">
                <div class="flex flex-col sm:flex-row">

                    {# Image du logement #}
                    <div class="w-full sm:w-48 h-40 sm:h-auto bg-gray-100 flex-shrink-0">
                        {% set cover = reservation.property.media|filter(m => m.isCover)|first %}
                        {% if cover %}
                            <img src="{{ cover.fileUrl }}"
                                 alt="{{ reservation.property.title }}"
                                 class="w-full h-full object-cover">
                        {% else %}
                            <div class="w-full h-full flex items-center justify-center">
                                <svg class="w-10 h-10 text-gray-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 19.5h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5z"/>
                                </svg>
                            </div>
                        {% endif %}
                    </div>

                    {# Infos #}
                    <div class="flex-1 p-5 flex flex-col justify-between gap-3">
                        <div class="flex items-start justify-between gap-4">
                            <div>
                                <a href="{{ path('app_property_show', { id: reservation.property.id }) }}"
                                   class="font-semibold text-gray-900 hover:underline">
                                    {{ reservation.property.title }}
                                </a>
                                <p class="text-sm text-gray-500 mt-0.5">
                                    {% if reservation.property.address %}
                                        {{ reservation.property.address.city }}, {{ reservation.property.address.country }}
                                    {% endif %}
                                </p>
                            </div>

                            {# Badge statut #}
                            <span class="flex-shrink-0 inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold
                                {% if reservation.status == 'confirmed' %}bg-green-100 text-green-700
                                {% elseif reservation.status == 'pending' %}bg-yellow-100 text-yellow-700
                                {% elseif reservation.status == 'cancelled' %}bg-red-100 text-red-700
                                {% elseif reservation.status == 'completed' %}bg-blue-100 text-blue-700
                                {% else %}bg-gray-100 text-gray-600{% endif %}">
                                {% if reservation.status == 'confirmed' %}Confirmée
                                {% elseif reservation.status == 'pending' %}En attente
                                {% elseif reservation.status == 'cancelled' %}Annulée
                                {% elseif reservation.status == 'completed' %}Terminée
                                {% else %}{{ reservation.status }}{% endif %}
                            </span>
                        </div>

                        {# Dates + détails #}
                        <div class="flex flex-wrap items-center gap-4 text-sm text-gray-500">
                            <div class="flex items-center gap-1.5">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/>
                                </svg>
                                <span>
                                 {{ reservation.checkinDate|date('d/m/Y') }}
→
{{ reservation.checkoutDate|date('d/m/Y') }}
                                </span>
                            </div>
                            <div class="flex items-center gap-1.5">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/>
                                </svg>
                                <span>{{ reservation.guestsCount }} voyageur{{ reservation.guestsCount > 1 ? 's' : '' }}</span>
                            </div>
                        </div>

                        {# Prix + actions #}
                        <div class="flex items-center justify-between pt-3 border-t border-gray-100">
                            <div>
                                <span class="font-bold text-gray-900">{{ reservation.totalPrice }} {{ reservation.currency }}</span>
                                {% if reservation.cleaningFee %}
                                    <span class="text-xs text-gray-400 ml-1">+ {{ reservation.cleaningFee }} {{ reservation.currency }} ménage</span>
                                {% endif %}
                            </div>
                            <div class="flex items-center gap-2">
                                {% if reservation.status == 'completed' and reservation.reviews is empty %}
                                <a href="#" class="text-xs font-semibold text-[#FF385C] hover:underline">
                                    Laisser un avis
                                </a>
                                {% endif %}
                                {% if reservation.cancellationReason %}
                                <span class="text-xs text-gray-400 italic">
                                    Motif : {{ reservation.cancellationReason }}
                                </span>
                                {% endif %}
                                <a href="{{ path('app_property_show', { id: reservation.property.id }) }}"
                                   class="text-xs font-semibold text-gray-600 border border-gray-300 rounded-lg px-3 py-1.5 hover:border-gray-400 transition-colors">
                                    Voir le logement
                                </a>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    {% endif %}

</div>
{% endblock %}