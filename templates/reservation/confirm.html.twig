{% extends 'layout/base.html.twig' %}

{% block title %}Réservation confirmée - Airbnb{% endblock %}

{% block stylesheets %}
    <script src="https://cdn.tailwindcss.com"></script>
{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

    {# Success header #}
    <div class="text-center mb-10">
        <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-10 h-10 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
            </svg>
        </div>
        <h1 class="text-3xl font-bold text-gray-900">Réservation envoyée !</h1>
        <p class="text-gray-500 mt-2">Votre demande a bien été prise en compte.</p>
    </div>

    {# Reservation card #}
    {% set property = reservation.property %}
    {% set nights = reservation.checkinDate.diff(reservation.checkoutDate).days %}

    <div class="border border-gray-200 rounded-2xl overflow-hidden shadow-sm">

        {# Property image + title #}
        {% set coverMedia = null %}
        {% for media in property.media %}
            {% if media.isCover and coverMedia is null %}{% set coverMedia = media %}{% endif %}
        {% endfor %}

        <div class="flex items-center gap-4 p-5 border-b border-gray-100">
            {% if coverMedia %}
                <img src="{{ coverMedia.fileUrl }}" alt="{{ property.title }}" class="w-20 h-20 object-cover rounded-xl shrink-0">
            {% else %}
                <div class="w-20 h-20 bg-gray-100 rounded-xl flex items-center justify-center shrink-0">
                    <svg class="w-8 h-8 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                    </svg>
                </div>
            {% endif %}
            <div>
                <h2 class="font-semibold text-gray-900">{{ property.title }}</h2>
                {% if property.address %}
                <p class="text-sm text-gray-500">{{ property.address.city }}, {{ property.address.country }}</p>
                {% endif %}
                <p class="text-sm text-gray-500 mt-0.5">{{ property.propertyType|capitalize }}</p>
            </div>
        </div>

        {# Dates #}
        <div class="grid grid-cols-2 divide-x divide-gray-100 border-b border-gray-100">
            <div class="p-5">
                <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Arrivée</p>
                <p class="font-semibold text-gray-900">{{ reservation.checkinDate|date('d/m/Y') }}</p>
                {% if property.checkinTime %}
                <p class="text-sm text-gray-500">Après {{ property.checkinTime|date('H:i') }}</p>
                {% endif %}
            </div>
            <div class="p-5">
                <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Départ</p>
                <p class="font-semibold text-gray-900">{{ reservation.checkoutDate|date('d/m/Y') }}</p>
                {% if property.checkoutTime %}
                <p class="text-sm text-gray-500">Avant {{ property.checkoutTime|date('H:i') }}</p>
                {% endif %}
            </div>
        </div>

        {# Details #}
        <div class="p-5 border-b border-gray-100 space-y-2">
            <div class="flex justify-between text-sm">
                <span class="text-gray-600">Voyageurs</span>
                <span class="font-medium text-gray-900">{{ reservation.guestsCount }} personne{{ reservation.guestsCount > 1 ? 's' : '' }}</span>
            </div>
            <div class="flex justify-between text-sm">
                <span class="text-gray-600">Durée</span>
                <span class="font-medium text-gray-900">{{ nights }} nuit{{ nights > 1 ? 's' : '' }}</span>
            </div>
            <div class="flex justify-between text-sm">
                <span class="text-gray-600">Prix par nuit</span>
                <span class="font-medium text-gray-900">{{ property.pricePerNight|number_format(2, ',', ' ') }} €</span>
            </div>
            {% if reservation.cleaningFee %}
            <div class="flex justify-between text-sm">
                <span class="text-gray-600">Frais de ménage</span>
                <span class="font-medium text-gray-900">{{ reservation.cleaningFee|number_format(2, ',', ' ') }} {{ reservation.currency }}</span>
            </div>
            {% endif %}
            {% if reservation.serviceFee %}
            <div class="flex justify-between text-sm">
                <span class="text-gray-600">Frais de service</span>
                <span class="font-medium text-gray-900">{{ reservation.serviceFee|number_format(2, ',', ' ') }} {{ reservation.currency }}</span>
            </div>
            {% endif %}
        </div>

        {# Total #}
        <div class="p-5 flex justify-between items-center bg-gray-50">
            <span class="font-semibold text-gray-900">Total</span>
            <span class="text-xl font-bold text-gray-900">{{ reservation.totalPrice|number_format(2, ',', ' ') }} {{ reservation.currency }}</span>
        </div>

        {# Status #}
        <div class="p-5 border-t border-gray-100">
            <div class="flex items-center gap-3">
                <div class="w-2 h-2 rounded-full
                    {{ reservation.status == 'confirmed' ? 'bg-green-500' :
                       reservation.status == 'pending'   ? 'bg-yellow-400' :
                       reservation.status == 'cancelled' ? 'bg-red-500' : 'bg-gray-400' }}">
                </div>
                <span class="text-sm text-gray-700">
                    Statut :
                    <strong>
                        {% if reservation.status == 'confirmed' %}Confirmée
                        {% elseif reservation.status == 'pending' %}En attente de confirmation
                        {% elseif reservation.status == 'cancelled' %}Annulée
                        {% else %}{{ reservation.status }}
                        {% endif %}
                    </strong>
                </span>
            </div>
        </div>
    </div>

    {# Actions #}
    <div class="mt-6 flex flex-col sm:flex-row gap-3">
        <a href="{{ path('app_reservation_index') }}"
           class="flex-1 text-center border border-gray-300 text-gray-700 font-medium py-3 px-6 rounded-xl hover:bg-gray-50 transition-colors">
            Voir mes réservations
        </a>
        <a href="{{ path('app_property_index') }}"
           class="flex-1 text-center bg-[#FF385C] hover:bg-[#E0284F] text-white font-semibold py-3 px-6 rounded-xl transition-colors">
            Explorer d'autres logements
        </a>
    </div>

</div>
{% endblock %}
