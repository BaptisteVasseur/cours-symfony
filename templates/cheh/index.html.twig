{% extends 'layout/base.html.twig' %}

{% block title %}Bienvenue Cheh{% endblock %}

{% block body %}
<div class="min-h-screen flex flex-col items-center justify-center bg-yellow-50 py-16 px-4 text-center">

    <div class="text-9xl mb-6 animate-bounce">💩</div>

    <h1 class="text-4xl font-black text-yellow-900 mb-4 uppercase tracking-widest">
        Bienvenue, Cheh.
    </h1>

    <p class="text-2xl text-yellow-800 font-semibold mb-2">
        Tu n'as accès qu'à cette page.
    </p>
    <p class="text-lg text-yellow-700 mb-10">
        Et franchement, c'est déjà trop pour toi. 💩
    </p>

    <div class="flex gap-6 text-6xl mb-10">
        <span>💩</span><span>💩</span><span>💩</span>
    </div>

    <a href="{{ path('app_logout') }}"
       class="bg-yellow-600 hover:bg-yellow-700 text-white font-bold py-3 px-8 rounded-xl transition-colors text-lg">
        Se déconnecter (et partir en courant)
    </a>

</div>
{% endblock %}
