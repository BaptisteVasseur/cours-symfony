{% set variant     = variant|default('hero') %}
{% set destination = destination|default('') %}
{% set checkin     = checkin is defined and checkin ? checkin|date('Y-m-d') : '' %}
{% set checkout    = checkout is defined and checkout ? checkout|date('Y-m-d') : '' %}
{% set guests      = guests|default(1) %}

{% if variant == 'hero' %}
    <div class="mb-10" data-controller="search" data-search-guests-value="{{ guests }}" data-search-suggestions-url-value="{{ path('api_search_suggestions') }}">

        {# ── Desktop ─────────────────────────────────────────────── #}
        <form action="{{ path('app_search') }}" method="get" class="hidden md:block">
            <div class="bg-white rounded-full shadow-[0_2px_16px_rgba(0,0,0,0.12)] hover:shadow-[0_4px_24px_rgba(0,0,0,0.18)] transition-shadow duration-200 flex items-stretch max-w-4xl mx-auto border border-gray-100">

                {# Destination #}
                <div class="group flex-1 min-w-0 relative" data-search-target="field" data-action="click->search#selectField">
                    <div class="px-6 py-3.5 rounded-full cursor-pointer transition-colors duration-150 group-hover:bg-gray-100/70 h-full flex flex-col justify-center">
                        <label class="block text-xs font-bold text-gray-900 mb-0.5 cursor-pointer">Où</label>
                        <input
                            type="text"
                            name="destination"
                            value="{{ destination }}"
                            placeholder="Rechercher une destination"
                            autocomplete="off"
                            class="w-full text-sm text-gray-500 placeholder-gray-400 focus:outline-none bg-transparent cursor-pointer"
                            data-search-target="destinationInput"
                            data-action="input->search#onDestinationInput keydown->search#onDestinationKeydown focus->search#selectField"
                        >
                    </div>
                    <div class="hidden absolute left-0 top-full mt-2 w-full min-w-[300px] bg-white border border-gray-200 rounded-2xl shadow-xl z-50 overflow-hidden"
                         data-search-target="autocompleteList"
                         data-action="click->search#stopPropagation">
                    </div>
                </div>

                {# Séparateur #}
                <div class="w-px bg-gray-200 self-stretch my-3"></div>

                {# Arrivée #}
                <div class="group flex-1 min-w-0" data-search-target="field" data-action="click->search#selectField">
                    <div class="px-6 py-3.5 rounded-full cursor-pointer transition-colors duration-150 group-hover:bg-gray-100/70 h-full flex flex-col justify-center">
                        <label class="block text-xs font-bold text-gray-900 mb-0.5 cursor-pointer">Arrivée</label>
                        <input type="date" name="checkin" value="{{ checkin }}"
                               min="{{ 'now'|date('Y-m-d') }}"
                               class="w-full text-sm text-gray-500 focus:outline-none bg-transparent cursor-pointer"
                               data-search-target="checkinInput"
                               data-action="focus->search#selectField change->search#onCheckinChange">
                    </div>
                </div>

                {# Séparateur #}
                <div class="w-px bg-gray-200 self-stretch my-3"></div>

                {# Départ #}
                <div class="group flex-1 min-w-0" data-search-target="field" data-action="click->search#selectField">
                    <div class="px-6 py-3.5 rounded-full cursor-pointer transition-colors duration-150 group-hover:bg-gray-100/70 h-full flex flex-col justify-center">
                        <label class="block text-xs font-bold text-gray-900 mb-0.5 cursor-pointer">Départ</label>
                        <input type="date" name="checkout" value="{{ checkout }}"
                               min="{{ checkin ?: 'now'|date('Y-m-d') }}"
                               class="w-full text-sm text-gray-500 focus:outline-none bg-transparent cursor-pointer"
                               data-search-target="checkoutInput"
                               data-action="focus->search#selectField">
                    </div>
                </div>

                {# Séparateur #}
                <div class="w-px bg-gray-200 self-stretch my-3"></div>

                {# Voyageurs + Bouton #}
                <div class="flex items-center gap-1 pr-2 pl-2 py-2">
                    <div class="group flex-1 min-w-0 relative" data-search-target="field" data-action="click->search#toggleGuests">
                        <div class="px-4 py-1.5 rounded-full cursor-pointer transition-colors duration-150 group-hover:bg-gray-100/70 flex flex-col justify-center">
                            <label class="block text-xs font-bold text-gray-900 mb-0.5 cursor-pointer">Voyageurs</label>
                            <span class="text-sm text-gray-500 whitespace-nowrap" data-search-target="guestsLabel">{{ guests }} voyageur{{ guests > 1 ? 's' : '' }}</span>
                            <input type="hidden" name="guests" value="{{ guests }}" data-search-target="guestsInput">
                        </div>

                        <div class="hidden absolute top-full right-0 mt-3 bg-white border border-gray-200 rounded-2xl shadow-xl p-6 w-80 z-50"
                             data-search-target="guestsPanel"
                             data-action="click->search#stopPropagation">
                            <div class="flex items-center justify-between">
                                <div>
                                    <p class="font-semibold text-gray-900 text-sm">Voyageurs</p>
                                    <p class="text-xs text-gray-500">Adultes et enfants</p>
                                </div>
                                <div class="flex items-center space-x-3">
                                    <button type="button"
                                            class="w-8 h-8 rounded-full border border-gray-300 flex items-center justify-center text-gray-600 hover:border-gray-900 disabled:opacity-30 disabled:cursor-not-allowed transition"
                                            data-action="search#decrementGuests"
                                            data-search-target="decrementBtn">
                                        <i class="fa-solid fa-minus text-xs"></i>
                                    </button>
                                    <span class="w-6 text-center font-semibold text-sm" data-search-target="guestsCount">{{ guests }}</span>
                                    <button type="button"
                                            class="w-8 h-8 rounded-full border border-gray-300 flex items-center justify-center text-gray-600 hover:border-gray-900 transition"
                                            data-action="search#incrementGuests">
                                        <i class="fa-solid fa-plus text-xs"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <button type="submit"
                            class="bg-brand hover:bg-brandHover text-white rounded-full px-5 py-3.5 flex items-center gap-2 transition-all duration-150 font-semibold text-sm shadow-sm hover:shadow-md shrink-0">
                        <i class="fa-solid fa-magnifying-glass text-sm"></i>
                        <span>Rechercher</span>
                    </button>
                </div>

            </div>
        </form>

        {# ── Mobile ──────────────────────────────────────────────── #}
        <form action="{{ path('app_search') }}" method="get" class="md:hidden">
            <button type="button"
                    class="w-full bg-white border border-gray-200 rounded-full shadow-md px-5 py-3.5 flex items-center gap-3"
                    data-action="click->search#openMobile">
                <div class="w-9 h-9 bg-brand/10 text-brand rounded-full flex items-center justify-center shrink-0">
                    <i class="fa-solid fa-magnifying-glass text-sm"></i>
                </div>
                <div class="text-left min-w-0">
                    <p class="font-semibold text-sm text-gray-900 truncate">
                        {{ destination ?: 'Où allez-vous ?' }}
                    </p>
                    <p class="text-xs text-gray-400">
                        {% if checkin %}{{ checkin|date('d/m/Y') }}{% if checkout %} → {{ checkout|date('d/m/Y') }}{% endif %}{% else %}Toutes dates{% endif %} · {{ guests }} voyageur{{ guests > 1 ? 's' : '' }}
                    </p>
                </div>
            </button>

            <div class="hidden fixed inset-0 z-[60] bg-white overflow-y-auto" data-search-target="mobilePanel">
                <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100 sticky top-0 bg-white z-10">
                    <button type="button"
                            class="w-9 h-9 flex items-center justify-center rounded-full hover:bg-gray-100 transition text-gray-600"
                            data-action="search#closeMobile">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                    <span class="font-semibold text-sm">Recherche</span>
                    <span class="w-9"></span>
                </div>
                <div class="p-5 space-y-4">
                    <div class="relative">
                        <label class="block text-xs font-bold text-gray-700 mb-2">Où</label>
                        <div class="relative">
                            <i class="fa-solid fa-magnifying-glass absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400 text-xs pointer-events-none"></i>
                            <input
                                type="text"
                                name="destination"
                                value="{{ destination }}"
                                placeholder="Ville, région, pays…"
                                autocomplete="off"
                                class="w-full border border-gray-300 rounded-xl pl-9 pr-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand/30 focus:border-brand"
                                data-search-target="destinationInput"
                                data-action="input->search#onDestinationInput keydown->search#onDestinationKeydown"
                            >
                        </div>
                        <div class="hidden absolute left-0 top-full mt-1 w-full bg-white border border-gray-200 rounded-2xl shadow-xl z-50 overflow-hidden"
                             data-search-target="autocompleteList"
                             data-action="click->search#stopPropagation">
                        </div>
                    </div>
                    <div class="grid grid-cols-2 gap-3">
                        <div>
                            <label class="block text-xs font-bold text-gray-700 mb-2">Arrivée</label>
                            <input type="date" name="checkin" value="{{ checkin }}"
                                   min="{{ 'now'|date('Y-m-d') }}"
                                   class="w-full border border-gray-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand/30 focus:border-brand"
                                   data-search-target="checkinInput"
                                   data-action="change->search#onCheckinChange">
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-gray-700 mb-2">Départ</label>
                            <input type="date" name="checkout" value="{{ checkout }}"
                                   min="{{ checkin ?: 'now'|date('Y-m-d') }}"
                                   class="w-full border border-gray-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand/30 focus:border-brand"
                                   data-search-target="checkoutInput">
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-gray-700 mb-2">Voyageurs</label>
                        <div class="flex items-center justify-between border border-gray-300 rounded-xl px-4 py-3">
                            <span class="text-sm text-gray-600" data-search-target="guestsLabel">{{ guests }} voyageur{{ guests > 1 ? 's' : '' }}</span>
                            <div class="flex items-center gap-3">
                                <button type="button"
                                        class="w-7 h-7 rounded-full border border-gray-300 flex items-center justify-center text-gray-600 hover:border-gray-900 disabled:opacity-30 transition"
                                        data-action="search#decrementGuests"
                                        data-search-target="decrementBtn">
                                    <i class="fa-solid fa-minus text-xs"></i>
                                </button>
                                <span class="w-5 text-center font-semibold text-sm" data-search-target="guestsCount">{{ guests }}</span>
                                <button type="button"
                                        class="w-7 h-7 rounded-full border border-gray-300 flex items-center justify-center text-gray-600 hover:border-gray-900 transition"
                                        data-action="search#incrementGuests">
                                    <i class="fa-solid fa-plus text-xs"></i>
                                </button>
                            </div>
                            <input type="hidden" name="guests" value="{{ guests }}" data-search-target="guestsInput">
                        </div>
                    </div>
                    <button type="submit"
                            class="w-full bg-brand hover:bg-brandHover text-white rounded-xl py-4 font-semibold text-sm transition flex items-center justify-center gap-2">
                        <i class="fa-solid fa-magnifying-glass"></i>
                        Rechercher
                    </button>
                </div>
            </div>
        </form>
    </div>

{% else %}
    {# ── Compact variant (header) ────────────────────────────────── #}
    <div data-controller="search" data-search-guests-value="{{ guests }}" data-search-suggestions-url-value="{{ path('api_search_suggestions') }}">
        <form action="{{ path('app_search') }}" method="get" class="hidden md:flex items-center border border-gray-200 rounded-full p-2 pl-5 shadow-sm hover:shadow-md transition max-w-md w-full mx-4 bg-white">
            <div class="flex items-center gap-3 text-sm text-gray-700 flex-1 min-w-0 divide-x divide-gray-200">
                <div class="relative pr-3 flex-1 min-w-0">
                    <input
                        type="text"
                        name="destination"
                        value="{{ destination }}"
                        placeholder="N'importe où"
                        autocomplete="off"
                        class="w-full truncate focus:outline-none bg-transparent placeholder-gray-500 font-semibold text-sm"
                        data-search-target="destinationInput"
                        data-action="input->search#onDestinationInput keydown->search#onDestinationKeydown"
                    >
                    <div class="hidden absolute left-0 top-full mt-2 w-64 bg-white border border-gray-200 rounded-2xl shadow-xl z-50 overflow-hidden"
                         data-search-target="autocompleteList"
                         data-action="click->search#stopPropagation">
                    </div>
                </div>
                <input type="date" name="checkin" value="{{ checkin }}"
                       class="pl-3 pr-3 w-28 text-gray-500 focus:outline-none bg-transparent text-sm font-normal">
                <span class="pl-3 pr-1 text-gray-500 text-sm font-normal whitespace-nowrap">{{ guests }} voy.</span>
                <input type="hidden" name="guests" value="{{ guests }}">
            </div>
            <button type="submit" class="bg-brand text-white p-2.5 rounded-full hover:bg-brandHover transition shrink-0 shadow-sm">
                <i class="fa-solid fa-magnifying-glass text-xs"></i>
            </button>
        </form>
    </div>
{% endif %}
