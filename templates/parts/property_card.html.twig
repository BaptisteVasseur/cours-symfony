<article class="group cursor-pointer">
    <a href="{{ path('app_property_show', { id: property.id }) }}" class="block">

       <div class="relative rounded-2xl overflow-hidden aspect-square bg-gray-200 mb-3">
    {% set cover = property.media|filter(m => m.isCover)|first %}
    {% if cover %}
        <img src="{{ cover.fileUrl }}" alt="{{ property.title }}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300">
    {% else %}
        <div class="w-full h-full flex items-center justify-center">
            <svg class="w-12 h-12 text-gray-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 19.5h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/>
            </svg>
        </div>
    {% endif %}

    <button class="absolute top-3 right-3 z-10" aria-label="Ajouter aux favoris" onclick="event.preventDefault()">
        <svg class="w-6 h-6 drop-shadow" fill="white" stroke="white" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/>
        </svg>
    </button>
</div>

        {# Infos #}
        <div class="space-y-0.5">
            <h3 class="font-semibold text-gray-900 text-sm truncate">{{ property.title }}</h3>
<p class="text-sm text-gray-500">
    {% if property.address %}
        {{ property.address.city }}, {{ property.address.country }}
    {% else %}
        Adresse non renseignée
    {% endif %}
</p>            <p class="text-sm text-gray-900 mt-1">
                <span class="font-semibold">{{ property.pricePerNight }} €</span>
                <span class="text-gray-500 font-normal">/ nuit</span>
            </p>
        </div>

    </a>
</article>