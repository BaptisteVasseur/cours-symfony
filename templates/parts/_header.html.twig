<!-- Header -->
<header class="header">
    <div class="header-content">
        <a href="#" class="logo">
            <span class="logo-icon">🏠</span>
            airbnb
        </a>

        <div class="search-bar">
            <div class="search-item location">
                <strong>Où</strong><br>
                <span style="color: #717171;">Partout</span>
            </div>
            <div class="search-item dates">
                <strong>Quand</strong><br>
                <span style="color: #717171;">Ajouter des dates</span>
            </div>
            <div class="search-item guests">
                <strong>Voyageurs</strong><br>
                <span style="color: #717171;">Ajouter des voyageurs</span>
            </div>
            <div class="search-icon">🔍</div>
        </div>

        {% if is_granted('ROLE_ADMIN') %}
            <button>Administration</button>
        {% endif %}

        {% if is_granted('ROLE_USER') %}
            Vous êtes connecté
        {% else %}
            <div class="user-menu">
                <a href="{{ path('app_user_new') }}" class="become-host">Devenez hôte</a>
                <a href="{{ path('app_login') }}" class="user-actions">
                    <span>🌐</span>
                    <div class="user-icon">👤</div>
                </a>
            </div>
        {% endif %}

    </div>
</header>
