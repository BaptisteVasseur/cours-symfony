{% extends 'layout/host.html.twig' %}

{% block page_title %}Vue d'ensemble{% endblock %}

{% block content %}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
        <a href="{{ path('app_host_property_index') }}" class="bg-white rounded-xl border border-gray-200 p-5 hover:shadow-md transition">
            <p class="text-sm text-gray-500">Mes Annonces</p>
            <p class="text-lg font-bold text-gray-900">Gérer les logements</p>
        </a>
        <a href="{{ path('app_host_booking_index') }}" class="bg-white rounded-xl border border-gray-200 p-5 hover:shadow-md transition">
            <p class="text-sm text-gray-500">Réservations reçues</p>
            <p class="text-lg font-bold text-gray-900">Gérer les demandes</p>
        </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
        <div class="bg-white p-5 rounded-xl border border-gray-200 shadow-sm flex items-center justify-between">
            <div>
                <p class="text-xs font-medium text-gray-400 uppercase">Mes logements</p>
                <h4 class="text-2xl font-bold text-gray-900 mt-1">{{ totalProperties }}</h4>
            </div>
            <div class="w-12 h-12 bg-rose-50 text-brand rounded-xl flex items-center justify-center text-xl"><i class="fa-solid fa-house"></i></div>
        </div>
        <div class="bg-white p-5 rounded-xl border border-gray-200 shadow-sm flex items-center justify-between">
            <div>
                <p class="text-xs font-medium text-gray-400 uppercase">Mes revenus cumulés</p>
                <h4 class="text-2xl font-bold text-gray-900 mt-1">{{ revenue|number_format(0, ',', ' ') }} €</h4>
                <span class="text-xs text-gray-400 font-normal">Réservations confirmées / terminées</span>
            </div>
            <div class="w-12 h-12 bg-emerald-50 text-emerald-600 rounded-xl flex items-center justify-center text-xl"><i class="fa-solid fa-wallet"></i></div>
        </div>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200 flex flex-col sm:flex-row sm:items-center sm:justify-between space-y-2 sm:space-y-0">
            <h3 class="font-bold text-gray-900">Réservations récentes</h3>
            <a href="{{ path('app_host_booking_index') }}" class="text-xs font-semibold text-brand hover:underline">Voir toutes</a>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse text-sm">
                <thead>
                    <tr class="bg-gray-50 text-gray-400 font-semibold border-b border-gray-200 uppercase text-[11px] tracking-wider">
                        <th class="px-6 py-3">Hébergement</th>
                        <th class="px-6 py-3">Voyageur</th>
                        <th class="px-6 py-3">Dates</th>
                        <th class="px-6 py-3">Total</th>
                        <th class="px-6 py-3">Statut</th>
                        <th class="px-6 py-3 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                    {% for reservation in reservations %}
                        {% set cover = reservation.property.coverMedia %}
                        {% set guestProfile = reservation.guest ? reservation.guest.profile : null %}
                        <tr class="hover:bg-gray-50/70 transition">
                            <td class="px-6 py-4 font-semibold text-gray-900">{{ reservation.property.title }}</td>
                            <td class="px-6 py-4">
                                {% if guestProfile and (guestProfile.firstName or guestProfile.lastName) %}
                                    {{ guestProfile.firstName }} {{ guestProfile.lastName }}
                                {% else %}
                                    {{ reservation.guest ? reservation.guest.email : '—' }}
                                {% endif %}
                            </td>
                            <td class="px-6 py-4">
                                Du {{ reservation.checkinDate|date('d/m/Y') }}<br>
                                au {{ reservation.checkoutDate|date('d/m/Y') }}
                            </td>
                            <td class="px-6 py-4 font-medium text-gray-900">{{ reservation.totalPrice|number_format(0, ',', ' ') }} €</td>
                            <td class="px-6 py-4">
                                {% if reservation.status == 'pending' %}
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-50 text-amber-800 border border-amber-200"><i class="fa-solid fa-clock text-[8px] mr-1.5"></i> En attente</span>
                                {% elseif reservation.status == 'confirmed' %}
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-emerald-50 text-emerald-800 border border-emerald-200"><i class="fa-solid fa-circle-check text-[8px] mr-1.5"></i> Confirmée</span>
                                {% elseif reservation.status == 'completed' %}
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-50 text-blue-800 border border-blue-200"><i class="fa-solid fa-circle-check text-[8px] mr-1.5"></i> Terminée</span>
                                {% else %}
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-50 text-gray-800 border border-gray-200"><i class="fa-solid fa-circle-xmark text-[8px] mr-1.5"></i> Annulée</span>
                                {% endif %}
                            </td>
                            <td class="px-6 py-4 text-right space-x-2">
                                {% if reservation.status == 'pending' %}
                                    <div class="flex items-center justify-end gap-2">
                                        <form method="post" action="{{ path('app_host_booking_approve', { id: reservation.id }) }}" class="inline">
                                            <input type="hidden" name="_token" value="{{ csrf_token('approve' ~ reservation.id) }}">
                                            <button type="submit" class="text-xs bg-emerald-600 hover:bg-emerald-700 text-white font-semibold px-2.5 py-1.5 rounded-lg transition">Accepter</button>
                                        </form>
                                        <form method="post" action="{{ path('app_host_booking_reject', { id: reservation.id }) }}" class="inline">
                                            <input type="hidden" name="_token" value="{{ csrf_token('reject' ~ reservation.id) }}">
                                            <button type="submit" class="text-xs bg-rose-600 hover:bg-rose-700 text-white font-semibold px-2.5 py-1.5 rounded-lg transition">Refuser</button>
                                        </form>
                                    </div>
                                {% else %}
                                    <span class="text-xs text-gray-400">—</span>
                                {% endif %}
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="px-6 py-8 text-center text-gray-400">Aucune réservation récente.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
