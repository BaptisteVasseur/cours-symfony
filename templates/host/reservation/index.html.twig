{% extends 'layout/base.html.twig' %}

{% block title %}Demandes recues - StayShare{% endblock %}

{% block body %}
    <main class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
            <div>
                <p class="text-sm font-semibold uppercase text-rose-600">Espace hote</p>
                <h1 class="mt-2 text-3xl font-bold text-gray-950">Demandes de reservation</h1>
                <p class="mt-2 text-sm text-gray-600">Acceptez ou refusez les demandes avant paiement du voyageur.</p>
            </div>
            <a href="{{ path('app_host_logement_index') }}" class="rounded-md border border-gray-200 px-4 py-2.5 text-sm font-semibold text-gray-900 hover:border-rose-300 hover:text-rose-600">Mes annonces</a>
        </div>

        <section class="mt-8 grid gap-5">
            {% for reservation in reservations %}
                <article class="rounded-lg border border-gray-100 bg-white p-5 shadow-sm">
                    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
                        <div>
                            <p class="text-sm text-gray-500">{{ reservation.voyageur.prenom }} {{ reservation.voyageur.nom }} - {{ reservation.dateDemande|date('d/m/Y H:i') }}</p>
                            <h2 class="mt-1 text-xl font-semibold text-gray-950">
                                <a href="{{ path('app_host_reservation_show', { id: reservation.id }) }}" class="hover:text-rose-600">{{ reservation.logement.titre }}</a>
                            </h2>
                            <p class="mt-2 text-sm text-gray-600">
                                {{ reservation.dateArrivee|date('d/m/Y') }} - {{ reservation.dateDepart|date('d/m/Y') }}
                                · {{ reservation.nombreVoyageurs }} voyageur{{ reservation.nombreVoyageurs > 1 ? 's' : '' }}
                            </p>
                        </div>
                        <span class="rounded-md bg-gray-100 px-3 py-2 text-sm font-semibold text-gray-700">{{ reservation.statut.value }}</span>
                    </div>

                    <div class="mt-5 flex flex-wrap items-center justify-between gap-3">
                        <p class="text-sm text-gray-700"><strong>{{ reservation.montantTotal }} EUR</strong> total · revenu hote {{ reservation.montantHote }} EUR</p>
                        <a href="{{ path('app_host_reservation_show', { id: reservation.id }) }}" class="rounded-md border border-gray-200 px-4 py-2 text-sm font-semibold text-gray-900 hover:border-rose-300 hover:text-rose-600">Traiter</a>
                    </div>
                </article>
            {% else %}
                <div class="rounded-lg border border-gray-100 bg-white p-8 text-center shadow-sm">
                    <h2 class="text-xl font-semibold text-gray-950">Aucune demande recue</h2>
                    <p class="mt-2 text-sm text-gray-600">Les demandes de vos voyageurs apparaitront ici.</p>
                </div>
            {% endfor %}
        </section>
    </main>
{% endblock %}
