{% extends 'layout/base.html.twig' %}

{% block title %}Calendrier - {{ logement.titre }}{% endblock %}

{% block body %}
    <main class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
        <a href="{{ path('app_host_logement_show', { id: logement.id }) }}" class="text-sm font-semibold text-rose-600 hover:text-rose-700">Retour a l'annonce</a>

        <div class="mt-5 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
            <div>
                <p class="text-sm font-semibold uppercase text-rose-600">Calendrier hote</p>
                <h1 class="mt-2 text-3xl font-bold text-gray-950">{{ logement.titre }}</h1>
                <p class="mt-2 text-sm text-gray-600">{{ mois|date('F Y')|capitalize }}</p>
            </div>
            <div class="flex gap-2">
                <a href="{{ path('app_host_logement_calendar', { id: logement.id, mois: mois_precedent }) }}" class="rounded-md border border-gray-200 px-3 py-2 text-sm font-semibold text-gray-800 hover:bg-gray-50">Mois precedent</a>
                <a href="{{ path('app_host_logement_calendar', { id: logement.id, mois: mois_suivant }) }}" class="rounded-md border border-gray-200 px-3 py-2 text-sm font-semibold text-gray-800 hover:bg-gray-50">Mois suivant</a>
            </div>
        </div>

        <div class="mt-8 grid gap-6 lg:grid-cols-[1fr_340px]">
            <section class="rounded-lg border border-gray-100 bg-white p-5 shadow-sm">
                <div class="grid grid-cols-7 gap-2 text-center text-xs font-semibold uppercase text-gray-500">
                    <div>Lun</div>
                    <div>Mar</div>
                    <div>Mer</div>
                    <div>Jeu</div>
                    <div>Ven</div>
                    <div>Sam</div>
                    <div>Dim</div>
                </div>

                <div class="mt-3 space-y-2">
                    {% for semaine in semaines %}
                        <div class="grid grid-cols-7 gap-2">
                            {% for jour in semaine %}
                                {% set disponibilite = jour.disponibilite %}
                                {% set statut = disponibilite ? disponibilite.statut.value : 'non_defini' %}
                                {% set classes = {
                                    disponible: 'border-green-200 bg-green-50 text-green-900',
                                    reservee: 'border-rose-200 bg-rose-50 text-rose-900',
                                    bloquee: 'border-gray-300 bg-gray-100 text-gray-800',
                                    non_defini: 'border-gray-100 bg-white text-gray-500'
                                } %}
                                <div class="min-h-24 rounded-md border p-2 text-left {{ classes[statut] }} {{ jour.dans_mois ? '' : 'opacity-40' }}">
                                    <div class="text-sm font-semibold">{{ jour.date|date('d') }}</div>
                                    <div class="mt-2 text-xs">
                                        {% if statut == 'disponible' %}
                                            Disponible
                                        {% elseif statut == 'reservee' %}
                                            Reservee
                                        {% elseif statut == 'bloquee' %}
                                            Bloquee
                                            {% if disponibilite.raisonBlocage %}
                                                <div class="mt-1 text-[11px] leading-tight">{{ disponibilite.raisonBlocage }}</div>
                                            {% endif %}
                                        {% else %}
                                            Non ouverte
                                        {% endif %}
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% endfor %}
                </div>
            </section>

            <aside class="h-fit space-y-6">
                <section class="rounded-lg border border-gray-100 bg-white p-5 shadow-sm">
                    <h2 class="text-lg font-semibold text-gray-950">Bloquer une periode</h2>
                    <form method="post" action="{{ path('app_host_logement_calendar_block', { id: logement.id }) }}" class="mt-5 space-y-4">
                        <input type="hidden" name="_token" value="{{ csrf_token('host_logement_calendar_block_' ~ logement.id) }}">
                        <input type="hidden" name="mois" value="{{ mois|date('Y-m') }}">

                        <label class="block">
                            <span class="text-sm font-medium text-gray-700">Debut</span>
                            <input name="date_debut" type="date" required class="mt-2 w-full rounded-md border border-gray-300 px-3 py-2 focus:border-rose-500 focus:outline-none focus:ring-2 focus:ring-rose-200">
                        </label>

                        <label class="block">
                            <span class="text-sm font-medium text-gray-700">Fin incluse</span>
                            <input name="date_fin" type="date" required class="mt-2 w-full rounded-md border border-gray-300 px-3 py-2 focus:border-rose-500 focus:outline-none focus:ring-2 focus:ring-rose-200">
                        </label>

                        <label class="block">
                            <span class="text-sm font-medium text-gray-700">Motif</span>
                            <textarea name="raison_blocage" rows="3" class="mt-2 w-full rounded-md border border-gray-300 px-3 py-2 focus:border-rose-500 focus:outline-none focus:ring-2 focus:ring-rose-200" placeholder="Travaux, usage personnel..."></textarea>
                        </label>

                        <button type="submit" class="w-full rounded-md bg-gray-950 px-4 py-2.5 text-sm font-semibold text-white hover:bg-gray-800">Bloquer</button>
                    </form>
                </section>

                <section class="rounded-lg border border-gray-100 bg-white p-5 shadow-sm">
                    <h2 class="text-lg font-semibold text-gray-950">Ouvrir une periode</h2>
                    <form method="post" action="{{ path('app_host_logement_calendar_open', { id: logement.id }) }}" class="mt-5 space-y-4">
                        <input type="hidden" name="_token" value="{{ csrf_token('host_logement_calendar_open_' ~ logement.id) }}">
                        <input type="hidden" name="mois" value="{{ mois|date('Y-m') }}">

                        <label class="block">
                            <span class="text-sm font-medium text-gray-700">Debut</span>
                            <input name="date_debut" type="date" required class="mt-2 w-full rounded-md border border-gray-300 px-3 py-2 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-200">
                        </label>

                        <label class="block">
                            <span class="text-sm font-medium text-gray-700">Fin incluse</span>
                            <input name="date_fin" type="date" required class="mt-2 w-full rounded-md border border-gray-300 px-3 py-2 focus:border-emerald-500 focus:outline-none focus:ring-2 focus:ring-emerald-200">
                        </label>

                        <p class="text-xs leading-5 text-gray-500">Les dates non ouvertes deviennent disponibles, les dates bloquees sont debloquees. Les reservations confirmees ne sont pas modifiees.</p>

                        <button type="submit" class="w-full rounded-md bg-emerald-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-emerald-700">Ouvrir / debloquer</button>
                    </form>
                </section>

                <section class="rounded-lg border border-gray-100 bg-white p-5 shadow-sm">
                    <h2 class="text-lg font-semibold text-gray-950">Legende</h2>
                    <div class="mt-4 space-y-2 text-sm text-gray-700">
                        <p><span class="inline-block h-3 w-3 rounded-sm bg-green-100 align-middle ring-1 ring-green-200"></span> Disponible</p>
                        <p><span class="inline-block h-3 w-3 rounded-sm bg-rose-100 align-middle ring-1 ring-rose-200"></span> Reservee</p>
                        <p><span class="inline-block h-3 w-3 rounded-sm bg-gray-100 align-middle ring-1 ring-gray-300"></span> Bloquee</p>
                        <p><span class="inline-block h-3 w-3 rounded-sm bg-white align-middle ring-1 ring-gray-200"></span> Non ouverte</p>
                    </div>
                </section>
            </aside>
        </div>
    </main>
{% endblock %}
