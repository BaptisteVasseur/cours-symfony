{% extends 'layout/host.html.twig' %}

{% block page_title %}Modifier le logement{% endblock %}

{% block content %}
<div class="mb-6">
    <a href="{{ path('host_properties') }}" class="inline-flex items-center gap-2 text-sm text-slate-500 hover:text-slate-900 transition">
        <i class="fa-solid fa-arrow-left text-xs"></i>
        Retour à la liste
    </a>
</div>

<div class="grid grid-cols-1 xl:grid-cols-3 gap-6">
    <div class="xl:col-span-2 bg-white rounded-xl border border-slate-200 shadow-sm p-6">
        <h3 class="font-bold text-slate-900 mb-6">Modifier « {{ property.title }} »</h3>
        {{ include('host/properties/_form.html.twig', { button_label: 'Mettre à jour' }) }}
    </div>
    <div class="bg-white rounded-xl border border-red-100 shadow-sm p-6 h-fit space-y-4">
        <h3 class="font-bold text-red-600 mb-2">Zone de danger</h3>
        <p class="text-xs text-slate-500">La suppression est définitive et retirera toutes les données associées à ce logement.</p>
        <form method="post" action="{{ path('host_property_delete', {id: property.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer définitivement ce logement ?');">
            <input type="hidden" name="_token" value="{{ csrf_token('delete_property_' ~ property.id) }}">
            <button type="submit" class="w-full py-2.5 px-4 text-sm font-semibold text-white bg-red-600 rounded-lg hover:bg-red-700 transition">
                Supprimer le logement
            </button>
        </form>
    </div>
</div>
{% endblock %}
