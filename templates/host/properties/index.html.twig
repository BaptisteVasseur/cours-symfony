{% extends 'layout/host.html.twig' %}

{% block page_title %}Mes logements{% endblock %}

{% block content %}
<div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
    <div class="p-6 border-b border-slate-100 flex items-center justify-between">
        <div>
            <h2 class="text-base font-bold text-slate-900">Liste de vos logements</h2>
            <p class="text-xs text-slate-500 mt-1">Gérez vos propriétés, leurs tarifs et plannings.</p>
        </div>
        <a href="{{ path('app_property_new') }}" class="px-4 py-2 text-sm font-semibold text-white bg-[#FF385C] rounded-lg hover:bg-[#E61E4D] transition shadow-sm">
            Créer un nouveau logement
        </a>
    </div>

    {% if properties is empty %}
        <div class="p-12 text-center">
            <div class="text-4xl text-slate-300 mb-3">
                <i class="fa-solid fa-house-chimney-user"></i>
            </div>
            <h3 class="text-sm font-bold text-slate-900">Aucun logement pour le moment</h3>
            <p class="text-xs text-slate-500 mt-1">Commencez dès maintenant en publiant votre première annonce.</p>
            <a href="{{ path('app_property_new') }}" class="mt-4 inline-block px-4 py-2 text-xs font-semibold text-[#FF385C] border border-[#FF385C] rounded-lg hover:bg-red-50 transition">
                Créer un logement
            </a>
        </div>
    {% else %}
        <div class="overflow-x-auto">
            <table class="w-full border-collapse text-left text-sm text-slate-500">
                <thead class="bg-slate-50 text-xs font-semibold text-slate-700 uppercase">
                    <tr>
                        <th class="px-6 py-4">Titre / Type</th>
                        <th class="px-6 py-4">Statut</th>
                        <th class="px-6 py-4">Prix / Nuit</th>
                        <th class="px-6 py-4">Réservation instantanée</th>
                        <th class="px-6 py-4">Créé le</th>
                        <th class="px-6 py-4 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 border-t border-slate-100">
                    {% for p in properties %}
                        <tr class="hover:bg-slate-50">
                            <td class="px-6 py-4">
                                <div class="font-semibold text-slate-950">{{ p.title }}</div>
                                <div class="text-xs text-slate-400 mt-0.5">{{ p.propertyType|capitalize }}</div>
                            </td>
                            <td class="px-6 py-4">
                                <span class="inline-flex items-center gap-1.5 px-2 py-1 text-xs font-semibold rounded-full 
                                    {% if p.status == 'published' %}bg-emerald-50 text-emerald-700
                                    {% elseif p.status == 'pending' %}bg-amber-50 text-amber-700
                                    {% else %}bg-slate-100 text-slate-700{% endif %}">
                                    <span class="w-1.5 h-1.5 rounded-full 
                                        {% if p.status == 'published' %}bg-emerald-600
                                        {% elseif p.status == 'pending' %}bg-amber-600
                                        {% else %}bg-slate-600{% endif %}"></span>
                                    {{ p.status|capitalize }}
                                </span>
                            </td>
                            <td class="px-6 py-4 font-medium text-slate-900">
                                {{ p.pricePerNight }} €
                            </td>
                            <td class="px-6 py-4">
                                {% if p.instantBooking %}
                                    <span class="text-emerald-600"><i class="fa-solid fa-bolt mr-1"></i>Oui</span>
                                {% else %}
                                    <span class="text-slate-400">Non</span>
                                {% endif %}
                            </td>
                            <td class="px-6 py-4 text-xs">
                                {{ p.createdAt|date('d/m/Y') }}
                            </td>
                            <td class="px-6 py-4 text-right">
                                 <div class="flex items-center justify-end gap-3">
                                     <a href="{{ path('host_property_show', {id: p.id}) }}" class="text-slate-600 hover:text-slate-950 font-medium" title="Consulter">
                                         <i class="fa-solid fa-eye mr-1"></i> Consulter
                                     </a>
                                     <a href="{{ path('host_availability_index', {id: p.id}) }}" class="text-slate-600 hover:text-[#FF385C] font-medium" title="Disponibilités & Calendrier">
                                         <i class="fa-solid fa-calendar-days mr-1"></i> Calendrier
                                     </a>
                                     <a href="{{ path('host_property_edit', {id: p.id}) }}" class="text-slate-600 hover:text-slate-950 font-medium" title="Modifier">
                                         <i class="fa-solid fa-pen-to-square mr-1"></i> Modifier
                                     </a>
                                     <form method="post" action="{{ path('host_property_delete', {id: p.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce logement ?');" class="inline">
                                         <input type="hidden" name="_token" value="{{ csrf_token('delete_property_' ~ p.id) }}">
                                         <button type="submit" class="text-red-500 hover:text-red-700 font-medium">
                                             <i class="fa-solid fa-trash-can"></i>
                                         </button>
                                     </form>
                                 </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
</div>
{% endblock %}
