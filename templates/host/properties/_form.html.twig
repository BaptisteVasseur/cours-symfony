{% form_theme form 'form/admin_theme.html.twig' %}

{{ form_start(form, { attr: { class: 'space-y-2' } }) }}

<div class="grid grid-cols-1 lg:grid-cols-2 gap-x-6">
    <div>
        <h4 class="text-sm font-bold text-slate-900 mb-4 pb-2 border-b border-slate-100">Informations générales</h4>
        {{ form_row(form.title) }}
        {{ form_row(form.description) }}
        {{ form_row(form.cancellationPolicy) }}
        {{ form_row(form.propertyType) }}
    </div>
    <div>
        <h4 class="text-sm font-bold text-slate-900 mb-4 pb-2 border-b border-slate-100">Capacité & tarifs</h4>
        <div class="grid grid-cols-2 gap-x-4">
            {{ form_row(form.maxGuests) }}
            {{ form_row(form.bedrooms) }}
            {{ form_row(form.beds) }}
            {{ form_row(form.bathrooms) }}
        </div>
        {{ form_row(form.pricePerNight) }}
        {{ form_row(form.cleaningFee) }}
        {{ form_row(form.securityDeposit) }}
        <div class="grid grid-cols-2 gap-x-4">
            {{ form_row(form.checkinTime) }}
            {{ form_row(form.checkoutTime) }}
        </div>
        {{ form_row(form.instantBooking) }}
    </div>
</div>

<div class="flex items-center gap-3 pt-6 mt-6 border-t border-slate-200">
    <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold text-sm px-5 py-2.5 rounded-lg transition">
        {{ button_label|default('Enregistrer') }}
    </button>
    <a href="{{ path('host_properties') }}" class="text-sm font-semibold text-slate-600 hover:text-slate-900 px-4 py-2.5 rounded-lg hover:bg-slate-100 transition">
        Annuler
    </a>
</div>

{{ form_end(form) }}
