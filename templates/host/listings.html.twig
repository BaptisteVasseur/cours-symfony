{% extends 'layout/base.html.twig' %}

{% block page_title %}Mes logements{% endblock %}

{% block body %}
<div class="max-w-4xl mx-auto px-4 py-8">

    <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold text-gray-900">Mes logements</h1>
    </div>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="mb-4 rounded-lg px-4 py-3 text-sm font-medium
                {% if label == 'success' %}bg-green-50 text-green-700 border border-green-200
                {% else %}bg-red-50 text-red-700 border border-red-200{% endif %}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    {% if listings is empty %}
        <div class="text-center py-16 text-gray-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto mb-3 opacity-40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 9.75L12 3l9 6.75V21a.75.75 0 01-.75.75H3.75A.75.75 0 013 21V9.75z"/>
            </svg>
            <p class="text-base">Vous n'avez aucun logement pour le moment.</p>
        </div>
    {% else %}
        <div class="space-y-4">
            {% for listing in listings %}
            <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-5 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 mb-1">
                        <h2 class="text-base font-semibold text-gray-900 truncate">{{ listing.title }}</h2>
                        {% if listing.isActive %}
                            <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-green-50 text-green-700">
                                <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>Actif
                            </span>
                        {% else %}
                            <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-500">
                                <span class="w-1.5 h-1.5 rounded-full bg-gray-400"></span>Inactif
                            </span>
                        {% endif %}
                        {% if listing.instantBooking %}
                            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-blue-50 text-blue-700">
                                Résa. instantanée
                            </span>
                        {% endif %}
                    </div>
                    <p class="text-sm text-gray-500">{{ listing.city }}, {{ listing.country }} · {{ listing.pricePerNight }} €/nuit · {{ listing.maxGuests }} voyageurs max</p>
                </div>
                <div class="flex items-center gap-2 shrink-0">
                    <a href="{{ path('host_calendar', {id: listing.id}) }}"
                       class="flex items-center gap-1.5 border border-airbnb text-airbnb text-sm font-medium px-3 py-2 rounded-lg hover:bg-red-50 transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                        </svg>
                        Calendrier
                    </a>
                    <a href="{{ path('app_listing_details', {id: listing.id}) }}"
                       class="text-sm text-gray-500 hover:text-gray-800 border border-gray-200 px-3 py-2 rounded-lg hover:bg-gray-50 transition-colors">
                        Voir
                    </a>
                </div>
            </div>
            {% endfor %}
        </div>
    {% endif %}

</div>
{% endblock %}
