{% extends 'layout/user.html.twig' %}

{% block title %}{{ schedule.id is defined and schedule.id ? 'Modifier' : 'Nouvelle' }} plage de disponibilité{% endblock %}

{% block body %}
<div class="container mx-auto px-4 py-8 max-w-2xl">
    <h1 class="text-2xl font-bold text-gray-900 mb-6">
        {{ schedule.id ? 'Modifier la plage' : 'Nouvelle plage de disponibilité' }}
    </h1>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <form method="post">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                    <label for="startDate" class="block text-sm font-medium text-gray-700 mb-1">Date de début</label>
                    <input type="date" id="startDate" name="startDate" required
                           value="{{ schedule.startDate ? schedule.startDate|date('Y-m-d') : '' }}"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:outline-none">
                </div>
                <div>
                    <label for="endDate" class="block text-sm font-medium text-gray-700 mb-1">Date de fin</label>
                    <input type="date" id="endDate" name="endDate" required
                           value="{{ schedule.endDate ? schedule.endDate|date('Y-m-d') : '' }}"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:outline-none">
                </div>
                <div>
                    <label for="checkInTime" class="block text-sm font-medium text-gray-700 mb-1">Heure d'arrivée</label>
                    <input type="time" id="checkInTime" name="checkInTime" required
                           value="{{ schedule.checkInTime ? schedule.checkInTime|date('H:i') : '15:00' }}"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:outline-none">
                </div>
                <div>
                    <label for="checkOutTime" class="block text-sm font-medium text-gray-700 mb-1">Heure de départ</label>
                    <input type="time" id="checkOutTime" name="checkOutTime" required
                           value="{{ schedule.checkOutTime ? schedule.checkOutTime|date('H:i') : '11:00' }}"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:outline-none">
                </div>
                <div>
                    <label for="minimumStay" class="block text-sm font-medium text-gray-700 mb-1">Séjour minimum (nuits)</label>
                    <input type="number" id="minimumStay" name="minimumStay" min="1" required
                           value="{{ schedule.minimumStay ?? 1 }}"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:outline-none">
                </div>
                <div>
                    <label for="maximumStay" class="block text-sm font-medium text-gray-700 mb-1">Séjour maximum (nuits, optionnel)</label>
                    <input type="number" id="maximumStay" name="maximumStay" min="1"
                           value="{{ schedule.maximumStay ?? '' }}"
                           class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:outline-none"
                           placeholder="Illimité">
                </div>
            </div>

            <div class="mt-5">
                <label class="block text-sm font-medium text-gray-700 mb-2">Jours disponibles</label>
                <div class="flex flex-wrap gap-2">
                    {% set dayNames = {1: 'Lundi', 2: 'Mardi', 3: 'Mercredi', 4: 'Jeudi', 5: 'Vendredi', 6: 'Samedi', 7: 'Dimanche'} %}
                    {% for num, label in dayNames %}
                        <label class="flex items-center gap-1.5 cursor-pointer select-none">
                            <input type="checkbox" name="daysOfWeek[]" value="{{ num }}"
                                   {% if schedule.daysOfWeek is null or num in (schedule.daysOfWeek ?? []) %}checked{% endif %}
                                   class="rounded border-gray-300 text-blue-600 focus:ring-blue-500">
                            <span class="text-sm text-gray-700">{{ label }}</span>
                        </label>
                    {% endfor %}
                </div>
                <p class="text-xs text-gray-400 mt-1">Cochez tous les jours pour une disponibilité quotidienne.</p>
            </div>

            <div class="flex justify-end gap-3 mt-6">
                <a href="{{ path('host_availability_index', {id: property.id}) }}" class="px-4 py-2 text-sm text-gray-600 border rounded-lg hover:bg-gray-50">Annuler</a>
                <button type="submit" class="px-5 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700">
                    {{ schedule.id ? 'Enregistrer' : 'Créer la plage' }}
                </button>
            </div>
        </form>
    </div>
</div>
{% endblock %}
