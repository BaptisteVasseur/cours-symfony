{% extends 'layout/app.html.twig' %}

{% block title %}Disponibilités — {{ property.title }}{% endblock %}

{% block content %}
    {% set frMonths = ['', 'janvier', 'février', 'mars', 'avril', 'mai', 'juin', 'juillet', 'août', 'septembre', 'octobre', 'novembre', 'décembre'] %}
    {% set cellClasses = {
        free: 'bg-emerald-50 text-emerald-900',
        reserved: 'bg-red-100 text-red-800 font-medium',
        blocked: 'bg-amber-100 text-amber-800 font-medium',
    } %}

    <main class="flex-grow px-6 md:px-12 py-8 max-w-5xl mx-auto w-full">
        <a href="{{ path('app_account_properties') }}" class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-gray-900 mb-6">
            <i class="fa-solid fa-arrow-left"></i> Mes propriétés
        </a>

        <div class="mb-8">
            <h1 class="text-2xl md:text-3xl font-semibold text-gray-900 mb-2">Disponibilités</h1>
            <p class="text-gray-500">{{ property.title }}</p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <div class="lg:col-span-2 space-y-8">
                <div class="bg-white border border-gray-200 rounded-2xl p-6 shadow-sm">
                    <div class="flex items-center justify-between mb-4">
                        <a href="{{ path('app_host_availability_index', { id: property.id, month: prevMonth }) }}"
                           class="inline-flex items-center justify-center w-9 h-9 rounded-full text-gray-600 hover:bg-gray-100 transition"
                           aria-label="Mois précédent">
                            <i class="fa-solid fa-chevron-left"></i>
                        </a>
                        <h2 class="font-semibold text-gray-900">{{ frMonths[month|date('n')]|capitalize }} {{ month|date('Y') }}</h2>
                        <a href="{{ path('app_host_availability_index', { id: property.id, month: nextMonth }) }}"
                           class="inline-flex items-center justify-center w-9 h-9 rounded-full text-gray-600 hover:bg-gray-100 transition"
                           aria-label="Mois suivant">
                            <i class="fa-solid fa-chevron-right"></i>
                        </a>
                    </div>

                    <table class="w-full table-fixed border-separate border-spacing-1 text-sm">
                        <thead>
                            <tr>
                                {% for day in ['Lun', 'Mar', 'Mer', 'Jeu', 'Ven', 'Sam', 'Dim'] %}
                                    <th class="pb-2 text-xs font-medium text-gray-400 uppercase">{{ day }}</th>
                                {% endfor %}
                            </tr>
                        </thead>
                        <tbody>
                            {% for week in weeks %}
                                <tr>
                                    {% for cell in week %}
                                        {% if cell is null %}
                                            <td class="h-10"></td>
                                        {% else %}
                                            <td class="h-10 text-center rounded-lg {{ cellClasses[cell.state] }}">{{ cell.day }}</td>
                                        {% endif %}
                                    {% endfor %}
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>

                    <div class="flex flex-wrap gap-2 mt-4 text-xs">
                        <span class="px-3 py-1 rounded-full bg-emerald-50 text-emerald-900">Libre</span>
                        <span class="px-3 py-1 rounded-full bg-red-100 text-red-800">Réservé (confirmé)</span>
                        <span class="px-3 py-1 rounded-full bg-amber-100 text-amber-800">Bloqué par l'hôte</span>
                    </div>
                </div>

                <div class="bg-white border border-gray-200 rounded-2xl p-6 shadow-sm">
                    <h2 class="font-semibold text-gray-900 mb-4">Périodes bloquées ce mois-ci</h2>
                    {% if unavailabilities is empty %}
                        <p class="text-sm text-gray-500">Aucune période bloquée sur ce mois.</p>
                    {% else %}
                        <ul class="divide-y divide-gray-100">
                            {% for u in unavailabilities %}
                                <li class="flex items-center justify-between gap-4 py-3">
                                    <div>
                                        <p class="text-sm text-gray-900">
                                            Du {{ u.startDate|date('d/m/Y') }} au {{ u.endDate|date('d/m/Y') }} <span class="text-gray-400">(exclu)</span>
                                        </p>
                                        <p class="text-xs text-gray-500 mt-1">
                                            <span class="inline-block px-2 py-0.5 rounded-full bg-amber-100 text-amber-800">{{ u.reason.label }}</span>
                                            {% if u.note %}<span class="ml-2">{{ u.note }}</span>{% endif %}
                                        </p>
                                    </div>
                                    <form method="post" action="{{ path('app_host_availability_delete', { id: property.id, unavailabilityId: u.id }) }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_unavailability_' ~ u.id) }}">
                                        <button type="submit"
                                                class="inline-flex items-center justify-center w-9 h-9 rounded-full text-red-600 hover:bg-red-50 transition"
                                                aria-label="Supprimer cette période">
                                            <i class="fa-regular fa-trash-can"></i>
                                        </button>
                                    </form>
                                </li>
                            {% endfor %}
                        </ul>
                    {% endif %}
                </div>

                <div class="bg-white border border-gray-200 rounded-2xl p-6 shadow-sm">
                    <h2 class="font-semibold text-gray-900 mb-1">Synchronisation calendrier (iCal)</h2>
                    <p class="text-sm text-gray-500 mb-4">Synchronisez vos séjours confirmés avec votre agenda personnel (Google Calendar, Outlook).</p>

                    {% if property.icalExportToken %}
                        <input type="text" readonly onclick="this.select()"
                               value="{{ url('app_api_property_calendar', { id: property.id, token: property.icalExportToken }) }}"
                               class="w-full bg-gray-50 border border-gray-300 rounded-lg px-3 py-2 text-sm font-mono text-gray-700 mb-2">
                        <p class="text-xs text-gray-500 mb-4">À coller dans Google Calendar ou Outlook (« S'abonner à un agenda »). Seuls les séjours confirmés sont exportés.</p>
                        <div class="flex flex-wrap gap-3">
                            <form method="post" action="{{ path('app_host_ical_export_generate', { id: property.id }) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('ical_export_generate_' ~ property.id) }}">
                                <button type="submit" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 rounded-lg hover:bg-gray-200 transition">
                                    <i class="fa-solid fa-rotate"></i> Régénérer le lien
                                </button>
                            </form>
                            <form method="post" action="{{ path('app_host_ical_export_revoke', { id: property.id }) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('ical_export_revoke_' ~ property.id) }}">
                                <button type="submit" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-red-700 bg-red-50 rounded-lg hover:bg-red-100 transition">
                                    <i class="fa-regular fa-circle-xmark"></i> Révoquer le lien
                                </button>
                            </form>
                        </div>
                    {% else %}
                        <form method="post" action="{{ path('app_host_ical_export_generate', { id: property.id }) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('ical_export_generate_' ~ property.id) }}">
                            <button type="submit" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-semibold text-white bg-brand hover:bg-brandHover rounded-lg transition">
                                <i class="fa-solid fa-link"></i> Générer le lien de synchronisation
                            </button>
                        </form>
                    {% endif %}
                </div>
            </div>

            <aside>
                <div class="bg-white border border-gray-200 rounded-2xl p-6 shadow-sm lg:sticky lg:top-28">
                    <h2 class="font-semibold text-gray-900 mb-4">Déclarer une indisponibilité</h2>
                    {{ form_start(form, { attr: { class: 'space-y-4' } }) }}
                        {{ form_row(form.startDate, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm' } }) }}
                        {{ form_row(form.endDate, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm' } }) }}
                        {{ form_row(form.reason, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm' } }) }}
                        {{ form_row(form.note, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm', rows: 2 } }) }}
                        <button type="submit" class="w-full bg-brand hover:bg-brandHover text-white font-semibold py-3 rounded-xl transition">
                            Bloquer la période
                        </button>
                    {{ form_end(form) }}
                </div>
            </aside>
        </div>
    </main>
{% endblock %}
