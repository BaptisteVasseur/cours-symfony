{% extends 'layout/user.html.twig' %}

{% block title %}Bloquer une date — {{ property.title }}{% endblock %}

{% block body %}
<div class="container mx-auto px-4 py-8 max-w-md">
    <h1 class="text-2xl font-bold text-gray-900 mb-6">Bloquer une date</h1>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <form method="post" action="{{ path('host_availability_exception_new', {id: property.id}) }}">
            <div class="mb-4">
                <label for="date" class="block text-sm font-medium text-gray-700 mb-1">Date à bloquer</label>
                <input type="date" id="date" name="date" required
                       min="{{ 'today'|date('Y-m-d') }}"
                       class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:outline-none">
            </div>
            <div class="mb-6">
                <label for="reason" class="block text-sm font-medium text-gray-700 mb-1">Motif (optionnel)</label>
                <input type="text" id="reason" name="reason" maxlength="255" placeholder="Ex : ménage, travaux, usage personnel..."
                       class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:outline-none">
            </div>
            <div class="flex justify-end gap-3">
                <a href="{{ path('host_availability_index', {id: property.id}) }}" class="px-4 py-2 text-sm text-gray-600 border rounded-lg hover:bg-gray-50">Annuler</a>
                <button type="submit" class="px-5 py-2 text-sm font-medium text-white bg-red-600 rounded-lg hover:bg-red-700">Bloquer cette date</button>
            </div>
        </form>
    </div>
</div>
{% endblock %}
