{% extends 'layout/user.html.twig' %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-3xl mx-auto w-full">
        <a href="{{ path('host_calendar_show', {id: property.id}) }}"
           class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-gray-900 mb-6">
            <i class="fa-solid fa-arrow-left"></i>
            Retour au calendrier
        </a>

        <h1 class="text-2xl font-semibold text-gray-900 mb-2">Paramètres iCal</h1>
        <p class="text-gray-500 mb-8">{{ property.title }}</p>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 px-4 py-3 rounded-lg text-sm
                    {% if label == 'error' %}bg-red-50 text-red-700 border border-red-200
                    {% else %}bg-green-50 text-green-700 border border-green-200{% endif %}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        {% if app.request.host in ['localhost', '127.0.0.1'] %}
        <div class="bg-amber-50 border border-amber-200 rounded-2xl p-5 mb-6">
            <div class="flex items-start gap-3">
                <i class="fa-solid fa-triangle-exclamation text-amber-500 mt-0.5"></i>
                <div class="flex-1 min-w-0">
                    <p class="text-sm font-semibold text-amber-800 mb-1">Vous êtes en local — Google Calendar ne peut pas accéder à ces liens</p>
                    <p class="text-sm text-amber-700 mb-3">Pour synchroniser avec Google Calendar, exposez votre serveur avec <strong>ngrok</strong> :</p>
                    <ol class="text-sm text-amber-700 space-y-1 list-decimal list-inside mb-3">
                        <li>Dans un terminal : <code class="bg-amber-100 px-1.5 py-0.5 rounded font-mono text-xs">ngrok http {{ app.request.port }}</code></li>
                        <li>Copiez l'URL <code class="bg-amber-100 px-1.5 py-0.5 rounded font-mono text-xs">https://xxxx.ngrok-free.app</code> affichée</li>
                        <li>Remplacez <code class="bg-amber-100 px-1.5 py-0.5 rounded font-mono text-xs">http://localhost:{{ app.request.port }}</code> par cette URL dans les liens ci-dessous</li>
                        <li>Dans Google Calendar → <strong>Autres agendas</strong> → <strong>+</strong> → <strong>À partir de l'URL</strong></li>
                    </ol>
                    <p class="text-xs text-amber-600">L'URL ngrok change à chaque redémarrage (plan gratuit) et ne se refraîchit que toutes les 24h. En production ce sera votre vrai domaine.</p>
                </div>
            </div>
        </div>
        {% endif %}

        <div class="bg-white border border-gray-200 rounded-2xl p-6 space-y-6">
            {# Property iCal export #}
            <div>
                <h2 class="text-base font-semibold text-gray-900 mb-1">Exporter le calendrier de ce logement</h2>
                <p class="text-sm text-gray-500 mb-3">
                    Copiez ce lien et collez-le dans votre application de calendrier (Google Calendar, Airbnb, Booking.com…)
                </p>
                {% if property.calendarToken %}
                    {% set propertyIcalUrl = url('ical_property', {token: property.calendarToken}) %}
                    <div class="flex items-center gap-2">
                        <input type="text" readonly value="{{ propertyIcalUrl }}"
                               class="flex-1 border border-gray-300 rounded-lg px-3 py-2 text-sm text-gray-600 bg-gray-50 cursor-pointer"
                               onclick="this.select(); document.execCommand('copy'); this.blur(); alert('Lien copié !')">
                        <a href="{{ propertyIcalUrl }}" download
                           class="text-sm text-brand hover:underline whitespace-nowrap">
                            <i class="fa-solid fa-download mr-1"></i>Télécharger
                        </a>
                    </div>
                {% else %}
                    <p class="text-sm text-gray-400 italic">Aucun lien généré. Cliquez sur "Régénérer" ci-dessous.</p>
                {% endif %}
            </div>

            {# Host aggregated iCal #}
            {% if app.user.calendarToken %}
                <div class="border-t border-gray-100 pt-5">
                    <h2 class="text-base font-semibold text-gray-900 mb-1">Exporter tous mes logements</h2>
                    <p class="text-sm text-gray-500 mb-3">
                        Un flux unique regroupant les réservations de tous vos logements.
                    </p>
                    {% set hostIcalUrl = url('ical_host', {token: app.user.calendarToken}) %}
                    <div class="flex items-center gap-2">
                        <input type="text" readonly value="{{ hostIcalUrl }}"
                               class="flex-1 border border-gray-300 rounded-lg px-3 py-2 text-sm text-gray-600 bg-gray-50 cursor-pointer"
                               onclick="this.select(); document.execCommand('copy'); this.blur(); alert('Lien copié !')">
                        <a href="{{ hostIcalUrl }}" download
                           class="text-sm text-brand hover:underline whitespace-nowrap">
                            <i class="fa-solid fa-download mr-1"></i>Télécharger
                        </a>
                    </div>
                </div>
            {% endif %}

            {# Regenerate token #}
            <div class="border-t border-gray-100 pt-5">
                <h2 class="text-base font-semibold text-gray-900 mb-1">Régénérer le lien</h2>
                <p class="text-sm text-red-600 mb-3">
                    Attention : tout lien partagé précédemment ne fonctionnera plus.
                </p>
                <form method="POST" action="{{ path('host_calendar_settings', {id: property.id}) }}">
                    <input type="hidden" name="action" value="regen_token">
                    <input type="hidden" name="_token" value="{{ csrf_token('regen_token_' ~ property.id) }}">
                    <button type="submit"
                            class="bg-gray-900 hover:bg-gray-700 text-white text-sm font-semibold px-5 py-2.5 rounded-xl transition-colors">
                        <i class="fa-solid fa-arrows-rotate mr-1"></i>Régénérer le lien iCal
                    </button>
                </form>
            </div>
        </div>
    </main>
{% endblock %}
