{% extends 'layout/user.html.twig' %}

{% block title %}Ajouter un calendrier externe — {{ property.title }}{% endblock %}

{% block body %}
<div class="container mx-auto px-4 py-8 max-w-lg">
    <h1 class="text-2xl font-bold text-gray-900 mb-2">Importer un calendrier externe</h1>
    <p class="text-sm text-gray-500 mb-6">Synchronisez vos réservations depuis Airbnb, Booking.com ou tout autre service compatible iCal.</p>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <form method="post" action="{{ path('host_availability_ical_sync_new', {id: property.id}) }}">
            <div class="mb-4">
                <label for="providerName" class="block text-sm font-medium text-gray-700 mb-1">Plateforme</label>
                <input type="text" id="providerName" name="providerName" required maxlength="100"
                       placeholder="Ex : Airbnb, Booking.com..."
                       class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-[#FF385C] focus:outline-none">
            </div>
            <div class="mb-6">
                <label for="iCalUrl" class="block text-sm font-medium text-gray-700 mb-1">URL du calendrier iCal</label>
                <input type="url" id="iCalUrl" name="iCalUrl" required
                       placeholder="https://www.airbnb.fr/calendar/ical/..."
                       class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-[#FF385C] focus:outline-none">
                <p class="text-xs text-gray-400 mt-1">Trouvez cette URL dans les paramètres de votre logement sur la plateforme source.</p>
            </div>
            <div class="flex justify-end gap-3">
                <a href="{{ path('host_availability_index', {id: property.id}) }}" class="px-4 py-2 text-sm text-gray-600 border rounded-lg hover:bg-gray-50 transition">Annuler</a>
                <button type="submit" class="px-5 py-2 text-sm font-medium text-white bg-[#FF385C] rounded-lg hover:bg-[#E61E4D] transition shadow-sm">Ajouter et synchroniser</button>
            </div>
        </form>
    </div>
</div>
{% endblock %}
