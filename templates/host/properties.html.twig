{% extends 'layout/user.html.twig' %}

{% block title %}Mes logements{% endblock %}

{% block content %}
    <div class="max-w-6xl mx-auto px-4 py-10">
        <div class="flex items-center justify-between mb-8">
            <div>
                <h1 class="text-2xl md:text-3xl font-bold text-gray-900">Mes logements</h1>
                <p class="text-gray-500 text-sm mt-1">Gérez le calendrier et les disponibilités de vos annonces.</p>
            </div>
        </div>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 px-4 py-3 rounded-lg text-sm font-medium {{ label == 'success' ? 'bg-emerald-50 text-emerald-800 border border-emerald-200' : 'bg-red-50 text-red-800 border border-red-200' }}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        {% if properties is empty %}
            <div class="bg-white border border-gray-200 rounded-2xl p-10 text-center text-gray-500">
                Vous n'avez pas encore de logement.
            </div>
        {% else %}
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {% for property in properties %}
                    <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden shadow-sm">
                        <div class="h-40 bg-gray-100 overflow-hidden">
                            {% set cover = property.coverMedia %}
                            {% if cover %}
                                <img src="{{ cover.fileUrl }}" alt="{{ property.title }}" class="w-full h-full object-cover">
                            {% endif %}
                        </div>
                        <div class="p-5">
                            <div class="flex items-center justify-between mb-2">
                                <h2 class="font-semibold text-gray-900 truncate">{{ property.title }}</h2>
                                <span class="text-xs px-2 py-1 rounded-full {{ property.status == 'published' ? 'bg-emerald-50 text-emerald-700' : 'bg-gray-100 text-gray-600' }}">
                                    {{ property.status }}
                                </span>
                            </div>
                            <p class="text-sm text-gray-500 mb-4">
                                {{ property.address ? property.address.city : 'Adresse non renseignée' }}
                                · {{ property.maxGuests }} voyageurs max
                            </p>
                            <a href="{{ path('app_host_calendar', { id: property.id }) }}"
                               class="inline-flex items-center gap-2 text-sm font-semibold text-white bg-brand hover:bg-brandHover px-4 py-2 rounded-xl transition">
                                <i class="fa-regular fa-calendar"></i> Gérer le calendrier
                            </a>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
{% endblock %}
