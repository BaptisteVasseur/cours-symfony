{% extends 'layout/base.html.twig' %}

{% block title %}Demandes de réservation — Hôte{% endblock %}

{% block body %}
<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-2xl font-bold text-gray-900 mb-1">Demandes en attente</h1>
    <p class="text-gray-500 mb-6">Acceptez ou refusez les demandes de réservation de vos logements.</p>

    {% if pendingBookings is empty %}
        <div class="bg-white border border-gray-200 rounded-2xl p-12 text-center text-gray-500">
            Aucune demande en attente. 🎉
        </div>
    {% else %}
        <div class="space-y-4">
            {% for booking in pendingBookings %}
                <div class="bg-white border border-gray-200 rounded-2xl p-5">
                    <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4">
                        <div>
                            <h2 class="font-semibold text-gray-900">{{ booking.listing.title }}</h2>
                            <p class="text-sm text-gray-500 mt-1">
                                {{ booking.guest.firstName }} {{ booking.guest.lastName }} ·
                                {{ booking.checkIn|date('d/m/Y') }} → {{ booking.checkOut|date('d/m/Y') }} ·
                                {{ booking.nightsCount }} nuit(s) · {{ booking.guestsCount }} voyageur(s)
                            </p>
                            <p class="text-sm text-gray-400 mt-1">Demandé le {{ booking.createdAt|date('d/m/Y H:i') }}</p>
                        </div>
                        <div class="text-right whitespace-nowrap">
                            <div class="font-bold text-gray-900">{{ booking.totalAmount }} {{ booking.currency ?? 'EUR' }}</div>
                        </div>
                    </div>

                    <div class="mt-4 flex flex-col sm:flex-row gap-3">
                        <form method="post" action="{{ path('app_host_booking_accept', {id: booking.id}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('moderate_' ~ booking.id) }}">
                            <button class="px-5 py-2 bg-green-600 text-white font-semibold rounded-lg hover:bg-green-700 transition">Accepter</button>
                        </form>

                        <form method="post" action="{{ path('app_host_booking_reject', {id: booking.id}) }}" class="flex-1 flex gap-2">
                            <input type="hidden" name="_token" value="{{ csrf_token('moderate_' ~ booking.id) }}">
                            <input type="text" name="reason" required placeholder="Motif du refus (obligatoire)"
                                   class="flex-1 px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#FF385C]">
                            <button class="px-5 py-2 border border-red-300 text-red-600 font-medium rounded-lg hover:bg-red-50 transition">Refuser</button>
                        </form>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}
