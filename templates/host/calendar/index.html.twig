{% extends 'layout/app.html.twig' %}

{% block title %}Calendrier — {{ property.title }}{% endblock %}

{% set frMonths = ['Janvier', 'Février', 'Mars', 'Avril', 'Mai', 'Juin', 'Juillet', 'Août', 'Septembre', 'Octobre', 'Novembre', 'Décembre'] %}
{% set weekdays = ['Lun', 'Mar', 'Mer', 'Jeu', 'Ven', 'Sam', 'Dim'] %}
{% set stateClasses = {
    'available': 'bg-white text-gray-800 border-gray-200',
    'booked': 'bg-rose-100 text-rose-700 border-rose-200',
    'blocked': 'bg-gray-200 text-gray-500 border-gray-300',
    'past': 'bg-gray-50 text-gray-300 border-gray-100',
} %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-4xl mx-auto w-full">
        <div class="flex items-center justify-between mb-6">
            <div>
                <h1 class="text-2xl font-semibold text-gray-900">Calendrier</h1>
                <p class="text-gray-500">{{ property.title }}</p>
            </div>
            <a href="{{ path('app_host_moderation') }}" class="text-sm font-semibold text-brand hover:underline">Demandes reçues</a>
        </div>

        <div class="border border-gray-200 rounded-2xl p-6 mb-6">
            <div class="flex items-center justify-between mb-4">
                <a href="{{ path('app_host_calendar', { id: property.id, mois: prevMonth }) }}" class="px-3 py-1.5 rounded-lg border border-gray-200 hover:bg-gray-50 text-sm">←</a>
                <h2 class="text-lg font-semibold">{{ frMonths[month|date('n') - 1] }} {{ month|date('Y') }}</h2>
                <a href="{{ path('app_host_calendar', { id: property.id, mois: nextMonth }) }}" class="px-3 py-1.5 rounded-lg border border-gray-200 hover:bg-gray-50 text-sm">→</a>
            </div>

            <div class="grid grid-cols-7 gap-1 text-center text-xs font-semibold text-gray-400 mb-1">
                {% for label in weekdays %}<div>{{ label }}</div>{% endfor %}
            </div>
            <div class="grid grid-cols-7 gap-1">
                {% if leadingBlanks > 0 %}{% for i in 1..leadingBlanks %}<div></div>{% endfor %}{% endif %}
                {% for cell in days %}
                    <div class="aspect-square rounded-lg border flex items-center justify-center text-sm {{ stateClasses[cell.state] }}">{{ cell.day }}</div>
                {% endfor %}
            </div>

            <div class="flex flex-wrap gap-4 mt-4 text-xs text-gray-500">
                <span class="inline-flex items-center gap-1"><span class="w-3 h-3 rounded bg-white border border-gray-200"></span> Disponible</span>
                <span class="inline-flex items-center gap-1"><span class="w-3 h-3 rounded bg-rose-100 border border-rose-200"></span> Réservé</span>
                <span class="inline-flex items-center gap-1"><span class="w-3 h-3 rounded bg-gray-200 border border-gray-300"></span> Bloqué</span>
            </div>
        </div>

        <form method="post" action="{{ path('app_host_calendar_block', { id: property.id }) }}" class="border border-gray-200 rounded-2xl p-6">
            <input type="hidden" name="_token" value="{{ csrf_token('host_calendar_' ~ property.id) }}">
            <h2 class="text-lg font-semibold mb-4">Bloquer / rouvrir une période</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
                <label class="text-sm text-gray-600">Du
                    <input type="date" name="from" required class="mt-1 w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
                </label>
                <label class="text-sm text-gray-600">Au (exclus)
                    <input type="date" name="to" required class="mt-1 w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
                </label>
            </div>
            <div class="flex gap-3">
                <button type="submit" name="action" value="block" class="bg-gray-900 hover:bg-black text-white text-sm font-semibold rounded-lg px-4 py-2.5">Bloquer</button>
                <button type="submit" name="action" value="unblock" class="border border-gray-300 hover:bg-gray-50 text-sm font-semibold rounded-lg px-4 py-2.5">Rouvrir</button>
            </div>
        </form>

        <div class="border border-gray-200 rounded-2xl p-6 mt-6">
            <h2 class="text-lg font-semibold mb-2">Synchronisation iCal (export)</h2>
            <p class="text-sm text-gray-500 mb-4">Partagez ce lien sécurisé avec Google Calendar ou Outlook pour exporter vos séjours confirmés.</p>
            {% if property.exportToken %}
                <input type="text" readonly value="{{ url('app_api_property_calendar', { id: property.id }) }}?token={{ property.exportToken }}" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm bg-gray-50 mb-3" onclick="this.select()">
            {% endif %}
            <form method="post" action="{{ path('app_host_calendar_token', { id: property.id }) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('host_calendar_token_' ~ property.id) }}">
                <button type="submit" class="border border-gray-300 hover:bg-gray-50 text-sm font-semibold rounded-lg px-4 py-2.5">
                    {{ property.exportToken ? 'Régénérer le lien' : 'Générer le lien iCal' }}
                </button>
            </form>
        </div>
    </main>
{% endblock %}
