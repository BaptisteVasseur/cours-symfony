{% extends 'layout/base.html.twig' %}

{% block page_title %}Calendrier — {{ listing.title }}{% endblock %}

{% block extra_styles %}
<style>
    .day-blocked  { background-color: #FEE2E2; }
    .day-booking  { background-color: #DBEAFE; }
    .day-today    { font-weight: 700; }
    .day-outside  { background-color: #F9FAFB; }
</style>
{% endblock %}

{% block body %}
<div class="max-w-5xl mx-auto px-4 py-8 space-y-8">

    {# ── En-tête ── #}
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Calendrier</h1>
            <p class="text-sm text-gray-500 mt-0.5">{{ listing.title }}</p>
        </div>
        <a href="{{ path('app_listing_details', {id: listing.id}) }}"
           class="text-sm text-airbnb hover:underline self-start sm:self-auto">
            ← Retour au logement
        </a>
    </div>

    {# ── Flash messages ── #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="rounded-lg px-4 py-3 text-sm font-medium
                {% if label == 'success' %}bg-green-50 text-green-700 border border-green-200
                {% elseif label == 'error' %}bg-red-50 text-red-700 border border-red-200
                {% else %}bg-blue-50 text-blue-700 border border-blue-200{% endif %}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

        {# ════════════════════════════════════════
           COLONNE GAUCHE — Calendrier mensuel
           ════════════════════════════════════════ #}
        <div class="lg:col-span-2 space-y-4">

            {# Navigation mois #}
            <div class="flex items-center justify-between">
                <a href="{{ path('host_calendar', {id: listing.id, month: prevMonth}) }}"
                   class="p-2 rounded-full hover:bg-gray-100 transition-colors text-gray-600" aria-label="Mois précédent">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
                    </svg>
                </a>
                <h2 class="text-lg font-semibold text-gray-800">
                    {{ monthLabel }}
                </h2>
                <a href="{{ path('host_calendar', {id: listing.id, month: nextMonth}) }}"
                   class="p-2 rounded-full hover:bg-gray-100 transition-colors text-gray-600" aria-label="Mois suivant">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                    </svg>
                </a>
            </div>

            {# Grille calendrier #}
            <div class="border border-gray-200 rounded-xl overflow-hidden shadow-sm">

                {# Entêtes jours #}
                <div class="grid grid-cols-7 bg-gray-50 border-b border-gray-200">
                    {% for dayName in ['Lun', 'Mar', 'Mer', 'Jeu', 'Ven', 'Sam', 'Dim'] %}
                        <div class="py-2 text-center text-xs font-semibold text-gray-500 uppercase tracking-wide">
                            {{ dayName }}
                        </div>
                    {% endfor %}
                </div>

                {# Cases du mois #}
                {% set todayStr = 'now'|date('Y-m-d') %}
                {% set year  = firstDay|date('Y') %}
                {% set month = firstDay|date('m') %}

                <div class="grid grid-cols-7">

                    {# Cellules vides avant le 1er #}
                    {% for i in 1..startPad %}
                        <div class="day-outside min-h-[64px] border-b border-r border-gray-100"></div>
                    {% endfor %}

                    {# Jours du mois #}
                    {% for day in 1..daysInMonth %}
                        {% set dateStr = year ~ '-' ~ ('%02d'|format(month)) ~ '-' ~ ('%02d'|format(day)) %}
                        {% set status  = occupiedDays[dateStr] ?? null %}
                        {% set isToday = (dateStr == todayStr) %}

                        <div class="min-h-[64px] border-b border-r border-gray-100 p-1.5 relative
                            {% if status == 'blocked' %}day-blocked
                            {% elseif status == 'booking' %}day-booking
                            {% else %}bg-white hover:bg-gray-50{% endif %}">
                            <span class="text-xs {% if isToday %}day-today text-airbnb{% else %}text-gray-700{% endif %}">
                                {{ day }}
                            </span>
                            {% if status == 'blocked' %}
                                <span class="block text-[10px] text-red-500 leading-tight mt-0.5">Bloqué</span>
                            {% elseif status == 'booking' %}
                                <span class="block text-[10px] text-blue-600 leading-tight mt-0.5">Réservé</span>
                            {% endif %}
                        </div>
                    {% endfor %}

                    {# Cellules vides après le dernier jour pour compléter la dernière semaine #}
                    {% set totalCells = startPad + daysInMonth %}
                    {% set remainder  = totalCells % 7 %}
                    {% if remainder > 0 %}
                        {% for i in 1..(7 - remainder) %}
                            <div class="day-outside min-h-[64px] border-b border-r border-gray-100"></div>
                        {% endfor %}
                    {% endif %}

                </div>
            </div>

            {# Légende #}
            <div class="flex flex-wrap gap-4 text-sm text-gray-600">
                <span class="flex items-center gap-1.5">
                    <span class="inline-block w-3 h-3 rounded-sm bg-[#DBEAFE] border border-blue-200"></span>
                    Réservation confirmée
                </span>
                <span class="flex items-center gap-1.5">
                    <span class="inline-block w-3 h-3 rounded-sm bg-[#FEE2E2] border border-red-200"></span>
                    Période bloquée
                </span>
                <span class="flex items-center gap-1.5">
                    <span class="inline-block w-3 h-3 rounded-sm bg-white border border-gray-300"></span>
                    Disponible
                </span>
            </div>
        </div>

        {# ════════════════════════════════════════
           COLONNE DROITE — Formulaire + liste
           ════════════════════════════════════════ #}
        <div class="space-y-6">

            {# Formulaire bloquer une période #}
            <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-5">
                <h3 class="text-base font-semibold text-gray-900 mb-4">Bloquer une période</h3>

                {{ form_start(form, {attr: {class: 'space-y-4'}}) }}

                    <div>
                        {{ form_label(form.startDate, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.startDate, {attr: {class: 'block w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-airbnb focus:border-transparent'}}) }}
                        {{ form_errors(form.startDate) }}
                    </div>

                    <div>
                        {{ form_label(form.endDate, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.endDate, {attr: {class: 'block w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-airbnb focus:border-transparent'}}) }}
                        {{ form_errors(form.endDate) }}
                    </div>

                    <div>
                        {{ form_label(form.reason, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(form.reason, {attr: {class: 'block w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-airbnb focus:border-transparent'}}) }}
                        {{ form_errors(form.reason) }}
                    </div>

                    <button type="submit"
                            class="w-full bg-airbnb hover:bg-airbnb-dark text-white font-semibold text-sm py-2.5 rounded-lg transition-colors">
                        Bloquer ces dates
                    </button>

                {{ form_end(form) }}
            </div>

            {# Liste des périodes bloquées sur le mois affiché #}
            {% if blockedPeriods is not empty %}
            <div class="bg-white border border-gray-200 rounded-xl shadow-sm p-5">
                <h3 class="text-base font-semibold text-gray-900 mb-3">Périodes bloquées ce mois</h3>
                <ul class="space-y-2">
                    {% for bp in blockedPeriods %}
                    <li class="flex items-start justify-between gap-2 text-sm text-gray-700 bg-red-50 rounded-lg px-3 py-2">
                        <div>
                            <span class="font-medium">
                                {{ bp.startDate|date('d/m') }} → {{ bp.endDate|date('d/m/Y') }}
                            </span>
                            {% if bp.reason %}
                                <br><span class="text-xs text-gray-500">{{ bp.reason }}</span>
                            {% endif %}
                        </div>
                        <form method="post"
                              action="{{ path('host_blocked_period_delete', {id: bp.id}) }}"
                              onsubmit="return confirm('Supprimer cette période bloquée ?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_bp_' ~ bp.id) }}">
                            <input type="hidden" name="month" value="{{ firstDay|date('Y-m') }}">
                            <button type="submit"
                                    class="shrink-0 text-red-500 hover:text-red-700 transition-colors"
                                    aria-label="Supprimer">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                                </svg>
                            </button>
                        </form>
                    </li>
                    {% endfor %}
                </ul>
            </div>
            {% endif %}

        </div>
    </div>

</div>
{% endblock %}
