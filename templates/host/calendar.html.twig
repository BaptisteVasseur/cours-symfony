{% extends 'host/_layout.html.twig' %}

{% block title %}Calendrier — {{ property.title }}{% endblock %}

{% block host_content %}
<div class="space-y-8 max-w-5xl">

    {# Header #}
    <div class="flex items-center gap-4">
        <a href="{{ path('host_dashboard') }}" class="text-gray-400 hover:text-gray-600 transition">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
        </a>
        <h1 class="text-2xl font-bold text-gray-900">{{ property.title }}</h1>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

        {# ── Calendrier ── #}
        <div class="lg:col-span-2 bg-white border border-gray-200 rounded-2xl p-6">
            {# Navigation mois #}
            <div class="flex items-center justify-between mb-6">
                <a href="{{ path('host_property_calendar', {id: property.id, month: prevMonth}) }}"
                   class="p-2 hover:bg-gray-100 rounded-lg transition">
                    <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                    </svg>
                </a>
                <h2 class="text-lg font-semibold text-gray-900 capitalize">{{ monthLabel }}</h2>
                <a href="{{ path('host_property_calendar', {id: property.id, month: nextMonth}) }}"
                   class="p-2 hover:bg-gray-100 rounded-lg transition">
                    <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                </a>
            </div>

            {# Jours de la semaine #}
            <div class="grid grid-cols-7 mb-2">
                {% for day in ['Lun', 'Mar', 'Mer', 'Jeu', 'Ven', 'Sam', 'Dim'] %}
                    <div class="text-center text-xs font-medium text-gray-400 py-1">{{ day }}</div>
                {% endfor %}
            </div>

            {# Grille des jours #}
            <div class="grid grid-cols-7 gap-1">
                {# Cellules vides avant le 1er du mois (lundi = 1) #}
                {% for i in 1..(firstDayOfWeek - 1) %}
                    <div></div>
                {% endfor %}

                {% for dateKey, state in calendarStates %}
                    {% set dayNum = dateKey|date('j') %}
                    <div class="aspect-square flex items-center justify-center rounded-lg text-sm font-medium
                        {% if state == 'confirmed' %}bg-red-500 text-white
                        {% elseif state == 'pending' %}bg-yellow-400 text-white
                        {% elseif state == 'blocked' %}bg-gray-300 text-gray-600
                        {% else %}bg-gray-50 text-gray-700 hover:bg-gray-100{% endif %}
                        transition cursor-default" title="{{ state }}">
                        {{ dayNum }}
                    </div>
                {% endfor %}
            </div>

            {# Légende #}
            <div class="mt-6 flex flex-wrap gap-4 text-xs text-gray-500">
                <span class="flex items-center gap-1.5"><span class="w-3 h-3 bg-red-500 rounded-sm"></span> Confirmé</span>
                <span class="flex items-center gap-1.5"><span class="w-3 h-3 bg-yellow-400 rounded-sm"></span> En attente</span>
                <span class="flex items-center gap-1.5"><span class="w-3 h-3 bg-gray-300 rounded-sm"></span> Bloqué</span>
                <span class="flex items-center gap-1.5"><span class="w-3 h-3 bg-gray-50 border border-gray-200 rounded-sm"></span> Disponible</span>
            </div>
        </div>

        {# ── Panneau droit ── #}
        <div class="space-y-6">

            {# Mode réservation instantanée #}
            <div class="bg-white border border-gray-200 rounded-2xl p-5">
                <h3 class="font-semibold text-gray-900 mb-2">Mode de réservation</h3>
                <p class="text-sm text-gray-500 mb-4">
                    {% if property.instantBooking %}
                        <span class="text-green-600 font-medium">Réservation instantanée activée</span> — les voyageurs sont confirmés immédiatement.
                    {% else %}
                        <span class="text-yellow-600 font-medium">Sur demande</span> — vous validez chaque demande manuellement.
                    {% endif %}
                </p>
                <form method="POST" action="{{ path('host_property_calendar', {id: property.id, month: year ~ '-' ~ month}) }}">
                    <input type="hidden" name="toggle_instant" value="1">
                    <input type="hidden" name="_token_instant" value="{{ csrf_token('toggle_instant_' ~ property.id) }}">
                    <button type="submit"
                            class="w-full text-sm border rounded-xl py-2 font-medium transition
                                   {{ property.instantBooking ? 'border-yellow-300 text-yellow-600 hover:bg-yellow-50' : 'border-green-300 text-green-600 hover:bg-green-50' }}">
                        {% if property.instantBooking %}Passer en mode "Sur demande"{% else %}Activer la réservation instantanée{% endif %}
                    </button>
                </form>
            </div>

            {# Bloquer des dates #}
            <div class="bg-white border border-gray-200 rounded-2xl p-5">
                <h3 class="font-semibold text-gray-900 mb-4">Bloquer une période</h3>
                {{ form_start(blockForm, {attr: {class: 'space-y-3'}}) }}
                    <div>
                        {{ form_label(blockForm.startDate) }}
                        {{ form_widget(blockForm.startDate) }}
                        {{ form_errors(blockForm.startDate) }}
                    </div>
                    <div>
                        {{ form_label(blockForm.endDate) }}
                        {{ form_widget(blockForm.endDate) }}
                        {{ form_errors(blockForm.endDate) }}
                    </div>
                    <div>
                        {{ form_label(blockForm.reason) }}
                        {{ form_widget(blockForm.reason) }}
                    </div>
                    <button type="submit"
                            class="w-full bg-gray-900 hover:bg-gray-700 text-white text-sm py-2 rounded-xl font-medium transition">
                        Bloquer
                    </button>
                {{ form_end(blockForm) }}
            </div>

            {# iCal token #}
            <div class="bg-white border border-gray-200 rounded-2xl p-5">
                <h3 class="font-semibold text-gray-900 mb-2">Synchronisation iCal</h3>
                {% if property.calendarToken %}
                    <p class="text-xs text-gray-500 mb-3">URL à copier dans Google Calendar / Outlook :</p>
                    <code class="block bg-gray-50 border border-gray-200 rounded-lg p-2 text-xs text-gray-700 break-all mb-3">
                        {{ app.request.schemeAndHttpHost ~ path('app_ical_export', {id: property.id}) }}?token={{ property.calendarToken }}
                    </code>
                    <form method="POST" action="{{ path('host_property_calendar', {id: property.id}) }}"
                          onsubmit="return confirm('Révoquer le token ? Les liens existants ne fonctionneront plus.')">
                        <input type="hidden" name="revoke_token" value="1">
                        <input type="hidden" name="_token_rev" value="{{ csrf_token('revoke_token_' ~ property.id) }}">
                        <button type="submit" class="text-xs text-red-500 hover:underline">Révoquer le token</button>
                    </form>
                {% else %}
                    <p class="text-sm text-gray-500 mb-3">Aucun token généré.</p>
                    <form method="POST" action="{{ path('host_property_calendar', {id: property.id}) }}">
                        <input type="hidden" name="gen_token" value="1">
                        <input type="hidden" name="_token_cal" value="{{ csrf_token('gen_token_' ~ property.id) }}">
                        <button type="submit"
                                class="w-full border border-gray-300 text-sm text-gray-700 hover:bg-gray-50 py-2 rounded-xl transition">
                            Générer un lien iCal
                        </button>
                    </form>
                {% endif %}
            </div>
        </div>
    </div>

    {# ── Périodes bloquées ── #}
    {% if blockedPeriods is not empty %}
        <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100">
                <h3 class="font-semibold text-gray-900">Périodes bloquées ({{ blockedPeriods|length }})</h3>
            </div>
            <table class="w-full text-sm">
                <thead class="bg-gray-50 text-gray-500">
                    <tr>
                        <th class="px-6 py-3 text-left font-medium">Début</th>
                        <th class="px-6 py-3 text-left font-medium">Fin</th>
                        <th class="px-6 py-3 text-left font-medium">Motif</th>
                        <th class="px-6 py-3 text-left font-medium">Action</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    {% for period in blockedPeriods %}
                        <tr class="hover:bg-gray-50">
                            <td class="px-6 py-3">{{ period.startDate|date('d/m/Y') }}</td>
                            <td class="px-6 py-3">{{ period.endDate|date('d/m/Y') }}</td>
                            <td class="px-6 py-3 text-gray-500">{{ period.reason ?: '—' }}</td>
                            <td class="px-6 py-3">
                                <form method="POST"
                                      action="{{ path('host_availability_delete', {id: period.id}) }}"
                                      onsubmit="return confirm('Supprimer cette période ?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('del_avail_' ~ period.id) }}">
                                    <button type="submit"
                                            class="text-xs text-red-500 hover:text-red-700 font-medium">
                                        Supprimer
                                    </button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% endif %}
</div>
{% endblock %}
