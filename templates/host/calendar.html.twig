{% extends 'layouts/user.html.twig' %}

{% block title %}Calendrier hôte{% endblock %}

{% block content %}
    <main class="mx-auto max-w-6xl px-6 py-10">
        <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <p class="text-sm font-semibold text-rose-500">Espace hôte</p>
                <h1 class="text-3xl font-bold text-neutral-900">
                    Calendrier — {{ property.title }}
                </h1>
                <p class="mt-2 text-neutral-500">
                    Consultez le calendrier de votre logement et bloquez des périodes d'indisponibilité.
                </p>
            </div>

            <a href="{{ path('app_host_property_index') }}"
               class="rounded-full border border-neutral-300 px-5 py-2 text-sm font-semibold hover:bg-neutral-100">
                Retour
            </a>
        </div>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 rounded-2xl px-5 py-3 text-sm font-medium
                    {{ label == 'success' ? 'bg-green-50 text-green-700' : 'bg-red-50 text-red-700' }}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        <section class="grid gap-8 lg:grid-cols-[1fr_360px]">
            <div class="rounded-3xl border border-neutral-200 bg-white p-6 shadow-sm">
                <div class="mb-6 flex items-center justify-between gap-4">
                    <a href="{{ path('app_host_property_calendar', {
                        id: property.id,
                        year: previousMonth|date('Y'),
                        month: previousMonth|date('m')
                    }) }}"
                       class="rounded-full border border-neutral-300 px-4 py-2 text-sm font-semibold hover:bg-neutral-100">
                        ← Mois précédent
                    </a>

                    <h2 class="text-xl font-bold text-neutral-900">
                        {{ currentMonth|date('m/Y') }}
                    </h2>

                    <a href="{{ path('app_host_property_calendar', {
                        id: property.id,
                        year: nextMonth|date('Y'),
                        month: nextMonth|date('m')
                    }) }}"
                       class="rounded-full border border-neutral-300 px-4 py-2 text-sm font-semibold hover:bg-neutral-100">
                        Mois suivant →
                    </a>
                </div>

                <div class="grid grid-cols-7 gap-2 text-center text-sm font-semibold text-neutral-500">
                    <div>Lun</div>
                    <div>Mar</div>
                    <div>Mer</div>
                    <div>Jeu</div>
                    <div>Ven</div>
                    <div>Sam</div>
                    <div>Dim</div>
                </div>

                <div class="mt-4 grid grid-cols-7 gap-3">
                    {% set firstWeekday = currentMonth|date('N') %}

                    {% if firstWeekday > 1 %}
                        {% for i in 1..(firstWeekday - 1) %}
                            <div class="min-h-32 rounded-2xl bg-neutral-50"></div>
                        {% endfor %}
                    {% endif %}

                    {% for day in calendarDays %}
                        <div class="min-h-32 rounded-2xl border p-3
                            {{ day.isAvailable ? 'border-neutral-200 bg-white' : 'border-rose-200 bg-rose-50' }}">

                            <div class="flex items-center justify-between">
                                <span class="font-bold text-neutral-900">
                                    {{ day.date|date('d') }}
                                </span>
                            </div>

                            {% if not day.isAvailable %}
                                <p class="mt-3 inline-block rounded-full bg-rose-100 px-2 py-1 text-xs font-semibold text-rose-700">
                                    Bloqué
                                </p>
                            {% else %}
                                <p class="mt-2 text-xs font-semibold text-green-600">
                                    Disponible
                                </p>

                                <div class="mt-2 space-y-1 text-xs text-neutral-600">
                                    <p class="rounded-lg bg-neutral-50 px-2 py-1">
                                        {% if day.availability and day.availability.priceOverride %}
                                            {{ day.availability.priceOverride }} €
                                        {% else %}
                                            {{ property.pricePerNight }} €
                                        {% endif %}
                                    </p>

                                    {% if day.availability and day.availability.minimumStay %}
                                        <p class="rounded-lg bg-neutral-50 px-2 py-1 leading-tight">
                                            Min. {{ day.availability.minimumStay }} nuit{{ day.availability.minimumStay > 1 ? 's' : '' }}
                                        </p>
                                    {% endif %}
                                </div>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            </div>

            <aside class="space-y-6">
                <section class="rounded-3xl border border-neutral-200 bg-white p-6 shadow-sm">
                    <h2 class="text-xl font-bold text-neutral-900">
                        Bloquer une période
                    </h2>

                    <p class="mt-2 text-sm text-neutral-500">
                        Les dates sélectionnées seront marquées comme indisponibles pour les voyageurs.
                    </p>

                    <form method="post" class="mt-6 space-y-4">
                        <div>
                            <label for="startDate" class="text-sm font-semibold text-neutral-700">
                                Date de début
                            </label>
                            <input type="date"
                                   id="startDate"
                                   name="startDate"
                                   required
                                   class="mt-2 w-full rounded-2xl border border-neutral-300 px-4 py-3 outline-none focus:border-neutral-900">
                        </div>

                        <div>
                            <label for="endDate" class="text-sm font-semibold text-neutral-700">
                                Date de fin
                            </label>
                            <input type="date"
                                   id="endDate"
                                   name="endDate"
                                   required
                                   class="mt-2 w-full rounded-2xl border border-neutral-300 px-4 py-3 outline-none focus:border-neutral-900">
                        </div>

                        <button type="submit"
                                class="w-full rounded-full bg-rose-500 px-5 py-3 font-bold text-white hover:bg-rose-600">
                            Bloquer la période
                        </button>
                    </form>
                </section>

                <section class="rounded-3xl border border-neutral-200 bg-white p-6 shadow-sm">
                    <h2 class="text-xl font-bold text-neutral-900">
                        Légende
                    </h2>

                    <div class="mt-4 space-y-3 text-sm text-neutral-700">
                        <div class="flex items-center gap-3">
                            <span class="h-4 w-4 rounded border border-neutral-300 bg-white"></span>
                            <span>Jour disponible</span>
                        </div>

                        <div class="flex items-center gap-3">
                            <span class="h-4 w-4 rounded border border-rose-300 bg-rose-100"></span>
                            <span>Jour bloqué par l'hôte</span>
                        </div>

                        <div class="flex items-center gap-3">
                            <span class="h-4 w-4 rounded bg-neutral-50"></span>
                            <span>Prix affiché : prix normal ou prix spécifique si configuré</span>
                        </div>
                    </div>
                </section>
            </aside>
        </section>
    </main>
{% endblock %}
