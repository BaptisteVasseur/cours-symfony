{% extends 'layout/user.html.twig' %}

{% block title %}Calendrier — {{ property.title }}{% endblock %}

{% block content %}
    <div class="max-w-5xl mx-auto px-4 py-10">
        <a href="{{ path('app_host_property_index') }}" class="text-sm text-gray-500 hover:text-gray-900 mb-4 inline-flex items-center gap-2">
            <i class="fa-solid fa-arrow-left"></i> Mes logements
        </a>

        <h1 class="text-2xl md:text-3xl font-bold text-gray-900 mb-1">{{ property.title }}</h1>
        <p class="text-gray-500 text-sm mb-6">{{ property.maxGuests }} voyageurs max · {{ property.pricePerNight }} {{ 'EUR' }} / nuit</p>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 px-4 py-3 rounded-lg text-sm font-medium {{ label == 'success' ? 'bg-emerald-50 text-emerald-800 border border-emerald-200' : 'bg-red-50 text-red-800 border border-red-200' }}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <div class="lg:col-span-2 bg-white border border-gray-200 rounded-2xl p-6 shadow-sm">
                <div class="flex items-center justify-between mb-6">
                    <a href="{{ path('app_host_calendar', { id: property.id, year: prev.format('Y'), month: prev.format('n') }) }}"
                       class="w-9 h-9 flex items-center justify-center rounded-full hover:bg-gray-100">
                        <i class="fa-solid fa-chevron-left"></i>
                    </a>
                    <h2 class="font-semibold text-gray-900 capitalize">{{ monthLabel }}</h2>
                    <a href="{{ path('app_host_calendar', { id: property.id, year: next.format('Y'), month: next.format('n') }) }}"
                       class="w-9 h-9 flex items-center justify-center rounded-full hover:bg-gray-100">
                        <i class="fa-solid fa-chevron-right"></i>
                    </a>
                </div>

                <div class="grid grid-cols-7 gap-1 text-center text-xs font-semibold text-gray-400 mb-2">
                    <div>Lun</div><div>Mar</div><div>Mer</div><div>Jeu</div><div>Ven</div><div>Sam</div><div>Dim</div>
                </div>

                <div class="grid grid-cols-7 gap-1">
                    {% for cell in cells %}
                        {% if cell is null %}
                            <div></div>
                        {% else %}
                            {% set style = {
                                'available': 'bg-white text-gray-800 border-gray-200',
                                'blocked':   'bg-red-50 text-red-700 border-red-200 line-through',
                                'imported':  'bg-amber-50 text-amber-700 border-amber-200 line-through',
                                'reserved':  'bg-gray-800 text-white border-gray-800',
                                'past':      'bg-gray-50 text-gray-300 border-gray-100'
                            } %}
                            <div class="aspect-square flex flex-col items-center justify-center rounded-lg border text-sm {{ style[cell.status] }}"
                                 title="{{ cell.date }} — {{ cell.status }}">
                                <span>{{ cell.day }}</span>
                            </div>
                        {% endif %}
                    {% endfor %}
                </div>

                <div class="flex flex-wrap gap-4 mt-6 text-xs text-gray-500">
                    <span class="inline-flex items-center gap-1"><span class="w-3 h-3 rounded bg-white border border-gray-300"></span> Disponible</span>
                    <span class="inline-flex items-center gap-1"><span class="w-3 h-3 rounded bg-red-100 border border-red-200"></span> Bloqué (manuel)</span>
                    <span class="inline-flex items-center gap-1"><span class="w-3 h-3 rounded bg-amber-100 border border-amber-200"></span> Importé (iCal)</span>
                    <span class="inline-flex items-center gap-1"><span class="w-3 h-3 rounded bg-gray-800"></span> Réservé</span>
                </div>
            </div>

            <div class="space-y-6">
                <div class="bg-white border border-gray-200 rounded-2xl p-6 shadow-sm">
                    <h3 class="font-semibold text-gray-900 mb-4 flex items-center gap-2">
                        <i class="fa-solid fa-lock text-red-500"></i> Bloquer une période
                    </h3>
                    <form method="post" action="{{ path('app_host_availability_block', { id: property.id }) }}" class="space-y-4">
                        <input type="hidden" name="_token" value="{{ csrf_token('block' ~ property.id) }}">
                        <div>
                            <label class="block text-xs font-semibold text-gray-600 mb-1">Du</label>
                            <input type="date" name="from" required class="w-full border border-gray-300 rounded-xl px-3 py-2 text-sm">
                        </div>
                        <div>
                            <label class="block text-xs font-semibold text-gray-600 mb-1">Au</label>
                            <input type="date" name="to" required class="w-full border border-gray-300 rounded-xl px-3 py-2 text-sm">
                        </div>
                        <button type="submit" class="w-full bg-brand hover:bg-brandHover text-white font-semibold text-sm py-2.5 rounded-xl transition">
                            Bloquer ces dates
                        </button>
                    </form>
                </div>

                <div class="bg-white border border-gray-200 rounded-2xl p-6 shadow-sm">
                    <h3 class="font-semibold text-gray-900 mb-4 flex items-center gap-2">
                        <i class="fa-solid fa-lock-open text-emerald-500"></i> Libérer une période
                    </h3>
                    <form method="post" action="{{ path('app_host_availability_unblock', { id: property.id }) }}" class="space-y-4">
                        <input type="hidden" name="_token" value="{{ csrf_token('unblock' ~ property.id) }}">
                        <div>
                            <label class="block text-xs font-semibold text-gray-600 mb-1">Du</label>
                            <input type="date" name="from" required class="w-full border border-gray-300 rounded-xl px-3 py-2 text-sm">
                        </div>
                        <div>
                            <label class="block text-xs font-semibold text-gray-600 mb-1">Au</label>
                            <input type="date" name="to" required class="w-full border border-gray-300 rounded-xl px-3 py-2 text-sm">
                        </div>
                        <button type="submit" class="w-full border border-gray-300 hover:bg-gray-50 text-gray-900 font-semibold text-sm py-2.5 rounded-xl transition">
                            Libérer ces dates
                        </button>
                    </form>
                    <p class="text-xs text-gray-400 mt-3">Seuls les blocages manuels sont libérés. Les dates importées via iCal restent gérées par la synchronisation.</p>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
