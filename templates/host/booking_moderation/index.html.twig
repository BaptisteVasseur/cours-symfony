{% extends 'layout/app.html.twig' %}

{% block title %}Demandes de réservation{% endblock %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-4xl mx-auto w-full">
        <h1 class="text-2xl font-semibold text-gray-900 mb-1">Demandes reçues</h1>
        <p class="text-gray-500 mb-6">Acceptez ou refusez les demandes en attente sur vos logements.</p>

        {% if reservations is empty %}
            <div class="border border-gray-200 rounded-2xl p-10 text-center text-gray-500">
                Aucune demande en attente pour le moment.
            </div>
        {% else %}
            <div class="space-y-4">
                {% for reservation in reservations %}
                    {% set guestProfile = reservation.guest ? reservation.guest.profile : null %}
                    <div class="border border-gray-200 rounded-2xl p-5">
                        <div class="flex flex-wrap items-start justify-between gap-4">
                            <div>
                                <h2 class="text-lg font-semibold">{{ reservation.property.title }}</h2>
                                <p class="text-sm text-gray-500 mt-1">
                                    {{ reservation.checkinDate|date('d/m/Y') }} → {{ reservation.checkoutDate|date('d/m/Y') }}
                                    · {{ reservation.guestsCount }} voyageur(s)
                                </p>
                                <p class="text-sm text-gray-500">
                                    Demandé par
                                    {{ guestProfile ? guestProfile.firstName ~ ' ' ~ guestProfile.lastName : reservation.guest.email }}
                                </p>
                                <p class="text-base font-semibold mt-2">{{ reservation.totalPrice|number_format(2, ',', ' ') }} {{ reservation.currency|default('EUR') }}</p>
                            </div>
                            <div class="flex flex-col gap-2 w-full sm:w-auto">
                                <form method="post" action="{{ path('app_host_moderation_accept', { id: reservation.id }) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('moderate_' ~ reservation.id) }}">
                                    <button type="submit" class="w-full bg-brand hover:bg-brandHover text-white text-sm font-semibold rounded-lg px-4 py-2.5">Accepter</button>
                                </form>
                                <form method="post" action="{{ path('app_host_moderation_reject', { id: reservation.id }) }}" class="space-y-2">
                                    <input type="hidden" name="_token" value="{{ csrf_token('moderate_' ~ reservation.id) }}">
                                    <textarea name="reason" rows="2" required maxlength="2000" placeholder="Motif du refus" class="w-full text-sm border border-gray-300 rounded-lg p-2"></textarea>
                                    <button type="submit" class="w-full border border-red-300 text-red-700 hover:bg-red-50 text-sm font-semibold rounded-lg px-4 py-2.5">Refuser</button>
                                </form>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </main>
{% endblock %}
