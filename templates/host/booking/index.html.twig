{% extends 'layout/app.html.twig' %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-5xl mx-auto w-full">
        <h1 class="text-2xl md:text-3xl font-semibold text-gray-900 mb-2">Demandes en attente</h1>
        <p class="text-gray-500 mb-8">Réservations à valider pour vos logements</p>

        {% if reservations|length > 0 %}
            <div class="space-y-4">
                {% for reservation in reservations %}
                    {% set property = reservation.property %}
                    <article class="border border-gray-200 rounded-xl p-6">
                        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
                            <div>
                                <h2 class="text-lg font-semibold">{{ property.title }}</h2>
                                <p class="text-sm text-gray-500 mt-1">
                                    {{ reservation.checkinDate|date('d/m/Y') }} → {{ reservation.checkoutDate|date('d/m/Y') }}
                                    · {{ reservation.guestsCount }} voyageur(s)
                                </p>
                                <p class="text-sm text-gray-500">
                                    Voyageur : {{ reservation.guest.email }}
                                </p>
                                <p class="text-sm font-semibold mt-2">
                                    {{ reservation.totalPrice|number_format(2, ',', ' ') }} {{ reservation.currency }}
                                </p>
                            </div>
                            <div class="flex flex-col gap-2 shrink-0">
                                <form method="post" action="{{ path('app_host_booking_accept', { id: reservation.id }) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('accept_reservation_' ~ reservation.id) }}">
                                    <button type="submit" class="w-full px-4 py-2 bg-green-600 text-white rounded-lg font-semibold hover:bg-green-700">
                                        Accepter
                                    </button>
                                </form>
                                <form method="post" action="{{ path('app_host_booking_refuse', { id: reservation.id }) }}" class="space-y-2">
                                    <textarea name="refusal[cancellationReason]" rows="2" placeholder="Motif du refus" required class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm"></textarea>
                                    <input type="hidden" name="refusal[_token]" value="{{ csrf_token('refuse_reservation') }}">
                                    <button type="submit" class="w-full px-4 py-2 bg-red-600 text-white rounded-lg font-semibold hover:bg-red-700">
                                        Refuser
                                    </button>
                                </form>
                            </div>
                        </div>
                    </article>
                {% endfor %}
            </div>
        {% else %}
            <div class="text-center py-16 border border-dashed border-gray-200 rounded-xl">
                <p class="text-gray-500">Aucune demande en attente.</p>
            </div>
        {% endif %}
    </main>
{% endblock %}
