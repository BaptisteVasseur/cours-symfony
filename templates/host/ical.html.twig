{% extends 'layouts/user.html.twig' %}

{% block title %}Synchronisation iCal - Tableau de bord hôte{% endblock %}

{% block content %}
<main class="mx-auto max-w-6xl px-6 py-10">
    <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
            <p class="text-sm font-semibold text-rose-500">Espace hôte</p>
            <h1 class="text-3xl font-bold text-neutral-900">Synchronisation iCal</h1>
            <p class="mt-2 text-neutral-500">
                Exportez les réservations confirmées vers votre agenda personnel (Google Calendar, Outlook, etc.).
            </p>
        </div>
        <a href="{{ path('app_host_dashboard') }}"
           class="rounded-full border border-neutral-300 px-5 py-2 text-sm font-semibold hover:bg-neutral-100">
            Retour au tableau de bord
        </a>
    </div>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="mb-4 rounded-2xl px-5 py-3 text-sm font-medium
                {{ label == 'success' ? 'bg-green-50 text-green-700' : 'bg-red-50 text-red-700' }}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    {% if properties is empty %}
        <div class="rounded-3xl border border-neutral-200 bg-neutral-50 p-8 text-center">
            <p class="text-neutral-600">Vous n'avez aucune propriété disponible.</p>
        </div>
    {% else %}
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {% for property in properties %}
                <div class="rounded-3xl border border-neutral-200 bg-white p-6 shadow-sm hover:shadow-md transition">
                    <div class="mb-4">
                        <h3 class="text-lg font-bold text-neutral-900">{{ property.title }}</h3>
                        <p class="mt-1 text-sm text-neutral-500">
                            {% if property.icalToken %}
                                Token généré ✓
                            {% else %}
                                Pas de token disponible
                            {% endif %}
                        </p>
                    </div>

                    {% if property.icalToken %}
                        <div class="mb-4 space-y-3">
                            <div>
                                <label class="text-sm font-semibold text-neutral-700">Lien d'accès sécurisé :</label>
                                <div class="mt-2 flex gap-2">
                                    <input type="text" 
                                           readonly
                                           value="{{ url('app_ical_export', {id: property.id, token: property.icalToken}) }}"
                                           id="link-{{ property.id }}"
                                           class="flex-1 rounded-lg border border-neutral-300 bg-neutral-50 px-3 py-2 text-xs text-neutral-700 font-mono"
                                    />
                                    <button type="button" 
                                            onclick="copyToClipboard('link-{{ property.id }}')"
                                            class="rounded-lg bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 text-sm font-semibold transition">
                                        Copier
                                    </button>
                                </div>
                            </div>

                            <div>
                                <a href="{{ url('app_ical_export', {id: property.id, token: property.icalToken}) }}"
                                   target="_blank"
                                   class="inline-block w-full rounded-lg bg-rose-500 hover:bg-rose-600 text-white text-center px-4 py-2 font-semibold transition">
                                    Télécharger le fichier .ics
                                </a>
                            </div>
                        </div>

                        <div class="rounded-lg bg-neutral-50 p-4 text-sm text-neutral-700 space-y-2">
                            <p class="font-semibold text-neutral-900">Comment synchroniser :</p>
                            <ul class="space-y-1 text-xs">
                                <li class="flex gap-2">
                                    <span class="font-semibold text-rose-500">•</span>
                                    <span><strong>Google Calendar :</strong> Paramètres → Ajouter d'autres agendas → Importer par URL</span>
                                </li>
                                <li class="flex gap-2">
                                    <span class="font-semibold text-rose-500">•</span>
                                    <span><strong>Outlook :</strong> Accueil → Ajouter un agenda → Importer depuis un fichier</span>
                                </li>
                                <li class="flex gap-2">
                                    <span class="font-semibold text-rose-500">•</span>
                                    <span><strong>Apple Calendar :</strong> Fichier → Importer → Sélectionner le fichier .ics</span>
                                </li>
                            </ul>
                        </div>

                        <div class="mt-4 text-xs text-neutral-500 border-t pt-4">
                            <p>
                                <strong>⚠️ Sécurité :</strong> Ce lien est personnalisé et contient un token unique. Ne le partagez pas publiquement. 
                                Seules les réservations confirmées sont exportées.
                            </p>
                        </div>
                    {% else %}
                        <div class="rounded-lg bg-amber-50 border border-amber-200 p-4 text-sm text-amber-700">
                            Impossible de générer le lien pour cette propriété. Contactez le support.
                        </div>
                    {% endif %}
                </div>
            {% endfor %}
        </div>
    {% endif %}
</main>

<script>
function copyToClipboard(elementId) {
    const element = document.getElementById(elementId);
    element.select();
    document.execCommand('copy');
    alert('Lien copié dans le presse-papiers !');
}
</script>
{% endblock %}
