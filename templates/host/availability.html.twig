{% extends 'layout/user.html.twig' %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-4xl mx-auto w-full">
        <a href="{{ path('app_host_dashboard') }}" class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-gray-900 mb-6">← Retour au tableau de bord</a>

        <h1 class="text-2xl md:text-3xl font-semibold text-gray-900 mb-2">Gestion des disponibilités</h1>
        <p class="text-gray-500 mb-8">{{ property.title }}</p>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 px-4 py-3 rounded-lg text-sm font-medium {{ label == 'success' ? 'bg-emerald-50 text-emerald-800 border border-emerald-200' : 'bg-red-50 text-red-800 border border-red-200' }}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        {# Google Calendar Sync #}
        {% set googleSync = property.googleCalendarSync %}
        <div class="border border-gray-200 rounded-xl p-6 mb-8">
            <h2 class="text-lg font-semibold text-gray-900 mb-4">Synchronisation Google Calendar</h2>
            {% if googleSync and googleSync.isConnected %}
                <div class="flex items-start gap-3 mb-4">
                    <div class="bg-emerald-50 border border-emerald-200 rounded-lg p-3 flex-grow">
                        <p class="text-sm font-semibold text-emerald-900">Calendrier connecté</p>
                        {% if googleSync.lastSyncAt %}
                            <p class="text-xs text-emerald-700 mt-1">Dernière synchronisation : {{ googleSync.lastSyncAt|date('d/m/Y à H:i') }}</p>
                        {% endif %}
                        {% if googleSync.lastError %}
                            <p class="text-xs text-red-600 mt-1">Erreur : {{ googleSync.lastError }}</p>
                        {% endif %}
                    </div>
                </div>
                <form method="post" action="{{ path('app_host_disconnect_google', { id: property.id }) }}" class="inline">
                    <input type="hidden" name="_token" value="{{ csrf_token('disconnect_google' ~ property.id) }}">
                    <button type="submit" class="text-sm border border-red-200 text-red-700 px-4 py-2 rounded-lg font-semibold hover:bg-red-50 transition"
                            onclick="return confirm('Déconnecter le calendrier Google ? Les événements importés resteront bloqués.')">
                        Déconnecter Google Calendar
                    </button>
                </form>
            {% else %}
                <p class="text-sm text-gray-600 mb-4">Connecte ton calendrier Google pour synchroniser automatiquement les réservations et bloquer les périodes occupées.</p>
                <a href="{{ path('app_host_connect_google', { id: property.id }) }}"
                   class="inline-block bg-gray-900 text-white font-semibold text-sm px-4 py-2.5 rounded-lg hover:bg-gray-700 transition">
                    Connecter Google Calendar
                </a>
            {% endif %}
        </div>

        {# Flux iCal #}
        <div class="border border-gray-200 rounded-xl p-6 mb-8">
            <h2 class="text-lg font-semibold text-gray-900 mb-4">Flux iCal</h2>
            <p class="text-sm text-gray-600 mb-4">
                Abonne-toi à ce flux dans ton calendrier (Google Calendar, Apple Calendar, Outlook) pour voir les réservations confirmées.
            </p>
            {% if property.icalToken %}
                {% set icalUrl = url('app_property_ical', { id: property.id, token: property.icalToken }) %}
                <div class="bg-gray-50 border border-gray-200 rounded-lg p-3 mb-4">
                    <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">URL du flux iCal</label>
                    <div class="flex gap-2">
                        <input type="text" value="{{ icalUrl }}" readonly
                               class="flex-grow text-xs font-mono bg-white border border-gray-200 rounded px-2 py-1.5 text-gray-700"
                               onclick="this.select()" id="ical-url">
                        <button onclick="navigator.clipboard.writeText('{{ icalUrl }}').then(() => { this.textContent = 'Copié !'; setTimeout(() => this.textContent = 'Copier', 2000); })"
                                class="text-xs border border-gray-200 px-3 py-1.5 rounded-lg font-semibold hover:bg-gray-50 shrink-0">
                            Copier
                        </button>
                    </div>
                </div>
                <div class="flex items-center gap-3">
                    <form method="post" action="{{ path('app_host_regenerate_ical_token', { id: property.id }) }}" class="inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('regenerate_ical_' ~ property.id) }}">
                        <button type="submit" class="text-sm border border-red-200 text-red-700 px-4 py-2 rounded-lg font-semibold hover:bg-red-50 transition"
                                onclick="return confirm('Régénérer le token ? L\'ancienne URL ne fonctionnera plus.')">
                            Régénérer le token
                        </button>
                    </form>
                    {% if property.icalTokenRegeneratedAt %}
                        <span class="text-xs text-gray-400">Regénéré le {{ property.icalTokenRegeneratedAt|date('d/m/Y à H:i') }}</span>
                    {% endif %}
                </div>
            {% else %}
                <form method="post" action="{{ path('app_host_regenerate_ical_token', { id: property.id }) }}" class="inline">
                    <input type="hidden" name="_token" value="{{ csrf_token('regenerate_ical_' ~ property.id) }}">
                    <button type="submit" class="inline-block bg-gray-900 text-white font-semibold text-sm px-4 py-2.5 rounded-lg hover:bg-gray-700 transition">
                        Activer le flux iCal
                    </button>
                </form>
            {% endif %}
        </div>

        <div class="border border-gray-200 rounded-xl p-6 mb-8">
            <h2 class="text-lg font-semibold text-gray-900 mb-4">Bloquer une période</h2>
            <form method="post" action="{{ path('app_host_availability', { id: property.id }) }}" class="grid grid-cols-1 sm:grid-cols-3 gap-4 items-end">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Date d'arrivée</label>
                    <input type="date" name="checkinDate" required class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Date de départ</label>
                    <input type="date" name="checkoutDate" required class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
                </div>
                <div>
                    <button type="submit" class="w-full bg-gray-900 text-white font-semibold text-sm px-4 py-2.5 rounded-lg hover:bg-gray-700 transition">Bloquer ces dates</button>
                </div>
                <input type="hidden" name="_token" value="{{ csrf_token('availability_' ~ property.id.toRfc4122()) }}">
            </form>
        </div>

        <div class="border border-gray-200 rounded-xl overflow-hidden">
            <div class="p-5 border-b border-gray-100">
                <h2 class="text-lg font-semibold text-gray-900">Périodes d'indisponibilité</h2>
            </div>
            {% if blockedDates|length > 0 %}
                <table class="w-full text-left text-sm">
                    <thead>
                        <tr class="text-xs uppercase text-gray-400 border-b border-gray-100">
                            <th class="py-3 px-5">Date</th>
                            <th class="py-3 px-5 text-right">Action</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        {% set currentPeriod = null %}
                        {% set periodStart = null %}
                        {% set periodId = null %}
                        {% for blocked in blockedDates %}
                            <tr>
                                <td class="py-3 px-5 text-gray-900">{{ blocked.availableDate|date('d/m/Y') }}</td>
                                <td class="py-3 px-5 text-right">
                                    <form method="post" action="{{ path('app_host_availability_delete', { id: blocked.id }) }}" onsubmit="return confirm('Supprimer cette indisponibilité ?')" class="inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_' ~ blocked.id.toRfc4122()) }}">
                                        <button type="submit" class="text-xs text-red-600 hover:text-red-800 font-semibold">Supprimer</button>
                                    </form>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            {% else %}
                <p class="text-sm text-gray-500 p-5">Aucune date bloquée pour ce logement.</p>
            {% endif %}
        </div>
    </main>
{% endblock %}
