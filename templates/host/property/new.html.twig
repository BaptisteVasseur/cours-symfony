{% extends 'layout/app.html.twig' %}

{% block title %}Nouvelle annonce{% endblock %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-3xl mx-auto w-full">
        <a href="{{ path('app_account_properties') }}" class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-gray-900 mb-6">
            <i class="fa-solid fa-arrow-left"></i> Retour à mes propriétés
        </a>
        <h1 class="text-2xl font-semibold text-gray-900 mb-1">Créer une annonce</h1>
        <p class="text-gray-500 mb-6">Votre annonce sera publiée après validation par un administrateur.</p>
        <div class="border border-gray-200 rounded-2xl p-6">
            {{ include('host/property/_form.html.twig', { button_label: 'Créer l\'annonce' }) }}
        </div>
    </main>
{% endblock %}
