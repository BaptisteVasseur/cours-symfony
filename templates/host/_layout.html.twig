{% extends 'layout/base.html.twig' %}

{% block body %}
<div class="flex min-h-screen bg-gray-50">
    {# Sidebar #}
    <aside class="w-64 bg-white border-r border-gray-200 flex-shrink-0 hidden lg:block">
        <div class="p-6">
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-4">Espace hôte</p>
            <nav class="space-y-1">
                {% set navItems = [
                    {route: 'host_dashboard', label: 'Tableau de bord', icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6'},
                ] %}
                {% for item in navItems %}
                    {% set isActive = app.request.attributes.get('_route') starts with item.route %}
                    <a href="{{ path(item.route) }}"
                       class="flex items-center gap-3 px-3 py-2 rounded-xl text-sm transition
                              {{ isActive ? 'bg-rose-50 text-rose-600 font-semibold' : 'text-gray-600 hover:bg-gray-50' }}">
                        <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="{{ item.icon }}"/>
                        </svg>
                        {{ item.label }}
                    </a>
                {% endfor %}
                <a href="{{ path('app_property_index') }}"
                   class="flex items-center gap-3 px-3 py-2 rounded-xl text-sm text-gray-600 hover:bg-gray-50 transition">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
                    </svg>
                    Mes logements
                </a>
            </nav>
        </div>
    </aside>

    {# Content #}
    <main class="flex-1 p-8 min-w-0">
        {% for type, messages in app.flashes %}
            {% for msg in messages %}
                <div class="mb-4 px-4 py-3 rounded-xl text-sm
                    {{ type == 'success' ? 'bg-green-50 text-green-700 border border-green-200'
                       : (type == 'error' ? 'bg-red-50 text-red-700 border border-red-200'
                       : 'bg-blue-50 text-blue-700 border border-blue-200') }}">
                    {{ msg }}
                </div>
            {% endfor %}
        {% endfor %}

        {% block host_content %}{% endblock %}
    </main>
</div>
{% endblock %}
