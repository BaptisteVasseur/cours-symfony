{% extends 'layout/user.html.twig' %}

{% block content %}
<main class="flex-grow px-6 md:px-12 py-8 max-w-5xl mx-auto w-full">

    <div class="flex items-center justify-between mb-8">
        <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">Mes propriétés</h1>
        <div class="flex items-center gap-3">
            {% if isHost %}
                <a href="{{ path('host_dashboard') }}"
                   class="inline-flex items-center gap-2 text-sm font-medium text-gray-600 border border-gray-200 hover:bg-gray-50 px-4 py-2.5 rounded-xl transition">
                    <i class="fa-solid fa-chart-line"></i>
                    Tableau de bord
                </a>
                <a href="{{ path('host_new_property') }}"
                   class="inline-flex items-center gap-2 bg-brand hover:bg-brandHover text-white font-semibold px-5 py-2.5 rounded-xl text-sm transition">
                    <i class="fa-solid fa-plus"></i>
                    Ajouter un logement
                </a>
            {% endif %}
        </div>
    </div>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="mb-6 px-4 py-3 rounded-lg text-sm
                {% if label == 'success' %}bg-green-50 text-green-700 border border-green-200
                {% else %}bg-red-50 text-red-700 border border-red-200{% endif %}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    {% if not isHost %}
        {# Not a host yet #}
        <div class="flex flex-col items-center justify-center py-20 text-center border-2 border-dashed border-gray-200 rounded-2xl">
            <div class="w-20 h-20 bg-brand/10 rounded-full flex items-center justify-center mb-6">
                <i class="fa-solid fa-house-chimney text-brand text-3xl"></i>
            </div>
            <h2 class="text-xl font-semibold text-gray-900 mb-2">Vous n'avez pas encore de logement</h2>
            <p class="text-gray-500 text-sm max-w-sm mb-8">
                Commencez à accueillir des voyageurs en proposant votre logement sur notre plateforme.
                C'est simple et rapide !
            </p>
            <a href="{{ path('become_host') }}"
               class="inline-flex items-center gap-2 bg-brand hover:bg-brandHover text-white font-semibold px-8 py-3 rounded-xl transition text-sm">
                <i class="fa-solid fa-bolt"></i>
                Devenir hôte et proposer un logement
            </a>
        </div>

    {% elseif propertiesByCountry is empty %}
        {# Host but no properties #}
        <div class="flex flex-col items-center justify-center py-20 text-center border-2 border-dashed border-gray-200 rounded-2xl">
            <div class="w-20 h-20 bg-gray-100 rounded-full flex items-center justify-center mb-6">
                <i class="fa-solid fa-house text-gray-400 text-3xl"></i>
            </div>
            <h2 class="text-xl font-semibold text-gray-900 mb-2">Aucun logement pour le moment</h2>
            <p class="text-gray-500 text-sm max-w-sm mb-8">
                Vous n'avez pas encore ajouté de logement. Créez votre première annonce !
            </p>
            <a href="{{ path('become_host') }}"
               class="inline-flex items-center gap-2 bg-brand hover:bg-brandHover text-white font-semibold px-8 py-3 rounded-xl transition text-sm">
                <i class="fa-solid fa-plus"></i>
                Créer mon premier logement
            </a>
        </div>

    {% else %}
        {% set statusColors = {
            'published': 'bg-green-100 text-green-700',
            'pending':   'bg-yellow-100 text-yellow-700',
            'rejected':  'bg-red-100 text-red-600',
        } %}
        {% set statusLabels = {
            'published': 'En ligne',
            'pending':   'En attente',
            'rejected':  'Refusée',
        } %}

        <div class="space-y-10">
            {% for country, properties in propertiesByCountry %}
                <div>
                    <div class="flex items-center gap-3 mb-5">
                        <span class="text-xs font-bold text-gray-400 uppercase tracking-widest">{{ country }}</span>
                        <div class="flex-1 h-px bg-gray-200"></div>
                        <span class="text-xs text-gray-400">{{ properties|length }} logement{{ properties|length > 1 ? 's' : '' }}</span>
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                        {% for property in properties %}
                            {% set cover = property.coverMedia %}
                            {% set placeholderImage = 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=800&q=80' %}

                            <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition">
                                <div class="relative aspect-video">
                                    <img
                                        src="{{ cover ? cover.fileUrl : placeholderImage }}"
                                        alt="{{ property.title }}"
                                        class="w-full h-full object-cover"
                                    >
                                    <span class="absolute top-3 left-3 text-xs font-semibold px-2.5 py-1 rounded-full {{ statusColors[property.status] ?? 'bg-gray-100 text-gray-600' }}">
                                        {{ statusLabels[property.status] ?? property.status }}
                                    </span>
                                </div>
                                <div class="p-4">
                                    <h3 class="font-semibold text-gray-900 text-sm line-clamp-1 mb-1">{{ property.title }}</h3>
                                    {% if property.address %}
                                        <p class="text-xs text-gray-500 mb-3">
                                            <i class="fa-solid fa-location-dot mr-1"></i>
                                            {{ property.address.city }}
                                        </p>
                                    {% endif %}
                                    <div class="flex items-center justify-between text-xs text-gray-500 mb-4">
                                        <span>{{ property.pricePerNight|number_format(0, ',', ' ') }} € / nuit</span>
                                        <span>Max {{ property.maxGuests }} pers.</span>
                                    </div>
                                    <div class="flex gap-2">
                                        <a href="{{ path('app_logement_detail', { id: property.id }) }}"
                                           class="flex-1 text-center text-xs font-semibold border border-gray-200 text-gray-700 hover:bg-gray-50 px-3 py-2 rounded-lg transition">
                                            Voir
                                        </a>
                                        <a href="{{ path('host_calendar_show', { id: property.id }) }}"
                                           class="flex-1 text-center text-xs font-semibold border border-gray-200 text-gray-700 hover:bg-gray-50 px-3 py-2 rounded-lg transition">
                                            Calendrier
                                        </a>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}

</main>
{% endblock %}
