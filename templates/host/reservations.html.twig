{% extends 'layout/user.html.twig' %}

{% block title %}Demandes & réservations{% endblock %}

{% set statusLabels = {
    'confirmed': 'Confirmée',
    'completed': 'Terminée',
    'pending': 'En attente',
    'cancelled': 'Annulée',
} %}
{% set statusColors = {
    'confirmed': 'bg-green-100 text-green-800',
    'completed': 'bg-blue-100 text-blue-800',
    'pending': 'bg-yellow-100 text-yellow-800',
    'cancelled': 'bg-red-100 text-red-800',
} %}

{% macro guestName(reservation) %}
    {%- set p = reservation.guest ? reservation.guest.profile : null -%}
    {{- p ? p.firstName ~ ' ' ~ p.lastName : (reservation.guest ? reservation.guest.email : 'Voyageur') -}}
{% endmacro %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-5xl mx-auto w-full">
        <div class="mb-8">
            <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">Demandes & réservations</h1>
            <p class="text-gray-500 mt-1">Modérez les demandes en attente et suivez vos réservations.</p>
        </div>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 px-4 py-3 rounded-lg text-sm font-medium {{ label == 'success' ? 'bg-emerald-50 text-emerald-800 border border-emerald-200' : 'bg-red-50 text-red-800 border border-red-200' }}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        <section class="mb-12">
            <h2 class="text-lg font-semibold text-gray-900 mb-4">Demandes en attente ({{ pending|length }})</h2>
            {% if pending is empty %}
                <div class="text-center py-10 border border-dashed border-gray-200 rounded-xl text-gray-500">
                    Aucune demande en attente.
                </div>
            {% else %}
                <div class="space-y-4">
                    {% for reservation in pending %}
                        <div class="border border-gray-200 rounded-xl p-5">
                            <div class="flex flex-wrap items-start justify-between gap-4">
                                <div>
                                    <p class="font-semibold text-gray-900">{{ reservation.property.title }}</p>
                                    <p class="text-sm text-gray-500 mt-1">
                                        {{ _self.guestName(reservation) }} · {{ reservation.guestsCount }} voyageur(s)
                                    </p>
                                    <p class="text-sm text-gray-500">
                                        Du {{ reservation.checkinDate|date('d/m/Y') }} au {{ reservation.checkoutDate|date('d/m/Y') }}
                                        · <span class="font-semibold text-gray-900">{{ reservation.totalPrice|number_format(2, ',', ' ') }} {{ reservation.currency }}</span>
                                    </p>
                                </div>
                                <div class="flex items-center gap-2">
                                    <form method="post" action="{{ path('app_host_reservation_accept', { id: reservation.id }) }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('accept' ~ reservation.id) }}">
                                        <button type="submit" class="bg-emerald-600 hover:bg-emerald-700 text-white font-semibold text-sm px-4 py-2 rounded-lg transition">
                                            Accepter
                                        </button>
                                    </form>
                                </div>
                            </div>
                            <form method="post" action="{{ path('app_host_reservation_reject', { id: reservation.id }) }}" class="mt-4 flex flex-col sm:flex-row gap-2">
                                <input type="hidden" name="_token" value="{{ csrf_token('reject' ~ reservation.id) }}">
                                <input type="text" name="reason" required placeholder="Motif du refus"
                                       class="flex-grow border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand/20">
                                <button type="submit" class="bg-red-50 hover:bg-red-100 text-red-700 font-semibold text-sm px-4 py-2 rounded-lg border border-red-200 transition">
                                    Refuser
                                </button>
                            </form>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </section>

        <section>
            <h2 class="text-lg font-semibold text-gray-900 mb-4">Toutes les réservations ({{ reservations|length }})</h2>
            {% if reservations is empty %}
                <div class="text-center py-10 border border-dashed border-gray-200 rounded-xl text-gray-500">
                    Aucune réservation.
                </div>
            {% else %}
                <div class="space-y-3">
                    {% for reservation in reservations %}
                        <div class="border border-gray-200 rounded-xl p-4 flex flex-wrap items-center justify-between gap-3">
                            <div>
                                <p class="font-semibold text-gray-900">{{ reservation.property.title }}</p>
                                <p class="text-sm text-gray-500">
                                    {{ _self.guestName(reservation) }} · {{ reservation.checkinDate|date('d/m/Y') }} → {{ reservation.checkoutDate|date('d/m/Y') }}
                                </p>
                            </div>
                            <div class="flex items-center gap-3">
                                <span class="text-xs font-semibold px-3 py-1 rounded-full {{ statusColors[reservation.status]|default('bg-gray-100 text-gray-800') }}">
                                    {{ statusLabels[reservation.status]|default(reservation.status) }}
                                </span>
                                {% if reservation.status in ['pending', 'confirmed'] %}
                                    <form method="post" action="{{ path('app_host_reservation_cancel', { id: reservation.id }) }}"
                                          onsubmit="return confirm('Annuler cette réservation ?');" class="flex items-center gap-2">
                                        <input type="hidden" name="_token" value="{{ csrf_token('hostcancel' ~ reservation.id) }}">
                                        <input type="text" name="reason" required placeholder="Motif"
                                               class="border border-gray-300 rounded-lg px-2 py-1.5 text-xs w-32 focus:outline-none">
                                        <button type="submit" class="text-xs text-red-700 font-semibold px-2.5 py-1.5 rounded-lg border border-red-200 hover:bg-red-50 transition">
                                            Annuler
                                        </button>
                                    </form>
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </section>
    </main>
{% endblock %}
