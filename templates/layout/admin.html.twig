<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Admin{% endblock %} — Airbnb</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'airbnb': '#FF385C',
                        'airbnb-dark': '#E31C5F',
                    }
                }
            }
        }
    </script>
    <style>
        * { box-sizing: border-box; }
        body { font-family: ui-sans-serif, system-ui, -apple-system, sans-serif; }
        .sidebar-link { transition: all 0.15s ease; }
        .sidebar-link:hover { background: rgba(255,255,255,0.08); }
        .sidebar-link.active { background: rgba(255,56,92,0.15); border-left: 3px solid #FF385C; }
        .sidebar-link.active svg { color: #FF385C; }
        .sidebar-link.active span { color: #fff; }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body class="bg-gray-50 min-h-screen">

<div class="flex min-h-screen">

    {# SIDEBAR #}
    <aside class="w-64 bg-[#1a1a2e] min-h-screen flex flex-col fixed top-0 left-0 z-40">

        <div class="px-6 py-5 border-b border-white/10 flex items-center gap-3">
            <svg class="w-7 h-7 flex-shrink-0" viewBox="0 0 32 32" fill="#FF385C">
                <path d="M16 1C10.925 1 5.989 3.672 3.335 7.991c-2.656 4.32-2.656 9.697 0 14.018C5.989 26.328 10.925 29 16 29c5.075 0 10.011-2.672 12.665-6.991 2.656-4.32 2.656-9.697 0-14.018C26.011 3.672 21.075 1 16 1zm0 25.333c-5.891 0-10.667-4.776-10.667-10.667S10.109 5 16 5s10.667 4.776 10.667 10.667S21.891 26.333 16 26.333z"/>
            </svg>
            <div>
                <p class="text-white font-bold text-sm leading-tight">airbnb</p>
                <p class="text-white/40 text-xs">Admin Panel</p>
            </div>
        </div>

        <nav class="flex-1 px-3 py-4 space-y-0.5 overflow-y-auto">

            <p class="px-3 pt-2 pb-1 text-white/30 text-xs font-semibold uppercase tracking-widest">Principal</p>

            <a href="#" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg">
                <svg class="w-5 h-5 text-white/50" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z"/>
                </svg>
                <span class="text-white/60 text-sm font-medium">Dashboard</span>
            </a>

            <a href="#" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg">
                <svg class="w-5 h-5 text-white/50" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/>
                </svg>
                <span class="text-white/60 text-sm font-medium">Utilisateurs</span>
            </a>

            <a href="#" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg">
                <svg class="w-5 h-5 text-white/50" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 21v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21m0 0h4.5V3.545M12.75 21h7.5V10.75M2.25 21h1.5m18 0h-18M2.25 9l4.5-1.636M18.75 3l-1.5.545m0 6.205l3 1m1.5.5l-1.5-.5M6.75 7.364V3h-3v18m3-13.636l10.5-3.819"/>
                </svg>
                <span class="text-white/60 text-sm font-medium">Logements</span>
            </a>

            <a href="#" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg">
                <svg class="w-5 h-5 text-white/50" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/>
                </svg>
                <span class="text-white/60 text-sm font-medium">Reservations</span>
            </a>

            <a href="#" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg">
                <svg class="w-5 h-5 text-white/50" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/>
                </svg>
                <span class="text-white/60 text-sm font-medium">Avis</span>
            </a>

            <p class="px-3 pt-4 pb-1 text-white/30 text-xs font-semibold uppercase tracking-widest">Finances</p>

            <a href="#" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg">
                <svg class="w-5 h-5 text-white/50" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z"/>
                </svg>
                <span class="text-white/60 text-sm font-medium">Paiements</span>
            </a>

            <p class="px-3 pt-4 pb-1 text-white/30 text-xs font-semibold uppercase tracking-widest">Systeme</p>

            <a href="#" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg">
                <svg class="w-5 h-5 text-white/50" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10.343 3.94c.09-.542.56-.94 1.11-.94h1.093c.55 0 1.02.398 1.11.94l.149.894c.07.424.384.764.78.93.398.164.855.142 1.205-.108l.737-.527a1.125 1.125 0 011.45.12l.773.774c.39.389.44 1.002.12 1.45l-.527.737c-.25.35-.272.806-.107 1.204.165.397.505.71.93.78l.893.15c.543.09.94.56.94 1.109v1.094c0 .55-.397 1.02-.94 1.11l-.893.149c-.425.07-.765.383-.93.78-.165.398-.143.854.107 1.204l.527.738c.32.447.269 1.06-.12 1.45l-.774.773a1.125 1.125 0 01-1.449.12l-.738-.527c-.35-.25-.806-.272-1.203-.107-.397.165-.71.505-.781.929l-.149.894c-.09.542-.56.94-1.11.94h-1.094c-.55 0-1.019-.398-1.11-.94l-.148-.894c-.071-.424-.384-.764-.781-.93-.398-.164-.854-.142-1.204.108l-.738.527c-.447.32-1.06.269-1.45-.12l-.773-.774a1.125 1.125 0 01-.12-1.45l.527-.737c.25-.35.273-.806.108-1.204-.165-.397-.505-.71-.93-.78l-.894-.15c-.542-.09-.94-.56-.94-1.109v-1.094c0-.55.398-1.02.94-1.11l.894-.149c.424-.07.765-.383.93-.78.165-.398.143-.854-.108-1.204l-.526-.738a1.125 1.125 0 01.12-1.45l.773-.773a1.125 1.125 0 011.45-.12l.737.527c.35.25.807.272 1.204.107.397-.165.71-.505.78-.929l.15-.894z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
                <span class="text-white/60 text-sm font-medium">Parametres</span>
            </a>

        </nav>

        {# User bas de sidebar #}
        <div class="px-4 py-4 border-t border-white/10">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-[#FF385C] flex items-center justify-center text-white text-xs font-bold flex-shrink-0">
                    {{ app.user ? app.user.email|first|upper : 'A' }}
                </div>
                <div class="flex-1 min-w-0">
                    <p class="text-white text-xs font-semibold truncate">
                        {{ app.user ? app.user.email : 'Admin' }}
                    </p>
                    <p class="text-white/40 text-xs">Administrateur</p>
                </div>
                <a href="#" class="text-white/30 hover:text-white/70 transition-colors" title="Deconnexion">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15M12 9l-3 3m0 0l3 3m-3-3h12.75"/>
                    </svg>
                </a>
            </div>
        </div>

    </aside>

    {# MAIN #}
    <div class="flex-1 flex flex-col ml-64">

        <header class="bg-white border-b border-gray-200 px-8 h-16 flex items-center justify-between sticky top-0 z-30">
            <nav class="flex items-center gap-2 text-sm">
                <span class="text-gray-400">Admin</span>
                {% block breadcrumb %}{% endblock %}
            </nav>
            <div class="flex items-center gap-3">
                <button class="relative p-2 rounded-lg hover:bg-gray-100 transition-colors">
                    <svg class="w-5 h-5 text-gray-500" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0"/>
                    </svg>
                    <span class="absolute top-1.5 right-1.5 w-2 h-2 bg-[#FF385C] rounded-full"></span>
                </button>
                <a href="{{ path('app_home') }}" target="_blank" class="flex items-center gap-2 text-sm text-gray-500 hover:text-gray-900 border border-gray-200 rounded-lg px-3 py-1.5 hover:border-gray-300 transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
                    </svg>
                    Voir le site
                </a>
            </div>
        </header>

        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="mx-8 mt-4 flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium
                    {% if type == 'success' %}bg-green-50 text-green-800 border border-green-200
                    {% elseif type == 'error' %}bg-red-50 text-red-800 border border-red-200
                    {% elseif type == 'warning' %}bg-yellow-50 text-yellow-800 border border-yellow-200
                    {% else %}bg-blue-50 text-blue-800 border border-blue-200{% endif %}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        <main class="flex-1 px-8 py-8">
            {% block body %}{% endblock %}
        </main>

    </div>
</div>

{% block javascripts %}{% endblock %}
</body>
</html>
