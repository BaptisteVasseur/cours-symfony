<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Airbnb Clone - Vacances & Hébergements</title>
        <script src="https://cdn.tailwindcss.com"></script>
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
        <script>
            tailwind.config = {
                theme: {
                    extend: {
                        colors: {
                            brand: '#FF385C',
                            brandHover: '#E61E4D'
                        }
                    }
                }
            }
        </script>
        {% block stylesheets %}{% endblock %}
        {% block javascripts %}
            {{ importmap('app') }}
        {% endblock %}
    </head>

    <body>
        {% block content %}
        <div class="min-h-screen bg-white">
            {% include 'layout/header.html.twig' %}

            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
                        <div class="px-4 py-3 rounded-lg shadow-md text-sm {{ label == 'success' ? 'bg-green-100 text-green-800' : (label == 'error' ? 'bg-red-100 text-red-800' : 'bg-yellow-100 text-yellow-800') }}">
                            {{ message }}
                        </div>
                    </div>
                {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}

            {% include 'layout/footer.html.twig' %}
        </div>
        {% endblock %}
    </body>
</html>
