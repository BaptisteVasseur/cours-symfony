<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Airbnb Clone - Vacances & Hébergements</title>
        <script src="https://cdn.tailwindcss.com"></script>
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
        <script>
            tailwind.config = {
                theme: {
                    extend: {
                        colors: {
                            brand: '#FF385C',
                            brandHover: '#E61E4D'
                        }
                    }
                }
            }
        </script>
        {% block javascripts %}
            {{ importmap('app') }}
        {% endblock %}
    </head>

    <body class="bg-gray-50">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="fixed top-24 left-1/2 -translate-x-1/2 z-[100] min-w-[300px]">
                    <div class="{% if label == 'success' %}bg-green-600{% else %}bg-red-600{% endif %} text-white px-6 py-3 rounded-2xl shadow-2xl flex items-center gap-3 animate-bounce">
                        <i class="fa-solid {% if label == 'success' %}fa-circle-check{% else %}fa-circle-exclamation{% endif %}"></i>
                        <span class="font-bold">{{ message }}</span>
                    </div>
                </div>
            {% endfor %}
        {% endfor %}

        {% block body %}{% endblock %}
    </body>


</html>
