<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Airbnb Clone - Vacances & Hébergements</title>
        <script src="https://cdn.tailwindcss.com"></script>
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
        <script>
            tailwind.config = {
                theme: {
                    extend: {
                        colors: {
                            brand: '#FF385C',
                            brandHover: '#E61E4D'
                        }
                    }
                }
            }
        </script>
        {% block javascripts %}
            {{ importmap('app') }}
        {% endblock %}
        <script>
            function toggleFavorite(button) {
                const propertyId = button.getAttribute('data-property-id');
                
                fetch(`/logement/${propertyId}/favori`, {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                })
                .then(response => {
                    if (response.status === 401) {
                        window.location.href = '/login';
                        return;
                    }
                    if (!response.ok) {
                        throw new Error('Une erreur est survenue.');
                    }
                    return response.json();
                })
                .then(data => {
                    if (data && typeof data.favorited !== 'undefined') {
                        button.setAttribute('data-favorited', data.favorited ? 'true' : 'false');
                        button.setAttribute('aria-label', data.favorited ? 'Retirer des favoris' : 'Ajouter aux favoris');
                        const icon = button.querySelector('i');
                        if (data.favorited) {
                            icon.className = 'fa-solid fa-heart text-rose-500';
                        } else {
                            icon.className = 'fa-regular fa-heart text-white';
                        }
                    }
                })
                .catch(error => console.error(error));
            }
        </script>
    </head>

    {% block body %}{% endblock %}

</html>
