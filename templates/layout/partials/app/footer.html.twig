<footer class="bg-gray-950 text-gray-400 mt-auto">
    <div class="max-w-screen-xl mx-auto px-6 md:px-8 py-12 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-8">
        <div class="col-span-2 sm:col-span-3 lg:col-span-1 mb-2">
            <a href="{{ path('app_home') }}" class="inline-flex items-center gap-2 text-white font-extrabold text-lg mb-3">
                <svg width="22" height="22" viewBox="0 0 32 32" fill="currentColor" class="text-brand">
                    <path d="M16 1C10.2 1 5.5 6 5.5 12.2c0 7.8 10.5 18.8 10.5 18.8s10.5-11 10.5-18.8C26.5 6 21.8 1 16 1zm0 15a4.5 4.5 0 1 1 0-9 4.5 4.5 0 0 1 0 9z"/>
                </svg>
                StayNest
            </a>
            <p class="text-sm leading-relaxed">Des logements uniques pour des séjours inoubliables.</p>
        </div>

        <div>
            <p class="text-white font-semibold text-sm mb-4">Voyager</p>
            <ul class="space-y-3 text-sm">
                <li><a href="{{ path('app_search') }}" class="hover:text-white transition">Rechercher</a></li>
                <li><a href="{{ path('app_home') }}" class="hover:text-white transition">Logements</a></li>
                <li><a href="{{ path('app_help') }}" class="hover:text-white transition">Centre d'aide</a></li>
            </ul>
        </div>

        <div>
            <p class="text-white font-semibold text-sm mb-4">Héberger</p>
            <ul class="space-y-3 text-sm">
                {% if app.user %}
                <li><a href="{{ path('app_host_reservation_index') }}" class="hover:text-white transition">Dashboard hôte</a></li>
                <li><a href="{{ path('app_account_properties') }}" class="hover:text-white transition">Mes annonces</a></li>
                {% else %}
                <li><a href="{{ path('app_register') }}" class="hover:text-white transition">Proposer un logement</a></li>
                {% endif %}
            </ul>
        </div>

        <div>
            <p class="text-white font-semibold text-sm mb-4">StayNest</p>
            <ul class="space-y-3 text-sm">
                <li><a href="#" class="hover:text-white transition">À propos</a></li>
                <li><a href="#" class="hover:text-white transition">Confidentialité</a></li>
                <li><a href="#" class="hover:text-white transition">Conditions</a></li>
            </ul>
        </div>
    </div>

    <div class="border-t border-gray-800">
        <div class="max-w-screen-xl mx-auto px-6 md:px-8 py-5 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs">
            <p>© 2026 StayNest, Inc. · Tous droits réservés.</p>
            <div class="flex items-center gap-4">
                <span class="flex items-center gap-1 cursor-pointer hover:text-white transition"><i class="fa-solid fa-globe"></i> Français</span>
                <span class="flex items-center gap-1 cursor-pointer hover:text-white transition"><i class="fa-solid fa-euro-sign"></i> EUR</span>
            </div>
        </div>
    </div>
</footer>
