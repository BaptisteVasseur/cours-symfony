<header class="sticky top-0 z-50 bg-navy/90 backdrop-blur-md border-b border-white/[0.06]" style="box-shadow: 0 1px 0 rgba(230,57,70,0.18);">
    <div class="max-w-screen-xl mx-auto px-4 md:px-8 h-16 flex items-center gap-4">

        {# Logo #}
        <a href="{{ path('app_home') }}" class="logo-link flex items-center gap-2 shrink-0 select-none">
            <svg width="26" height="26" viewBox="0 0 32 32" fill="none" class="shrink-0">
                <path d="M16 1C10.2 1 5.5 6 5.5 12.2c0 7.8 10.5 18.8 10.5 18.8s10.5-11 10.5-18.8C26.5 6 21.8 1 16 1zm0 15a4.5 4.5 0 1 1 0-9 4.5 4.5 0 0 1 0 9z" fill="url(#logoGrad)"/>
                <defs>
                    <linearGradient id="logoGrad" x1="5.5" y1="1" x2="26.5" y2="31" gradientUnits="userSpaceOnUse">
                        <stop stop-color="#FCA5A5"/>
                        <stop offset="1" stop-color="#E63946"/>
                    </linearGradient>
                </defs>
            </svg>
            <span class="logo-text hidden sm:inline font-display font-600 text-lg tracking-wide text-white">Airbnb</span>
        </a>

        {# Search bar (desktop) #}
        {% include 'components/search_bar.html.twig' with { variant: 'header' } %}

        {# Right actions #}
        <div class="flex items-center gap-2 shrink-0 ml-auto">
            <a href="{{ path('app_search') }}" class="sm:hidden w-9 h-9 flex items-center justify-center text-white/60 hover:text-gold rounded-full hover:bg-white/10 transition" aria-label="Rechercher">
                <i class="fa-solid fa-magnifying-glass text-sm"></i>
            </a>

            {% if app.user %}
                {% include 'layout/partials/app/header_profile_menu.html.twig' %}
            {% else %}
                <a href="{{ path('app_register') }}" class="hidden sm:inline-flex text-sm font-medium text-white/70 hover:text-white py-2 px-4 hover:bg-white/10 rounded-full transition">
                    S'inscrire
                </a>
                <a href="{{ path('app_login') }}" class="text-sm font-semibold py-2 px-5 rounded-full transition"
                   style="background: linear-gradient(135deg, #E63946, #FCA5A5); color: #FFFFFF;">
                    Se connecter
                </a>
            {% endif %}
        </div>

    </div>
</header>
