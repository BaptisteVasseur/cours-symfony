<header class="sticky top-0 z-50 bg-white border-b border-gray-200 px-4 md:px-8 py-3 flex items-center gap-3 md:gap-6">
    <a href="{{ path('app_home') }}" class="flex items-center text-brand text-xl font-bold tracking-tight shrink-0">
        <i class="fa-brands fa-airbnb mr-1.5 text-2xl"></i>
        <span class="hidden sm:inline">airbnb</span>
    </a>

    <a href="{{ path('app_search') }}" class="flex-1 max-w-sm mx-auto hidden sm:flex items-center gap-2 border border-gray-200 rounded-full px-4 py-2 text-sm text-gray-500 hover:shadow-sm transition min-w-0">
        <i class="fa-solid fa-magnifying-glass text-brand shrink-0"></i>
        <span class="truncate">Rechercher un logement</span>
    </a>

    <div class="flex items-center gap-2 shrink-0 ml-auto">
        <a href="{{ path('app_search') }}" class="sm:hidden p-2 text-gray-600 hover:bg-gray-50 rounded-full" aria-label="Rechercher">
            <i class="fa-solid fa-magnifying-glass"></i>
        </a>

        {% if app.user %}
            <a href="{{ path('app_notifications_index') }}" class="relative p-2 text-gray-600 hover:bg-gray-50 rounded-full transition" aria-label="Notifications">
                <i class="fa-regular fa-bell text-xl"></i>
                <span id="notification-badge" 
                      class="hidden absolute top-1 right-1 bg-red-500 text-white text-xs font-bold rounded-full min-w-[18px] h-[18px] flex items-center justify-center px-1">
                    0
                </span>
            </a>
            
            {% include 'layout/partials/app/header_profile_menu.html.twig' %}
        {% else %}
            <a href="{{ path('app_login') }}" class="text-sm font-semibold py-2 px-4 border border-gray-200 rounded-full hover:shadow-md transition whitespace-nowrap">
                Se connecter
            </a>
        {% endif %}
    </div>
</header>

{% if app.user %}
<script>
    let lastBadgeCount = 0;
    let badgeUpdatePromise = null;
    
    function updateNotificationBadge(force = false) {
        // Ne pas faire plusieurs requêtes en même temps
        if (badgeUpdatePromise) {
            return badgeUpdatePromise;
        }
        
        badgeUpdatePromise = fetch('{{ path('app_notifications_unread_count') }}', {
            cache: 'no-store',
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
        .then(response => response.json())
        .then(data => {
            const badge = document.getElementById('notification-badge');
            if (data.count > 0) {
                badge.classList.remove('hidden');
                badge.textContent = data.count > 99 ? '99+' : data.count;
            } else {
                badge.classList.add('hidden');
            }
            lastBadgeCount = data.count;
            badgeUpdatePromise = null;
        })
        .catch(error => {
            console.error('Erreur:', error);
            badgeUpdatePromise = null;
        });
        
        return badgeUpdatePromise;
    }
    
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function() {
            updateNotificationBadge();
        });
    } else {
        updateNotificationBadge();
    }
    
    setInterval(updateNotificationBadge, 15000);
    
    document.addEventListener('visibilitychange', function() {
        if (!document.hidden) {
            updateNotificationBadge();
        }
    });
    
    document.addEventListener('turbo:load', function() {
        updateNotificationBadge();
    });
    
    document.addEventListener('pjax:success', function() {
        updateNotificationBadge();
    });
</script>
{% endif %}