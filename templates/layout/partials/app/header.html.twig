<header class="sticky top-0 z-50 bg-white border-b border-gray-100 shadow-sm">
    <div class="max-w-screen-xl mx-auto px-4 md:px-8 h-16 flex items-center gap-4">

        {# Logo   #}
        <a href="{{ path('app_home') }}" class="flex items-center gap-1.5 text-brand font-extrabold text-xl tracking-tight shrink-0 select-none">
            <svg width="28" height="28" viewBox="0 0 32 32" fill="currentColor" class="shrink-0">
                <path d="M16 1C10.2 1 5.5 6 5.5 12.2c0 7.8 10.5 18.8 10.5 18.8s10.5-11 10.5-18.8C26.5 6 21.8 1 16 1zm0 15a4.5 4.5 0 1 1 0-9 4.5 4.5 0 0 1 0 9z"/>
            </svg>
            <span class="hidden sm:inline">StayNest</span>
        </a>

        {# Search bar (desktop)   #}
        {% include 'components/search_bar.html.twig' with { variant: 'header' } %}

        {# Right actions   #}
        <div class="flex items-center gap-2 shrink-0 ml-auto">
            {# Mobile search icon   #}
            <a href="{{ path('app_search') }}" class="sm:hidden w-10 h-10 flex items-center justify-center text-gray-600 hover:bg-gray-100 rounded-full transition" aria-label="Rechercher">
                <i class="fa-solid fa-magnifying-glass"></i>
            </a>

            {% if app.user %}
                {% include 'layout/partials/app/header_profile_menu.html.twig' %}
            {% else %}
                <a href="{{ path('app_register') }}" class="hidden sm:inline-flex text-sm font-semibold text-gray-700 hover:text-gray-900 py-2 px-4 hover:bg-gray-100 rounded-full transition">
                    S'inscrire
                </a>
                <a href="{{ path('app_login') }}" class="text-sm font-semibold py-2.5 px-5 bg-brand hover:bg-brandHover text-white rounded-full transition shadow-sm">
                    Se connecter
                </a>
            {% endif %}
        </div>

    </div>
</header>
