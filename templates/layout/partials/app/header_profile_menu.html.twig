{% set profile = app.user.profile %}
{% set displayName = profile and (profile.firstName or profile.lastName) ? (profile.firstName ~ ' ' ~ profile.lastName)|trim : app.user.email %}
{% set initials = profile and profile.firstName ? profile.firstName|first|upper ~ (profile.lastName ? profile.lastName|first|upper : '') : app.user.email|first|upper %}
{% set avatar = profile and profile.avatarUrl ? profile.avatarUrl : null %}

<div class="relative" data-profile-menu>
    <button type="button" data-profile-menu-toggle
        class="flex items-center gap-2.5 border border-gray-200 rounded-full pl-4 pr-1.5 py-1.5 hover:shadow-md transition bg-white"
        aria-expanded="false" aria-haspopup="true">
        <i class="fa-solid fa-bars text-gray-500 text-sm"></i>
        <div class="w-8 h-8 rounded-full overflow-hidden shrink-0 bg-brand text-white flex items-center justify-center font-bold text-xs">
            {% if avatar %}
                <img src="{{ avatar }}" alt="{{ displayName }}" class="w-full h-full object-cover">
            {% else %}
                {{ initials }}
            {% endif %}
        </div>
    </button>

    <div data-profile-menu-dropdown class="hidden absolute right-0 top-full mt-2 w-64 bg-white rounded-2xl shadow-popup border border-gray-100 py-1.5 z-50 overflow-hidden">

        <div class="px-4 py-3 border-b border-gray-100">
            <p class="font-semibold text-gray-900 text-sm truncate">{{ displayName }}</p>
            <p class="text-xs text-gray-400 truncate mt-0.5">{{ app.user.email }}</p>
        </div>

        <div class="py-1">
            <a href="{{ path('app_reservation_index') }}" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 hover:bg-surface transition">
                <i class="fa-solid fa-suitcase-rolling w-4 text-center text-brand"></i>
                Mes réservations
            </a>
            {% if is_granted('ROLE_HOST') %}
            <a href="{{ path('app_host_reservation_index') }}" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 hover:bg-surface transition">
                <i class="fa-solid fa-house-chimney-user w-4 text-center text-brand"></i>
                Tableau de bord hôte
            </a>
            {% endif %}
            <a href="{{ path('app_account_properties') }}" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 hover:bg-surface transition">
                <i class="fa-solid fa-house w-4 text-center text-gray-400"></i>
                Mes propriétés
            </a>
            <a href="{{ path('app_messages_index') }}" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 hover:bg-surface transition">
                <i class="fa-solid fa-envelope w-4 text-center text-gray-400"></i>
                Messages
            </a>
        </div>

        <div class="border-t border-gray-100 py-1">
            <a href="{{ path('app_account_profile') }}" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 hover:bg-surface transition">
                <i class="fa-solid fa-user w-4 text-center text-gray-400"></i>
                Mon profil
            </a>
            <a href="{{ path('app_account_settings') }}" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 hover:bg-surface transition">
                <i class="fa-solid fa-gear w-4 text-center text-gray-400"></i>
                Paramètres
            </a>
            <a href="{{ path('app_help') }}" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 hover:bg-surface transition">
                <i class="fa-solid fa-circle-question w-4 text-center text-gray-400"></i>
                Aide
            </a>
        </div>

        {% if is_granted('ROLE_ADMIN') %}
        <div class="border-t border-gray-100 py-1">
            <a href="{{ path('app_admin_home') }}" class="flex items-center gap-3 px-4 py-2.5 text-sm font-medium text-brand hover:bg-brandLight transition">
                <i class="fa-solid fa-shield-halved w-4 text-center"></i>
                Administration
            </a>
        </div>
        {% endif %}

        <div class="border-t border-gray-100 py-1">
            <a href="{{ path('app_logout') }}" class="flex items-center gap-3 px-4 py-2.5 text-sm font-semibold text-red-600 hover:bg-red-50 transition">
                <i class="fa-solid fa-right-from-bracket w-4 text-center"></i>
                Se déconnecter
            </a>
        </div>
    </div>
</div>

<script>
document.querySelectorAll('[data-profile-menu]').forEach((menu) => {
    const toggle = menu.querySelector('[data-profile-menu-toggle]');
    const dropdown = menu.querySelector('[data-profile-menu-dropdown]');
    toggle?.addEventListener('click', (e) => {
        e.stopPropagation();
        const isOpen = !dropdown.classList.contains('hidden');
        dropdown.classList.toggle('hidden', isOpen);
        toggle.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
    });
    document.addEventListener('click', (e) => {
        if (!menu.contains(e.target)) {
            dropdown.classList.add('hidden');
            toggle?.setAttribute('aria-expanded', 'false');
        }
    });
});
</script>
