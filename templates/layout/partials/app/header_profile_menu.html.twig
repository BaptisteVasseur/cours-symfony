{% set profile = app.user.profile %}
{% set displayName = profile and (profile.firstName or profile.lastName) ? (profile.firstName ~ ' ' ~ profile.lastName)|trim : app.user.email %}
{% set initials = profile and profile.firstName ? profile.firstName|first|upper ~ (profile.lastName ? profile.lastName|first|upper : '') : app.user.email|first|upper %}
{% set avatar = profile and profile.avatarUrl ? profile.avatarUrl : null %}

<div class="relative" data-profile-menu>
    <button type="button" data-profile-menu-toggle
        class="flex items-center gap-2 border border-white/15 rounded-full pl-3.5 pr-1 py-1 hover:border-gold/40 transition bg-white/[0.06] backdrop-blur-sm"
        aria-expanded="false" aria-haspopup="true">
        <i class="fa-solid fa-bars text-white/50 text-xs"></i>
        <div class="w-7 h-7 rounded-full overflow-hidden shrink-0 flex items-center justify-center font-bold text-xs text-white" style="background: linear-gradient(135deg, #E63946, #FCA5A5);">
            {% if avatar %}
                <img src="{{ avatar }}" alt="{{ displayName }}" class="w-full h-full object-cover">
            {% else %}
                {{ initials }}
            {% endif %}
        </div>
    </button>

    <div data-profile-menu-dropdown class="hidden absolute right-0 top-full mt-2 w-64 bg-navy border border-white/10 rounded-2xl shadow-popup py-1.5 z-50 overflow-hidden" style="box-shadow: 0 20px 60px rgba(0,0,0,0.5);">

        <div class="px-4 py-3 border-b border-white/[0.07]">
            <p class="font-semibold text-white text-sm truncate">{{ displayName }}</p>
            <p class="text-xs text-white/30 truncate mt-0.5">{{ app.user.email }}</p>
        </div>

        {% if is_granted('ROLE_HOST') %}
        <div class="py-1 border-b border-white/[0.07]">
            <p class="px-4 pt-2 pb-1 text-[9px] font-bold uppercase tracking-widest text-gold/50">Espace hôte</p>
            <a href="{{ path('app_host_reservation_index') }}" class="flex items-center gap-3 px-4 py-2.5 text-sm font-medium text-gold hover:bg-white/[0.05] transition">
                <i class="fa-solid fa-table-list w-4 text-center"></i>
                Demandes de réservation
            </a>
            <a href="{{ path('app_account_properties') }}" class="flex items-center gap-3 px-4 py-2.5 text-sm text-white/70 hover:bg-white/[0.05] hover:text-white transition">
                <i class="fa-solid fa-house w-4 text-center text-white/30"></i>
                Mes logements
            </a>
        </div>
        {% endif %}

        <div class="py-1">
            <a href="{{ path('app_reservation_index') }}" class="flex items-center gap-3 px-4 py-2.5 text-sm text-white/70 hover:bg-white/[0.05] hover:text-white transition">
                <i class="fa-solid fa-suitcase-rolling w-4 text-center text-gold/60"></i>
                Mes réservations
            </a>
            <a href="{{ path('app_messages_index') }}" class="flex items-center gap-3 px-4 py-2.5 text-sm text-white/70 hover:bg-white/[0.05] hover:text-white transition">
                <i class="fa-solid fa-envelope w-4 text-center text-white/30"></i>
                Messages
            </a>
        </div>

        <div class="border-t border-white/[0.07] py-1">
            <a href="{{ path('app_account_profile') }}" class="flex items-center gap-3 px-4 py-2.5 text-sm text-white/70 hover:bg-white/[0.05] hover:text-white transition">
                <i class="fa-solid fa-user w-4 text-center text-white/30"></i>
                Mon profil
            </a>
            <a href="{{ path('app_account_settings') }}" class="flex items-center gap-3 px-4 py-2.5 text-sm text-white/70 hover:bg-white/[0.05] hover:text-white transition">
                <i class="fa-solid fa-gear w-4 text-center text-white/30"></i>
                Paramètres
            </a>
            <a href="{{ path('app_help') }}" class="flex items-center gap-3 px-4 py-2.5 text-sm text-white/70 hover:bg-white/[0.05] hover:text-white transition">
                <i class="fa-solid fa-circle-question w-4 text-center text-white/30"></i>
                Aide
            </a>
        </div>

        {% if is_granted('ROLE_ADMIN') %}
        <div class="border-t border-white/[0.07] py-1">
            <a href="{{ path('app_admin_home') }}" class="flex items-center gap-3 px-4 py-2.5 text-sm font-medium text-gold hover:bg-white/[0.05] transition">
                <i class="fa-solid fa-shield-halved w-4 text-center"></i>
                Administration
            </a>
        </div>
        {% endif %}

        <div class="border-t border-white/[0.07] py-1">
            <a href="{{ path('app_logout') }}" class="flex items-center gap-3 px-4 py-2.5 text-sm font-semibold text-red-400 hover:bg-red-500/10 transition">
                <i class="fa-solid fa-right-from-bracket w-4 text-center"></i>
                Se déconnecter
            </a>
        </div>
    </div>
</div>

<script>
document.querySelectorAll('[data-profile-menu]').forEach((menu) => {
    const toggle = menu.querySelector('[data-profile-menu-toggle]');
    const dropdown = menu.querySelector('[data-profile-menu-dropdown]');
    toggle?.addEventListener('click', (e) => {
        e.stopPropagation();
        const isOpen = !dropdown.classList.contains('hidden');
        dropdown.classList.toggle('hidden', isOpen);
        toggle.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
    });
    document.addEventListener('click', (e) => {
        if (!menu.contains(e.target)) {
            dropdown.classList.add('hidden');
            toggle?.setAttribute('aria-expanded', 'false');
        }
    });
});
</script>
