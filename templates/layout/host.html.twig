{% extends 'layout/base.html.twig' %}

{% block body %}
    <body class="bg-slate-50 font-sans antialiased text-gray-800 flex h-screen overflow-hidden">

    {% include 'layout/parts/host_sidebar.html.twig' %}

    <div class="flex-grow flex flex-col overflow-hidden">
        <header class="bg-white border-b border-gray-200 px-6 py-4 flex items-center justify-between shrink-0">
            <h1 class="text-lg font-bold text-gray-900">
                {% block page_title %}Espace Hôte{% endblock %}
            </h1>
            <div class="flex items-center gap-4">
                <a href="{{ path('app_home') }}" class="text-sm font-medium text-slate-600 hover:text-slate-900 flex items-center gap-1">
                    <i class="fa-solid fa-arrow-left"></i> Retour au site
                </a>
            </div>
        </header>

        <main class="flex-grow p-6 overflow-y-auto">
            {% block content %}{% endblock %}
        </main>
    </div>

    </body>
{% endblock %}
