<header class="sticky top-0 z-50 bg-white border-b border-gray-200 px-6 md:px-12 py-4 flex items-center justify-between">
    <a href="{{ path('app_home') }}" class="flex items-center text-brand text-2xl font-bold tracking-tight">
        <i class="fa-brands fa-airbnb mr-2 text-3xl"></i>
        <span>airbnb</span>
    </a>

    {% include 'parts/search_bar.html.twig' with { variant: 'compact' } %}

    <div class="flex items-center space-x-4">
        <a href="{{ path('app_reservation_index') }}" class="text-sm font-semibold py-2 px-4 hover:bg-gray-50 rounded-full hidden lg:inline-block">
            Mes réservations
        </a>
        <span class="text-sm font-semibold py-2 px-4 hover:bg-gray-50 rounded-full cursor-pointer hidden lg:inline-block">Mettre mon logement sur Airbnb</span>
        <button class="text-gray-600 hover:bg-gray-50 p-2 rounded-full hidden sm:block">
            <i class="fa-solid fa-globe"></i>
        </button>

        {% if app.user %}
            <div class="flex items-center space-x-3 border border-gray-200 rounded-full p-2 pl-3 hover:shadow-md transition cursor-pointer">
                <i class="fa-solid fa-bars text-gray-600"></i>
                <div class="w-8 h-8 bg-gray-500 text-white rounded-full flex items-center justify-center font-bold text-sm overflow-hidden">
                    <img src="https://images.unsplash.com/photo-1534528741775-53994a69daeb?auto=format&fit=crop&w=100&q=80" alt="Avatar">
                </div>
            </div>
        {% else %}
            <a href="/login">Se connecter</a>
        {% endif %}


    </div>
</header>
