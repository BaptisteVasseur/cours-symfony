<header class="sticky top-0 z-50 bg-white border-b border-gray-200 px-6 md:px-12 py-4 flex items-center justify-between">
    <a href="{{ path('app_home') }}" class="flex items-center text-brand text-2xl font-bold tracking-tight">
        <i class="fa-solid fa-house-chimney mr-2 text-3xl"></i>
        <span>Airbnb</span>
    </a>

    {% include 'parts/search_bar.html.twig' with { variant: 'compact' } %}

    <div class="flex items-center space-x-4">
        {% if app.user %}
            <a href="{{ path('app_booking_history') }}" class="text-sm font-semibold py-2 px-4 hover:bg-gray-50 rounded-full hidden lg:inline-block">
                Mes réservations
            </a>
            {% if is_granted('ROLE_HOST') and not is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_host_dashboard') }}" class="text-sm font-semibold py-2 px-4 hover:bg-gray-50 rounded-full text-brand hidden lg:inline-block">
                    Interface hôte
                </a>
            {% endif %}
            {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('admin_dashboard') }}" class="text-sm font-semibold py-2 px-4 hover:bg-gray-50 rounded-full text-brand hidden lg:inline-block">
                    Interface admin
                </a>
            {% endif %}
            {% include 'layout/parts/header_profile_menu.html.twig' %}
        {% else %}
            <a href="{{ path('app_login') }}" class="text-sm font-semibold py-2 px-4 border border-gray-200 rounded-full hover:shadow-md transition">
                Se connecter
            </a>
            <a href="{{ path('app_register') }}" class="text-sm font-semibold py-2 px-4 bg-brand text-white rounded-full hover:bg-brandHover transition hidden sm:inline-block">
                S'inscrire
            </a>
        {% endif %}
    </div>
</header>
