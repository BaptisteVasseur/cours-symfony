<header class="sticky top-0 z-50 bg-white border-b border-gray-200 px-6 md:px-12 py-4 flex items-center justify-between">
    <a href="{{ path('app_home') }}" class="flex items-center text-brand text-2xl font-bold tracking-tight">
        <i class="fa-brands fa-airbnb mr-2 text-3xl"></i>
        <span>airbnb</span>
    </a>

    <div class="flex items-center space-x-4">
        <a href="{{ path('app_reservation_index') }}" class="text-sm font-semibold py-2 px-4 hover:bg-gray-50 rounded-full hidden lg:inline-block">
            Mes réservations
        </a>
        {% if app.user and is_granted('ROLE_HOST') %}
            <a href="{{ path('host_my_properties') }}" class="text-sm font-semibold py-2 px-4 hover:bg-gray-50 rounded-full hidden lg:inline-block">Mes propriétés</a>
        {% else %}
            <a href="{{ path('become_host') }}" class="text-sm font-semibold py-2 px-4 hover:bg-gray-50 rounded-full hidden lg:inline-block">Mettre mon logement sur Airbnb</a>
        {% endif %}
        <button class="text-gray-600 hover:bg-gray-50 p-2 rounded-full hidden sm:block">
            <i class="fa-solid fa-globe"></i>
        </button>

        {% if app.user %}
            {% include 'layout/parts/header_profile_menu.html.twig' %}
        {% else %}
            <a href="{{ path('app_login') }}" class="text-sm font-semibold py-2 px-4 border border-gray-200 rounded-full hover:shadow-md transition">
                Se connecter
            </a>
        {% endif %}


    </div>
</header>
