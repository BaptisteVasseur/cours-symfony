<header class="sticky top-0 z-50 bg-white border-b border-gray-200 shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16 gap-4">

            {# Logo #}
            <a href="{{ path('app_home') }}" class="flex items-center gap-1 shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" class="h-8 w-8 fill-[#FF385C]">
                    <path d="M16 1C10.5 1 3 10.3 3 17.4c0 4.8 3.2 8.6 8 9.4.5.1 1 .1 1.5.1 2 0 3.8-.6 5.3-1.7.3-.2.6-.4.9-.4s.6.2.9.4c1.5 1.1 3.3 1.7 5.3 1.7.5 0 1 0 1.5-.1 4.8-.8 8-4.6 8-9.4C34.4 10.3 21.5 1 16 1zm7.4 23.5c-.4.1-.8.1-1.2.1-1.5 0-2.9-.5-4.1-1.3-.6-.4-1.3-.7-2.1-.7s-1.5.3-2.1.7c-1.2.8-2.6 1.3-4.1 1.3-.4 0-.8 0-1.2-.1-3.6-.6-6-3.5-6-7.1 0-6 6.8-14.4 13.4-14.4S29.4 11.4 29.4 17.4c0 3.6-2.4 6.5-6 7.1z"/>
                </svg>
                <span class="hidden sm:block text-[#FF385C] font-bold text-lg tracking-tight">airbnb</span>
            </a>

            {# Search bar #}
            <div class="hidden md:flex flex-1 max-w-xl">
                <div class="flex items-center w-full border border-gray-300 rounded-full shadow-sm hover:shadow-md transition-shadow cursor-pointer divide-x divide-gray-200 bg-white">
                    <div class="flex-1 px-4 py-2">
                        <p class="text-xs font-semibold text-gray-800">Où</p>
                        <p class="text-xs text-gray-400 truncate">Destinations</p>
                    </div>
                    <div class="flex-1 px-4 py-2">
                        <p class="text-xs font-semibold text-gray-800">Arrivée</p>
                        <p class="text-xs text-gray-400">Ajouter des dates</p>
                    </div>
                    <div class="flex items-center gap-2 px-3 py-2">
                        <div>
                            <p class="text-xs font-semibold text-gray-800">Voyageurs</p>
                            <p class="text-xs text-gray-400">Ajouter des voyageurs</p>
                        </div>
                        <button class="bg-[#FF385C] text-white rounded-full p-2 hover:bg-[#E0324F] transition-colors shrink-0">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/>
                            </svg>
                        </button>
                    </div>
                </div>
            </div>

            {# Right nav #}
            <nav class="flex items-center gap-1 shrink-0">
                <a href="#" class="hidden lg:block text-sm font-medium text-gray-700 hover:bg-gray-100 rounded-full px-4 py-2 transition-colors whitespace-nowrap">
                    Proposer votre logement
                </a>

                {# Language selector #}
                <button class="p-2 rounded-full hover:bg-gray-100 transition-colors text-gray-600" aria-label="Langue">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18zm0 0c-2.4 0-4-4-4-9s1.6-9 4-9m0 18c2.4 0 4-4 4-9s-1.6-9-4-9M3 12h18"/>
                    </svg>
                </button>

                {# User menu #}
                <div class="relative" x-data="{ open: false }">
                    <button
                        @click="open = !open"
                        class="flex items-center gap-2 border border-gray-300 rounded-full px-3 py-2 hover:shadow-md transition-shadow bg-white"
                        aria-label="Menu utilisateur"
                    >
                        {# Hamburger #}
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
                        </svg>
                        {# Avatar placeholder #}
                        {% if app.user %}
                            <div class="h-7 w-7 rounded-full bg-gray-500 flex items-center justify-center text-white text-xs font-semibold overflow-hidden">
                                {% if app.user.profile %}
                                    {{ app.user.profile.firstName|slice(0, 1) ~ app.user.profile.lastName|slice(0, 1) }}
                                {% endif %}
                            </div>
                        {% else %}
                        <div class="h-7 w-7 rounded-full bg-gray-500 flex items-center justify-center text-white text-xs font-semibold overflow-hidden">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd" d="M10 9a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm-7 9a7 7 0 1 1 14 0H3z" clip-rule="evenodd"/>
                            </svg>
                        </div>
                        {% endif %}
                    </button>

                    {# Dropdown #}
                    <div
                        x-show="open"
                        @click.outside="open = false"
                        x-transition
                        class="absolute right-0 mt-2 w-56 bg-white rounded-xl shadow-lg border border-gray-200 overflow-hidden z-50"
                        style="display: none;"
                    >
                        {% if app.user %}
                            <div class="py-1">
                                {% if is_granted('ROLE_ADMIN') %}
                                    <a href="{{ path('app_admin_dashboard') }}" class="block px-4 py-2.5 text-sm font-semibold text-[#FF385C] hover:bg-gray-50">Dashboard admin</a>
                                {% endif %}
                                <a href="#" class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50">Mon profil</a>
                                <a href="{{ path('booking_my') }}" class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50">Mes réservations</a>
                                {% if is_granted('ROLE_HOST') %}
                                <a href="{{ path('host_listings') }}" class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50">Mes logements</a>
                                <a href="{{ path('host_bookings') }}" class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50">Mes réservations (hôte)</a>
                                {% endif %}
                            </div>
                            <div class="border-t border-gray-200 py-1">
                                <a href="#" class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50">Aide</a>
                                <a href="{{ path('app_logout') }}" class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50">Déconnexion</a>
                            </div>
                        {% else %}
                            <div class="py-1">
                                <a href="#" class="block px-4 py-2.5 text-sm font-semibold text-gray-800 hover:bg-gray-50">Inscription</a>
                                <a href="{{ path('app_login') }}" class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50">Connexion</a>
                            </div>
                            <div class="border-t border-gray-200 py-1">
                                <a href="#" class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50">Proposer votre logement</a>
                                <a href="#" class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50">Aide</a>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </nav>

        </div>
    </div>
</header>
