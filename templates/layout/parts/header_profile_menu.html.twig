{% set profile = app.user.profile %}
{% set displayName = profile and (profile.firstName or profile.lastName) ? (profile.firstName ~ ' ' ~ profile.lastName)|trim : app.user.email %}
{% set initials = profile and profile.firstName ? profile.firstName|first|upper ~ (profile.lastName ? profile.lastName|first|upper : '') : app.user.email|first|upper %}

<div class="relative" data-profile-menu>
    <button type="button" data-profile-menu-toggle class="flex items-center space-x-3 border border-gray-200 rounded-full p-2 pl-3 hover:shadow-md transition bg-white" aria-expanded="false" aria-haspopup="true">
        <i class="fa-solid fa-bars text-gray-600 text-sm"></i>
        <div class="w-8 h-8 bg-gray-700 text-white rounded-full flex items-center justify-center font-bold text-xs overflow-hidden shrink-0">
            {{ initials }}
        </div>
    </button>

    <div data-profile-menu-dropdown class="hidden absolute right-0 top-full mt-3 w-72 bg-white rounded-2xl shadow-xl border border-gray-200 py-2 z-50 overflow-hidden">
        <div class="px-4 py-3 border-b border-gray-100">
            <p class="font-semibold text-gray-900 text-sm truncate">{{ displayName }}</p>
            <p class="text-xs text-gray-500 truncate">{{ app.user.email }}</p>
        </div>

        <nav class="py-2">
            <a href="{{ path('app_booking_history') }}" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 transition">
                <i class="fa-solid fa-suitcase-rolling w-4 text-center text-gray-400"></i>
                Mes réservations
            </a>
            {% if is_granted('ROLE_HOST') and not is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_host_property_index') }}" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 transition">
                    <i class="fa-solid fa-house w-4 text-center text-gray-400"></i>
                    Mes propriétés
                </a>
            {% endif %}
            <a href="#" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 transition">
                <i class="fa-solid fa-envelope w-4 text-center text-gray-400"></i>
                Mes messages
            </a>
            <a href="#" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 transition">
                <i class="fa-solid fa-user w-4 text-center text-gray-400"></i>
                Mon profil
            </a>
            <a href="#" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 transition">
                <i class="fa-solid fa-gear w-4 text-center text-gray-400"></i>
                Paramètres du compte
            </a>
            <a href="#" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 transition">
                <i class="fa-solid fa-circle-question w-4 text-center text-gray-400"></i>
                Centre d'aide
            </a>
        </nav>

        {% if is_granted('ROLE_HOST') or is_granted('ROLE_ADMIN') %}
            <div class="border-t border-gray-100 py-2">
                {% if is_granted('ROLE_HOST') and not is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('app_host_dashboard') }}" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 transition">
                        <i class="fa-solid fa-house-user w-4 text-center text-brand"></i>
                        Interface hôte
                    </a>
                {% endif %}
                {% if is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('admin_dashboard') }}" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 transition">
                        <i class="fa-solid fa-shield-halved w-4 text-center text-brand"></i>
                        Interface admin
                    </a>
                {% endif %}
            </div>
        {% endif %}

        <div class="border-t border-gray-100 py-2">
            <a href="{{ path('app_logout') }}" class="flex items-center gap-3 px-4 py-2.5 text-sm text-gray-700 hover:bg-gray-50 transition">
                <i class="fa-solid fa-right-from-bracket w-4 text-center text-gray-400"></i>
                Déconnexion
            </a>
        </div>
    </div>
</div>

<script>
    document.querySelectorAll('[data-profile-menu]').forEach((menu) => {
        const toggle = menu.querySelector('[data-profile-menu-toggle]');
        const dropdown = menu.querySelector('[data-profile-menu-dropdown]');

        toggle?.addEventListener('click', (e) => {
            e.stopPropagation();
            const isOpen = !dropdown.classList.contains('hidden');
            dropdown.classList.toggle('hidden', isOpen);
            toggle.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
        });

        document.addEventListener('click', (e) => {
            if (!menu.contains(e.target)) {
                dropdown.classList.add('hidden');
                toggle?.setAttribute('aria-expanded', 'false');
            }
        });
    });
</script>
