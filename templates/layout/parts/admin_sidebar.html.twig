<aside class="w-64 bg-gray-900 text-white flex flex-col justify-between hidden md:flex shrink-0">
    <div>
        <div class="p-5 border-b border-gray-800 flex items-center space-x-2 text-brand text-xl font-bold">
            <i class="fa-brands fa-airbnb text-2xl"></i>
            <span class="text-white text-sm tracking-wider uppercase font-semibold">Admin Panel</span>
        </div>
        <nav class="p-4 space-y-1">
            <a href="{{ path('app_admin_home') }}" class="flex items-center space-x-3 {{ app.request.attributes.get('_route') == 'app_admin_home' ? 'bg-gray-800 text-white' : 'text-gray-400 hover:bg-gray-800 hover:text-white' }} px-4 py-3 rounded-lg text-sm font-medium transition">
                <i class="fa-solid fa-chart-pie text-brand"></i>
                <span>Vue d'ensemble</span>
            </a>
            <a href="{{ path('app_property_index') }}" class="flex items-center space-x-3 {{ app.request.attributes.get('_route') starts with 'app_property' ? 'bg-gray-800 text-white' : 'text-gray-400 hover:bg-gray-800 hover:text-white' }} px-4 py-3 rounded-lg text-sm font-medium transition">
                <i class="fa-solid fa-house"></i>
                <span>Annonces (Logements)</span>
            </a>
            <a href="{{ path('app_user_index') }}" class="flex items-center space-x-3 {{ app.request.attributes.get('_route') starts with 'app_user' ? 'bg-gray-800 text-white' : 'text-gray-400 hover:bg-gray-800 hover:text-white' }} px-4 py-3 rounded-lg text-sm font-medium transition">
                <i class="fa-solid fa-users"></i>
                <span>Utilisateurs</span>
            </a>
            <a href="{{ path('app_admin_reservation_index') }}" class="flex items-center space-x-3 {{ app.request.attributes.get('_route') starts with 'app_admin_reservation' ? 'bg-gray-800 text-white' : 'text-gray-400 hover:bg-gray-800 hover:text-white' }} px-4 py-3 rounded-lg text-sm font-medium transition">
                <i class="fa-solid fa-credit-card"></i>
                <span>Réservations & Revenus</span>
            </a>
            <a href="{{ path('app_admin_report_index') }}" class="flex items-center space-x-3 {{ app.request.attributes.get('_route') starts with 'app_admin_report' ? 'bg-gray-800 text-white' : 'text-gray-400 hover:bg-gray-800 hover:text-white' }} px-4 py-3 rounded-lg text-sm font-medium transition">
                <i class="fa-solid fa-triangle-exclamation"></i>
                <span>Signalements</span>
            </a>
            <a href="{{ path('app_admin_review_index') }}" class="flex items-center space-x-3 {{ app.request.attributes.get('_route') starts with 'app_admin_review' ? 'bg-gray-800 text-white' : 'text-gray-400 hover:bg-gray-800 hover:text-white' }} px-4 py-3 rounded-lg text-sm font-medium transition">
                <i class="fa-solid fa-star"></i>
                <span>Modération avis</span>
            </a>
        </nav>
    </div>

    {% set u = app.user %}
    {% set p = u.profile %}
    {% set name = p and (p.firstName or p.lastName) ? (p.firstName ~ ' ' ~ p.lastName)|trim : u.email %}
    {% set initials = p and p.firstName ? p.firstName|first|upper ~ (p.lastName ? p.lastName|first|upper : '') : u.email|first|upper %}
    <div class="p-4 border-t border-gray-800 flex items-center space-x-3">
        <div class="w-9 h-9 bg-brand text-white rounded-full flex items-center justify-center font-bold text-sm">
            {{ initials }}
        </div>
        <div class="overflow-hidden">
            <p class="text-xs font-semibold text-white truncate">{{ name }}</p>
            <span class="text-[10px] text-emerald-400 font-medium">
                <i class="fa-solid fa-circle text-[8px] mr-1"></i> 
                {{ is_granted('ROLE_SUPER_ADMIN') ? 'Super Admin' : 'Admin' }}
            </span>
        </div>
    </div>
</aside>
