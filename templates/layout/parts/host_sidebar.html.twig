{% set u = app.user %}
{% set p = u.profile %}
{% set name = p and (p.firstName or p.lastName) ? (p.firstName ~ ' ' ~ p.lastName)|trim : u.email %}
{% set initials = p and p.firstName ? p.firstName|first|upper ~ (p.lastName ? p.lastName|first|upper : '') : u.email|first|upper %}

<aside class="w-64 bg-slate-900 text-white flex flex-col justify-between hidden md:flex shrink-0">
    <div>
        <div class="p-5 border-b border-slate-800 flex items-center space-x-2 text-blue-500 text-xl font-bold">
            <i class="fa-brands fa-airbnb text-2xl"></i>
            <span class="text-white text-sm tracking-wider uppercase font-semibold">Espace Hôte</span>
        </div>
        <nav class="p-4 space-y-1">
            <a href="{{ path('host_dashboard') }}" class="flex items-center space-x-3 {{ app.request.attributes.get('_route') == 'host_dashboard' ? 'bg-slate-800 text-white' : 'text-slate-400 hover:bg-slate-800 hover:text-white' }} px-4 py-3 rounded-lg text-sm font-medium transition">
                <i class="fa-solid fa-chart-pie text-blue-500"></i>
                <span>Tableau de bord</span>
            </a>
            <a href="{{ path('host_properties') }}" class="flex items-center space-x-3 {{ app.request.attributes.get('_route') starts with 'host_property' or app.request.attributes.get('_route') == 'app_property_new' ? 'bg-slate-800 text-white' : 'text-slate-400 hover:bg-slate-800 hover:text-white' }} px-4 py-3 rounded-lg text-sm font-medium transition">
                <i class="fa-solid fa-house"></i>
                <span>Mes logements</span>
            </a>
            <a href="{{ path('host_reservations') }}" class="flex items-center space-x-3 {{ app.request.attributes.get('_route') starts with 'host_reservation' ? 'bg-slate-800 text-white' : 'text-slate-400 hover:bg-slate-800 hover:text-white' }} px-4 py-3 rounded-lg text-sm font-medium transition">
                <i class="fa-solid fa-calendar-days"></i>
                <span>Réservations reçues</span>
            </a>
            <a href="{{ path('app_home') }}" class="flex items-center space-x-3 text-slate-400 hover:bg-slate-800 hover:text-white px-4 py-3 rounded-lg text-sm font-medium transition">
                <i class="fa-solid fa-globe"></i>
                <span>Retour au site</span>
            </a>
        </nav>
    </div>

    <div class="p-4 border-t border-slate-800 flex items-center space-x-3">
        <div class="w-9 h-9 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold text-sm">
            {{ initials }}
        </div>
        <div class="overflow-hidden">
            <p class="text-xs font-semibold text-white truncate">{{ name }}</p>
            <span class="text-[10px] text-blue-400 font-medium">Hôte</span>
        </div>
    </div>
</aside>
