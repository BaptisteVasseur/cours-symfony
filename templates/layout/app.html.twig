{% extends 'layout/base.html.twig' %}

{% block body %}
    <body class="text-gray-800 font-sans antialiased bg-white flex flex-col min-h-screen">

    {% include 'layout/partials/app/header.html.twig' %}

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="mx-auto mt-4 max-w-4xl px-6 md:px-12 w-full">
                <div class="px-4 py-3 rounded-lg text-sm font-medium {{ label == 'success' ? 'bg-emerald-50 text-emerald-800 border border-emerald-200' : 'bg-red-50 text-red-800 border border-red-200' }}">
                    {{ message }}
                </div>
            </div>
        {% endfor %}
    {% endfor %}

    {% block content %}{% endblock %}

    {% include 'layout/partials/app/footer.html.twig' %}

    </body>
{% endblock %}
