{% extends 'layout/base.html.twig' %}

{% block body %}
    <body class="text-gray-800 font-sans antialiased bg-white flex flex-col min-h-screen">

    {% include 'layout/partials/app/header.html.twig' %}

    <div class="w-full max-w-6xl mx-auto px-6 md:px-12 mt-6 shrink-0">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 px-5 py-4 rounded-2xl text-sm border flex items-start shadow-sm transition duration-200 ease-in-out {{ label == 'success' ? 'bg-emerald-50 border-emerald-100 text-emerald-900' : 'bg-rose-50 border-rose-100 text-rose-900' }}">
                    {% if label == 'success' %}
                        <i class="fa-solid fa-circle-check text-emerald-500 mt-0.5 mr-3 text-base shrink-0"></i>
                    {% else %}
                        <i class="fa-solid fa-circle-exclamation text-rose-500 mt-0.5 mr-3 text-base shrink-0"></i>
                    {% endif %}
                    <div>{{ message }}</div>
                </div>
            {% endfor %}
        {% endfor %}
    </div>

    {% if app.user is not null and not app.user.isEmailVerified() %}
        <div id="email-verify-banner" class="w-full max-w-6xl mx-auto px-6 md:px-12 mb-2">
            <div class="relative flex items-start gap-3 bg-amber-50 border border-amber-200 rounded-2xl px-5 py-4 shadow-sm">
                <i class="fa-solid fa-triangle-exclamation text-amber-500 mt-0.5 text-base shrink-0"></i>
                <div class="flex-1 text-sm text-amber-900">
                    <p class="font-semibold mb-1">Adresse email non vérifiée</p>
                    <p class="mb-2">Veuillez vérifier votre adresse email pour sécuriser votre compte. Consultez votre boîte de réception pour le lien de vérification.</p>
                    <form action="{{ path('app_email_resend_verification') }}" method="POST" class="inline">
                        <button type="submit" class="text-amber-700 font-semibold underline hover:text-amber-900 transition">Renvoyer l'email de vérification</button>
                    </form>
                </div>
                <button type="button" onclick="document.getElementById('email-verify-banner').remove()" class="text-amber-400 hover:text-amber-600 transition p-1 shrink-0" aria-label="Fermer">
                    <i class="fa-solid fa-xmark text-lg"></i>
                </button>
            </div>
        </div>
    {% endif %}

    {% block content %}{% endblock %}

    {% include 'layout/partials/app/footer.html.twig' %}

    </body>
{% endblock %}
