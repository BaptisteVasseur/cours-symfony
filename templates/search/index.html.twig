{% extends 'layout/base.html.twig' %}

{% block title %}
    {% if criteria.destination %}Logements à {{ criteria.destination }}{% else %}Recherche de logements{% endif %} — Airbnb
{% endblock %}

{% block body %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    {# ── Barre de recherche ── #}
    <div class="bg-white border border-gray-200 rounded-2xl p-6 shadow-sm mb-8">
        <form method="GET" action="{{ path('app_search') }}" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
            <div>
                <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Destination</label>
                <input type="text" name="destination" value="{{ criteria.destination }}"
                       placeholder="Ville, adresse…"
                       class="w-full border border-gray-300 rounded-xl px-4 py-2 text-sm focus:ring-2 focus:ring-rose-400 focus:outline-none">
            </div>
            <div>
                <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Arrivée</label>
                <input type="date" name="checkin"
                       value="{{ criteria.checkIn ? criteria.checkIn|date('Y-m-d') : '' }}"
                       min="{{ 'today'|date('Y-m-d') }}"
                       class="w-full border border-gray-300 rounded-xl px-4 py-2 text-sm focus:ring-2 focus:ring-rose-400 focus:outline-none">
            </div>
            <div>
                <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Départ</label>
                <input type="date" name="checkout"
                       value="{{ criteria.checkOut ? criteria.checkOut|date('Y-m-d') : '' }}"
                       class="w-full border border-gray-300 rounded-xl px-4 py-2 text-sm focus:ring-2 focus:ring-rose-400 focus:outline-none">
            </div>
            <div>
                <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Voyageurs</label>
                <div class="flex gap-2">
                    <input type="number" name="guests" value="{{ criteria.guests }}" min="1" placeholder="1"
                           class="flex-1 border border-gray-300 rounded-xl px-4 py-2 text-sm focus:ring-2 focus:ring-rose-400 focus:outline-none">
                    <button type="submit"
                            class="bg-rose-500 hover:bg-rose-600 text-white rounded-xl px-4 py-2 text-sm font-medium transition">
                        Rechercher
                    </button>
                </div>
            </div>
        </form>
    </div>

    {# ── Résultats ── #}
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-xl font-bold text-gray-900">
            {% if criteria.destination %}
                Logements à <span class="text-rose-500">{{ criteria.destination }}</span>
            {% else %}
                Tous les logements disponibles
            {% endif %}
            {% if criteria.hasDateRange %}
                · {{ criteria.checkIn|date('d/m') }} → {{ criteria.checkOut|date('d/m') }}
                {% if criteria.nights %}
                    ({{ criteria.nights }} nuit{% if criteria.nights > 1 %}s{% endif %})
                {% endif %}
            {% endif %}
        </h1>
        <span class="text-sm text-gray-500">{{ properties|length }} résultat(s)</span>
    </div>

    {% if properties is empty %}
        <div class="text-center py-20">
            <p class="text-gray-400 text-lg mb-4">Aucun logement disponible pour ces critères.</p>
            <a href="{{ path('app_search') }}" class="text-rose-500 hover:underline text-sm">Effacer les filtres</a>
        </div>
    {% else %}
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
            {% for property in properties %}
                {% set firstImage = property.images.first %}
                <a href="{{ path('app_property_show', {id: property.id}) }}" class="block group">
                    <div class="rounded-2xl overflow-hidden bg-gray-100 aspect-square mb-3">
                        {% if firstImage %}
                            <img src="{{ firstImage.imageUrl }}" alt="{{ property.title }}"
                                 class="w-full h-full object-cover group-hover:scale-105 transition duration-300">
                        {% else %}
                            <div class="w-full h-full flex items-center justify-center text-gray-300">
                                <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                                </svg>
                            </div>
                        {% endif %}
                    </div>
                    <div class="flex items-start justify-between">
                        <div class="flex-1 min-w-0">
                            <p class="font-semibold text-gray-900 truncate">{{ property.title }}</p>
                            <p class="text-sm text-gray-500">{{ property.city }}, {{ property.country }}</p>
                            {% if property.averageRating %}
                                <p class="text-xs text-gray-500 mt-0.5">
                                    ★ {{ property.averageRating }} · {{ property.reviews|length }} avis
                                </p>
                            {% endif %}
                            {% if criteria.nights %}
                                <p class="text-sm font-semibold text-gray-900 mt-1">
                                    {{ (criteria.nights * property.pricePerNight)|number_format(0, ',', ' ') }} € total
                                    <span class="text-xs font-normal text-gray-500">({{ property.pricePerNight }} €/nuit)</span>
                                </p>
                            {% else %}
                                <p class="text-sm font-semibold text-gray-900 mt-1">
                                    {{ property.pricePerNight }} € <span class="font-normal text-gray-500">/ nuit</span>
                                </p>
                            {% endif %}
                        </div>
                        {% if property.instantBooking %}
                            <span class="ml-2 mt-0.5 text-xs bg-green-100 text-green-700 px-2 py-0.5 rounded-full font-medium whitespace-nowrap">
                                Instant
                            </span>
                        {% endif %}
                    </div>
                </a>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}
