{% extends 'layout/base.html.twig' %}

{% block title %}Gestion des utilisateurs — Admin{% endblock %}

{% block body %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex items-center justify-between mb-6">
        <div>
            <a href="{{ path('app_admin_dashboard') }}" class="text-sm text-gray-500 hover:text-[#FF385C]">← Tableau de bord</a>
            <h1 class="text-2xl font-bold text-gray-900 mt-1">Utilisateurs</h1>
        </div>
        <a href="{{ path('app_user_new') }}" class="px-4 py-2 bg-[#FF385C] text-white font-semibold rounded-lg hover:bg-[#E11D48] transition">+ Nouvel utilisateur</a>
    </div>

    <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden">
        <table class="w-full text-sm">
            <thead class="bg-gray-50 text-left text-gray-500">
                <tr>
                    <th class="px-4 py-3 font-medium">Nom</th>
                    <th class="px-4 py-3 font-medium">Email</th>
                    <th class="px-4 py-3 font-medium">Rôle</th>
                    <th class="px-4 py-3 font-medium">Statut</th>
                    <th class="px-4 py-3 font-medium text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                {% for user in users %}
                    <tr class="hover:bg-gray-50">
                        <td class="px-4 py-3 font-medium text-gray-900">{{ user.firstName }} {{ user.lastName }}</td>
                        <td class="px-4 py-3 text-gray-600">{{ user.email }}</td>
                        <td class="px-4 py-3">
                            <span class="px-2 py-1 rounded-full text-xs {{ user.role == 'admin' ? 'bg-gray-900 text-white' : (user.role == 'host' ? 'bg-blue-100 text-blue-700' : 'bg-gray-100 text-gray-600') }}">{{ user.role ?? 'guest' }}</span>
                        </td>
                        <td class="px-4 py-3 text-gray-600">{{ user.status ?? '—' }}</td>
                        <td class="px-4 py-3">
                            <div class="flex justify-end gap-2">
                                <a href="{{ path('app_user_show', {id: user.id}) }}" class="text-gray-500 hover:text-[#FF385C]">Voir</a>
                                <a href="{{ path('app_user_edit', {id: user.id}) }}" class="text-gray-500 hover:text-[#FF385C]">Éditer</a>
                                <form method="post" action="{{ path('app_user_delete', {id: user.id}) }}" onsubmit="return confirm('Supprimer cet utilisateur ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                                    <button class="text-gray-500 hover:text-red-600">Suppr.</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="5" class="px-4 py-8 text-center text-gray-400">Aucun utilisateur.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
