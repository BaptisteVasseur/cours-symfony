{% extends 'layout/base.html.twig' %}

{% block title %}{{ user.firstName }} {{ user.lastName }} — Admin{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <a href="{{ path('app_user_index') }}" class="text-sm text-gray-500 hover:text-[#FF385C]">← Liste des utilisateurs</a>
    <h1 class="text-2xl font-bold text-gray-900 mt-2 mb-6">{{ user.firstName }} {{ user.lastName }}</h1>

    <div class="bg-white border border-gray-200 rounded-2xl divide-y divide-gray-100">
        {% set rows = {
            'Email': user.email,
            'Téléphone': user.phone ?? '—',
            'Rôle': user.role ?? 'guest',
            'Statut': user.status ?? '—',
            'Email vérifié': user.emailVerified ? 'Oui' : 'Non',
            'Téléphone vérifié': user.phoneVerified ? 'Oui' : 'Non',
            'Identité vérifiée': user.identityVerified ? 'Oui' : 'Non',
            'Créé le': user.createdAt ? user.createdAt|date('d/m/Y H:i') : '—',
        } %}
        {% for label, value in rows %}
            <div class="flex justify-between px-5 py-3 text-sm">
                <span class="text-gray-500">{{ label }}</span>
                <span class="text-gray-900 font-medium">{{ value }}</span>
            </div>
        {% endfor %}
    </div>

    <div class="mt-6 flex gap-3">
        <a href="{{ path('app_user_edit', {id: user.id}) }}" class="px-5 py-2.5 bg-[#FF385C] text-white font-semibold rounded-lg hover:bg-[#E11D48] transition">Éditer</a>
    </div>
</div>
{% endblock %}
