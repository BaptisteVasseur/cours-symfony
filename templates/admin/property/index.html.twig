{% extends 'layout/admin.html.twig' %}

{% block page_title %}Gestion des annonces{% endblock %}

{% block content %}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="mb-4 px-4 py-3 rounded-lg text-sm font-medium {{ label == 'success' ? 'bg-emerald-50 text-emerald-800 border border-emerald-200' : 'bg-red-50 text-red-800 border border-red-200' }}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
        <div class="bg-white p-5 rounded-xl border border-gray-200 shadow-sm flex items-center justify-between">
            <div>
                <p class="text-xs font-medium text-gray-400 uppercase">Total annonces</p>
                <h4 class="text-2xl font-bold text-gray-900 mt-1">{{ total }}</h4>
            </div>
            <div class="w-12 h-12 bg-blue-50 text-blue-600 rounded-xl flex items-center justify-center text-xl">
                <i class="fa-solid fa-house"></i>
            </div>
        </div>
        <div class="bg-white p-5 rounded-xl border border-gray-200 shadow-sm flex items-center justify-between">
            <div>
                <p class="text-xs font-medium text-gray-400 uppercase">Publiées</p>
                <h4 class="text-2xl font-bold text-gray-900 mt-1">{{ published }}</h4>
            </div>
            <div class="w-12 h-12 bg-emerald-50 text-emerald-600 rounded-xl flex items-center justify-center text-xl">
                <i class="fa-solid fa-circle-check"></i>
            </div>
        </div>
        <div class="bg-white p-5 rounded-xl border border-gray-200 shadow-sm flex items-center justify-between">
            <div>
                <p class="text-xs font-medium text-gray-400 uppercase">En attente</p>
                <h4 class="text-2xl font-bold text-gray-900 mt-1">{{ pending }}</h4>
            </div>
            <div class="w-12 h-12 bg-amber-50 text-amber-600 rounded-xl flex items-center justify-center text-xl">
                <i class="fa-solid fa-clock"></i>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
            <h3 class="font-bold text-gray-900">Liste des annonces</h3>
            <div class="flex items-center gap-2 flex-wrap">
                <a href="{{ path('app_property_index') }}" class="text-xs font-semibold px-3 py-1.5 rounded-lg transition {{ statusFilter is null ? 'bg-gray-900 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200' }}">Toutes</a>
                <a href="{{ path('app_property_index', { status: 'published' }) }}" class="text-xs font-semibold px-3 py-1.5 rounded-lg transition {{ statusFilter == 'published' ? 'bg-emerald-600 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200' }}">Publiées</a>
                <a href="{{ path('app_property_index', { status: 'pending' }) }}" class="text-xs font-semibold px-3 py-1.5 rounded-lg transition {{ statusFilter == 'pending' ? 'bg-amber-500 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200' }}">En attente</a>
                <a href="{{ path('app_property_new') }}" class="inline-flex items-center gap-2 bg-brand hover:bg-brandHover text-white font-semibold text-sm px-4 py-2 rounded-lg transition ml-auto">
                    <i class="fa-solid fa-plus text-xs"></i>
                    Nouvelle annonce
                </a>
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse text-sm">
                <thead>
                    <tr class="bg-gray-50 text-gray-400 font-semibold border-b border-gray-200 uppercase text-[11px] tracking-wider">
                        <th class="px-6 py-3">Annonce</th>
                        <th class="px-6 py-3">Type</th>
                        <th class="px-6 py-3">Statut</th>
                        <th class="px-6 py-3">Prix / nuit</th>
                        <th class="px-6 py-3">Capacité</th>
                        <th class="px-6 py-3 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                    {% for property in properties %}
                        {% include 'admin/property/partials/property_row.html.twig' with { property: property } %}
                    {% else %}
                        <tr>
                            <td colspan="6" class="px-6 py-12 text-center text-gray-400">
                                <i class="fa-solid fa-house-circle-xmark text-3xl mb-3 block"></i>
                                Aucune annonce trouvée.
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
