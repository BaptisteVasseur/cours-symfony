{% extends 'layout/admin.html.twig' %}

{% set cover = property.coverMedia %}
{% set averageRating = property.averageRating %}
{% set placeholderImage = 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=800&q=80' %}

{% set statusLabels = {
    'published': 'Publiée',
    'pending': 'En attente',
    'draft': 'Brouillon',
} %}
{% set statusClasses = {
    'published': 'bg-emerald-50 text-emerald-800 border border-emerald-200',
    'pending': 'bg-amber-50 text-amber-800 border border-amber-200',
    'draft': 'bg-gray-100 text-gray-700 border border-gray-200',
} %}

{% block page_title %}{{ property.title }}{% endblock %}

{% block content %}
    <div class="mb-6">
        <a href="{{ path('app_property_index') }}" class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-gray-900 transition">
            <i class="fa-solid fa-arrow-left text-xs"></i>
            Retour à la liste
        </a>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">
        <div class="xl:col-span-2 space-y-6">
            <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
                <div class="h-64 md:h-80">
                    <img src="{{ cover ? cover.fileUrl : placeholderImage }}" alt="{{ property.title }}" class="w-full h-full object-cover">
                </div>
                <div class="p-6">
                    <div class="flex flex-wrap items-start justify-between gap-3 mb-4">
                        <div>
                            <h2 class="text-xl font-bold text-gray-900">{{ property.title }}</h2>
                            {% if property.address %}
                                <p class="text-sm text-gray-500 mt-1">{{ property.address.city }}, {{ property.address.country }}</p>
                            {% endif %}
                        </div>
                        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold {{ statusClasses[property.status]|default('bg-gray-100 text-gray-700') }}">
                            {{ statusLabels[property.status]|default(property.status) }}
                        </span>
                        {% if property.status == 'pending' %}
                            <div class="mt-3 flex gap-2">
                                {{ include('admin/property/partials/moderation_actions.html.twig') }}
                            </div>
                        {% endif %}
                    </div>
                    {% if property.description %}
                        <p class="text-sm text-gray-600 leading-relaxed">{{ property.description }}</p>
                    {% endif %}
                </div>
            </div>

            <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
                <h3 class="font-bold text-gray-900 mb-4">Caractéristiques</h3>
                <dl class="grid grid-cols-2 md:grid-cols-4 gap-4 text-sm">
                    <div class="bg-gray-50 rounded-lg p-4 text-center">
                        <dt class="text-gray-400 text-xs uppercase mb-1">Voyageurs</dt>
                        <dd class="font-bold text-gray-900 text-lg">{{ property.maxGuests }}</dd>
                    </div>
                    <div class="bg-gray-50 rounded-lg p-4 text-center">
                        <dt class="text-gray-400 text-xs uppercase mb-1">Chambres</dt>
                        <dd class="font-bold text-gray-900 text-lg">{{ property.bedrooms }}</dd>
                    </div>
                    <div class="bg-gray-50 rounded-lg p-4 text-center">
                        <dt class="text-gray-400 text-xs uppercase mb-1">Lits</dt>
                        <dd class="font-bold text-gray-900 text-lg">{{ property.beds }}</dd>
                    </div>
                    <div class="bg-gray-50 rounded-lg p-4 text-center">
                        <dt class="text-gray-400 text-xs uppercase mb-1">Salles de bain</dt>
                        <dd class="font-bold text-gray-900 text-lg">{{ property.bathrooms }}</dd>
                    </div>
                </dl>
            </div>

            {% if property.reviews|length > 0 %}
                <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
                    <h3 class="font-bold text-gray-900 mb-4">Avis ({{ property.reviews|length }})</h3>
                    {% if averageRating %}
                        <p class="text-sm text-gray-500 mb-4">
                            Note moyenne : <span class="font-semibold text-gray-900">{{ averageRating|number_format(2, ',') }} / 5</span>
                        </p>
                    {% endif %}
                    <div class="space-y-4">
                        {% for review in property.reviews|slice(0, 3) %}
                            <div class="border-b border-gray-100 pb-4 last:border-0 last:pb-0">
                                <div class="flex items-center gap-1 mb-1">
                                    {% for i in 1..review.rating %}
                                        <i class="fa-solid fa-star text-xs text-amber-400"></i>
                                    {% endfor %}
                                </div>
                                {% if review.comment %}
                                    <p class="text-sm text-gray-600">{{ review.comment }}</p>
                                {% endif %}
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}
        </div>

        <div class="space-y-6">
            <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
                <h3 class="font-bold text-gray-900 mb-4">Tarification</h3>
                <dl class="space-y-3 text-sm">
                    <div class="flex justify-between">
                        <dt class="text-gray-500">Prix / nuit</dt>
                        <dd class="font-semibold">{{ property.pricePerNight|number_format(2, ',', ' ') }} €</dd>
                    </div>
                    {% if property.cleaningFee %}
                        <div class="flex justify-between">
                            <dt class="text-gray-500">Ménage</dt>
                            <dd class="font-semibold">{{ property.cleaningFee|number_format(2, ',', ' ') }} €</dd>
                        </div>
                    {% endif %}
                    {% if property.securityDeposit %}
                        <div class="flex justify-between">
                            <dt class="text-gray-500">Caution</dt>
                            <dd class="font-semibold">{{ property.securityDeposit|number_format(2, ',', ' ') }} €</dd>
                        </div>
                    {% endif %}
                </dl>
            </div>

            <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
                <h3 class="font-bold text-gray-900 mb-4">Informations</h3>
                <dl class="space-y-3 text-sm">
                    <div>
                        <dt class="text-gray-400 text-xs uppercase">Hôte</dt>
                        <dd class="font-medium text-gray-900">{{ property.host ? property.host.email : '—' }}</dd>
                    </div>
                    <div>
                        <dt class="text-gray-400 text-xs uppercase">Politique d'annulation</dt>
                        <dd class="font-medium text-gray-900">{{ property.cancellationPolicy ? property.cancellationPolicy.label : '—' }}</dd>
                    </div>
                    <div>
                        <dt class="text-gray-400 text-xs uppercase">Réservation instantanée</dt>
                        <dd class="font-medium text-gray-900">{{ property.instantBooking ? 'Oui' : 'Non' }}</dd>
                    </div>
                    <div>
                        <dt class="text-gray-400 text-xs uppercase">Créée le</dt>
                        <dd class="font-medium text-gray-900">{{ property.createdAt|date('d/m/Y H:i') }}</dd>
                    </div>
                    {% if property.updatedAt %}
                        <div>
                            <dt class="text-gray-400 text-xs uppercase">Modifiée le</dt>
                            <dd class="font-medium text-gray-900">{{ property.updatedAt|date('d/m/Y H:i') }}</dd>
                        </div>
                    {% endif %}
                    <div>
                        <dt class="text-gray-400 text-xs uppercase">Référence</dt>
                        <dd class="font-mono text-xs text-gray-600">{{ property.id }}</dd>
                    </div>
                </dl>
            </div>

            <div class="flex flex-col gap-2">
                <a href="{{ path('app_property_edit', { id: property.id }) }}" class="w-full text-center bg-gray-900 hover:bg-gray-700 text-white font-semibold text-sm px-4 py-2.5 rounded-lg transition">
                    Modifier l'annonce
                </a>
                <a href="{{ path('app_logement_detail', { id: property.id }) }}" target="_blank" class="w-full text-center border border-gray-200 hover:bg-gray-50 text-gray-700 font-semibold text-sm px-4 py-2.5 rounded-lg transition">
                    Voir sur le site
                </a>
                {{ include('admin/property/partials/delete_form.html.twig') }}
            </div>
        </div>
    </div>
{% endblock %}
