<tr class="hover:bg-gray-50/70 transition">
    <td class="px-6 py-4">
        <div class="flex items-center space-x-3">
            <div class="w-10 h-10 bg-gray-200 text-gray-600 rounded-full flex items-center justify-center font-bold text-sm shrink-0">
                {{ initials }}
            </div>
            <div>
                <p class="font-semibold text-gray-900">{{ name }}</p>
                <span class="text-xs text-gray-400">{{ email }}</span>
            </div>
        </div>
    </td>
    <td class="px-6 py-4">
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium {{ role_class }}">{{ role }}</span>
    </td>
    <td class="px-6 py-4">
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium {{ status_class }}">
            <i class="fa-solid {{ status_icon }} text-[8px] mr-1.5"></i> {{ status }}
        </span>
    </td>
    <td class="px-6 py-4 text-gray-500">{{ registered_at }}</td>
    <td class="px-6 py-4 text-right space-x-2">
        <button class="text-xs text-gray-600 hover:text-gray-900 font-semibold px-2.5 py-1.5 rounded-lg border border-gray-200 hover:bg-gray-50 transition">Voir</button>
        {% if status == 'Actif' %}
            <button class="text-xs bg-amber-50 text-amber-700 font-bold px-2.5 py-1.5 rounded-lg hover:bg-amber-100 transition">Suspendre</button>
        {% elseif status == 'Suspendu' %}
            <button class="text-xs bg-emerald-50 text-emerald-600 font-bold px-2.5 py-1.5 rounded-lg hover:bg-emerald-100 transition">Réactiver</button>
        {% else %}
            <button class="text-xs bg-emerald-50 text-emerald-600 font-bold px-2.5 py-1.5 rounded-lg hover:bg-emerald-100 transition">Valider</button>
            <button class="text-xs bg-rose-50 text-brand font-bold px-2.5 py-1.5 rounded-lg hover:bg-rose-100 transition">Refuser</button>
        {% endif %}
    </td>
</tr>
