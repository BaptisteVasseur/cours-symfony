{% extends 'base.html.twig' %}

{% block title %}Admin – {% block page_title %}Dashboard{% endblock %}{% endblock %}

{% block stylesheets %}
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        airbnb: { DEFAULT: '#FF385C', dark: '#E0324F' }
                    }
                }
            }
        }
    </script>
    {% block extra_styles %}{% endblock %}
{% endblock %}

{% block content %}
<div class="min-h-screen flex bg-gray-100" x-data="{ sidebarOpen: true }">

    {# ── Sidebar ── #}
    <aside class="w-64 shrink-0 bg-gray-900 text-white flex flex-col min-h-screen">

        {# Logo #}
        <div class="flex items-center gap-2 px-6 py-5 border-b border-gray-700">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" class="h-7 w-7 fill-[#FF385C]">
                <path d="M16 1C10.5 1 3 10.3 3 17.4c0 4.8 3.2 8.6 8 9.4.5.1 1 .1 1.5.1 2 0 3.8-.6 5.3-1.7.3-.2.6-.4.9-.4s.6.2.9.4c1.5 1.1 3.3 1.7 5.3 1.7.5 0 1 0 1.5-.1 4.8-.8 8-4.6 8-9.4C34.4 10.3 21.5 1 16 1z"/>
            </svg>
            <div>
                <p class="text-white font-bold text-sm leading-tight">airbnb</p>
                <p class="text-gray-400 text-xs">Administration</p>
            </div>
        </div>

        {# Nav #}
        <nav class="flex-1 px-3 py-4 space-y-1 overflow-y-auto">

            {% set currentRoute = app.request.attributes.get('_route') %}

            {% macro navItem(route, label, icon, current) %}
                <a href="{{ path(route) }}"
                   class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors
                          {{ current ? 'bg-gray-700 text-white' : 'text-gray-400 hover:bg-gray-800 hover:text-white' }}">
                    <span class="text-base">{{ icon }}</span>
                    {{ label }}
                </a>
            {% endmacro %}

            <p class="px-3 pt-2 pb-1 text-xs font-semibold text-gray-500 uppercase tracking-wider">Général</p>
            <a href="{{ path('app_admin_dashboard') }}"
               class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors
                      {{ currentRoute == 'app_admin_dashboard' ? 'bg-gray-700 text-white' : 'text-gray-400 hover:bg-gray-800 hover:text-white' }}">
                <span>📊</span> Dashboard
            </a>

            <p class="px-3 pt-4 pb-1 text-xs font-semibold text-gray-500 uppercase tracking-wider">Gestion</p>
            <a href="{{ path('app_listing_index') }}"
               class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors
                      {{ currentRoute starts with 'app_listing' ? 'bg-gray-700 text-white' : 'text-gray-400 hover:bg-gray-800 hover:text-white' }}">
                <span>🏠</span> Logements
            </a>
            <a href="#" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-gray-400 hover:bg-gray-800 hover:text-white transition-colors">
                <span>👥</span> Utilisateurs
            </a>
            <a href="#" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-gray-400 hover:bg-gray-800 hover:text-white transition-colors">
                <span>📅</span> Réservations
            </a>
            <a href="#" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-gray-400 hover:bg-gray-800 hover:text-white transition-colors">
                <span>⭐</span> Avis
            </a>
            <a href="#" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-gray-400 hover:bg-gray-800 hover:text-white transition-colors">
                <span>⚠️</span> Litiges
            </a>

            <p class="px-3 pt-4 pb-1 text-xs font-semibold text-gray-500 uppercase tracking-wider">Paramètres</p>
            <a href="#" class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-gray-400 hover:bg-gray-800 hover:text-white transition-colors">
                <span>⚙️</span> Configuration
            </a>

        </nav>

        {# User #}
        <div class="border-t border-gray-700 px-4 py-4 flex items-center gap-3">
            <div class="h-8 w-8 rounded-full bg-[#FF385C] flex items-center justify-center text-white text-xs font-bold shrink-0">
                {% if app.user and app.user.profile %}
                    {{ app.user.profile.firstName|slice(0,1)|upper }}
                {% else %}
                    A
                {% endif %}
            </div>
            <div class="min-w-0 flex-1">
                <p class="text-sm font-medium text-white truncate">
                    {% if app.user and app.user.profile %}
                        {{ app.user.profile.firstName }} {{ app.user.profile.lastName }}
                    {% else %}
                        Admin
                    {% endif %}
                </p>
                <p class="text-xs text-gray-400 truncate">{{ app.user ? app.user.userIdentifier : '' }}</p>
            </div>
            <a href="{{ path('app_logout') }}" class="text-gray-400 hover:text-white transition-colors shrink-0" title="Déconnexion">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                </svg>
            </a>
        </div>
    </aside>

    {# ── Main content ── #}
    <div class="flex-1 flex flex-col min-h-screen overflow-hidden">

        {# Topbar #}
        <header class="bg-white border-b border-gray-200 px-8 py-4 flex items-center justify-between shrink-0">
            <div>
                <h1 class="text-xl font-semibold text-gray-900">{% block topbar_title %}{% block page_title_display %}{% endblock %}{% endblock %}</h1>
                {% block breadcrumb %}{% endblock %}
            </div>
            <div class="flex items-center gap-3">
                <a href="{{ path('app_home') }}" target="_blank"
                   class="flex items-center gap-1.5 text-sm text-gray-500 hover:text-gray-900 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                    </svg>
                    Voir le site
                </a>
            </div>
        </header>

        {# Flash messages #}
        <div class="px-8 pt-4">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="mb-3 flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium
                                {{ label == 'success' ? 'bg-green-50 text-green-800 border border-green-200' : 'bg-red-50 text-red-800 border border-red-200' }}">
                        <span>{{ label == 'success' ? '✓' : '!' }}</span>
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}
        </div>

        {# Page body #}
        <main class="flex-1 px-8 py-6">
            {% block body %}{% endblock %}
        </main>

    </div>
</div>
{% endblock %}

{% block javascripts %}
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% block extra_scripts %}{% endblock %}
{% endblock %}
