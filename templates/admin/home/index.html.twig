{% extends 'layout/admin.html.twig' %}

{% block page_title %}Gestion des Hébergements{% endblock %}

{% block content %}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="bg-white p-5 rounded-xl border border-gray-200 shadow-sm flex items-center justify-between">
            <div>
                <p class="text-xs font-medium text-gray-400 uppercase">Total Annonces</p>
                <h4 class="text-2xl font-bold text-gray-900 mt-1">24 580</h4>
                <span class="text-xs text-emerald-500 font-semibold"><i class="fa-solid fa-arrow-up text-[10px] mr-1"></i>+12% ce mois</span>
            </div>
            <div class="w-12 h-12 bg-rose-50 text-brand rounded-xl flex items-center justify-center text-xl"><i class="fa-solid fa-house"></i></div>
        </div>
        <div class="bg-white p-5 rounded-xl border border-gray-200 shadow-sm flex items-center justify-between">
            <div>
                <p class="text-xs font-medium text-gray-400 uppercase">Volume d'affaires</p>
                <h4 class="text-2xl font-bold text-gray-900 mt-1">142 350 €</h4>
                <span class="text-xs text-emerald-500 font-semibold"><i class="fa-solid fa-arrow-up text-[10px] mr-1"></i>+8.3%</span>
            </div>
            <div class="w-12 h-12 bg-emerald-50 text-emerald-600 rounded-xl flex items-center justify-center text-xl"><i class="fa-solid fa-wallet"></i></div>
        </div>
        <div class="bg-white p-5 rounded-xl border border-gray-200 shadow-sm flex items-center justify-between">
            <div>
                <p class="text-xs font-medium text-gray-400 uppercase">Signalements Actifs</p>
                <h4 class="text-2xl font-bold text-gray-900 mt-1">14</h4>
                <span class="text-xs text-amber-600 font-semibold"><i class="fa-solid fa-triangle-exclamation text-[10px] mr-1"></i>À traiter d'urgence</span>
            </div>
            <div class="w-12 h-12 bg-amber-50 text-amber-600 rounded-xl flex items-center justify-center text-xl"><i class="fa-solid fa-circle-exclamation"></i></div>
        </div>
        <div class="bg-white p-5 rounded-xl border border-gray-200 shadow-sm flex items-center justify-between">
            <div>
                <p class="text-xs font-medium text-gray-400 uppercase">Utilisateurs Actifs</p>
                <h4 class="text-2xl font-bold text-gray-900 mt-1">118 420</h4>
                <span class="text-xs text-gray-400 font-normal">Actuels sur les dernières 24h</span>
            </div>
            <div class="w-12 h-12 bg-blue-50 text-blue-600 rounded-xl flex items-center justify-center text-xl"><i class="fa-solid fa-users"></i></div>
        </div>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200 flex flex-col sm:flex-row sm:items-center sm:justify-between space-y-2 sm:space-y-0">
            <h3 class="font-bold text-gray-900">Dernières annonces soumises à la vérification</h3>
            <div class="flex items-center space-x-2">
                <input type="text" placeholder="Filtrer par ville..." class="text-sm border border-gray-200 rounded-lg px-3 py-1.5 focus:outline-none focus:border-gray-400">
                <button class="bg-gray-100 text-gray-700 font-semibold text-xs px-3 py-2 rounded-lg hover:bg-gray-200 transition">Exporter (.csv)</button>
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse text-sm">
                <thead>
                    <tr class="bg-gray-50 text-gray-400 font-semibold border-b border-gray-200 uppercase text-[11px] tracking-wider">
                        <th class="px-6 py-3">Hébergement</th>
                        <th class="px-6 py-3">Hôte</th>
                        <th class="px-6 py-3">Prix / Nuit</th>
                        <th class="px-6 py-3">Statut</th>
                        <th class="px-6 py-3 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                    <tr class="hover:bg-gray-50/70 transition">
                        <td class="px-6 py-4 flex items-center space-x-3">
                            <img src="https://images.unsplash.com/photo-1512917774080-9991f1c4c750?auto=format&fit=crop&w=80&q=80" alt="Logement" class="w-12 h-12 object-cover rounded-lg">
                            <div>
                                <p class="font-semibold text-gray-900">Villa Luxe avec Piscine Privée</p>
                                <span class="text-xs text-gray-400">Chamonix, France</span>
                            </div>
                        </td>
                        <td class="px-6 py-4">Jean-Marc D.</td>
                        <td class="px-6 py-4 font-medium text-gray-900">145 €</td>
                        <td class="px-6 py-4">
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-50 text-amber-800 border border-amber-200"><i class="fa-solid fa-clock text-[8px] mr-1.5"></i> En attente</span>
                        </td>
                        <td class="px-6 py-4 text-right space-x-2">
                            <button class="text-xs bg-emerald-50 text-emerald-600 font-bold px-2.5 py-1.5 rounded-lg hover:bg-emerald-100 transition">Approuver</button>
                            <button class="text-xs bg-rose-50 text-brand font-bold px-2.5 py-1.5 rounded-lg hover:bg-rose-100 transition">Refuser</button>
                        </td>
                    </tr>
                    <tr class="hover:bg-gray-50/70 transition">
                        <td class="px-6 py-4 flex items-center space-x-3">
                            <img src="https://images.unsplash.com/photo-1540555700478-4be289fbecef?auto=format&fit=crop&w=80&q=80" alt="Logement" class="w-12 h-12 object-cover rounded-lg">
                            <div>
                                <p class="font-semibold text-gray-900">Loft Industriel Vue Mer</p>
                                <span class="text-xs text-gray-400">Santorin, Grèce</span>
                            </div>
                        </td>
                        <td class="px-6 py-4">Elena K.</td>
                        <td class="px-6 py-4 font-medium text-gray-900">280 €</td>
                        <td class="px-6 py-4">
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-emerald-50 text-emerald-800 border border-emerald-200"><i class="fa-solid fa-check text-[8px] mr-1.5"></i> Approuvé</span>
                        </td>
                        <td class="px-6 py-4 text-right">
                            <button class="text-xs text-gray-400 hover:text-gray-900 font-semibold px-2.5 py-1.5 rounded-lg border border-gray-200 hover:bg-gray-50 transition">Editer</button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
