{% extends 'layout/admin.html.twig' %}

{% block page_title %}Vue d'ensemble{% endblock %}

{% block content %}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="bg-white p-5 rounded-xl border border-gray-200 shadow-sm flex items-center justify-between">
            <div>
                <p class="text-xs font-medium text-gray-400 uppercase">Total annonces</p>
                <h4 class="text-2xl font-bold text-gray-900 mt-1">{{ totalProperties }}</h4>
            </div>
            <div class="w-12 h-12 bg-rose-50 text-brand rounded-xl flex items-center justify-center text-xl"><i class="fa-solid fa-house"></i></div>
        </div>
        <div class="bg-white p-5 rounded-xl border border-gray-200 shadow-sm flex items-center justify-between">
            <div>
                <p class="text-xs font-medium text-gray-400 uppercase">Volume d'affaires</p>
                <h4 class="text-2xl font-bold text-gray-900 mt-1">{{ revenue|number_format(0, ',', ' ') }} €</h4>
                <span class="text-xs text-gray-400 font-normal">Réservations confirmées / terminées</span>
            </div>
            <div class="w-12 h-12 bg-emerald-50 text-emerald-600 rounded-xl flex items-center justify-center text-xl"><i class="fa-solid fa-wallet"></i></div>
        </div>
        <div class="bg-white p-5 rounded-xl border border-gray-200 shadow-sm flex items-center justify-between">
            <div>
                <p class="text-xs font-medium text-gray-400 uppercase">Signalements actifs</p>
                <h4 class="text-2xl font-bold text-gray-900 mt-1">{{ openReports }}</h4>
                {% if openReports > 0 %}
                    <a href="{{ path('app_admin_report_index') }}" class="text-xs text-amber-600 font-semibold hover:underline"><i class="fa-solid fa-triangle-exclamation text-[10px] mr-1"></i>À traiter</a>
                {% endif %}
            </div>
            <div class="w-12 h-12 bg-amber-50 text-amber-600 rounded-xl flex items-center justify-center text-xl"><i class="fa-solid fa-circle-exclamation"></i></div>
        </div>
        <div class="bg-white p-5 rounded-xl border border-gray-200 shadow-sm flex items-center justify-between">
            <div>
                <p class="text-xs font-medium text-gray-400 uppercase">Utilisateurs actifs</p>
                <h4 class="text-2xl font-bold text-gray-900 mt-1">{{ activeUsers }}</h4>
            </div>
            <div class="w-12 h-12 bg-blue-50 text-blue-600 rounded-xl flex items-center justify-center text-xl"><i class="fa-solid fa-users"></i></div>
        </div>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200 flex flex-col sm:flex-row sm:items-center sm:justify-between space-y-2 sm:space-y-0">
            <h3 class="font-bold text-gray-900">Annonces en attente de modération</h3>
            <a href="{{ path('app_property_index', { status: 'pending' }) }}" class="text-xs font-semibold text-brand hover:underline">Voir toutes</a>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse text-sm">
                <thead>
                    <tr class="bg-gray-50 text-gray-400 font-semibold border-b border-gray-200 uppercase text-[11px] tracking-wider">
                        <th class="px-6 py-3">Hébergement</th>
                        <th class="px-6 py-3">Hôte</th>
                        <th class="px-6 py-3">Prix / nuit</th>
                        <th class="px-6 py-3">Statut</th>
                        <th class="px-6 py-3 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                    {% for property in pendingProperties %}
                        {% set cover = property.coverMedia %}
                        {% set hostProfile = property.host ? property.host.profile : null %}
                        <tr class="hover:bg-gray-50/70 transition">
                            <td class="px-6 py-4">
                                <div class="flex items-center space-x-3">
                                    <img src="{{ cover ? cover.fileUrl : 'https://images.unsplash.com/photo-1512917774080-9991f1c4c750?auto=format&fit=crop&w=80&q=80' }}" alt="{{ property.title }}" class="w-12 h-12 object-cover rounded-lg">
                                    <div>
                                        <p class="font-semibold text-gray-900">{{ property.title }}</p>
                                        {% if property.address %}
                                            <span class="text-xs text-gray-400">{{ property.address.city }}, {{ property.address.country }}</span>
                                        {% endif %}
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4">
                                {% if hostProfile and (hostProfile.firstName or hostProfile.lastName) %}
                                    {{ hostProfile.firstName }} {{ hostProfile.lastName|first }}.
                                {% else %}
                                    {{ property.host ? property.host.email : '—' }}
                                {% endif %}
                            </td>
                            <td class="px-6 py-4 font-medium text-gray-900">{{ property.pricePerNight|number_format(0, ',', ' ') }} €</td>
                            <td class="px-6 py-4">
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-50 text-amber-800 border border-amber-200"><i class="fa-solid fa-clock text-[8px] mr-1.5"></i> En attente</span>
                            </td>
                            <td class="px-6 py-4 text-right space-x-2">
                                {{ include('admin/property/partials/moderation_actions.html.twig') }}
                                <a href="{{ path('app_property_show', { id: property.id }) }}" class="text-xs text-gray-600 hover:text-gray-900 font-semibold px-2.5 py-1.5 rounded-lg border border-gray-200 hover:bg-gray-50 transition inline-block">Voir</a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="px-6 py-8 text-center text-gray-400">Aucune annonce en attente.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
