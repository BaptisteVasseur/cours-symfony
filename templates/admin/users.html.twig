{% extends 'admin/_layout.html.twig' %}

{% block title %}Utilisateurs — Admin{% endblock %}

{% block admin_content %}
<div class="space-y-6">
    <div class="flex items-center justify-between">
        <h1 class="text-2xl font-bold text-gray-900">Utilisateurs</h1>
        <span class="text-sm text-gray-500">{{ users|length }} utilisateur(s)</span>
    </div>

    <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden">
        <table class="w-full text-sm">
            <thead class="bg-gray-50 border-b border-gray-100">
                <tr>
                    <th class="px-6 py-3 text-left font-medium text-gray-500">Utilisateur</th>
                    <th class="px-6 py-3 text-left font-medium text-gray-500">Rôle</th>
                    <th class="px-6 py-3 text-left font-medium text-gray-500">Réservations</th>
                    <th class="px-6 py-3 text-left font-medium text-gray-500">Logements</th>
                    <th class="px-6 py-3 text-left font-medium text-gray-500">Inscrit le</th>
                    <th class="px-6 py-3 text-left font-medium text-gray-500">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                {% for user in users %}
                    <tr class="hover:bg-gray-50 transition">
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-3">
                                <div class="w-8 h-8 bg-rose-100 rounded-full flex items-center justify-center text-rose-600 font-semibold text-sm flex-shrink-0">
                                    {{ user.firstName|first|upper }}
                                </div>
                                <div>
                                    <p class="font-medium text-gray-900">{{ user.firstName }} {{ user.lastName }}</p>
                                    <p class="text-xs text-gray-400">{{ user.email }}</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4">
                            <span class="px-2.5 py-1 rounded-full text-xs font-medium
                                {% if user.role.value == 'ADMIN' %}bg-purple-100 text-purple-700
                                {% elseif user.role.value == 'HOST' %}bg-blue-100 text-blue-700
                                {% else %}bg-gray-100 text-gray-600{% endif %}">
                                {{ user.role.value|lower|capitalize }}
                            </span>
                        </td>
                        <td class="px-6 py-4 text-gray-600">{{ user.bookings|length }}</td>
                        <td class="px-6 py-4 text-gray-600">{{ user.properties|length }}</td>
                        <td class="px-6 py-4 text-gray-500">{{ user.createdAt|date('d/m/Y') }}</td>
                        <td class="px-6 py-4">
                            <div class="flex items-center gap-2">
                                <a href="{{ path('admin_user_edit', {id: user.id}) }}"
                                   class="text-xs px-3 py-1.5 rounded-lg bg-gray-100 text-gray-700 hover:bg-gray-200 transition font-medium">
                                    Éditer
                                </a>
                                {% if user != app.user %}
                                    <form method="POST" action="{{ path('admin_user_delete', {id: user.id}) }}"
                                          onsubmit="return confirm('Supprimer {{ user.firstName }} {{ user.lastName }} ?')">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_user_' ~ user.id) }}">
                                        <button type="submit"
                                                class="text-xs px-3 py-1.5 rounded-lg bg-red-50 text-red-600 hover:bg-red-100 transition font-medium">
                                            Supprimer
                                        </button>
                                    </form>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
