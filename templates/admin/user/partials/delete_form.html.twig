<form method="post" action="{{ path('app_user_delete', { id: user.id }) }}" onsubmit="return confirm('Confirmer la suppression de cet utilisateur ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
    <button type="submit" class="w-full bg-red-50 hover:bg-red-100 text-red-700 font-semibold text-sm px-4 py-2.5 rounded-lg border border-red-200 transition">
        <i class="fa-solid fa-trash-can text-xs mr-1.5"></i>
        Supprimer l'utilisateur
    </button>
</form>
