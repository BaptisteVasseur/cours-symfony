{% form_theme form 'form/admin_theme.html.twig' %}

{{ form_start(form, { attr: { class: 'space-y-2' } }) }}

<div class="grid grid-cols-1 lg:grid-cols-2 gap-x-6">
    <div>
        <h4 class="text-sm font-bold text-gray-900 mb-4 pb-2 border-b border-gray-100">Compte</h4>
        {{ form_row(form.email) }}
        {{ form_row(form.plainPassword) }}
        {{ form_row(form.phone) }}
        {{ form_row(form.status) }}
        {{ form_row(form.assignedRoles) }}
        {{ form_row(form.isEmailVerified) }}
        {{ form_row(form.is2faEnabled) }}
        <div class="grid grid-cols-2 gap-x-4">
            {{ form_row(form.preferredLanguage) }}
            {{ form_row(form.preferredCurrency) }}
        </div>
    </div>
    <div>
        <h4 class="text-sm font-bold text-gray-900 mb-4 pb-2 border-b border-gray-100">Profil</h4>
        {{ form_row(form.profile.firstName) }}
        {{ form_row(form.profile.lastName) }}
        {{ form_row(form.profile.birthDate) }}
        {{ form_row(form.profile.avatarUrl) }}
        {{ form_row(form.profile.bio) }}
        {{ form_row(form.profile.identityStatus) }}
    </div>
</div>

<div class="flex items-center gap-3 pt-6 mt-6 border-t border-gray-200">
    <button type="submit" class="bg-brand hover:bg-brandHover text-white font-semibold text-sm px-5 py-2.5 rounded-lg transition">
        {{ button_label|default('Enregistrer') }}
    </button>
    <a href="{{ path('app_user_index') }}" class="text-sm font-semibold text-gray-600 hover:text-gray-900 px-4 py-2.5 rounded-lg hover:bg-gray-100 transition">
        Annuler
    </a>
</div>

{{ form_end(form) }}
