{% extends 'layout/admin.html.twig' %}

{% set profile = user.profile %}
{% set roleLabel = user.assignedRoles|length > 0 ? roleLabels[user.assignedRoles|first]|default('Voyageur') : 'Voyageur' %}
{% set displayName = profile and (profile.firstName or profile.lastName) ? (profile.firstName ~ ' ' ~ profile.lastName)|trim : user.email %}
{% set initials = profile and profile.firstName ? profile.firstName|first|upper ~ (profile.lastName ? profile.lastName|first|upper : '') : user.email|first|upper %}

{% set statusLabels = {
    'active': 'Actif',
    'pending': 'En attente',
    'suspended': 'Suspendu',
} %}
{% set statusClasses = {
    'active': 'bg-emerald-50 text-emerald-800 border border-emerald-200',
    'pending': 'bg-amber-50 text-amber-800 border border-amber-200',
    'suspended': 'bg-gray-100 text-gray-700 border border-gray-200',
} %}

{% block page_title %}{{ displayName }}{% endblock %}

{% block content %}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="mb-4 px-4 py-3 rounded-lg text-sm font-medium {{ label == 'success' ? 'bg-emerald-50 text-emerald-800 border border-emerald-200' : 'bg-red-50 text-red-800 border border-red-200' }}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    <div class="mb-6">
        <a href="{{ path('app_user_index') }}" class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-gray-900 transition">
            <i class="fa-solid fa-arrow-left text-xs"></i>
            Retour à la liste
        </a>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">
        <div class="xl:col-span-2 space-y-6">
            <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
                <div class="flex items-start gap-4">
                    <div class="w-16 h-16 bg-gray-200 text-gray-600 rounded-full flex items-center justify-center font-bold text-xl shrink-0 overflow-hidden">
                        {% if profile and profile.avatarUrl %}
                            <img src="{{ profile.avatarUrl }}" alt="{{ displayName }}" class="w-full h-full object-cover">
                        {% else %}
                            {{ initials }}
                        {% endif %}
                    </div>
                    <div class="flex-grow">
                        <div class="flex flex-wrap items-start justify-between gap-3">
                            <div>
                                <h2 class="text-xl font-bold text-gray-900">{{ displayName }}</h2>
                                <p class="text-sm text-gray-500 mt-1">{{ user.email }}</p>
                            </div>
                            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold {{ statusClasses[user.status]|default('bg-gray-100 text-gray-700') }}">
                                {{ statusLabels[user.status]|default(user.status) }}
                            </span>
                        </div>
                        {% if profile and profile.bio %}
                            <p class="text-sm text-gray-600 mt-4 leading-relaxed">{{ profile.bio }}</p>
                        {% endif %}
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
                <h3 class="font-bold text-gray-900 mb-4">Informations du compte</h3>
                <dl class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
                    <div>
                        <dt class="text-gray-400 text-xs uppercase mb-1">Téléphone</dt>
                        <dd class="font-medium text-gray-900">{{ user.phone|default('—') }}</dd>
                    </div>
                    <div>
                        <dt class="text-gray-400 text-xs uppercase mb-1">Rôle principal</dt>
                        <dd class="font-medium text-gray-900">{{ roleLabel }}</dd>
                    </div>
                    <div>
                        <dt class="text-gray-400 text-xs uppercase mb-1">Email vérifié</dt>
                        <dd class="font-medium text-gray-900">{{ user.isEmailVerified ? 'Oui' : 'Non' }}</dd>
                    </div>
                    <div>
                        <dt class="text-gray-400 text-xs uppercase mb-1">2FA</dt>
                        <dd class="font-medium text-gray-900">{{ user.is2faEnabled ? 'Activée' : 'Désactivée' }}</dd>
                    </div>
                    <div>
                        <dt class="text-gray-400 text-xs uppercase mb-1">Langue</dt>
                        <dd class="font-medium text-gray-900">{{ user.preferredLanguage|default('—')|upper }}</dd>
                    </div>
                    <div>
                        <dt class="text-gray-400 text-xs uppercase mb-1">Devise</dt>
                        <dd class="font-medium text-gray-900">{{ user.preferredCurrency|default('—') }}</dd>
                    </div>
                </dl>
            </div>

            {% if profile %}
                <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
                    <h3 class="font-bold text-gray-900 mb-4">Profil</h3>
                    <dl class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
                        <div>
                            <dt class="text-gray-400 text-xs uppercase mb-1">Date de naissance</dt>
                            <dd class="font-medium text-gray-900">{{ profile.birthDate ? profile.birthDate|date('d/m/Y') : '—' }}</dd>
                        </div>
                        <div>
                            <dt class="text-gray-400 text-xs uppercase mb-1">Identité</dt>
                            <dd class="font-medium text-gray-900">{{ profile.identityStatus|default('—') }}</dd>
                        </div>
                    </dl>
                </div>
            {% endif %}

            {{ include('admin/user/partials/documents_section.html.twig') }}

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5 text-center">
                    <p class="text-2xl font-bold text-gray-900">{{ user.properties|length }}</p>
                    <p class="text-xs text-gray-400 uppercase mt-1">Annonces</p>
                </div>
                <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-5 text-center">
                    <p class="text-2xl font-bold text-gray-900">{{ user.reservations|length }}</p>
                    <p class="text-xs text-gray-400 uppercase mt-1">Réservations</p>
                </div>
            </div>
        </div>

        <div class="space-y-6">
            <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
                <h3 class="font-bold text-gray-900 mb-4">Métadonnées</h3>
                <dl class="space-y-3 text-sm">
                    <div>
                        <dt class="text-gray-400 text-xs uppercase">Inscrit le</dt>
                        <dd class="font-medium text-gray-900">{{ user.createdAt|date('d/m/Y H:i') }}</dd>
                    </div>
                    {% if user.updatedAt %}
                        <div>
                            <dt class="text-gray-400 text-xs uppercase">Modifié le</dt>
                            <dd class="font-medium text-gray-900">{{ user.updatedAt|date('d/m/Y H:i') }}</dd>
                        </div>
                    {% endif %}
                    <div>
                        <dt class="text-gray-400 text-xs uppercase">Référence</dt>
                        <dd class="font-mono text-xs text-gray-600 break-all">{{ user.id }}</dd>
                    </div>
                </dl>
            </div>

            {{ include('admin/user/partials/roles_section.html.twig') }}

            <div class="flex flex-col gap-2">
                <a href="{{ path('app_user_edit', { id: user.id }) }}" class="w-full text-center bg-gray-900 hover:bg-gray-700 text-white font-semibold text-sm px-4 py-2.5 rounded-lg transition">
                    Modifier l'utilisateur
                </a>
                {{ include('admin/user/partials/delete_form.html.twig') }}
            </div>
        </div>
    </div>
{% endblock %}
