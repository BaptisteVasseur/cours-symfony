{% extends 'layout/admin.html.twig' %}

{% block page_title %}Utilisateurs{% endblock %}

{% block content %}
    {% include 'partials/_flash_messages.html.twig' %}

    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between gap-3">
            <h2 class="font-bold text-gray-900">Liste des utilisateurs</h2>
            <a href="{{ path('admin_user_new') }}" class="inline-flex items-center gap-2 bg-brand hover:bg-brandHover text-white font-semibold text-sm px-4 py-2 rounded-lg transition">
                <i class="fa-solid fa-plus text-xs"></i>
                Nouvel utilisateur
            </a>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-left text-sm">
                <thead>
                    <tr class="bg-gray-50 text-gray-500 uppercase text-xs">
                        <th class="px-6 py-3">Nom</th>
                        <th class="px-6 py-3">Email</th>
                        <th class="px-6 py-3">Rôles</th>
                        <th class="px-6 py-3 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    {% for user in users %}
                        <tr>
                            <td class="px-6 py-4 font-semibold text-gray-900">{{ (user.firstName ~ ' ' ~ user.lastName)|trim ?: '-' }}</td>
                            <td class="px-6 py-4 text-gray-600">{{ user.email }}</td>
                            <td class="px-6 py-4">
                                <div class="flex flex-wrap gap-1.5">
                                    {% for role in user.roles %}
                                        <span class="inline-flex rounded-full bg-gray-100 px-2.5 py-1 text-xs font-semibold text-gray-700">{{ role }}</span>
                                    {% endfor %}
                                </div>
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex items-center justify-end gap-2">
                                    <a href="{{ path('admin_user_edit', {id: user.id}) }}" class="text-xs bg-gray-900 text-white font-semibold px-3 py-1.5 rounded-lg hover:bg-gray-700 transition">Modifier</a>
                                    <form method="post" action="{{ path('admin_user_delete', {id: user.id}) }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                                        <button type="submit" onclick="return confirm('Supprimer cet utilisateur ?')" class="text-xs text-red-700 bg-red-50 font-semibold px-3 py-1.5 rounded-lg hover:bg-red-100 transition">Supprimer</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="px-6 py-12 text-center text-gray-500">Aucun utilisateur.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
