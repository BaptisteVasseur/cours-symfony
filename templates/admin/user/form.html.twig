{% extends 'layout/admin.html.twig' %}
{% form_theme form 'form/admin_theme.html.twig' %}

{% block page_title %}{{ title }}{% endblock %}

{% block content %}
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
        {{ form_start(form, { attr: { class: 'space-y-6' } }) }}
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                <section class="space-y-2">
                    <h2 class="text-sm font-bold text-gray-900 pb-2 border-b border-gray-100">Identité</h2>
                    {{ form_row(form.firstName) }}
                    {{ form_row(form.lastName) }}
                    {{ form_row(form.email) }}
                    {{ form_row(form.plainPassword) }}
                </section>

                <section class="space-y-2">
                    <h2 class="text-sm font-bold text-gray-900 pb-2 border-b border-gray-100">Rôles</h2>
                    {{ form_row(form.roles) }}
                </section>
            </div>

            <div class="flex items-center gap-3 pt-4 border-t border-gray-200">
                <button type="submit" class="bg-brand hover:bg-brandHover text-white font-semibold text-sm px-5 py-2.5 rounded-lg transition">{{ button_label|default('Enregistrer') }}</button>
                <a href="{{ path('admin_user_index') }}" class="text-sm font-semibold text-gray-600 hover:text-gray-900 px-4 py-2.5 rounded-lg hover:bg-gray-100 transition">Annuler</a>
            </div>
        {{ form_end(form) }}
    </div>
{% endblock %}
