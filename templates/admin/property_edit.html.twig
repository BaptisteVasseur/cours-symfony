{% extends 'admin/_layout.html.twig' %}

{% block title %}Modifier {{ property.title }} — Admin{% endblock %}

{% block admin_content %}
<div class="max-w-2xl space-y-6">
    <div class="flex items-center gap-3">
        <a href="{{ path('admin_properties') }}" class="text-gray-400 hover:text-gray-600 transition">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        </a>
        <h1 class="text-2xl font-bold text-gray-900">Modifier le logement</h1>
    </div>

    <div class="bg-white border border-gray-200 rounded-2xl p-6">
        {{ form_start(form, {attr: {class: 'space-y-5'}}) }}

        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Titre</label>
            {{ form_widget(form.title) }}
            {{ form_errors(form.title) }}
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
            {{ form_widget(form.description) }}
            {{ form_errors(form.description) }}
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Adresse</label>
            {{ form_widget(form.address) }}
            {{ form_errors(form.address) }}
        </div>

        <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Ville</label>
                {{ form_widget(form.city) }}
                {{ form_errors(form.city) }}
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Pays</label>
                {{ form_widget(form.country) }}
                {{ form_errors(form.country) }}
            </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Prix / nuit (€)</label>
                {{ form_widget(form.pricePerNight) }}
                {{ form_errors(form.pricePerNight) }}
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Voyageurs max</label>
                {{ form_widget(form.maxGuests) }}
                {{ form_errors(form.maxGuests) }}
            </div>
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Statut</label>
            {{ form_widget(form.status) }}
            {{ form_errors(form.status) }}
        </div>

        <div class="flex gap-3 pt-2">
            <button type="submit" class="bg-rose-500 text-white px-6 py-2 rounded-xl hover:bg-rose-600 transition font-medium">
                Enregistrer
            </button>
            <a href="{{ path('admin_properties') }}" class="px-6 py-2 rounded-xl border border-gray-300 text-gray-700 hover:bg-gray-50 transition">
                Annuler
            </a>
        </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
