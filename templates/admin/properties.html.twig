{% extends 'admin/_layout.html.twig' %}

{% block title %}Logements — Admin{% endblock %}

{% block admin_content %}
<div class="space-y-6">
    <div class="flex items-center justify-between">
        <h1 class="text-2xl font-bold text-gray-900">Logements</h1>
        <span class="text-sm text-gray-500">{{ properties|length }} logement(s)</span>
    </div>

    <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden">
        {% if properties is empty %}
            <p class="px-6 py-12 text-center text-gray-400">Aucun logement</p>
        {% else %}
            <table class="w-full text-sm">
                <thead class="bg-gray-50 border-b border-gray-100">
                    <tr>
                        <th class="px-6 py-3 text-left font-medium text-gray-500">Logement</th>
                        <th class="px-6 py-3 text-left font-medium text-gray-500">Hôte</th>
                        <th class="px-6 py-3 text-left font-medium text-gray-500">Prix / nuit</th>
                        <th class="px-6 py-3 text-left font-medium text-gray-500">Réservations</th>
                        <th class="px-6 py-3 text-left font-medium text-gray-500">Statut</th>
                        <th class="px-6 py-3 text-left font-medium text-gray-500">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    {% for property in properties %}
                        <tr class="hover:bg-gray-50 transition">
                            <td class="px-6 py-4">
                                <a href="{{ path('app_property_show', {id: property.id}) }}"
                                   class="font-medium text-gray-900 hover:text-rose-500 transition max-w-[180px] block truncate">
                                    {{ property.title }}
                                </a>
                                <p class="text-xs text-gray-400">{{ property.city }}, {{ property.country }}</p>
                            </td>
                            <td class="px-6 py-4 text-gray-600">
                                {{ property.host.firstName }} {{ property.host.lastName }}
                            </td>
                            <td class="px-6 py-4 font-semibold text-gray-900">{{ property.pricePerNight }} €</td>
                            <td class="px-6 py-4 text-gray-600">{{ property.bookings|length }}</td>
                            <td class="px-6 py-4">
                                <span class="px-2.5 py-1 rounded-full text-xs font-medium
                                    {% if property.status.value == 'PUBLISHED' %}bg-green-100 text-green-700
                                    {% elseif property.status.value == 'DRAFT' %}bg-gray-100 text-gray-600
                                    {% else %}bg-red-100 text-red-700{% endif %}">
                                    {{ property.status.value|lower|capitalize }}
                                </span>
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-2">
                                    <a href="{{ path('admin_property_edit', {id: property.id}) }}"
                                       class="text-xs px-3 py-1.5 rounded-lg bg-gray-100 text-gray-700 hover:bg-gray-200 transition font-medium">
                                        Éditer
                                    </a>
                                    <form method="POST" action="{{ path('admin_property_delete', {id: property.id}) }}"
                                          onsubmit="return confirm('Supprimer ce logement et toutes ses données ?')">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_property_' ~ property.id) }}">
                                        <button type="submit"
                                                class="text-xs px-3 py-1.5 rounded-lg bg-red-50 text-red-600 hover:bg-red-100 transition font-medium">
                                            Supprimer
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
</div>
{% endblock %}
