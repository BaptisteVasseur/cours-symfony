{% extends 'layout/base.html.twig' %}

{% block title %}Moderation - {{ logement.titre }}{% endblock %}

{% block body %}
    {% set photo = logement.photos|first %}
    <main class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
        <a href="{{ path('app_admin_logement_index') }}" class="text-sm font-semibold text-rose-600 hover:text-rose-700">Retour aux annonces</a>

        <div class="mt-5 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
            <div>
                <p class="text-sm font-semibold uppercase text-rose-600">Moderation annonce</p>
                <h1 class="mt-2 text-3xl font-bold text-gray-950">{{ logement.titre }}</h1>
                <p class="mt-2 text-sm text-gray-600">Hote : {{ logement.hote.prenom }} {{ logement.hote.nom }}</p>
            </div>
            <span class="rounded-md bg-gray-100 px-3 py-2 text-sm font-semibold text-gray-700">{{ logement.statut.value }}</span>
        </div>

        <div class="mt-8 grid gap-6 lg:grid-cols-[1fr_340px]">
            <section class="space-y-6">
                <img src="{{ photo ? photo.url : 'https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?auto=format&fit=crop&w=1200&q=80' }}" alt="{{ logement.titre }}" class="h-96 w-full rounded-lg object-cover">

                <article class="rounded-lg border border-gray-100 bg-white p-5 shadow-sm">
                    <h2 class="text-lg font-semibold text-gray-950">Description</h2>
                    <p class="mt-4 leading-7 text-gray-700">{{ logement.description }}</p>
                </article>

                <article class="rounded-lg border border-gray-100 bg-white p-5 shadow-sm">
                    <h2 class="text-lg font-semibold text-gray-950">Adresse et capacite</h2>
                    <p class="mt-4 text-sm text-gray-700">{{ logement.adresse ? logement.adresse.adresseLigne1 ~ ', ' ~ logement.adresse.codePostal ~ ' ' ~ logement.adresse.ville ~ ', ' ~ logement.adresse.pays : 'Adresse incomplete' }}</p>
                    <p class="mt-3 text-sm text-gray-700">{{ logement.capaciteVoyageurs }} voyageurs · {{ logement.nombreChambres }} chambres · {{ logement.nombreLits }} lits</p>
                </article>
            </section>

            <aside class="h-fit rounded-lg border border-gray-100 bg-white p-5 shadow-sm">
                <h2 class="text-lg font-semibold text-gray-950">Decision admin</h2>
                <dl class="mt-5 space-y-3 text-sm text-gray-700">
                    <div class="flex justify-between gap-4"><dt>Photos</dt><dd>{{ logement.photos|length }}</dd></div>
                    <div class="flex justify-between gap-4"><dt>Disponibilites</dt><dd>{{ logement.disponibilites|length }}</dd></div>
                    <div class="flex justify-between gap-4"><dt>Prix nuit</dt><dd>{{ logement.tarif ? logement.tarif.prixNuit ~ ' EUR' : 'Non renseigne' }}</dd></div>
                    <div class="flex justify-between gap-4"><dt>Annulation</dt><dd>{{ logement.politiqueAnnulation ? logement.politiqueAnnulation.nom : 'Non renseignee' }}</dd></div>
                </dl>

                {% if logement.statut.value == 'en_attente' %}
                    <div class="mt-6 flex flex-col gap-3">
                        <form method="post" action="{{ path('app_admin_logement_publish', { id: logement.id }) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('admin_logement_publish_' ~ logement.id) }}">
                            <button type="submit" class="w-full rounded-md bg-rose-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-rose-700">Publier</button>
                        </form>
                        <form method="post" action="{{ path('app_admin_logement_return_draft', { id: logement.id }) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('admin_logement_return_draft_' ~ logement.id) }}">
                            <button type="submit" class="w-full rounded-md border border-gray-300 px-4 py-2.5 text-sm font-semibold text-gray-900 hover:border-red-300 hover:text-red-700">Renvoyer en brouillon</button>
                        </form>
                    </div>
                {% else %}
                    <p class="mt-6 rounded-md bg-gray-50 p-4 text-sm text-gray-700">Aucune action disponible pour ce statut.</p>
                {% endif %}
            </aside>
        </div>
    </main>
{% endblock %}
