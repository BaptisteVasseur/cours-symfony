{% extends 'layout/base.html.twig' %}

{% block title %}Annonces a moderer - StayShare{% endblock %}

{% block body %}
    <main class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
        <a href="{{ path('app_admin_dashboard') }}" class="text-sm font-semibold text-rose-600 hover:text-rose-700">Retour admin</a>

        <div class="mt-5">
            <p class="text-sm font-semibold uppercase text-rose-600">Moderation</p>
            <h1 class="mt-2 text-3xl font-bold text-gray-950">Annonces en attente</h1>
            <p class="mt-2 text-sm text-gray-600">Validez les annonces completes pour les rendre visibles publiquement.</p>
        </div>

        <section class="mt-8 grid gap-5">
            {% for logement in logements %}
                {% set photo = logement.photos|first %}
                <article class="grid overflow-hidden rounded-lg border border-gray-100 bg-white shadow-sm sm:grid-cols-[220px_1fr]">
                    <img src="{{ photo ? photo.url : 'https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?auto=format&fit=crop&w=900&q=80' }}" alt="{{ logement.titre }}" class="h-48 w-full object-cover sm:h-full">
                    <div class="p-5">
                        <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
                            <div>
                                <p class="text-sm text-gray-500">Hote : {{ logement.hote.prenom }} {{ logement.hote.nom }}</p>
                                <h2 class="mt-1 text-xl font-semibold text-gray-950">
                                    <a href="{{ path('app_admin_logement_show', { id: logement.id }) }}" class="hover:text-rose-600">{{ logement.titre }}</a>
                                </h2>
                                <p class="mt-2 text-sm text-gray-600">{{ logement.adresse ? logement.adresse.ville ~ ', ' ~ logement.adresse.pays : 'Adresse a confirmer' }}</p>
                            </div>
                            <span class="rounded-md bg-amber-100 px-3 py-2 text-sm font-semibold text-amber-800">{{ logement.statut.value }}</span>
                        </div>
                        <a href="{{ path('app_admin_logement_show', { id: logement.id }) }}" class="mt-5 inline-flex rounded-md border border-gray-200 px-4 py-2 text-sm font-semibold text-gray-900 hover:border-rose-300 hover:text-rose-600">Controler</a>
                    </div>
                </article>
            {% else %}
                <div class="rounded-lg border border-gray-100 bg-white p-8 text-center shadow-sm">
                    <h2 class="text-xl font-semibold text-gray-950">Aucune annonce en attente</h2>
                    <p class="mt-2 text-sm text-gray-600">Les annonces soumises par les hotes apparaitront ici.</p>
                </div>
            {% endfor %}
        </section>
    </main>
{% endblock %}
