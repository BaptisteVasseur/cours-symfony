{% extends 'layout/base.html.twig' %}

{% block body %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex gap-8">
        {# Sidebar #}
        <aside class="w-56 flex-shrink-0">
            <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden">
                <div class="px-4 py-4 border-b border-gray-100 bg-gray-50">
                    <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Administration</p>
                </div>
                <nav class="p-2 space-y-1">
                    <a href="{{ path('admin_dashboard') }}"
                       class="flex items-center gap-3 px-3 py-2 rounded-xl text-sm font-medium transition
                              {{ app.request.attributes.get('_route') == 'admin_dashboard' ? 'bg-rose-50 text-rose-600' : 'text-gray-700 hover:bg-gray-50' }}">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
                        Dashboard
                    </a>
                    <a href="{{ path('admin_bookings') }}"
                       class="flex items-center gap-3 px-3 py-2 rounded-xl text-sm font-medium transition
                              {{ app.request.attributes.get('_route') == 'admin_bookings' ? 'bg-rose-50 text-rose-600' : 'text-gray-700 hover:bg-gray-50' }}">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                        Réservations
                    </a>
                    <a href="{{ path('admin_users') }}"
                       class="flex items-center gap-3 px-3 py-2 rounded-xl text-sm font-medium transition
                              {{ app.request.attributes.get('_route') == 'admin_users' ? 'bg-rose-50 text-rose-600' : 'text-gray-700 hover:bg-gray-50' }}">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
                        Utilisateurs
                    </a>
                    <a href="{{ path('admin_properties') }}"
                       class="flex items-center gap-3 px-3 py-2 rounded-xl text-sm font-medium transition
                              {{ app.request.attributes.get('_route') == 'admin_properties' ? 'bg-rose-50 text-rose-600' : 'text-gray-700 hover:bg-gray-50' }}">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                        Logements
                    </a>
                </nav>
            </div>
        </aside>

        {# Main #}
        <main class="flex-1 min-w-0">
            {% block admin_content %}{% endblock %}
        </main>
    </div>
</div>
{% endblock %}
