{% extends 'admin/_layout.html.twig' %}

{% block title %}Dashboard Admin{% endblock %}

{% block admin_content %}
<div class="space-y-8">
    <h1 class="text-2xl font-bold text-gray-900">Dashboard</h1>

    {# Stat cards #}
    <div class="grid grid-cols-2 lg:grid-cols-3 gap-4">
        <div class="bg-white border border-gray-200 rounded-2xl p-5">
            <p class="text-sm text-gray-500">Réservations totales</p>
            <p class="text-3xl font-bold text-gray-900 mt-1">{{ stats.total_bookings }}</p>
            <div class="flex gap-2 mt-2 text-xs">
                <span class="bg-yellow-100 text-yellow-700 px-2 py-0.5 rounded-full">{{ stats.pending_bookings }} en attente</span>
                <span class="bg-green-100 text-green-700 px-2 py-0.5 rounded-full">{{ stats.confirmed_bookings }} confirmées</span>
            </div>
        </div>

        <div class="bg-white border border-gray-200 rounded-2xl p-5">
            <p class="text-sm text-gray-500">Chiffre d'affaires</p>
            <p class="text-3xl font-bold text-gray-900 mt-1">{{ stats.total_revenue|number_format(0, ',', ' ') }} €</p>
        </div>

        <div class="bg-white border border-gray-200 rounded-2xl p-5">
            <p class="text-sm text-gray-500">Utilisateurs</p>
            <p class="text-3xl font-bold text-gray-900 mt-1">{{ stats.total_users }}</p>
        </div>

        <div class="bg-white border border-gray-200 rounded-2xl p-5">
            <p class="text-sm text-gray-500">Logements</p>
            <p class="text-3xl font-bold text-gray-900 mt-1">{{ stats.total_properties }}</p>
        </div>
    </div>

    {# Recent bookings #}
    <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
            <h2 class="font-semibold text-gray-900">Dernières réservations</h2>
            <a href="{{ path('admin_bookings') }}" class="text-sm text-rose-500 hover:underline">Voir tout</a>
        </div>

        {% if recentBookings is empty %}
            <p class="px-6 py-8 text-sm text-gray-400 text-center">Aucune réservation</p>
        {% else %}
            <div class="divide-y divide-gray-100">
                {% for booking in recentBookings %}
                    <div class="px-6 py-4 flex items-center gap-4">
                        <div class="flex-1 min-w-0">
                            <p class="font-medium text-sm text-gray-900 truncate">{{ booking.property.title }}</p>
                            <p class="text-xs text-gray-500">
                                {{ booking.traveler.firstName }} {{ booking.traveler.lastName }}
                                · {{ booking.checkIn|date('d/m/Y') }} → {{ booking.checkOut|date('d/m/Y') }}
                            </p>
                        </div>
                        <span class="text-sm font-semibold text-gray-900 whitespace-nowrap">{{ booking.totalPrice }} €</span>
                        <span class="text-xs px-2.5 py-1 rounded-full font-medium whitespace-nowrap
                            {% if booking.status.value == 'CONFIRMED' %}bg-green-100 text-green-700
                            {% elseif booking.status.value == 'PENDING' %}bg-yellow-100 text-yellow-700
                            {% elseif booking.status.value == 'CANCELLED' %}bg-red-100 text-red-700
                            {% else %}bg-gray-100 text-gray-700{% endif %}">
                            {{ booking.status.value|lower|capitalize }}
                        </span>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
