{% extends 'layout/base.html.twig' %}

{% block title %}Administration - Tableau de bord{% endblock %}

{% block stylesheets %}
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        [x-cloak] { display: none !important; }
        .sidebar-link { @apply flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium text-gray-600 hover:bg-gray-100 hover:text-gray-900 transition-all; }
        .sidebar-link.active { @apply bg-[#FF385C] bg-opacity-10 text-[#FF385C]; }
    </style>
{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50 flex">

    {# ── Sidebar ── #}
    <aside class="w-64 shrink-0 bg-white border-r border-gray-200 flex flex-col h-screen sticky top-0">
        {# Logo #}
        <div class="flex items-center gap-2 px-6 py-5 border-b border-gray-100">
            <svg class="w-7 h-7 text-[#FF385C]" viewBox="0 0 32 32" fill="currentColor">
                <path d="M16 1C10.5 1 5 7.2 5 13.6c0 8.1 9.2 17 11 18.6.5.4 1.3.4 1.8 0C19.8 30.6 29 21.7 29 13.6 29 7.2 23.5 1 16 1zm0 17a5 5 0 1 1 0-10 5 5 0 0 1 0 10z"/>
            </svg>
            <span class="font-bold text-gray-900 text-lg">Admin</span>
            <span class="ml-auto text-xs bg-[#FF385C] text-white px-2 py-0.5 rounded-full">Pro</span>
        </div>

        {# Nav #}
        <nav class="flex-1 px-3 py-4 space-y-1 overflow-y-auto">
            <p class="px-3 text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Principal</p>
            <a href="#" class="sidebar-link active">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
                Tableau de bord
            </a>
            <a href="#" class="sidebar-link">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                Utilisateurs
                <span class="ml-auto bg-gray-100 text-gray-600 text-xs px-2 py-0.5 rounded-full">{{ users is defined ? users|length : '10' }}</span>
            </a>
            <a href="#" class="sidebar-link">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
                Propriétés
            </a>
            <a href="#" class="sidebar-link">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                Réservations
            </a>
            <a href="#" class="sidebar-link">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                Paiements
            </a>

            <p class="px-3 text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2 mt-6">Modération</p>
            <a href="#" class="sidebar-link">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                Signalements
                <span class="ml-auto bg-red-100 text-red-600 text-xs px-2 py-0.5 rounded-full">3</span>
            </a>
            <a href="#" class="sidebar-link">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
                Avis
            </a>
            <a href="#" class="sidebar-link">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                Journaux d'audit
            </a>
        </nav>

        {# Admin user #}
        <div class="px-4 py-4 border-t border-gray-100">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-[#FF385C] flex items-center justify-center text-white text-sm font-bold">A</div>
                <div class="min-w-0">
                    <p class="text-sm font-semibold text-gray-900 truncate">Administrateur</p>
                    <p class="text-xs text-gray-500 truncate">admin@airbnb.com</p>
                </div>
                <a href="/logout" class="ml-auto text-gray-400 hover:text-gray-600 shrink-0" title="Déconnexion">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
                </a>
            </div>
        </div>
    </aside>

    {# ── Main content ── #}
    <div class="flex-1 flex flex-col min-h-screen">

        {# Top bar #}
        <header class="bg-white border-b border-gray-200 px-8 py-4 flex items-center justify-between shrink-0">
            <div>
                <h1 class="text-xl font-bold text-gray-900">Tableau de bord</h1>
                <p class="text-sm text-gray-500">Bienvenue · {{ "now"|date("d/m/Y") }}</p>
            </div>
            <div class="flex items-center gap-3">
                <button class="relative text-gray-500 hover:text-gray-900 p-2 rounded-full hover:bg-gray-100 transition">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
                    <span class="absolute top-1 right-1 w-2 h-2 bg-red-500 rounded-full"></span>
                </button>
                <button class="bg-[#FF385C] text-white text-sm font-medium px-4 py-2 rounded-xl hover:bg-[#e0314f] transition">
                    + Nouveau logement
                </button>
            </div>
        </header>

        <main class="flex-1 px-8 py-6 space-y-6">

            {# KPI cards #}
            <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
                {% set kpis = [
                    {label: 'Utilisateurs', value: '10', delta: '+2 ce mois', icon: 'users', color: 'blue'},
                    {label: 'Propriétés', value: '248', delta: '+12 ce mois', icon: 'home', color: 'green'},
                    {label: 'Réservations', value: '1 842', delta: '+87 ce mois', icon: 'calendar', color: 'purple'},
                    {label: 'Revenus', value: '94 200 €', delta: '+14 % vs N-1', icon: 'money', color: 'rose'},
                ] %}
                {% for kpi in kpis %}
                <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5">
                    <div class="flex items-start justify-between">
                        <div>
                            <p class="text-sm text-gray-500 font-medium">{{ kpi.label }}</p>
                            <p class="text-2xl font-bold text-gray-900 mt-1">{{ kpi.value }}</p>
                            <p class="text-xs text-green-600 font-medium mt-1">{{ kpi.delta }}</p>
                        </div>
                        <div class="w-10 h-10 rounded-xl
                            {{ kpi.color == 'blue' ? 'bg-blue-50 text-blue-500' : '' }}
                            {{ kpi.color == 'green' ? 'bg-green-50 text-green-500' : '' }}
                            {{ kpi.color == 'purple' ? 'bg-purple-50 text-purple-500' : '' }}
                            {{ kpi.color == 'rose' ? 'bg-rose-50 text-rose-500' : '' }}
                            flex items-center justify-center">
                            {% if kpi.icon == 'users' %}
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                            {% elseif kpi.icon == 'home' %}
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
                            {% elseif kpi.icon == 'calendar' %}
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                            {% else %}
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                            {% endif %}
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>

            {# Users table #}
            <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
                <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
                    <h2 class="font-semibold text-gray-900">Utilisateurs récents</h2>
                    <div class="flex items-center gap-2">
                        <input type="text" placeholder="Rechercher…"
                               class="text-sm border border-gray-200 rounded-xl px-3 py-1.5 focus:outline-none focus:ring-2 focus:ring-[#FF385C] focus:border-transparent w-48">
                        <a href="#" class="text-sm text-[#FF385C] font-medium hover:underline">Voir tout</a>
                    </div>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="text-left text-xs font-semibold text-gray-500 uppercase tracking-wider bg-gray-50">
                                <th class="px-6 py-3">Utilisateur</th>
                                <th class="px-6 py-3">Email</th>
                                <th class="px-6 py-3">Statut</th>
                                <th class="px-6 py-3">Langue</th>
                                <th class="px-6 py-3">Inscription</th>
                                <th class="px-6 py-3 text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-50">
                            {% set demo_users = [
                                {first: 'Alice', last: 'Martin', email: 'alice@example.com', status: 'active', lang: 'FR', date: '01/06/2026', avatar: 'https://i.pravatar.cc/40?img=1'},
                                {first: 'Bob', last: 'Dupont', email: 'bob@example.com', status: 'active', lang: 'FR', date: '01/06/2026', avatar: 'https://i.pravatar.cc/40?img=2'},
                                {first: 'Clara', last: 'Lefebvre', email: 'clara@example.com', status: 'active', lang: 'EN', date: '01/06/2026', avatar: 'https://i.pravatar.cc/40?img=3'},
                                {first: 'David', last: 'Bernard', email: 'david@example.com', status: 'suspended', lang: 'FR', date: '01/06/2026', avatar: 'https://i.pravatar.cc/40?img=4'},
                                {first: 'Emma', last: 'Moreau', email: 'emma@example.com', status: 'active', lang: 'FR', date: '01/06/2026', avatar: 'https://i.pravatar.cc/40?img=5'},
                                {first: 'Fabrice', last: 'Petit', email: 'fabrice@example.com', status: 'active', lang: 'FR', date: '01/06/2026', avatar: 'https://i.pravatar.cc/40?img=6'},
                                {first: 'Grace', last: 'Simon', email: 'grace@example.com', status: 'pending', lang: 'EN', date: '01/06/2026', avatar: 'https://i.pravatar.cc/40?img=7'},
                                {first: 'Hugo', last: 'Laurent', email: 'hugo@example.com', status: 'active', lang: 'FR', date: '01/06/2026', avatar: 'https://i.pravatar.cc/40?img=8'},
                                {first: 'Inès', last: 'Garcia', email: 'ines@example.com', status: 'active', lang: 'ES', date: '01/06/2026', avatar: 'https://i.pravatar.cc/40?img=9'},
                                {first: 'Jules', last: 'Thomas', email: 'jules@example.com', status: 'active', lang: 'FR', date: '01/06/2026', avatar: 'https://i.pravatar.cc/40?img=10'},
                            ] %}

                            {% set real_users = users is defined ? users : demo_users %}

                            {% for u in real_users %}
                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="px-6 py-3">
                                    <div class="flex items-center gap-3">
                                        <img src="{{ u.avatar ?? (u.profile ? u.profile.avatarUrl : 'https://i.pravatar.cc/40') }}"
                                             alt="" class="w-8 h-8 rounded-full object-cover bg-gray-200">
                                        <span class="font-medium text-gray-900">
                                            {{ u.first ?? (u.profile ? u.profile.firstName : '') }}
                                            {{ u.last ?? (u.profile ? u.profile.lastName : '') }}
                                        </span>
                                    </div>
                                </td>
                                <td class="px-6 py-3 text-gray-500">{{ u.email ?? (u.email ?? '') }}</td>
                                <td class="px-6 py-3">
                                    {% set s = u.status ?? (u.status ?? 'active') %}
                                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium
                                        {{ s == 'active' ? 'bg-green-50 text-green-700' : '' }}
                                        {{ s == 'suspended' ? 'bg-red-50 text-red-700' : '' }}
                                        {{ s == 'pending' ? 'bg-yellow-50 text-yellow-700' : '' }}">
                                        <span class="w-1.5 h-1.5 rounded-full
                                            {{ s == 'active' ? 'bg-green-500' : '' }}
                                            {{ s == 'suspended' ? 'bg-red-500' : '' }}
                                            {{ s == 'pending' ? 'bg-yellow-500' : '' }}"></span>
                                        {{ s == 'active' ? 'Actif' : (s == 'suspended' ? 'Suspendu' : 'En attente') }}
                                    </span>
                                </td>
                                <td class="px-6 py-3 text-gray-500">{{ u.lang ?? (u.preferredLanguage ?? '—')|upper }}</td>
                                <td class="px-6 py-3 text-gray-500">{{ u.date ?? (u.createdAt ? u.createdAt|date('d/m/Y') : '—') }}</td>
                                <td class="px-6 py-3 text-right">
                                    <div class="flex items-center justify-end gap-1">
                                        <button class="p-1.5 text-gray-400 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition" title="Voir">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                                        </button>
                                        <button class="p-1.5 text-gray-400 hover:text-amber-600 hover:bg-amber-50 rounded-lg transition" title="Éditer">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                                        </button>
                                        <button class="p-1.5 text-gray-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition" title="Supprimer">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>

                {# Pagination #}
                <div class="px-6 py-3 border-t border-gray-100 flex items-center justify-between text-sm text-gray-500">
                    <span>Affichage de 1 à 10 sur 10 utilisateurs</span>
                    <div class="flex items-center gap-1">
                        <button class="px-3 py-1.5 rounded-lg border border-gray-200 hover:bg-gray-50 transition disabled:opacity-40" disabled>
                            ← Précédent
                        </button>
                        <button class="px-3 py-1.5 rounded-lg bg-[#FF385C] text-white text-xs font-medium">1</button>
                        <button class="px-3 py-1.5 rounded-lg border border-gray-200 hover:bg-gray-50 transition disabled:opacity-40" disabled>
                            Suivant →
                        </button>
                    </div>
                </div>
            </div>

        </main>
    </div>

</div>
{% endblock %}
