{% extends 'layouts/admin.html.twig' %}

{% block title %}Réservations — Admin{% endblock %}

{% block admin_content %}
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-xl font-semibold">Réservations ({{ reservations|length }})</h1>
        <a href="{{ path('admin_reservation_new') }}" class="px-4 py-2 bg-rausch hover:bg-rausch-dark text-white font-semibold rounded-lg transition">
            + Nouvelle
        </a>
    </div>

    <div class="bg-white border border-gray-200 rounded-xl overflow-hidden">
        <table class="w-full text-sm">
            <thead class="bg-gray-50 text-gray-600 text-left">
                <tr>
                    <th class="px-4 py-3 font-medium">Logement</th>
                    <th class="px-4 py-3 font-medium">Voyageur</th>
                    <th class="px-4 py-3 font-medium">Dates</th>
                    <th class="px-4 py-3 font-medium">Total</th>
                    <th class="px-4 py-3 font-medium">Statut</th>
                    <th class="px-4 py-3 font-medium text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                {% for reservation in reservations %}
                    <tr class="hover:bg-gray-50">
                        <td class="px-4 py-3 font-medium">{{ reservation.property ? reservation.property.title : '—' }}</td>
                        <td class="px-4 py-3 text-gray-600">{{ reservation.guest ? reservation.guest.email : '—' }}</td>
                        <td class="px-4 py-3 text-gray-600">{{ reservation.checkinDate|date('d/m/Y') }} → {{ reservation.checkoutDate|date('d/m/Y') }}</td>
                        <td class="px-4 py-3">{{ reservation.totalPrice }} {{ reservation.currency }}</td>
                        <td class="px-4 py-3">{{ reservation.status }}</td>
                        <td class="px-4 py-3">
                            <div class="flex items-center justify-end gap-2">
                                <a href="{{ path('admin_reservation_edit', { id: reservation.id }) }}" class="px-3 py-1.5 text-rausch hover:underline">Modifier</a>
                                <form method="post" action="{{ path('admin_reservation_delete', { id: reservation.id }) }}" onsubmit="return confirm('Supprimer cette réservation ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ reservation.id) }}">
                                    <button class="px-3 py-1.5 text-red-600 hover:underline">Supprimer</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="6" class="px-4 py-6 text-center text-gray-500">Aucune réservation.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
