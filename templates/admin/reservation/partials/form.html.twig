{% form_theme form 'form/admin_theme.html.twig' %}

{{ form_start(form, { attr: { class: 'space-y-2' } }) }}

<div class="grid grid-cols-1 lg:grid-cols-2 gap-x-6">
    <div>
        <h4 class="text-sm font-bold text-gray-900 mb-4 pb-2 border-b border-gray-100">Réservation</h4>
        {{ form_row(form.property) }}
        {{ form_row(form.guest) }}
        <div class="grid grid-cols-2 gap-x-4">
            {{ form_row(form.checkinDate) }}
            {{ form_row(form.checkoutDate) }}
        </div>
        {{ form_row(form.guestsCount) }}
        {{ form_row(form.status) }}
    </div>
    <div>
        <h4 class="text-sm font-bold text-gray-900 mb-4 pb-2 border-b border-gray-100">Tarification</h4>
        {{ form_row(form.totalPrice) }}
        {{ form_row(form.cleaningFee) }}
        {{ form_row(form.serviceFee) }}
        {{ form_row(form.securityDeposit) }}
        {{ form_row(form.currency) }}
        {{ form_row(form.cancellationReason) }}
    </div>
</div>

<div class="flex items-center gap-3 pt-6 mt-6 border-t border-gray-200">
    <button type="submit" class="bg-brand hover:bg-brandHover text-white font-semibold text-sm px-5 py-2.5 rounded-lg transition">
        {{ button_label|default('Enregistrer') }}
    </button>
    <a href="{{ path('app_admin_reservation_index') }}" class="text-sm font-semibold text-gray-600 hover:text-gray-900 px-4 py-2.5 rounded-lg hover:bg-gray-100 transition">
        Annuler
    </a>
</div>

{{ form_end(form) }}
