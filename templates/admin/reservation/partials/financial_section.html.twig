{% set paymentStatusLabels = {
    'pending': 'En attente',
    'succeeded': 'Réussi',
    'failed': 'Échoué',
    'refunded': 'Remboursé',
} %}
{% set payoutStatusLabels = {
    'pending': 'En attente',
    'paid': 'Versé',
    'failed': 'Échoué',
} %}
{% set refundStatusLabels = {
    'pending': 'En attente',
    'succeeded': 'Effectué',
    'failed': 'Échoué',
} %}

<div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
    <h3 class="font-bold text-gray-900 mb-4">Historique financier</h3>

    {% if reservation.invoice %}
        <div class="mb-6 p-4 rounded-lg bg-blue-50/50 border border-blue-100">
            <h4 class="text-sm font-bold text-gray-900 mb-2"><i class="fa-solid fa-file-invoice text-blue-600 mr-1"></i> Facture</h4>
            <dl class="grid grid-cols-2 gap-2 text-sm">
                <div>
                    <dt class="text-gray-400 text-xs">N° facture</dt>
                    <dd class="font-medium">{{ reservation.invoice.invoiceNumber }}</dd>
                </div>
                <div>
                    <dt class="text-gray-400 text-xs">Montant</dt>
                    <dd class="font-medium">{{ reservation.invoice.totalAmount|number_format(2, ',', ' ') }} {{ reservation.currency|default('EUR') }}</dd>
                </div>
                <div>
                    <dt class="text-gray-400 text-xs">Émise le</dt>
                    <dd class="font-medium">{{ reservation.invoice.createdAt|date('d/m/Y') }}</dd>
                </div>
                {% if reservation.invoice.pdfUrl %}
                    <div class="col-span-2">
                        <a href="{{ reservation.invoice.pdfUrl }}" target="_blank" class="text-xs font-semibold text-brand hover:underline">Télécharger le PDF</a>
                    </div>
                {% endif %}
            </dl>
        </div>
    {% endif %}

    {% if reservation.payments|length > 0 %}
        <div class="mb-6">
            <h4 class="text-sm font-bold text-gray-900 mb-3">Paiements</h4>
            <div class="space-y-3">
                {% for payment in reservation.payments %}
                    <div class="p-3 rounded-lg border border-gray-100 bg-gray-50/50 text-sm">
                        <div class="flex justify-between items-start">
                            <div>
                                <p class="font-semibold text-gray-900">{{ payment.amount|number_format(2, ',', ' ') }} {{ payment.currency|default(reservation.currency|default('EUR')) }}</p>
                                <p class="text-xs text-gray-400 mt-0.5">{{ payment.provider|default('Stripe') }} · {{ paymentStatusLabels[payment.status]|default(payment.status) }}</p>
                                {% if payment.paidAt %}
                                    <p class="text-xs text-gray-400">Payé le {{ payment.paidAt|date('d/m/Y H:i') }}</p>
                                {% endif %}
                            </div>
                            <span class="text-xs font-mono text-gray-400">{{ payment.providerPaymentIntent|slice(0, 12) }}…</span>
                        </div>
                        {% if payment.refunds|length > 0 %}
                            <div class="mt-3 pt-3 border-t border-gray-200">
                                <p class="text-xs font-semibold text-gray-500 uppercase mb-2">Remboursements</p>
                                {% for refund in payment.refunds %}
                                    <div class="flex justify-between text-xs text-gray-600 py-1">
                                        <span>{{ refund.reason|default('Remboursement') }} · {{ refundStatusLabels[refund.status]|default(refund.status) }}</span>
                                        <span class="font-medium">−{{ refund.amount|number_format(2, ',', ' ') }} {{ payment.currency|default('EUR') }}</span>
                                    </div>
                                {% endfor %}
                            </div>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
        </div>
    {% endif %}

    {% if reservation.payouts|length > 0 %}
        <div>
            <h4 class="text-sm font-bold text-gray-900 mb-3">Versements hôte</h4>
            <div class="space-y-2">
                {% for payout in reservation.payouts %}
                    <div class="flex justify-between items-center p-3 rounded-lg border border-gray-100 bg-emerald-50/30 text-sm">
                        <div>
                            <p class="font-semibold text-gray-900">{{ payout.amount|number_format(2, ',', ' ') }} {{ payout.currency|default('EUR') }}</p>
                            <p class="text-xs text-gray-400">{{ payoutStatusLabels[payout.status]|default(payout.status) }}{% if payout.paidAt %} · {{ payout.paidAt|date('d/m/Y') }}{% endif %}</p>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    {% endif %}

    {% if reservation.payments|length == 0 and reservation.payouts|length == 0 and not reservation.invoice %}
        <p class="text-sm text-gray-400">Aucune opération financière enregistrée.</p>
    {% endif %}
</div>
