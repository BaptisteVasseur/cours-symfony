<form method="post" action="{{ path('app_admin_reservation_delete', { id: reservation.id }) }}" onsubmit="return confirm('Confirmer la suppression de cette réservation ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ reservation.id) }}">
    <button type="submit" class="w-full bg-red-50 hover:bg-red-100 text-red-700 font-semibold text-sm px-4 py-2.5 rounded-lg border border-red-200 transition">
        <i class="fa-solid fa-trash-can text-xs mr-1.5"></i>
        Supprimer la réservation
    </button>
</form>
