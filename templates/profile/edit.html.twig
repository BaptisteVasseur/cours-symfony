{% extends 'layout/user.html.twig' %}
{% form_theme form 'form/admin_theme.html.twig' %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-3xl mx-auto w-full">
        <div class="mb-8">
            <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">Mon profil</h1>
            <p class="text-gray-500 mt-1">Mettez à jour vos informations personnelles.</p>
        </div>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 px-4 py-3 rounded-lg text-sm font-medium {{ label == 'success' ? 'bg-emerald-50 text-emerald-800 border border-emerald-200' : 'bg-red-50 text-red-800 border border-red-200' }}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
            {{ form_start(form, { attr: { class: 'space-y-2' } }) }}
                <div class="grid grid-cols-1 md:grid-cols-2 gap-x-4">
                    {{ form_row(form.firstName) }}
                    {{ form_row(form.lastName) }}
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-x-4">
                    {{ form_row(form.birthDate) }}
                    {{ form_row(form.avatarUrl) }}
                </div>
                {{ form_row(form.bio) }}

                <div class="flex items-center gap-3 pt-6 mt-6 border-t border-gray-200">
                    <button type="submit" class="bg-brand hover:bg-brandHover text-white font-semibold text-sm px-5 py-2.5 rounded-lg transition">
                        Enregistrer
                    </button>
                    <a href="{{ path('app_home') }}" class="text-sm font-semibold text-gray-600 hover:text-gray-900 px-4 py-2.5 rounded-lg hover:bg-gray-100 transition">
                        Retour
                    </a>
                </div>
            {{ form_end(form) }}
        </div>
    </main>
{% endblock %}
