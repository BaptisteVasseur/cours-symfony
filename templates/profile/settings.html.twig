{% extends 'layout/user.html.twig' %}

{% block title %}Paramètres du compte - Airbnb Clone{% endblock %}

{% block content %}
<div class="container mx-auto px-6 md:px-12 py-10 max-w-4xl">
    <h1 class="text-3xl font-bold text-gray-900 mb-8">Paramètres du compte</h1>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {# Colonne gauche : navigation simple #}
        <div class="space-y-2">
            <a href="{{ path('app_profile_show') }}" class="block w-full text-left px-4 py-2 text-sm text-gray-600 rounded-lg hover:bg-gray-100 font-medium">
                Informations personnelles
            </a>
            <a href="{{ path('app_profile_settings') }}" class="block w-full text-left px-4 py-2 text-sm text-brand bg-brand bg-opacity-5 rounded-lg font-semibold">
                Préférences du compte
            </a>
        </div>

        {# Colonne droite : formulaire #}
        <div class="md:col-span-2">
            <div class="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm">
                <h3 class="text-base font-bold text-gray-950 mb-6">Préférences & Devise</h3>

                {% form_theme form 'form/admin_theme.html.twig' %}
                {{ form_start(form) }}
                
                {{ form_row(form.email) }}
                {{ form_row(form.preferredLanguage) }}
                {{ form_row(form.preferredCurrency) }}

                <div class="flex justify-end gap-3 pt-6 mt-6 border-t border-gray-100">
                    <button type="submit" class="bg-brand hover:bg-brandHover text-white font-semibold text-sm px-5 py-2.5 rounded-lg transition">
                        Enregistrer les préférences
                    </button>
                </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
