{% extends 'layout/base.html.twig' %}

{% block page_title %}{{ listing.title }} – Airbnb Clone{% endblock %}

{% block body %}

{% set typeLabels = {
    'apartment': 'Appartement entier',
    'house':     'Maison entière',
    'villa':     'Villa entière',
    'studio':    'Studio entier',
    'loft':      'Loft entier',
    'chalet':    'Chalet entier',
    'cottage':   'Cottage entier',
} %}

{# ── Calcul note moyenne ── #}
{% set totalRating = 0 %}
{% for review in listing.reviews %}
    {% set totalRating = totalRating + review.rating %}
{% endfor %}
{% set reviewCount = listing.reviews|length %}
{% set avgRating = reviewCount > 0 ? (totalRating / reviewCount)|round(1) : null %}

{# ── Photos triées (position 0 en couverture) ── #}
{% set coverPhoto = null %}
{% set otherPhotos = [] %}
{% for photo in listing.photos %}
    {% if coverPhoto is null and photo.position == 0 %}
        {% set coverPhoto = photo %}
    {% else %}
        {% set otherPhotos = otherPhotos|merge([photo]) %}
    {% endif %}
{% endfor %}
{% if coverPhoto is null and listing.photos|length > 0 %}
    {% set coverPhoto = listing.photos|first %}
    {% set otherPhotos = listing.photos|slice(1) %}
{% endif %}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="mb-4 rounded-lg px-4 py-3 text-sm font-medium
                {% if label == 'success' %}bg-green-50 text-green-700 border border-green-200
                {% else %}bg-red-50 text-red-700 border border-red-200{% endif %}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    {# ── Breadcrumb ── #}
    <nav class="flex items-center gap-1.5 text-sm text-gray-500 mb-4">
        <a href="{{ path('app_home') }}" class="hover:underline">Accueil</a>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-gray-900 font-medium truncate max-w-xs">{{ listing.title }}</span>
    </nav>

    {# ── Titre ── #}
    <h1 class="text-2xl font-semibold text-gray-900 mb-2">{{ listing.title }}</h1>

    {# ── Sous-titre : note + localisation + actions ── #}
    <div class="flex flex-wrap items-center justify-between gap-3 mb-6">
        <div class="flex items-center gap-3 text-sm flex-wrap">
            {% if avgRating %}
                <span class="flex items-center gap-1 font-semibold text-gray-900">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 fill-gray-900" viewBox="0 0 20 20">
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                    </svg>
                    {{ avgRating }}
                </span>
                <span class="text-gray-500">·</span>
                <a href="#reviews" class="text-gray-900 underline">{{ reviewCount }} avis</a>
                <span class="text-gray-500">·</span>
            {% endif %}
            <span class="text-gray-700">{{ listing.city }}, {{ listing.country }}</span>
        </div>

        <div class="flex items-center gap-3 text-sm">
            {% if app.user and app.user == listing.host %}
            <a href="{{ path('host_calendar', {id: listing.id}) }}"
               class="flex items-center gap-1.5 border border-airbnb text-airbnb font-medium px-3 py-1.5 rounded-lg hover:bg-red-50 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                Gérer le calendrier
            </a>
            {% endif %}
            <button class="flex items-center gap-1.5 text-gray-700 hover:text-gray-900 hover:underline">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/>
                </svg>
                Partager
            </button>
            <button class="flex items-center gap-1.5 text-gray-700 hover:text-gray-900 hover:underline">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                </svg>
                Enregistrer
            </button>
        </div>
    </div>

    {# ── Galerie photos ── #}
    <div class="grid grid-cols-4 grid-rows-2 gap-2 rounded-2xl overflow-hidden h-[420px] mb-10 relative">
        {# Photo principale #}
        <div class="col-span-2 row-span-2 bg-gray-200">
            {% if coverPhoto %}
                <img src="{{ coverPhoto.url }}" alt="{{ listing.title }}" class="w-full h-full object-cover">
            {% else %}
                <div class="w-full h-full flex items-center justify-center bg-gray-200">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-20 w-20 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 22V12h6v10"/>
                    </svg>
                </div>
            {% endif %}
        </div>

        {# 4 photos secondaires #}
        {% for i in 0..3 %}
            {% set photo = otherPhotos[i] ?? null %}
            <div class="bg-gray-200">
                {% if photo %}
                    <img src="{{ photo.url }}" alt="{{ listing.title }}" class="w-full h-full object-cover">
                {% else %}
                    <div class="w-full h-full flex items-center justify-center bg-gray-100">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                        </svg>
                    </div>
                {% endif %}
            </div>
        {% endfor %}

        {% if listing.photos|length > 5 %}
            <button class="absolute bottom-4 right-4 flex items-center gap-2 bg-white border border-gray-900 text-gray-900 text-sm font-semibold px-4 py-2 rounded-lg hover:bg-gray-50 shadow transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>
                </svg>
                Voir les {{ listing.photos|length }} photos
            </button>
        {% endif %}
    </div>

    {# ── Contenu principal : 2 colonnes ── #}
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">

        {# ── Colonne gauche ── #}
        <div class="lg:col-span-2 space-y-10">

            {# Type + hôte #}
            <div class="flex items-center justify-between pb-8 border-b border-gray-200">
                <div>
                    <h2 class="text-xl font-semibold text-gray-900">
                        {{ typeLabels[listing.propertyType] ?? listing.propertyType|capitalize }} proposé par
                        {% if listing.host.profile %}
                            {{ listing.host.profile.firstName }}
                        {% else %}
                            l'hôte
                        {% endif %}
                    </h2>
                    <p class="text-gray-500 text-sm mt-1">
                        {{ listing.maxGuests }} voyageur{{ listing.maxGuests > 1 ? 's' }} ·
                        {{ listing.bedrooms }} chambre{{ listing.bedrooms > 1 ? 's' }} ·
                        {{ listing.bathrooms }} salle{{ listing.bathrooms > 1 ? 's' }} de bain
                    </p>
                </div>
                <div class="shrink-0">
                    {% if listing.host.profile and listing.host.profile.avatarUrl %}
                        <img src="{{ listing.host.profile.avatarUrl }}" alt="Hôte" class="h-14 w-14 rounded-full object-cover border border-gray-200">
                    {% else %}
                        <div class="h-14 w-14 rounded-full bg-gray-400 flex items-center justify-center text-white font-semibold text-lg">
                            {% if listing.host.profile %}
                                {{ listing.host.profile.firstName|first|upper }}
                            {% else %}
                                H
                            {% endif %}
                        </div>
                    {% endif %}
                </div>
            </div>

            {# Points forts #}
            <div class="space-y-5 pb-8 border-b border-gray-200">
                <div class="flex items-start gap-4">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 shrink-0 text-gray-700 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 10l1-3m0 0l8-4 8 4M4 7v13a1 1 0 001 1h14a1 1 0 001-1V7M9 21V11h6v10"/>
                    </svg>
                    <div>
                        <p class="font-semibold text-gray-900 text-sm">Logement entier</p>
                        <p class="text-gray-500 text-sm">Vous aurez le logement pour vous seul</p>
                    </div>
                </div>
                <div class="flex items-start gap-4">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 shrink-0 text-gray-700 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    <div>
                        <p class="font-semibold text-gray-900 text-sm">Nettoyage renforcé</p>
                        <p class="text-gray-500 text-sm">Cet hôte s'est engagé à respecter le processus de nettoyage renforcé</p>
                    </div>
                </div>
                {% if listing.cancellationPolicy %}
                    <div class="flex items-start gap-4">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 shrink-0 text-gray-700 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                        </svg>
                        <div>
                            <p class="font-semibold text-gray-900 text-sm">Annulation {{ listing.cancellationPolicy.name }}</p>
                            {% if listing.cancellationPolicy.description %}
                                <p class="text-gray-500 text-sm">{{ listing.cancellationPolicy.description }}</p>
                            {% endif %}
                        </div>
                    </div>
                {% endif %}
            </div>

            {# Description #}
            <div class="pb-8 border-b border-gray-200">
                <p class="text-gray-700 leading-relaxed whitespace-pre-line">{{ listing.description }}</p>
            </div>

            {# Équipements #}
            {% if listing.amenities|length > 0 %}
            <div class="pb-8 border-b border-gray-200">
                <h2 class="text-xl font-semibold text-gray-900 mb-6">Ce que propose ce logement</h2>

                {# Grouper par catégorie #}
                {% set amenitiesByCategory = {} %}
                {% for amenity in listing.amenities %}
                    {% set cat = amenity.category ?? 'Autre' %}
                    {% if amenitiesByCategory[cat] is not defined %}
                        {% set amenitiesByCategory = amenitiesByCategory|merge({ (cat): [] }) %}
                    {% endif %}
                    {% set amenitiesByCategory = amenitiesByCategory|merge({ (cat): amenitiesByCategory[cat]|merge([amenity]) }) %}
                {% endfor %}

                {% for category, items in amenitiesByCategory %}
                    {% if category != 'Autre' %}
                        <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mt-5 mb-3">{{ category }}</h3>
                    {% endif %}
                    <div class="grid grid-cols-2 gap-3">
                        {% for amenity in items %}
                            <div class="flex items-center gap-3 text-sm text-gray-700">
                                {% if amenity.icon %}
                                    <span class="text-lg">{{ amenity.icon }}</span>
                                {% else %}
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                                    </svg>
                                {% endif %}
                                {{ amenity.name }}
                            </div>
                        {% endfor %}
                    </div>
                {% endfor %}
            </div>
            {% endif %}

            {# Avis #}
            <div id="reviews" class="pb-8 border-b border-gray-200">
                <div class="flex items-center gap-3 mb-6">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 fill-gray-900" viewBox="0 0 20 20">
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                    </svg>
                    <h2 class="text-xl font-semibold text-gray-900">
                        {% if avgRating %}
                            {{ avgRating }} · {{ reviewCount }} avis
                        {% else %}
                            Aucun avis pour le moment
                        {% endif %}
                    </h2>
                </div>

                {% if reviewCount > 0 %}
                    {# Barres de progression par catégorie (placeholder visuel) #}
                    <div class="grid grid-cols-2 gap-x-8 gap-y-3 mb-8 text-sm">
                        {% for label in ['Propreté', 'Exactitude', 'Communication', 'Emplacement', 'Arrivée', 'Qualité/prix'] %}
                            <div class="flex items-center justify-between gap-3">
                                <span class="text-gray-700 shrink-0">{{ label }}</span>
                                <div class="flex-1 h-1 bg-gray-200 rounded-full overflow-hidden">
                                    <div class="h-full bg-gray-900 rounded-full" style="width: {{ (avgRating / 5 * 100)|round }}%"></div>
                                </div>
                                <span class="text-gray-900 font-medium shrink-0">{{ avgRating }}</span>
                            </div>
                        {% endfor %}
                    </div>

                    {# Liste des avis #}
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        {% for review in listing.reviews %}
                            <div>
                                <div class="flex items-center gap-3 mb-3">
                                    <div class="h-10 w-10 rounded-full bg-gray-300 flex items-center justify-center text-white font-semibold text-sm shrink-0">
                                        {% if review.reviewer.profile %}
                                            {{ review.reviewer.profile.firstName|first|upper }}
                                        {% else %}
                                            ?
                                        {% endif %}
                                    </div>
                                    <div>
                                        <p class="font-semibold text-gray-900 text-sm">
                                            {% if review.reviewer.profile %}
                                                {{ review.reviewer.profile.firstName }}
                                            {% else %}
                                                Voyageur
                                            {% endif %}
                                        </p>
                                        <p class="text-xs text-gray-400">{{ review.createdAt|date('F Y') }}</p>
                                    </div>
                                </div>
                                <div class="flex items-center gap-0.5 mb-2">
                                    {% for s in 1..5 %}
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 {{ s <= review.rating ? 'fill-gray-900' : 'fill-gray-200' }}" viewBox="0 0 20 20">
                                            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                                        </svg>
                                    {% endfor %}
                                </div>
                                {% if review.comment %}
                                    <p class="text-sm text-gray-700 leading-relaxed">{{ review.comment }}</p>
                                {% endif %}
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <p class="text-sm text-gray-500">Ce logement n'a pas encore reçu d'avis.</p>
                {% endif %}
            </div>

            {# À propos de l'hôte #}
            <div class="pb-8 border-b border-gray-200">
                <h2 class="text-xl font-semibold text-gray-900 mb-6">Hôte : {% if listing.host.profile %}{{ listing.host.profile.firstName }} {{ listing.host.profile.lastName }}{% else %}Hôte{% endif %}</h2>
                <div class="flex items-start gap-5">
                    <div class="shrink-0">
                        {% if listing.host.profile and listing.host.profile.avatarUrl %}
                            <img src="{{ listing.host.profile.avatarUrl }}" alt="Hôte" class="h-16 w-16 rounded-full object-cover">
                        {% else %}
                            <div class="h-16 w-16 rounded-full bg-gray-400 flex items-center justify-center text-white font-bold text-xl">
                                {% if listing.host.profile %}{{ listing.host.profile.firstName|first|upper }}{% else %}H{% endif %}
                            </div>
                        {% endif %}
                    </div>
                    <div class="space-y-1">
                        <p class="text-sm text-gray-500">Membre depuis {{ listing.host.createdAt|date('Y') }}</p>
                        {% if listing.host.profile and listing.host.profile.identityVerified %}
                            <p class="flex items-center gap-1.5 text-sm text-gray-700">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                                </svg>
                                Identité vérifiée
                            </p>
                        {% endif %}
                        {% if listing.host.profile and listing.host.profile.bio %}
                            <p class="text-sm text-gray-700 mt-3 leading-relaxed">{{ listing.host.profile.bio }}</p>
                        {% endif %}
                    </div>
                </div>
            </div>

        </div>{# /colonne gauche #}

        {# ── Colonne droite : widget de réservation ── #}
        <div class="lg:col-span-1">
            <div class="sticky top-24">
                <div class="border border-gray-200 rounded-2xl shadow-lg p-6 space-y-4">

                    {# Prix #}
                    <div class="flex items-baseline gap-2">
                        <span class="text-2xl font-semibold text-gray-900">
                            {{ listing.pricePerNight|number_format(0, ',', '\u{00A0}') }} €
                        </span>
                        <span class="text-gray-500 text-sm">/ nuit</span>
                        {% if avgRating %}
                            <span class="ml-auto flex items-center gap-1 text-sm">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 fill-gray-900" viewBox="0 0 20 20">
                                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                                </svg>
                                <span class="font-medium text-gray-900">{{ avgRating }}</span>
                                <span class="text-gray-400">({{ reviewCount }})</span>
                            </span>
                        {% endif %}
                    </div>

                    {% if not listing.active %}
                    {# ── Logement désactivé ── #}
                    <div class="rounded-xl bg-gray-50 border border-gray-200 p-5 text-center space-y-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 mx-auto text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/>
                        </svg>
                        <p class="text-sm font-semibold text-gray-500">Logement indisponible</p>
                        <p class="text-xs text-gray-400">Ce logement n'accepte pas de réservations pour le moment.</p>
                    </div>

                    {% elseif app.user and app.user != listing.host %}
                    {# ── Formulaire de réservation ── #}
                    <form method="post" action="{{ path('booking_new', {id: listing.id}) }}"
                          x-data="bookingWidget({{ listing.pricePerNight }})"
                          class="space-y-3">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('booking_new_' ~ listing.id) }}">

                        <div class="border border-gray-300 rounded-xl overflow-hidden text-sm">
                            <div class="grid grid-cols-2 divide-x divide-gray-300">
                                <div class="p-3">
                                    <label for="booking_checkin" class="block text-xs font-semibold text-gray-800 uppercase tracking-wide mb-0.5">Arrivée</label>
                                    <input type="date" id="booking_checkin" name="checkin" required
                                           min="{{ 'now'|date('Y-m-d') }}"
                                           x-model="checkin" @change="calcTotal()"
                                           class="w-full text-gray-700 text-sm focus:outline-none bg-transparent">
                                </div>
                                <div class="p-3">
                                    <label for="booking_checkout" class="block text-xs font-semibold text-gray-800 uppercase tracking-wide mb-0.5">Départ</label>
                                    <input type="date" id="booking_checkout" name="checkout" required
                                           x-model="checkout" @change="calcTotal()"
                                           class="w-full text-gray-700 text-sm focus:outline-none bg-transparent">
                                </div>
                            </div>
                            <div class="border-t border-gray-300 p-3">
                                <label for="booking_guests" class="block text-xs font-semibold text-gray-800 uppercase tracking-wide mb-0.5">Voyageurs</label>
                                <input type="number" id="booking_guests" name="guestsCount"
                                       min="1" max="{{ listing.maxGuests }}" value="1"
                                       x-model="guests"
                                       class="w-full text-gray-700 text-sm focus:outline-none bg-transparent">
                            </div>
                        </div>

                        <button type="submit"
                                class="w-full bg-[#FF385C] hover:bg-[#E0324F] text-white font-semibold py-3 rounded-xl transition-colors text-sm">
                            {% if listing.instantBooking %}Réserver{% else %}Envoyer une demande{% endif %}
                        </button>

                        <p class="text-center text-xs text-gray-500">Aucun montant ne sera débité pour l'instant</p>

                        {# Détail dynamique du calcul #}
                        <div class="space-y-2 text-sm text-gray-700 pt-2" x-show="nights > 0">
                            <div class="flex justify-between">
                                <span class="underline" x-text="`${pricePerNight} € × ${nights} nuit${nights > 1 ? 's' : ''}`"></span>
                                <span x-text="`${total} €`"></span>
                            </div>
                            <div class="flex justify-between font-semibold text-gray-900 border-t border-gray-200 pt-3 mt-1">
                                <span>Total</span>
                                <span x-text="`${total} €`"></span>
                            </div>
                        </div>

                    </form>

                    {% elseif not app.user %}
                    <a href="{{ path('app_login') }}"
                       class="block w-full text-center bg-[#FF385C] hover:bg-[#E0324F] text-white font-semibold py-3 rounded-xl transition-colors text-sm">
                        Connectez-vous pour réserver
                    </a>
                    {% else %}
                    <p class="text-center text-sm text-gray-400 py-2">Vous êtes l'hôte de ce logement.</p>
                    {% endif %}

                </div>

                {# Signaler #}
                <p class="text-center mt-4 text-xs text-gray-400 underline cursor-pointer hover:text-gray-600">Signaler ce logement</p>
            </div>
        </div>

    </div>{# /grid principale #}

</div>
{% endblock %}

{% block extra_scripts %}
<script>
function bookingWidget(pricePerNight) {
    return {
        pricePerNight: pricePerNight,
        checkin: '',
        checkout: '',
        guests: 1,
        nights: 0,
        total: 0,
        calcTotal() {
            if (this.checkin && this.checkout) {
                const d1 = new Date(this.checkin);
                const d2 = new Date(this.checkout);
                this.nights = Math.max(0, Math.round((d2 - d1) / 86400000));
                this.total  = this.nights * this.pricePerNight;
            }
        }
    };
}
</script>
{% endblock %}
