{% extends 'layout/user.html.twig' %}

{% set cover = property.coverMedia %}
{% set placeholderImage = 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=800&q=80' %}
{% set hostProfile = property.host ? property.host.profile : null %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-5xl mx-auto w-full">
        <a href="{{ path('app_logement_detail', { id: property.id }) }}" class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-gray-900 mb-6">
            <i class="fa-solid fa-arrow-left"></i>
            Retour au logement
        </a>

        <div class="mb-8">
            <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">Finaliser la réservation</h1>
            <p class="text-gray-500 mt-1">
                {{ property.instantBooking ? 'La réservation sera confirmée immédiatement si les dates sont disponibles.' : 'L’hôte devra valider cette demande avant confirmation.' }}
            </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <section class="lg:col-span-2 border border-gray-200 rounded-xl p-6">
                {{ form_start(form) }}
                    {{ form_errors(form) }}

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        {{ form_row(form.checkinDate) }}
                        {{ form_row(form.checkoutDate) }}
                    </div>

                    <div class="mt-4">
                        {{ form_row(form.guestsCount) }}
                    </div>

                    <button type="submit" class="mt-6 w-full bg-brand hover:bg-brandHover text-white font-semibold py-3 rounded-lg transition">
                        {{ property.instantBooking ? 'Confirmer la réservation' : 'Envoyer la demande' }}
                    </button>
                {{ form_end(form) }}
            </section>

            <aside>
                <div class="border border-gray-200 rounded-xl overflow-hidden sticky top-28">
                    <div class="h-44">
                        <img
                            src="{{ cover ? cover.fileUrl : placeholderImage }}"
                            alt="{{ property.title }}"
                            class="w-full h-full object-cover"
                        >
                    </div>
                    <div class="p-5">
                        <h2 class="font-semibold text-gray-900">{{ property.title }}</h2>
                        {% if property.address %}
                            <p class="text-sm text-gray-500 mt-1">{{ property.address.city }}, {{ property.address.country }}</p>
                        {% endif %}
                        {% if hostProfile %}
                            <p class="text-sm text-gray-500 mt-1">Hôte : {{ hostProfile.firstName }} {{ hostProfile.lastName }}</p>
                        {% endif %}

                        <div class="mt-5 pt-5 border-t border-gray-200">
                            <h3 class="text-sm font-semibold text-gray-900 mb-3">Récapitulatif</h3>
                            {% if priceBreakdown %}
                                <dl class="space-y-2 text-sm">
                                    <div class="flex justify-between">
                                        <dt class="text-gray-500">{{ priceBreakdown.nights }} nuit{{ priceBreakdown.nights > 1 ? 's' : '' }}</dt>
                                        <dd class="font-medium">{{ priceBreakdown.nightsAmount|number_format(2, ',', ' ') }} {{ priceBreakdown.currency }}</dd>
                                    </div>
                                    {% if priceBreakdown.cleaningFee > 0 %}
                                        <div class="flex justify-between">
                                            <dt class="text-gray-500">Frais de ménage</dt>
                                            <dd class="font-medium">{{ priceBreakdown.cleaningFee|number_format(2, ',', ' ') }} {{ priceBreakdown.currency }}</dd>
                                        </div>
                                    {% endif %}
                                    {% if priceBreakdown.serviceFee > 0 %}
                                        <div class="flex justify-between">
                                            <dt class="text-gray-500">Frais de service</dt>
                                            <dd class="font-medium">{{ priceBreakdown.serviceFee|number_format(2, ',', ' ') }} {{ priceBreakdown.currency }}</dd>
                                        </div>
                                    {% endif %}
                                    {% if priceBreakdown.securityDeposit > 0 %}
                                        <div class="flex justify-between">
                                            <dt class="text-gray-500">Caution</dt>
                                            <dd class="font-medium">{{ priceBreakdown.securityDeposit|number_format(2, ',', ' ') }} {{ priceBreakdown.currency }}</dd>
                                        </div>
                                    {% endif %}
                                    <div class="flex justify-between pt-3 border-t border-gray-200 text-base">
                                        <dt class="font-semibold text-gray-900">Total</dt>
                                        <dd class="font-bold text-gray-900">{{ priceBreakdown.totalAmount|number_format(2, ',', ' ') }} {{ priceBreakdown.currency }}</dd>
                                    </div>
                                </dl>
                            {% else %}
                                <p class="text-sm text-gray-500">Sélectionnez des dates valides pour voir le total.</p>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </aside>
        </div>
    </main>
{% endblock %}
