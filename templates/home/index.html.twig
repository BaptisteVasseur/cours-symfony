{% extends 'layout.html.twig' %}

{% block layout %}
    <!-- Hero Section -->
    <section class="hero">
        <h1>Trouvez votre prochaine escapade</h1>
        <p>Découvrez des logements uniques dans plus de 65 000 villes et 191 pays</p>
        <a href="#" class="cta-button">Explorer</a>
    </section>


    <!-- Properties -->
    <section class="properties">
        <h2>Logements populaires</h2>
        <div class="properties-grid">
            {% for property in properties %}
                {% include 'home/parts/_property-card.html.twig' %}
            {% endfor %}
        </div>
    </section>

{% endblock %}
