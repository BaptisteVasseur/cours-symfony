{% extends 'layout/app.html.twig' %}

{% block title %}Airbnb - Locations de vacances, maisons, appartements{% endblock %}

{% block content %}

{# Hero search (mobile) #}
<div class="md:hidden px-4 py-4">
    <button class="w-full flex items-center gap-3 border border-gray-300 rounded-full px-4 py-3 shadow-sm text-left hover:shadow-md transition">
        <svg class="w-4 h-4 text-gray-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <div>
            <p class="text-sm font-semibold text-gray-800">Destination</p>
            <p class="text-xs text-gray-500">N'importe où · N'importe quand · Ajouter des voyageurs</p>
        </div>
    </button>
</div>

{# Properties grid #}
<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">

    {# Filter bar #}
    <div class="flex items-center justify-between mb-6">
        <p class="text-sm text-gray-500">
            <span class="font-semibold text-gray-900">{{ properties|length }}</span> logement{{ properties|length > 1 ? 's' : '' }} disponible{{ properties|length > 1 ? 's' : '' }}
        </p>
        <button class="flex items-center gap-2 border border-gray-300 rounded-xl px-4 py-2 text-sm font-medium text-gray-700 hover:border-gray-900 transition">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2a1 1 0 01-.293.707L13 13.414V19a1 1 0 01-.553.894l-4 2A1 1 0 017 21v-7.586L3.293 6.707A1 1 0 013 6V4z"/>
            </svg>
            Filtres
        </button>
    </div>

    {# Cards grid #}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">

        {% if properties is defined and properties|length > 0 %}
            {% for property in properties %}
            {% set coverMedia = null %}
            {% for media in property.media %}
                {% if media.isCover and coverMedia is null %}{% set coverMedia = media %}{% endif %}
            {% endfor %}

            <a href="{{ path('app_property_show', {id: property.id}) }}" class="property-card group block">
                <div class="relative rounded-2xl overflow-hidden aspect-square bg-gray-100">
                    {% if coverMedia %}
                        <img src="{{ coverMedia.fileUrl }}" alt="{{ property.title }}"
                             class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300">
                    {% else %}
                        <div class="w-full h-full bg-gradient-to-br from-gray-100 to-gray-200 flex items-center justify-center">
                            <svg class="w-16 h-16 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                            </svg>
                        </div>
                    {% endif %}

                    {% if property.instantBooking %}
                    <div class="absolute top-3 left-3 bg-white text-gray-800 text-xs font-semibold px-2.5 py-1 rounded-full shadow-sm">
                        ⚡ Instantané
                    </div>
                    {% endif %}

                    <button class="absolute top-3 right-3 text-white hover:text-[#FF385C] transition-colors" aria-label="Sauvegarder" onclick="event.preventDefault()">
                        <svg class="w-6 h-6 heart-icon drop-shadow-md" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                        </svg>
                    </button>
                </div>

                <div class="mt-3">
                    <div class="flex items-start justify-between gap-2">
                        <p class="font-semibold text-gray-900 text-sm leading-snug line-clamp-1">{{ property.title }}</p>
                        {% if property.reviews|length > 0 %}
                        <div class="flex items-center gap-1 shrink-0">
                            <svg class="w-3.5 h-3.5 text-gray-900" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                            <span class="text-sm text-gray-500">({{ property.reviews|length }})</span>
                        </div>
                        {% endif %}
                    </div>
                    {% if property.address %}
                    <p class="text-sm text-gray-500 mt-0.5">{{ property.address.city }}, {{ property.address.country }}</p>
                    {% endif %}
                    <p class="text-sm text-gray-500">{{ property.bedrooms }} ch. · {{ property.beds }} lit{{ property.beds > 1 ? 's' : '' }}</p>
                    <p class="mt-1 text-sm">
                        <span class="font-semibold text-gray-900">{{ property.pricePerNight|number_format(0, ',', ' ') }} €</span>
                        <span class="text-gray-500"> / nuit</span>
                    </p>
                </div>
            </a>
            {% endfor %}
        {% else %}
            <div class="col-span-4 text-center py-20">
                <div class="text-6xl mb-4">🏠</div>
                <p class="text-gray-500 text-lg">Aucune propriété disponible pour le moment.</p>
            </div>
        {% endif %}

    </div>

    {# Show map button #}
    <div class="fixed bottom-6 left-1/2 -translate-x-1/2 z-40">
        <button class="flex items-center gap-2 bg-gray-900 text-white px-5 py-3 rounded-full shadow-xl hover:bg-gray-700 transition font-medium text-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
            </svg>
            Afficher la carte
        </button>
    </div>

</main>

{% endblock %}
