{% extends 'layout/base.html.twig' %}

{% block page_title %}Airbnb - Locations de vacances, maisons, appartements{% endblock %}

{# ── Filter categories bar (pleine largeur, hors container) ── #}
{% block hero %}
    <div class="border-b border-gray-200 bg-white sticky top-16 z-40">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center gap-6 overflow-x-auto scrollbar-hide py-4 no-scrollbar">

                {% set categories = [
                    { icon: '🏝️', label: 'Plages' },
                    { icon: '🏔️', label: 'Montagne' },
                    { icon: '🏙️', label: 'Villes' },
                    { icon: '🌊', label: 'Bord de mer' },
                    { icon: '🏡', label: 'Maisons' },
                    { icon: '🛖', label: 'Chalets' },
                    { icon: '🏰', label: 'Châteaux' },
                    { icon: '🌴', label: 'Tropiques' },
                    { icon: '🛥️', label: 'Bateaux' },
                    { icon: '🏕️', label: 'Camping' },
                    { icon: '🌾', label: 'Campagne' },
                    { icon: '🎡', label: 'Parcs' },
                    { icon: '🏊', label: 'Piscines' },
                    { icon: '🌋', label: 'Volcans' },
                ] %}

                {% for cat in categories %}
                    <button class="flex flex-col items-center gap-1.5 shrink-0 group {{ loop.first ? 'text-gray-900 border-b-2 border-gray-900 pb-1' : 'text-gray-500 hover:text-gray-900 pb-1' }} transition-colors min-w-[56px]">
                        <span class="text-2xl">{{ cat.icon }}</span>
                        <span class="text-xs font-medium whitespace-nowrap">{{ cat.label }}</span>
                    </button>
                {% endfor %}

            </div>
        </div>

        {# Filters button + map toggle #}
        <div class="border-t border-gray-100 py-2 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto flex items-center justify-between">
            <button class="flex items-center gap-2 border border-gray-300 rounded-xl px-4 py-2 text-sm font-medium text-gray-700 hover:border-gray-900 transition-colors bg-white shadow-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2a1 1 0 01-.293.707L13 13.414V19a1 1 0 01-.553.894l-4 2A1 1 0 017 21v-7.586L3.293 6.707A1 1 0 013 6V4z"/>
                </svg>
                Filtres
            </button>

            <label class="flex items-center gap-2 cursor-pointer">
                <span class="text-sm font-medium text-gray-700">Afficher le total</span>
                <div class="relative">
                    <input type="checkbox" class="sr-only peer">
                    <div class="w-10 h-6 bg-gray-200 rounded-full peer peer-checked:bg-gray-900 transition-colors"></div>
                    <div class="absolute top-1 left-1 w-4 h-4 bg-white rounded-full shadow transition-transform peer-checked:translate-x-4"></div>
                </div>
            </label>
        </div>
    </div>
{% endblock %}

{% block body %}
    <div class="py-6">

        {# Results count #}
        <p class="text-sm text-gray-500 mb-6">Plus de <strong class="text-gray-900">{ listings|length laela} logements</strong> disponibles</p>

        {# Listings grid #}
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-x-6 gap-y-10">


            {% for listings in listings %}
                {% include 'listing/listingcard.html.twig' %}
            {% endfor %}

        </div>

        {# Pagination #}
        <div class="mt-16 flex justify-center">
            <nav class="flex items-center gap-1" aria-label="Pagination">
                <button class="w-10 h-10 flex items-center justify-center rounded-full text-gray-500 hover:bg-gray-100 transition-colors" aria-label="Page précédente">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
                    </svg>
                </button>

                <button class="w-10 h-10 flex items-center justify-center rounded-full text-sm font-semibold bg-gray-900 text-white">1</button>
                <button class="w-10 h-10 flex items-center justify-center rounded-full text-sm text-gray-700 hover:bg-gray-100 transition-colors">2</button>
                <button class="w-10 h-10 flex items-center justify-center rounded-full text-sm text-gray-700 hover:bg-gray-100 transition-colors">3</button>
                <span class="w-10 h-10 flex items-center justify-center text-gray-500 text-sm">…</span>
                <button class="w-10 h-10 flex items-center justify-center rounded-full text-sm text-gray-700 hover:bg-gray-100 transition-colors">24</button>

                <button class="w-10 h-10 flex items-center justify-center rounded-full text-gray-500 hover:bg-gray-100 transition-colors" aria-label="Page suivante">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                    </svg>
                </button>
            </nav>
        </div>

    </div>

    {# Floating map button #}
    <div class="fixed bottom-8 left-1/2 -translate-x-1/2 z-40">
        <button class="flex items-center gap-2 bg-gray-900 text-white text-sm font-semibold px-5 py-3 rounded-full shadow-xl hover:bg-gray-700 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
            </svg>
            Afficher la carte
        </button>
    </div>
{% endblock %}
