{% extends 'layout/user.html.twig' %}

{% block title %}Home - Airbnb{% endblock %}

{% block body %}
<div class="max-w-7xl mx-auto px-6 py-10">

    <h2 class="text-2xl font-semibold text-gray-900 mb-6">Logements disponibles</h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
        {% for property in properties %}
            {% include 'parts/property_card.html.twig' with { property: property } %}
        {% else %}
            <p class="text-gray-500 col-span-full">Aucun logement disponible.</p>
        {% endfor %}
    </div>

</div>
{% endblock %}