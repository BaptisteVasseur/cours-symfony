{% extends 'layout/user.html.twig' %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-5xl mx-auto w-full">
        <div class="mb-8">
            <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">Mes réservations</h1>
            <p class="text-gray-500 mt-1">Historique de toutes vos réservations</p>
        </div>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 px-4 py-3 rounded-lg text-sm font-medium {{ label == 'success' ? 'bg-emerald-50 text-emerald-800 border border-emerald-200' : 'bg-red-50 text-red-800 border border-red-200' }}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        {% if pendingHostReservations is defined and pendingHostReservations|length > 0 %}
            <section class="mb-10">
                <h2 class="text-xl font-semibold text-gray-900 mb-4">Demandes à traiter</h2>
                <div class="space-y-4">
                    {% for reservation in pendingHostReservations %}
                        <div class="border border-amber-200 bg-amber-50 rounded-xl p-4">
                            <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
                                <div>
                                    <p class="font-semibold text-gray-900">{{ reservation.property.title }}</p>
                                    <p class="text-sm text-gray-600">
                                        {{ reservation.checkinDate|date('d/m/Y') }} → {{ reservation.checkoutDate|date('d/m/Y') }}
                                        · {{ reservation.guestsCount }} voyageur{{ reservation.guestsCount > 1 ? 's' : '' }}
                                        · {{ reservation.guest.email }}
                                    </p>
                                </div>
                                <div class="flex flex-col sm:flex-row gap-2">
                                    <form method="post" action="{{ path('app_reservation_accept', { id: reservation.id }) }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('accept' ~ reservation.id) }}">
                                        <button type="submit" class="w-full sm:w-auto bg-gray-900 text-white text-sm font-semibold px-4 py-2 rounded-lg hover:bg-gray-700 transition">
                                            Accepter
                                        </button>
                                    </form>
                                    <a href="{{ path('app_reservation_show', { id: reservation.id }) }}" class="w-full sm:w-auto border border-gray-300 bg-white text-gray-700 text-sm font-semibold px-4 py-2 rounded-lg hover:bg-gray-50 transition text-center">
                                        Refuser / annuler
                                    </a>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </section>
        {% endif %}

        {% if reservations|length > 0 %}
            <div class="space-y-4">
                {% for reservation in reservations %}
                    {% include 'parts/reservation_row.html.twig' with { reservation: reservation } %}
                {% endfor %}
            </div>
        {% else %}
            <div class="text-center py-16 border border-dashed border-gray-200 rounded-xl">
                <i class="fa-solid fa-suitcase-rolling text-4xl text-gray-300 mb-4"></i>
                <p class="text-gray-500">Aucune réservation pour le moment.</p>
                <a href="{{ path('app_home') }}" class="inline-block mt-4 text-brand font-semibold hover:underline">
                    Découvrir des logements
                </a>
            </div>
        {% endif %}
    </main>
{% endblock %}
