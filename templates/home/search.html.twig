{% extends 'layout/user.html.twig' %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8">
        {% include 'parts/search_bar.html.twig' with {
            destination: destination,
            checkin: checkinValue,
            checkout: checkoutValue,
            guests: guests,
        } %}

        {% if searchError %}
            <div class="mb-6 px-4 py-3 rounded-lg text-sm font-medium bg-red-50 text-red-800 border border-red-200">
                {{ searchError }}
            </div>
        {% endif %}

        <div class="mb-8">
            <h2 class="text-xl font-semibold text-gray-900">
                {% if destination %}
                    Logements a {{ destination }}
                {% else %}
                    Logements disponibles
                {% endif %}
            </h2>
            <p class="text-sm text-gray-500 mt-1">
                {% if checkin and checkout %}
                    Du {{ checkin|date('d/m/Y') }} au {{ checkout|date('d/m/Y') }}
                    -
                {% endif %}
                {{ guests }} voyageur{{ guests > 1 ? 's' : '' }}
            </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-6 gap-y-10">
            {% for property in properties %}
                {% include 'parts/card.html.twig' with {
                    property: property,
                    checkin: checkin,
                    checkout: checkout,
                } %}
            {% else %}
                <div class="col-span-full border border-dashed border-gray-200 rounded-xl py-16 text-center">
                    <p class="font-semibold text-gray-900">Aucun logement disponible</p>
                    <p class="text-sm text-gray-500 mt-1">Essayez une autre destination, d'autres dates ou moins de voyageurs.</p>
                </div>
            {% endfor %}
        </div>
    </main>
{% endblock %}
