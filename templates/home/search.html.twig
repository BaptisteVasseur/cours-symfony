{% extends 'layout/user.html.twig' %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8">
        <div class="mb-8">
            <h2 class="text-xl font-semibold text-gray-900">
                {% if destination %}
                    Logements à « {{ destination }} »
                {% else %}
                    Tous les logements disponibles
                {% endif %}
            </h2>
            <p class="text-sm text-gray-500 mt-1">
                {{ properties|length }} logement{{ properties|length > 1 ? 's' : '' }}
                {% if checkin and checkout %}
                    · du {{ checkin|date('d/m/Y') }} au {{ checkout|date('d/m/Y') }}
                {% endif %}
                {% if guests %}· {{ guests }} voyageur{{ guests > 1 ? 's' : '' }}{% endif %}
            </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-6 gap-y-10">
            {% for property in properties %}
                {% include 'parts/card.html.twig' with {
                    property: property,
                    checkin: checkin,
                    checkout: checkout,
                } %}
            {% else %}
                <p class="col-span-full text-gray-500 text-sm">Aucun logement trouvé pour ces critères.</p>
            {% endfor %}
        </div>
    </main>
{% endblock %}
