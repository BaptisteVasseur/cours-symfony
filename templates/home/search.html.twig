{% extends 'layout/user.html.twig' %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8">
        {% include 'parts/search_bar.html.twig' with {
            variant:     'hero',
            destination: destination,
            checkin:     checkin,
            checkout:    checkout,
            guests:      guests,
        } %}

        <div class="mb-6">
            <h2 class="text-xl font-semibold text-gray-900">
                {% if destination %}
                    Logements à {{ destination }}
                {% else %}
                    Tous les logements disponibles
                {% endif %}
            </h2>
            {% if checkin or checkout or guests > 1 %}
                <p class="text-sm text-gray-500 mt-1">
                    {% if checkin and checkout %}
                        Du {{ checkin|date('d/m/Y') }} au {{ checkout|date('d/m/Y') }}
                    {% endif %}
                    {% if guests %}· {{ guests }} voyageur{{ guests > 1 ? 's' : '' }}{% endif %}
                </p>
            {% endif %}
            <p class="text-sm text-gray-400 mt-1">{{ properties|length }} logement{{ properties|length > 1 ? 's' : '' }} trouvé{{ properties|length > 1 ? 's' : '' }}</p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-6 gap-y-10">
            {% for property in properties %}
                {% include 'parts/card.html.twig' with {
                    property: property,
                    checkin:  checkin,
                    checkout: checkout,
                    guests:   guests,
                } %}
            {% else %}
                <div class="col-span-full text-center py-16 border border-dashed border-gray-200 rounded-xl">
                    <i class="fa-solid fa-magnifying-glass text-4xl text-gray-300 mb-4"></i>
                    <p class="text-gray-500">Aucun logement disponible pour ces critères.</p>
                    <a href="{{ path('app_home') }}" class="inline-block mt-4 text-brand font-semibold hover:underline">
                        Voir tous les logements
                    </a>
                </div>
            {% endfor %}
        </div>
    </main>
{% endblock %}
