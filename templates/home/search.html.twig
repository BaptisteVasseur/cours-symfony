{% extends 'layout/base.html.twig' %}

{% block page_title %}Recherche – Airbnb Clone{% endblock %}

{% block body %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    {# ── Barre de recherche ── #}
    <form method="get" action="{{ path('app_search') }}"
          class="flex flex-col sm:flex-row gap-2 mb-8 bg-white border border-gray-200 rounded-2xl shadow-md p-4">
        <div class="flex-1 min-w-0">
            <label class="block text-xs font-semibold text-gray-700 mb-1 uppercase tracking-wide">Destination</label>
            <input type="text" name="destination" value="{{ destination }}"
                   placeholder="Ville, pays…"
                   class="w-full text-sm text-gray-800 placeholder-gray-400 focus:outline-none">
        </div>
        <div class="w-px bg-gray-200 hidden sm:block self-stretch"></div>
        <div class="sm:w-36">
            <label class="block text-xs font-semibold text-gray-700 mb-1 uppercase tracking-wide">Arrivée</label>
            <input type="date" name="checkin" value="{{ checkin }}"
                   min="{{ 'now'|date('Y-m-d') }}"
                   class="w-full text-sm text-gray-800 focus:outline-none">
        </div>
        <div class="w-px bg-gray-200 hidden sm:block self-stretch"></div>
        <div class="sm:w-36">
            <label class="block text-xs font-semibold text-gray-700 mb-1 uppercase tracking-wide">Départ</label>
            <input type="date" name="checkout" value="{{ checkout }}"
                   class="w-full text-sm text-gray-800 focus:outline-none">
        </div>
        <div class="w-px bg-gray-200 hidden sm:block self-stretch"></div>
        <div class="sm:w-28">
            <label class="block text-xs font-semibold text-gray-700 mb-1 uppercase tracking-wide">Voyageurs</label>
            <input type="number" name="guests" value="{{ guests }}" min="1"
                   placeholder="1"
                   class="w-full text-sm text-gray-800 focus:outline-none">
        </div>
        <button type="submit"
                class="bg-[#FF385C] hover:bg-[#E0324F] text-white rounded-xl px-6 py-2.5 text-sm font-semibold transition-colors shrink-0 self-end">
            Rechercher
        </button>
    </form>

    {# ── Résultats ── #}
    <p class="text-sm text-gray-500 mb-6">
        {% if listings|length == 0 %}
            Aucun logement disponible pour cette recherche.
        {% elseif listings|length == 1 %}
            1 logement disponible
        {% else %}
            {{ listings|length }} logements disponibles
        {% endif %}
        {% if destination %} pour <strong class="text-gray-800">{{ destination }}</strong>{% endif %}
        {% if checkin and checkout %} · du <strong class="text-gray-800">{{ checkin|date('d/m/Y') }}</strong> au <strong class="text-gray-800">{{ checkout|date('d/m/Y') }}</strong>{% endif %}
        {% if guests %} · {{ guests }} voyageur{{ guests > 1 ? 's' }}{% endif %}
    </p>

    {% if listings is empty %}
        <div class="text-center py-20 text-gray-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-14 w-14 mx-auto mb-4 opacity-30" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/>
            </svg>
            <p class="text-base font-medium">Aucun résultat</p>
            <p class="text-sm mt-1">Essayez d'autres dates ou une autre destination.</p>
            <a href="{{ path('app_home') }}" class="mt-4 inline-block text-sm text-[#FF385C] hover:underline">Voir tous les logements</a>
        </div>
    {% else %}
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
            {% for listing in listings %}
                {% set coverPhoto = null %}
                {% for photo in listing.photos %}
                    {% if coverPhoto is null and photo.position == 0 %}
                        {% set coverPhoto = photo %}
                    {% endif %}
                {% endfor %}
                {% if coverPhoto is null and listing.photos|length > 0 %}
                    {% set coverPhoto = listing.photos|first %}
                {% endif %}

                {% set totalRating = 0 %}
                {% for review in listing.reviews %}
                    {% set totalRating = totalRating + review.rating %}
                {% endfor %}
                {% set reviewCount = listing.reviews|length %}
                {% set avgRating = reviewCount > 0 ? (totalRating / reviewCount)|round(1) : null %}

                <a href="{{ path('app_listing_details', {id: listing.id}) }}"
                   class="group block rounded-2xl overflow-hidden hover:shadow-lg transition-shadow">
                    <div class="aspect-[4/3] bg-gray-200 overflow-hidden rounded-2xl mb-3">
                        {% if coverPhoto %}
                            <img src="{{ coverPhoto.url }}" alt="{{ listing.title }}"
                                 class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300">
                        {% else %}
                            <div class="w-full h-full flex items-center justify-center bg-gray-200">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 22V12h6v10"/>
                                </svg>
                            </div>
                        {% endif %}
                    </div>
                    <div class="px-1 space-y-0.5">
                        <div class="flex items-start justify-between gap-2">
                            <p class="font-semibold text-gray-900 text-sm leading-snug line-clamp-1">{{ listing.city }}, {{ listing.country }}</p>
                            {% if avgRating %}
                                <span class="flex items-center gap-0.5 text-xs shrink-0 mt-0.5">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 fill-gray-900" viewBox="0 0 20 20">
                                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                                    </svg>
                                    <span class="font-medium text-gray-900">{{ avgRating }}</span>
                                </span>
                            {% endif %}
                        </div>
                        <p class="text-xs text-gray-400 line-clamp-1">{{ listing.title }}</p>
                        {% if checkin and checkout %}
                            <p class="text-xs text-gray-400">{{ checkin }} – {{ checkout }}</p>
                        {% endif %}
                        <p class="text-sm text-gray-900 pt-1">
                            <span class="font-semibold">{{ listing.pricePerNight|number_format(0, ',', '\u{00A0}') }} €</span>
                            <span class="text-gray-500 font-normal"> / nuit</span>
                        </p>
                    </div>
                </a>
            {% endfor %}
        </div>
    {% endif %}

</div>
{% endblock %}
