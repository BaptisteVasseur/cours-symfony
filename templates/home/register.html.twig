{% extends 'layout/user.html.twig' %}

{% block content %}
    <div class="min-h-screen bg-gradient-to-br from-gray-50 to-gray-100 py-12 px-4 sm:px-6 lg:px-8">
        <div class="max-w-md mx-auto bg-white rounded-2xl shadow-lg p-8">
            <div class="mb-8">
                <h1 class="text-3xl font-bold text-gray-900 mb-2">Créer un compte</h1>
                <p class="text-gray-600">Rejoignez-nous et découvrez des expériences uniques</p>
            </div>

            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="mb-4 px-4 py-3 rounded-lg text-sm font-medium {{ label == 'success' ? 'bg-emerald-50 text-emerald-800 border border-emerald-200' : 'bg-red-50 text-red-800 border border-red-200' }}">
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}

            <form action="{{ path('app_register') }}" method="POST" class="space-y-6">
                <input type="hidden" name="_token" value="{{ csrf_token('register') }}">
                <div>
                    <label for="firstName" class="block text-sm font-semibold text-gray-700 mb-2">
                        Prénom
                    </label>
                    <input
                        type="text"
                        id="firstName"
                        name="firstName"
                        placeholder="Jean"
                        value="{{ values.firstName }}"
                        required
                        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent transition placeholder-gray-400"
                    >
                </div>

                <div>
                    <label for="lastName" class="block text-sm font-semibold text-gray-700 mb-2">
                        Nom
                    </label>
                    <input
                        type="text"
                        id="lastName"
                        name="lastName"
                        placeholder="Dupont"
                        value="{{ values.lastName }}"
                        required
                        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent transition placeholder-gray-400"
                    >
                </div>

                <div>
                    <label for="email" class="block text-sm font-semibold text-gray-700 mb-2">
                        Adresse e-mail
                    </label>
                    <input
                        type="email"
                        id="email"
                        name="email"
                        placeholder="vous@exemple.com"
                        value="{{ values.email }}"
                        required
                        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent transition placeholder-gray-400"
                    >
                </div>

                <div>
                    <label for="password" class="block text-sm font-semibold text-gray-700 mb-2">
                        Mot de passe
                    </label>
                    <input
                        type="password"
                        id="password"
                        name="password"
                        placeholder="••••••••"
                        required
                        minlength="8"
                        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent transition placeholder-gray-400"
                    >
                </div>

                <button
                    type="submit"
                    class="w-full bg-brand hover:bg-brandHover text-white font-bold py-3 px-4 rounded-lg transition duration-200 transform hover:scale-105 focus:outline-none focus:ring-2 focus:ring-brand focus:ring-offset-2"
                >
                    S'inscrire
                </button>

                <p class="text-center text-sm text-gray-600">
                    Vous avez déjà un compte?
                    <a href="{{ path('app_login') }}" class="text-brand font-semibold hover:underline">Se connecter</a>
                </p>
            </form>
        </div>
    </div>
{% endblock %}
