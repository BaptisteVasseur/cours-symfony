{% extends 'layout/user.html.twig' %}

{% set property = reservation.property %}
{% set cover = property ? property.coverMedia : null %}
{% set guestProfile = reservation.guest ? reservation.guest.profile : null %}
{% set hostProfile = property and property.host ? property.host.profile : null %}
{% set placeholderImage = 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=800&q=80' %}

{% set statusLabels = {
    'confirmed': 'Confirmée',
    'completed': 'Terminée',
    'pending': 'En attente',
    'cancelled': 'Annulée',
    'expired': 'Expirée',
} %}
{% set statusColors = {
    'confirmed': 'bg-green-100 text-green-800',
    'completed': 'bg-blue-100 text-blue-800',
    'pending': 'bg-yellow-100 text-yellow-800',
    'cancelled': 'bg-red-100 text-red-800',
    'expired': 'bg-gray-100 text-gray-500',
} %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-4xl mx-auto w-full">
        <a href="{{ path('app_reservation_index') }}" class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-gray-900 mb-6">
            <i class="fa-solid fa-arrow-left"></i>
            Retour aux réservations
        </a>

        <div class="mb-8">
            <div class="flex flex-wrap items-center gap-3 mb-2">
                <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">Confirmation de réservation</h1>
                <span class="text-sm font-semibold px-3 py-1 rounded-full {{ statusColors[reservation.status]|default('bg-gray-100 text-gray-800') }}">
                    {{ statusLabels[reservation.status]|default(reservation.status) }}
                </span>
            </div>
            <p class="text-gray-500">Réservation effectuée le {{ reservation.createdAt|date('d/m/Y à H:i') }}</p>
        </div>

        {% if reservation.status in ['confirmed', 'completed'] %}
            <div class="bg-green-50 border border-green-200 rounded-xl p-4 mb-8 flex items-start gap-3">
                <i class="fa-solid fa-circle-check text-green-600 mt-0.5"></i>
                <div>
                    <p class="font-semibold text-green-900">Votre réservation est {{ statusLabels[reservation.status]|lower }}</p>
                    <p class="text-sm text-green-700 mt-1">Un email de confirmation vous a été envoyé.</p>
                </div>
            </div>
        {% elseif reservation.status == 'cancelled' %}
            <div class="bg-red-50 border border-red-200 rounded-xl p-4 mb-8 flex items-start gap-3">
                <i class="fa-solid fa-circle-xmark text-red-600 mt-0.5 shrink-0"></i>
                <div>
                    {% if reservation.cancelledBy == 'admin' %}
                        <p class="font-semibold text-red-900">Votre demande a été refusée par l'administration</p>
                    {% elseif reservation.cancelledBy == 'host' %}
                        <p class="font-semibold text-red-900">Votre demande a été refusée par l'hôte</p>
                    {% elseif reservation.cancelledBy == 'guest' %}
                        <p class="font-semibold text-red-900">Vous avez annulé cette réservation</p>
                    {% else %}
                        <p class="font-semibold text-red-900">Cette réservation a été annulée</p>
                    {% endif %}
                    {% if reservation.cancellationReason %}
                        <p class="text-sm text-red-700 mt-1">Motif : {{ reservation.cancellationReason }}</p>
                    {% endif %}
                </div>
            </div>
        {% endif %}

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <div class="lg:col-span-2 space-y-6">
                {% if property %}
                    <section class="border border-gray-200 rounded-xl overflow-hidden">
                        <div class="flex flex-col sm:flex-row">
                            <div class="sm:w-48 h-40 sm:h-auto shrink-0">
                                <img
                                    src="{{ cover ? cover.fileUrl : placeholderImage }}"
                                    alt="{{ property.title }}"
                                    class="w-full h-full object-cover"
                                >
                            </div>
                            <div class="p-5">
                                <h2 class="text-lg font-semibold text-gray-900 mb-1">{{ property.title }}</h2>
                                {% if property.address %}
                                    <p class="text-sm text-gray-500 mb-3">{{ property.address.addressLine1 }}, {{ property.address.city }}</p>
                                {% endif %}
                                <a href="{{ path('app_logement_detail', { id: property.id }) }}" class="text-sm font-semibold text-brand hover:underline">
                                    Voir le logement
                                </a>
                            </div>
                        </div>
                    </section>
                {% endif %}

                <section class="border border-gray-200 rounded-xl p-6">
                    <h2 class="text-lg font-semibold text-gray-900 mb-4">Détails du séjour</h2>
                    <dl class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
                        <div>
                            <dt class="text-gray-500 mb-1">Arrivée</dt>
                            <dd class="font-semibold text-gray-900">{{ reservation.checkinDate|date('d/m/Y') }}</dd>
                        </div>
                        <div>
                            <dt class="text-gray-500 mb-1">Départ</dt>
                            <dd class="font-semibold text-gray-900">{{ reservation.checkoutDate|date('d/m/Y') }}</dd>
                        </div>
                        <div>
                            <dt class="text-gray-500 mb-1">Voyageurs</dt>
                            <dd class="font-semibold text-gray-900">{{ reservation.guestsCount }}</dd>
                        </div>
                        <div>
                            <dt class="text-gray-500 mb-1">Référence</dt>
                            <dd class="font-semibold text-gray-900 font-mono text-xs">{{ reservation.id }}</dd>
                        </div>
                    </dl>
                </section>

                {% if guestProfile or hostProfile %}
                    <section class="border border-gray-200 rounded-xl p-6">
                        <h2 class="text-lg font-semibold text-gray-900 mb-4">Participants</h2>
                        <div class="space-y-3 text-sm">
                            {% if guestProfile %}
                                <p><span class="text-gray-500">Voyageur :</span> <span class="font-semibold">{{ guestProfile.firstName }} {{ guestProfile.lastName }}</span></p>
                            {% endif %}
                            {% if hostProfile %}
                                <p><span class="text-gray-500">Hôte :</span> <span class="font-semibold">{{ hostProfile.firstName }} {{ hostProfile.lastName }}</span></p>
                            {% endif %}
                        </div>
                    </section>
                {% endif %}
            </div>

            <aside>
                <div class="border border-gray-200 rounded-xl p-6 sticky top-28">
                    <h2 class="text-lg font-semibold text-gray-900 mb-4">Récapitulatif</h2>
                    <dl class="space-y-3 text-sm">
                        <div class="flex justify-between">
                            <dt class="text-gray-500">Sous-total</dt>
                            <dd class="font-medium">{{ reservation.totalPrice|number_format(2, ',', ' ') }} {{ reservation.currency|default('EUR') }}</dd>
                        </div>
                        {% if reservation.cleaningFee %}
                            <div class="flex justify-between">
                                <dt class="text-gray-500">Frais de ménage</dt>
                                <dd class="font-medium">{{ reservation.cleaningFee|number_format(2, ',', ' ') }} {{ reservation.currency|default('EUR') }}</dd>
                            </div>
                        {% endif %}
                        {% if reservation.serviceFee %}
                            <div class="flex justify-between">
                                <dt class="text-gray-500">Frais de service</dt>
                                <dd class="font-medium">{{ reservation.serviceFee|number_format(2, ',', ' ') }} {{ reservation.currency|default('EUR') }}</dd>
                            </div>
                        {% endif %}
                        {% if reservation.securityDeposit %}
                            <div class="flex justify-between">
                                <dt class="text-gray-500">Caution</dt>
                                <dd class="font-medium">{{ reservation.securityDeposit|number_format(2, ',', ' ') }} {{ reservation.currency|default('EUR') }}</dd>
                            </div>
                        {% endif %}
                        <div class="flex justify-between pt-3 border-t border-gray-200 text-base">
                            <dt class="font-semibold text-gray-900">Total</dt>
                            <dd class="font-bold text-gray-900">{{ reservation.totalPrice|number_format(2, ',', ' ') }} {{ reservation.currency|default('EUR') }}</dd>
                        </div>
                    </dl>

                    {% if reservation.payments|length > 0 %}
                        <div class="mt-6 pt-6 border-t border-gray-200">
                            <h3 class="text-sm font-semibold text-gray-900 mb-3">Paiements</h3>
                            <ul class="space-y-2 text-sm">
                                {% for payment in reservation.payments %}
                                    <li class="flex justify-between text-gray-600">
                                        {% set statusLabels = {
                                            'succeeded':  'Payé',
                                            'pending':    'En attente',
                                            'failed':     'Échoué',
                                            'refunded':   'Remboursé',
                                            'cancelled':  'Annulé',
                                        } %}
                                        <span>{{ statusLabels[payment.status] ?? payment.status|capitalize }}</span>
                                        <span>{{ payment.amount|number_format(2, ',', ' ') }} {{ reservation.currency|default('EUR') }}</span>
                                    </li>
                                {% endfor %}
                            </ul>
                        </div>
                    {% endif %}

                    {% if reservation.status in ['pending', 'confirmed'] and app.user and reservation.guest and app.user.id == reservation.guest.id %}
                        <div class="mt-6 pt-6 border-t border-gray-200">
                            <a href="{{ path('booking_cancel', {id: reservation.id}) }}"
                               class="w-full inline-flex items-center justify-center gap-2 bg-red-50 hover:bg-red-100 text-red-700 font-semibold text-sm py-2.5 px-4 rounded-xl transition-colors border border-red-200">
                                <i class="fa-solid fa-circle-xmark"></i>
                                Annuler la réservation
                            </a>
                        </div>
                    {% endif %}
                </div>
            </aside>
        </div>
    </main>
{% endblock %}
