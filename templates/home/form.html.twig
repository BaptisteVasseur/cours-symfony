{% extends 'layout/user.html.twig' %}

{% block title %}Contact - Airbnb{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50 py-12 px-4">
    <div class="max-w-2xl mx-auto">

        {# Breadcrumb #}
        <nav class="mb-8 text-sm text-gray-500 flex items-center gap-2">
            <a href="/" class="hover:underline">Accueil</a>
            <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
            </svg>
            <span class="text-gray-900 font-medium">Nous contacter</span>
        </nav>

        {# Card #}
        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">

            {# Card header #}
            <div class="px-8 pt-8 pb-6 border-b border-gray-100">
                <h1 class="text-2xl font-bold text-gray-900 mb-1">Nous contacter</h1>
                <p class="text-sm text-gray-500">Notre équipe vous répondra dans les 24 heures.</p>
            </div>

            {# Form #}
            <form action="#" method="POST" class="px-8 py-8 space-y-6">

                {# Flash message (optionnel, affiché si session) #}
                {% if app.flashes('success') is defined and app.flashes('success') %}
                    <div class="flex items-start gap-3 bg-green-50 border border-green-200 text-green-800 rounded-xl px-4 py-3 text-sm">
                        <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                        {{ app.flashes('success')[0] }}
                    </div>
                {% endif %}

                {# Ligne Nom + Prénom #}
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div class="flex flex-col gap-1.5">
                        <label for="firstname" class="text-sm font-semibold text-gray-700">
                            Prénom <span class="text-airbnb">*</span>
                        </label>
                        <input
                            type="text"
                            id="firstname"
                            name="firstname"
                            placeholder="Jean"
                            required
                            class="w-full border border-gray-300 rounded-xl px-4 py-3 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-airbnb focus:border-transparent transition"
                        >
                    </div>
                    <div class="flex flex-col gap-1.5">
                        <label for="lastname" class="text-sm font-semibold text-gray-700">
                            Nom <span class="text-airbnb">*</span>
                        </label>
                        <input
                            type="text"
                            id="lastname"
                            name="lastname"
                            placeholder="Dupont"
                            required
                            class="w-full border border-gray-300 rounded-xl px-4 py-3 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-airbnb focus:border-transparent transition"
                        >
                    </div>
                </div>

                {# Email #}
                <div class="flex flex-col gap-1.5">
                    <label for="email" class="text-sm font-semibold text-gray-700">
                        Adresse e-mail <span class="text-airbnb">*</span>
                    </label>
                    <input
                        type="email"
                        id="email"
                        name="email"
                        placeholder="jean.dupont@example.com"
                        required
                        class="w-full border border-gray-300 rounded-xl px-4 py-3 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-airbnb focus:border-transparent transition"
                    >
                </div>

                {# Sujet #}
                <div class="flex flex-col gap-1.5">
                    <label for="subject" class="text-sm font-semibold text-gray-700">Sujet</label>
                    <div class="relative">
                        <select
                            id="subject"
                            name="subject"
                            class="w-full appearance-none border border-gray-300 rounded-xl px-4 py-3 text-sm text-gray-900 bg-white focus:outline-none focus:ring-2 focus:ring-airbnb focus:border-transparent transition"
                        >
                            <option value="" disabled selected>Sélectionnez un sujet</option>
                            <option value="reservation">Problème de réservation</option>
                            <option value="paiement">Paiement</option>
                            <option value="logement">Logement</option>
                            <option value="hote">Devenir hôte</option>
                            <option value="autre">Autre</option>
                        </select>
                        <svg class="pointer-events-none absolute right-4 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                        </svg>
                    </div>
                </div>

                {# Message #}
                <div class="flex flex-col gap-1.5">
                    <label for="message" class="text-sm font-semibold text-gray-700">
                        Message <span class="text-airbnb">*</span>
                    </label>
                    <textarea
                        id="message"
                        name="message"
                        rows="5"
                        required
                        placeholder="Décrivez votre problème ou votre demande..."
                        class="w-full border border-gray-300 rounded-xl px-4 py-3 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-airbnb focus:border-transparent transition resize-none"
                    ></textarea>
                    <p class="text-xs text-gray-400 text-right" id="char-count">0 / 500 caractères</p>
                </div>

                {# RGPD checkbox #}
                <div class="flex items-start gap-3">
                    <input
                        type="checkbox"
                        id="rgpd"
                        name="rgpd"
                        required
                        class="mt-0.5 w-4 h-4 accent-airbnb cursor-pointer flex-shrink-0"
                    >
                    <label for="rgpd" class="text-sm text-gray-600 cursor-pointer leading-relaxed">
                        J'accepte que mes données soient traitées conformément à la
                        <a href="#" class="text-airbnb underline hover:text-airbnb-dark">politique de confidentialité</a>
                        d'Airbnb. <span class="text-airbnb">*</span>
                    </label>
                </div>

                {# Divider #}
                <div class="border-t border-gray-100 pt-2"></div>

                {# Actions #}
                <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
                    <p class="text-xs text-gray-400 order-2 sm:order-1">
                        <span class="text-airbnb">*</span> Champs obligatoires
                    </p>
                    <button
                        type="submit"
                        class="order-1 sm:order-2 w-full sm:w-auto bg-airbnb hover:bg-airbnb-dark text-white font-semibold text-sm px-8 py-3.5 rounded-xl transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-airbnb"
                    >
                        Envoyer le message
                    </button>
                </div>

            </form>
        </div>

        {# Aide rapide #}
        <div class="mt-6 text-center text-sm text-gray-500">
            Besoin d'une réponse rapide ?
            <a href="#" class="text-gray-900 font-semibold underline hover:text-airbnb transition-colors ml-1">
                Consultez notre Centre d'aide →
            </a>
        </div>

    </div>
</div>

{% block javascripts %}
{{ parent() }}
<script>
    const textarea = document.getElementById('message');
    const counter  = document.getElementById('char-count');
    const max = 500;

    textarea.addEventListener('input', () => {
        const len = textarea.value.length;
        counter.textContent = len + ' / ' + max + ' caractères';
        counter.style.color = len > max ? '#E31C5F' : '';
        if (len > max) textarea.value = textarea.value.slice(0, max);
    });
</script>
{% endblock %}
{% endblock %}
