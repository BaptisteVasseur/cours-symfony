{% extends 'layout/user.html.twig' %}

{% set cover = property.coverMedia %}
{% set placeholderImage = 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=800&q=80' %}

{% block title %}Récapitulatif — {{ property.title }}{% endblock %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-4xl mx-auto w-full">
        <a href="{{ path('app_logement_detail', { id: property.id }) }}" class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-gray-900 mb-6">
            <i class="fa-solid fa-arrow-left"></i> Retour au logement
        </a>

        <h1 class="text-2xl md:text-3xl font-semibold text-gray-900 mb-8">Confirmer et payer</h1>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 px-4 py-3 rounded-lg text-sm font-medium {{ label == 'success' ? 'bg-emerald-50 text-emerald-800 border border-emerald-200' : 'bg-red-50 text-red-800 border border-red-200' }}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
            <div class="space-y-6">
                <section class="border border-gray-200 rounded-xl p-6">
                    <h2 class="text-lg font-semibold text-gray-900 mb-4">Votre voyage</h2>
                    <dl class="space-y-3 text-sm">
                        <div class="flex justify-between"><dt class="text-gray-500">Arrivée</dt><dd class="font-semibold">{{ checkin|date('d/m/Y') }}</dd></div>
                        <div class="flex justify-between"><dt class="text-gray-500">Départ</dt><dd class="font-semibold">{{ checkout|date('d/m/Y') }}</dd></div>
                        <div class="flex justify-between"><dt class="text-gray-500">Voyageurs</dt><dd class="font-semibold">{{ guests }}</dd></div>
                        <div class="flex justify-between"><dt class="text-gray-500">Nuits</dt><dd class="font-semibold">{{ price.nights }}</dd></div>
                    </dl>
                </section>

                {% if not available %}
                    <div class="px-4 py-3 rounded-lg text-sm font-medium bg-red-50 text-red-800 border border-red-200">
                        Ces dates ne sont pas disponibles pour ce logement (capacité, dates bloquées ou déjà réservées).
                    </div>
                {% elseif property.instantBooking %}
                    <div class="px-4 py-3 rounded-lg text-sm font-medium bg-emerald-50 text-emerald-800 border border-emerald-200">
                        Réservation instantanée : votre séjour sera confirmé immédiatement.
                    </div>
                {% else %}
                    <div class="px-4 py-3 rounded-lg text-sm font-medium bg-amber-50 text-amber-800 border border-amber-200">
                        Réservation sur demande : l'hôte devra valider votre demande.
                    </div>
                {% endif %}
            </div>

            <aside>
                <div class="border border-gray-200 rounded-xl p-6 sticky top-28">
                    <div class="flex gap-4 pb-4 border-b border-gray-200 mb-4">
                        <img src="{{ cover ? cover.fileUrl : placeholderImage }}" alt="{{ property.title }}" class="w-20 h-20 rounded-lg object-cover">
                        <div>
                            <p class="font-semibold text-gray-900">{{ property.title }}</p>
                            {% if property.address %}<p class="text-sm text-gray-500">{{ property.address.city }}</p>{% endif %}
                        </div>
                    </div>

                    <h2 class="text-base font-semibold text-gray-900 mb-3">Détails du prix</h2>
                    <dl class="space-y-2 text-sm">
                        <div class="flex justify-between"><dt class="text-gray-500">{{ property.pricePerNight|number_format(0, ',', ' ') }} € × {{ price.nights }} nuit(s)</dt><dd>{{ price.subtotal|number_format(2, ',', ' ') }} €</dd></div>
                        {% if price.cleaningFee > 0 %}
                            <div class="flex justify-between"><dt class="text-gray-500">Frais de ménage</dt><dd>{{ price.cleaningFee|number_format(2, ',', ' ') }} €</dd></div>
                        {% endif %}
                        <div class="flex justify-between"><dt class="text-gray-500">Frais de service</dt><dd>{{ price.serviceFee|number_format(2, ',', ' ') }} €</dd></div>
                        <div class="flex justify-between pt-3 border-t border-gray-200 text-base font-bold"><dt>Total</dt><dd>{{ price.total|number_format(2, ',', ' ') }} €</dd></div>
                    </dl>

                    <form method="post" action="{{ path('app_reservation_checkout', { id: property.id }) }}" class="mt-6">
                        <input type="hidden" name="_token" value="{{ csrf_token('checkout' ~ property.id) }}">
                        <input type="hidden" name="checkin" value="{{ checkin|date('Y-m-d') }}">
                        <input type="hidden" name="checkout" value="{{ checkout|date('Y-m-d') }}">
                        <input type="hidden" name="guests" value="{{ guests }}">
                        <button type="submit" {{ available ? '' : 'disabled' }}
                                class="w-full font-semibold py-3 rounded-lg transition {{ available ? 'bg-brand hover:bg-brandHover text-white' : 'bg-gray-200 text-gray-400 cursor-not-allowed' }}">
                            {{ property.instantBooking ? 'Réserver' : 'Envoyer la demande' }}
                        </button>
                    </form>
                </div>
            </aside>
        </div>
    </main>
{% endblock %}
