{% extends 'layouts/base.html.twig' %}

{% block title %}Mes réservations — Airstay{% endblock %}

{% block header %}
    {% include 'components/_header_user.html.twig' %}
{% endblock %}

{% block body %}
    <section class="max-w-3xl mx-auto px-6 py-10">
        <h1 class="text-3xl font-bold mb-6">Historique des réservations</h1>

        <div class="space-y-4">
            {% for reservation in reservations %}
                {% include 'components/_reservation_row.html.twig' with { reservation: reservation } %}
            {% else %}
                <p class="text-gray-500">Aucune réservation pour le moment.</p>
            {% endfor %}
        </div>
    </section>
{% endblock %}
