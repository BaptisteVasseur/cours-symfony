{% extends 'layout/base.html.twig' %}

{% block title %}Réservation confirmée !{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto px-4 py-16 text-center">

    <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
        <svg class="w-10 h-10 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
    </div>

    <h1 class="text-3xl font-bold text-gray-900 mb-2">Réservation confirmée !</h1>
    <p class="text-gray-500 mb-10">Votre séjour chez <strong>{{ booking.property.host.firstName }}</strong> est enregistré.</p>

    <div class="bg-white border border-gray-200 rounded-2xl p-6 text-left shadow-sm mb-8">

        {% if booking.property.images.first %}
            <img src="{{ booking.property.images.first.imageUrl }}" alt="" class="w-full h-48 object-cover rounded-xl mb-6">
        {% endif %}

        <h2 class="text-xl font-semibold text-gray-900 mb-1">{{ booking.property.title }}</h2>
        <p class="text-sm text-gray-500 mb-6">{{ booking.property.city }}, {{ booking.property.country }}</p>

        <div class="grid grid-cols-2 gap-4 py-4 border-t border-b border-gray-100 mb-6">
            <div>
                <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Arrivée</p>
                <p class="font-semibold text-gray-900">{{ booking.checkIn|date('D d M Y') }}</p>
            </div>
            <div>
                <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Départ</p>
                <p class="font-semibold text-gray-900">{{ booking.checkOut|date('D d M Y') }}</p>
            </div>
            <div>
                <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Voyageurs</p>
                <p class="font-semibold text-gray-900">{{ booking.guestsCount }}</p>
            </div>
            <div>
                <p class="text-xs text-gray-400 uppercase tracking-wide mb-1">Durée</p>
                <p class="font-semibold text-gray-900">{{ booking.nights }} nuit(s)</p>
            </div>
        </div>

        <div class="flex justify-between items-center">
            <p class="text-gray-500 text-sm">{{ booking.property.pricePerNight }} € × {{ booking.nights }} nuits</p>
            <p class="text-2xl font-bold text-gray-900">{{ booking.totalPrice }} €</p>
        </div>
    </div>

    <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="{{ path('app_booking_index') }}" class="bg-rose-500 hover:bg-rose-600 text-white font-semibold px-6 py-3 rounded-xl transition">
            Voir mes réservations
        </a>
        <a href="{{ path('app_home') }}" class="border border-gray-300 text-gray-700 font-semibold px-6 py-3 rounded-xl hover:bg-gray-50 transition">
            Retour à l'accueil
        </a>
    </div>

</div>
{% endblock %}
