{% extends 'layout/base.html.twig' %}

{% block title %}Gestion des réservations — HomeStay{% endblock %}

{% block body %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold text-gray-900">{{ is_granted('ROLE_ADMIN') ? 'Toutes les réservations' : 'Mes réservations' }}</h1>
        <a href="{{ path('app_booking_new') }}" class="px-4 py-2 bg-[#FF385C] text-white font-semibold rounded-lg hover:bg-[#E11D48] transition">+ Nouvelle réservation</a>
    </div>

    <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden">
        <table class="w-full text-sm">
            <thead class="bg-gray-50 text-left text-gray-500">
                <tr>
                    <th class="px-4 py-3 font-medium">Logement</th>
                    <th class="px-4 py-3 font-medium">Voyageur</th>
                    <th class="px-4 py-3 font-medium">Dates</th>
                    <th class="px-4 py-3 font-medium">Total</th>
                    <th class="px-4 py-3 font-medium">Statut</th>
                    <th class="px-4 py-3 font-medium text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                {% for booking in bookings %}
                    <tr class="hover:bg-gray-50">
                        <td class="px-4 py-3 font-medium text-gray-900">{{ booking.listing ? booking.listing.title : '—' }}</td>
                        <td class="px-4 py-3 text-gray-600">{{ booking.guest ? booking.guest.firstName ~ ' ' ~ booking.guest.lastName : '—' }}</td>
                        <td class="px-4 py-3 text-gray-600">{{ booking.checkIn ? booking.checkIn|date('d/m/Y') : '?' }} → {{ booking.checkOut ? booking.checkOut|date('d/m/Y') : '?' }}</td>
                        <td class="px-4 py-3 text-gray-600">{{ booking.totalAmount }} {{ booking.currency ?? 'EUR' }}</td>
                        <td class="px-4 py-3">
                            {% set s = booking.bookingStatus %}
                            <span class="px-2 py-1 rounded-full text-xs
                                {{ s == 'confirmed' ? 'bg-green-100 text-green-700' :
                                   (s == 'completed' ? 'bg-blue-100 text-blue-700' :
                                   (s == 'cancelled' ? 'bg-red-100 text-red-700' : 'bg-yellow-100 text-yellow-700')) }}">{{ s }}</span>
                        </td>
                        <td class="px-4 py-3">
                            <div class="flex justify-end gap-2">
                                <a href="{{ path('app_booking_show', {id: booking.id}) }}" class="text-gray-500 hover:text-[#FF385C]">Voir</a>
                                <a href="{{ path('app_booking_edit', {id: booking.id}) }}" class="text-gray-500 hover:text-[#FF385C]">Éditer</a>
                                <form method="post" action="{{ path('app_booking_delete', {id: booking.id}) }}" onsubmit="return confirm('Supprimer cette réservation ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ booking.id) }}">
                                    <button class="text-gray-500 hover:text-red-600">Suppr.</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="6" class="px-4 py-8 text-center text-gray-400">Aucune réservation.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
