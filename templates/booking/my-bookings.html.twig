{% extends 'layout/user.html.twig' %}

{% set statusLabels = {
    'confirmed': 'Confirmée',
    'completed': 'Terminée',
    'pending': 'En attente',
    'cancelled': 'Annulée',
    'expired': 'Expirée',
} %}
{% set statusColors = {
    'confirmed': 'bg-green-100 text-green-800',
    'completed': 'bg-blue-100 text-blue-800',
    'pending': 'bg-yellow-100 text-yellow-800',
    'cancelled': 'bg-red-100 text-red-800',
    'expired': 'bg-gray-100 text-gray-500',
} %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-5xl mx-auto w-full">
        <div class="mb-8">
            <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">Mes réservations</h1>
            <p class="text-gray-500 mt-1">Historique de toutes vos réservations</p>
        </div>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                {% if label == 'booking_confirmed' %}
                    <div class="mb-6 bg-green-50 border border-green-200 rounded-2xl px-5 py-4 flex items-start gap-4">
                        <div class="shrink-0 w-10 h-10 rounded-full bg-green-100 flex items-center justify-center">
                            <i class="fa-solid fa-circle-check text-green-600 text-base"></i>
                        </div>
                        <div>
                            <p class="font-semibold text-green-800">Réservation confirmée !</p>
                            <p class="text-green-700 text-sm mt-0.5">{{ message }}</p>
                        </div>
                    </div>
                {% elseif label == 'booking_pending' %}
                    <div class="mb-6 bg-amber-50 border border-amber-200 rounded-2xl px-5 py-4 flex items-start gap-4">
                        <div class="shrink-0 w-10 h-10 rounded-full bg-amber-100 flex items-center justify-center">
                            <i class="fa-solid fa-clock text-amber-600 text-base"></i>
                        </div>
                        <div>
                            <p class="font-semibold text-amber-800">Demande envoyée</p>
                            <p class="text-amber-700 text-sm mt-0.5">{{ message }}</p>
                        </div>
                    </div>
                {% elseif label == 'error' %}
                    <div class="mb-4 px-4 py-3 rounded-lg text-sm bg-red-50 text-red-700 border border-red-200">
                        {{ message }}
                    </div>
                {% else %}
                    <div class="mb-4 px-4 py-3 rounded-lg text-sm bg-green-50 text-green-700 border border-green-200">
                        {{ message }}
                    </div>
                {% endif %}
            {% endfor %}
        {% endfor %}

        {% if reservationsByYear|length > 0 %}
            <div class="space-y-10">
                {% for year, reservations in reservationsByYear %}
                    <div>
                        <div class="flex items-center gap-3 mb-4">
                            <span class="text-xs font-bold text-gray-400 uppercase tracking-widest">{{ year }}</span>
                            <div class="flex-1 h-px bg-gray-200"></div>
                            <span class="text-xs text-gray-400">{{ reservations|length }} réservation{{ reservations|length > 1 ? 's' : '' }}</span>
                        </div>
                        <div class="space-y-4">
                {% for reservation in reservations %}
                    {% set property = reservation.property %}
                    {% set cover = property ? property.coverMedia : null %}
                    {% set placeholderImage = 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=800&q=80' %}

                    <div class="bg-white border border-gray-200 rounded-2xl p-5 flex flex-col sm:flex-row gap-4 hover:shadow-sm transition-shadow">
                        <img
                            src="{{ cover ? cover.fileUrl : placeholderImage }}"
                            alt="{{ property ? property.title : 'Logement' }}"
                            class="w-full sm:w-32 h-32 sm:h-24 object-cover rounded-xl flex-shrink-0"
                        >
                        <div class="flex-1 min-w-0">
                            <div class="flex flex-wrap items-start justify-between gap-2 mb-1">
                                <h2 class="font-semibold text-gray-900 truncate">
                                    {{ property ? property.title : 'Logement supprimé' }}
                                </h2>
                                <span class="text-xs font-semibold px-2.5 py-1 rounded-full whitespace-nowrap {{ statusColors[reservation.status]|default('bg-gray-100 text-gray-800') }}">
                                    {{ statusLabels[reservation.status]|default(reservation.status) }}
                                </span>
                            </div>
                            {% if property and property.address %}
                                <p class="text-sm text-gray-500">{{ property.address.city }}</p>
                            {% endif %}
                            <p class="text-sm text-gray-600 mt-1">
                                {{ reservation.checkinDate|date('d/m/Y') }} → {{ reservation.checkoutDate|date('d/m/Y') }}
                                · {{ reservation.guestsCount }} voyageur(s)
                            </p>
                            <p class="text-sm font-semibold text-gray-900 mt-1">{{ reservation.totalPrice }} €</p>
                            {% if reservation.status == 'cancelled' and reservation.cancellationReason %}
                                <p class="text-xs text-red-600 mt-1.5 flex items-start gap-1">
                                    <i class="fa-solid fa-circle-info mt-0.5 shrink-0"></i>
                                    <span>
                                        {% if reservation.cancelledBy == 'admin' %}Refusée par l'administration
                                        {% elseif reservation.cancelledBy == 'host' %}Refusée par l'hôte
                                        {% else %}Annulée{% endif %}
                                         — {{ reservation.cancellationReason }}
                                    </span>
                                </p>
                            {% endif %}
                        </div>
                        <div class="flex sm:flex-col gap-2 items-start sm:items-end justify-end sm:justify-start">
                            <a href="{{ path('app_reservation_show', {id: reservation.id}) }}"
                               class="text-xs text-brand hover:underline font-medium">
                                Voir le détail
                            </a>
                            {% if property %}
                                <a href="{{ path('app_logement_detail', {id: property.id}) }}"
                                   class="text-xs text-gray-500 hover:underline">
                                    Voir le logement
                                </a>
                            {% endif %}
                            {% if reservation.status in ['pending', 'confirmed'] %}
                                <a href="{{ path('booking_cancel', {id: reservation.id}) }}"
                                   class="text-xs text-red-600 hover:underline">
                                    Annuler
                                </a>
                            {% endif %}
                            {% if reservation.status == 'pending' and reservation.expiresAt %}
                                <p class="text-xs text-yellow-600">
                                    Expire le {{ reservation.expiresAt|date('d/m/Y H:i') }}
                                </p>
                            {% endif %}
                        </div>
                    </div>
                {% endfor %}
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="text-center py-16 border border-dashed border-gray-200 rounded-xl">
                <i class="fa-solid fa-suitcase-rolling text-4xl text-gray-300 mb-4"></i>
                <p class="text-gray-500">Aucune réservation pour le moment.</p>
                <a href="{{ path('app_home') }}" class="inline-block mt-4 text-brand font-semibold hover:underline">
                    Découvrir des logements
                </a>
            </div>
        {% endif %}
    </main>
{% endblock %}
