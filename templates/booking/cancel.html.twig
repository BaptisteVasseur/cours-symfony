{% extends 'layout/user.html.twig' %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-2xl mx-auto w-full">
        <a href="{{ path('booking_my_bookings') }}" class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-gray-900 mb-6">
            <i class="fa-solid fa-arrow-left"></i>
            Retour à mes réservations
        </a>

        <div class="bg-white border border-gray-200 rounded-2xl p-8">
            <h1 class="text-xl font-semibold text-gray-900 mb-2">Annuler la réservation</h1>
            <p class="text-sm text-gray-500 mb-6">
                Logement : <strong>{{ reservation.property ? reservation.property.title : '—' }}</strong>
                · {{ reservation.checkinDate|date('d/m/Y') }} → {{ reservation.checkoutDate|date('d/m/Y') }}
            </p>

            {{ form_start(form, {attr: {class: 'space-y-5'}}) }}
                <input type="hidden" name="_token" value="{{ csrf_token('booking_cancel_' ~ reservation.id) }}">

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Motif d'annulation</label>
                    <select id="preset-cancel-reason" name="preset_reason"
                            class="w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-red-400 bg-white">
                        <option value="">— Sélectionner un motif —</option>
                        <option value="Changement de plans personnels">Changement de plans personnels</option>
                        <option value="Problème de santé ou urgence familiale">Problème de santé ou urgence familiale</option>
                        <option value="Logement ne correspond pas à mes attentes">Logement ne correspond pas à mes attentes</option>
                        <option value="Erreur de réservation (mauvaises dates ou logement)">Erreur de réservation (mauvaises dates ou logement)</option>
                        <option value="other">Autre (préciser ci-dessous)</option>
                    </select>
                </div>

                <div id="cancel-custom-wrapper">
                    <label class="block text-sm font-medium text-gray-700 mb-1" id="cancel-custom-label">Précisions <span class="text-gray-400 font-normal">(optionnel)</span></label>
                    {{ form_widget(form.cancellationReason, {attr: {
                        class: 'w-full border border-gray-300 rounded-lg px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-red-400',
                        rows: 3,
                        placeholder: 'Expliquez la raison de l\'annulation…'
                    }}) }}
                    {{ form_errors(form.cancellationReason) }}
                </div>

                <div class="flex gap-3">
                    <button type="submit" class="flex-1 bg-red-600 hover:bg-red-700 text-white font-semibold py-2.5 px-6 rounded-xl transition-colors text-sm">
                        Confirmer l'annulation
                    </button>
                    <a href="{{ path('booking_my_bookings') }}"
                       class="flex-1 text-center bg-gray-100 hover:bg-gray-200 text-gray-700 font-semibold py-2.5 px-6 rounded-xl transition-colors text-sm">
                        Retour
                    </a>
                </div>
            {{ form_end(form) }}

            <script>
            (function () {
                const select  = document.getElementById('preset-cancel-reason');
                const wrapper = document.getElementById('cancel-custom-wrapper');
                const label   = document.getElementById('cancel-custom-label');
                const textarea = wrapper.querySelector('textarea');

                function update() {
                    const val = select.value;
                    if (val === 'other') {
                        label.innerHTML = 'Précisions <span class="text-red-500">*</span>';
                        textarea.placeholder = 'Décrivez votre motif…';
                        textarea.required = true;
                        textarea.focus();
                    } else if (val !== '') {
                        label.innerHTML = 'Précisions <span class="text-gray-400 font-normal">(optionnel)</span>';
                        textarea.placeholder = 'Vous pouvez ajouter des détails si vous le souhaitez…';
                        textarea.required = false;
                    } else {
                        label.innerHTML = 'Précisions <span class="text-gray-400 font-normal">(optionnel)</span>';
                        textarea.placeholder = 'Expliquez la raison de l\'annulation…';
                        textarea.required = false;
                    }
                }

                select.addEventListener('change', update);

                wrapper.closest('form').addEventListener('submit', function (e) {
                    if (select.value === '' && textarea.value.trim() === '') {
                        e.preventDefault();
                        select.classList.add('ring-2', 'ring-red-400', 'border-red-400');
                        select.focus();
                    }
                });
            })();
            </script>
        </div>
    </main>
{% endblock %}
