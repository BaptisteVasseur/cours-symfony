{% extends 'layout/base.html.twig' %}

{% block title %}Réservation — {{ booking.property.title }}{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto px-4 py-10">
    <div class="mb-6">
        <a href="{{ path('app_booking_index') }}" class="text-sm text-gray-500 hover:underline">&larr; Mes réservations</a>
    </div>

    <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden shadow-sm">
        {% if booking.property.images.first %}
            <img src="{{ booking.property.images.first.imageUrl }}" alt="" class="w-full h-48 object-cover">
        {% else %}
            <div class="w-full h-48 bg-gray-100"></div>
        {% endif %}

        <div class="p-6">
            <div class="flex items-start justify-between mb-6">
                <div>
                    <h1 class="text-2xl font-bold text-gray-900">{{ booking.property.title }}</h1>
                    <p class="text-gray-500">{{ booking.property.city }}, {{ booking.property.country }}</p>
                </div>
                <span class="text-sm px-4 py-1.5 rounded-full font-medium
                    {% if booking.status.value == 'CONFIRMED' %}bg-green-100 text-green-700
                    {% elseif booking.status.value == 'PENDING' %}bg-yellow-100 text-yellow-700
                    {% elseif booking.status.value == 'CANCELLED' %}bg-red-100 text-red-700
                    {% else %}bg-gray-100 text-gray-700{% endif %}">
                    {{ booking.status.value|lower|capitalize }}
                </span>
            </div>

            <div class="grid grid-cols-2 gap-6 py-6 border-t border-b border-gray-100">
                <div>
                    <p class="text-xs text-gray-400 uppercase tracking-wide">Arrivée</p>
                    <p class="font-semibold text-gray-900 mt-1">{{ booking.checkIn|date('D d M Y') }}</p>
                </div>
                <div>
                    <p class="text-xs text-gray-400 uppercase tracking-wide">Départ</p>
                    <p class="font-semibold text-gray-900 mt-1">{{ booking.checkOut|date('D d M Y') }}</p>
                </div>
                <div>
                    <p class="text-xs text-gray-400 uppercase tracking-wide">Voyageurs</p>
                    <p class="font-semibold text-gray-900 mt-1">{{ booking.guestsCount }}</p>
                </div>
                <div>
                    <p class="text-xs text-gray-400 uppercase tracking-wide">Durée</p>
                    <p class="font-semibold text-gray-900 mt-1">{{ booking.nights }} nuit(s)</p>
                </div>
            </div>

            <div class="pt-6">
                <div class="flex justify-between items-center">
                    <p class="text-gray-600">{{ booking.property.pricePerNight }} € × {{ booking.nights }} nuits</p>
                    <p class="text-gray-600">{{ booking.totalPrice }} €</p>
                </div>
                <div class="flex justify-between items-center mt-3 pt-3 border-t border-gray-100">
                    <p class="font-bold text-gray-900">Total</p>
                    <p class="font-bold text-xl text-gray-900">{{ booking.totalPrice }} €</p>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
