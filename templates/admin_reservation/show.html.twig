{% extends 'layout/admin.html.twig' %}

{% set property = reservation.property %}
{% set cover = property ? property.coverMedia : null %}
{% set guest = reservation.guest %}
{% set guestProfile = guest ? guest.profile : null %}
{% set hostProfile = property and property.host ? property.host.profile : null %}
{% set placeholderImage = 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=800&q=80' %}

{% set statusLabels = {
    'confirmed': 'Confirmée',
    'completed': 'Terminée',
    'pending': 'En attente',
    'cancelled': 'Annulée',
    'expired': 'Expirée',
} %}
{% set statusClasses = {
    'confirmed': 'bg-emerald-50 text-emerald-800 border border-emerald-200',
    'completed': 'bg-blue-50 text-blue-800 border border-blue-200',
    'pending': 'bg-amber-50 text-amber-800 border border-amber-200',
    'cancelled': 'bg-red-50 text-red-800 border border-red-200',
    'expired': 'bg-gray-50 text-gray-500 border border-gray-200',
} %}

{% block page_title %}Réservation #{{ reservation.id|slice(0, 8) }}{% endblock %}

{% block content %}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="mb-4 px-4 py-3 rounded-lg text-sm font-medium {{ label == 'success' ? 'bg-emerald-50 text-emerald-800 border border-emerald-200' : 'bg-red-50 text-red-800 border border-red-200' }}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    <div class="mb-6">
        <a href="{{ path('app_admin_reservation_index') }}" class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-gray-900 transition">
            <i class="fa-solid fa-arrow-left text-xs"></i>
            Retour à la liste
        </a>
    </div>

    <div class="flex flex-wrap items-center gap-3 mb-6">
        <h2 class="text-xl font-bold text-gray-900">Détail de la réservation</h2>
        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold {{ statusClasses[reservation.status]|default('bg-gray-100 text-gray-700') }}">
            {{ statusLabels[reservation.status]|default(reservation.status) }}
        </span>
    </div>

    {% if reservation.status == 'cancelled' %}
        <div class="mb-6 bg-red-50 border border-red-200 rounded-xl p-4 flex items-start gap-3">
            <i class="fa-solid fa-circle-xmark text-red-600 mt-0.5 shrink-0"></i>
            <div>
                {% if reservation.cancelledBy == 'admin' %}
                    <p class="font-semibold text-red-900">Réservation refusée par l'administration</p>
                {% elseif reservation.cancelledBy == 'host' %}
                    <p class="font-semibold text-red-900">Réservation refusée par l'hôte</p>
                {% elseif reservation.cancelledBy == 'guest' %}
                    <p class="font-semibold text-red-900">Réservation annulée par le voyageur</p>
                {% elseif reservation.cancelledBy == 'system' %}
                    <p class="font-semibold text-red-900">Réservation annulée automatiquement</p>
                {% else %}
                    <p class="font-semibold text-red-900">Réservation annulée</p>
                {% endif %}
                {% if reservation.cancellationReason %}
                    <p class="text-sm text-red-700 mt-1">Motif : {{ reservation.cancellationReason }}</p>
                {% endif %}
            </div>
        </div>
    {% endif %}

    {% if reservation.status == 'pending' %}
        <div class="mb-6 bg-amber-50 border border-amber-200 rounded-xl p-5">
            <p class="font-semibold text-amber-900 mb-4">Actions sur cette demande</p>
            <div class="flex flex-col sm:flex-row gap-3">
                {# Approuver #}
                <form method="POST" action="{{ path('app_admin_reservation_approve', {id: reservation.id}) }}" class="flex-1">
                    <input type="hidden" name="_token" value="{{ csrf_token('admin_approve_' ~ reservation.id) }}">
                    <button type="submit"
                            class="w-full bg-emerald-600 hover:bg-emerald-700 text-white font-semibold text-sm px-4 py-2.5 rounded-lg transition flex items-center justify-center gap-2">
                        <i class="fa-solid fa-check"></i>
                        Confirmer la réservation
                    </button>
                </form>
                {# Refuser — toggle formulaire #}
                <button type="button" id="toggle-reject-form"
                        class="flex-1 bg-red-600 hover:bg-red-700 text-white font-semibold text-sm px-4 py-2.5 rounded-lg transition flex items-center justify-center gap-2">
                    <i class="fa-solid fa-xmark"></i>
                    Refuser la réservation
                </button>
            </div>

            {# Formulaire de refus (masqué par défaut) #}
            <div id="reject-form-panel" class="hidden mt-4 border-t border-amber-200 pt-4">
                {{ form_start(rejectForm, {attr: {class: 'space-y-3'}}) }}
                    <div>
                        {{ form_label(rejectForm.presetReason, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(rejectForm.presetReason, {attr: {class: 'w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-red-400'}}) }}
                        {{ form_errors(rejectForm.presetReason) }}
                    </div>
                    <div>
                        {{ form_label(rejectForm.customReason, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                        {{ form_widget(rejectForm.customReason, {attr: {class: 'w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-red-400'}}) }}
                        {{ form_errors(rejectForm.customReason) }}
                    </div>
                    <button type="submit"
                            class="bg-red-600 hover:bg-red-700 text-white font-semibold text-sm px-5 py-2.5 rounded-lg transition flex items-center gap-2">
                        <i class="fa-solid fa-ban"></i>
                        Confirmer le refus
                    </button>
                {{ form_end(rejectForm) }}
            </div>
        </div>
        <script>
            document.getElementById('toggle-reject-form').addEventListener('click', function () {
                const panel = document.getElementById('reject-form-panel');
                panel.classList.toggle('hidden');
                this.textContent = panel.classList.contains('hidden') ? ' Refuser la réservation' : ' Annuler';
            });
        </script>
    {% endif %}

    <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">
        <div class="xl:col-span-2 space-y-6">
            {% if property %}
                <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
                    <div class="flex flex-col sm:flex-row">
                        <div class="sm:w-56 h-44 sm:h-auto shrink-0">
                            <img src="{{ cover ? cover.fileUrl : placeholderImage }}" alt="{{ property.title }}" class="w-full h-full object-cover">
                        </div>
                        <div class="p-5 flex flex-col justify-center">
                            <h3 class="text-lg font-bold text-gray-900">{{ property.title }}</h3>
                            {% if property.address %}
                                <p class="text-sm text-gray-500 mt-1">{{ property.address.addressLine1 }}, {{ property.address.city }}</p>
                            {% endif %}
                            <a href="{{ path('app_logement_detail', { id: property.id }) }}" target="_blank" class="inline-flex items-center gap-1 text-sm font-semibold text-brand hover:underline mt-3">
                                Voir l'annonce <i class="fa-solid fa-arrow-up-right-from-square text-[10px]"></i>
                            </a>
                        </div>
                    </div>
                </div>
            {% endif %}

            <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
                <h3 class="font-bold text-gray-900 mb-4">Séjour</h3>
                <dl class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
                    <div>
                        <dt class="text-gray-400 text-xs uppercase mb-1">Arrivée</dt>
                        <dd class="font-semibold text-gray-900">{{ reservation.checkinDate|date('d/m/Y') }}</dd>
                    </div>
                    <div>
                        <dt class="text-gray-400 text-xs uppercase mb-1">Départ</dt>
                        <dd class="font-semibold text-gray-900">{{ reservation.checkoutDate|date('d/m/Y') }}</dd>
                    </div>
                    <div>
                        <dt class="text-gray-400 text-xs uppercase mb-1">Voyageurs</dt>
                        <dd class="font-semibold text-gray-900">{{ reservation.guestsCount }}</dd>
                    </div>
                    <div>
                        <dt class="text-gray-400 text-xs uppercase mb-1">Créée le</dt>
                        <dd class="font-semibold text-gray-900">{{ reservation.createdAt|date('d/m/Y H:i') }}</dd>
                    </div>
                </dl>
            </div>

            <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
                <h3 class="font-bold text-gray-900 mb-4">Participants</h3>
                <dl class="space-y-4 text-sm">
                    <div class="flex items-start gap-3">
                        <div class="w-10 h-10 bg-blue-50 text-blue-600 rounded-full flex items-center justify-center shrink-0">
                            <i class="fa-solid fa-user text-sm"></i>
                        </div>
                        <div>
                            <dt class="text-gray-400 text-xs uppercase">Voyageur</dt>
                            <dd class="font-semibold text-gray-900">
                                {% if guestProfile and (guestProfile.firstName or guestProfile.lastName) %}
                                    {{ guestProfile.firstName }} {{ guestProfile.lastName }}
                                {% else %}
                                    —
                                {% endif %}
                            </dd>
                            <dd class="text-gray-500">{{ guest ? guest.email : '—' }}</dd>
                            {% if guest %}
                                <a href="{{ path('app_user_show', { id: guest.id }) }}" class="text-xs font-semibold text-brand hover:underline mt-1 inline-block">Voir le profil</a>
                            {% endif %}
                        </div>
                    </div>
                    {% if hostProfile or (property and property.host) %}
                        <div class="flex items-start gap-3">
                            <div class="w-10 h-10 bg-rose-50 text-brand rounded-full flex items-center justify-center shrink-0">
                                <i class="fa-solid fa-house-user text-sm"></i>
                            </div>
                            <div>
                                <dt class="text-gray-400 text-xs uppercase">Hôte</dt>
                                <dd class="font-semibold text-gray-900">
                                    {% if hostProfile and (hostProfile.firstName or hostProfile.lastName) %}
                                        {{ hostProfile.firstName }} {{ hostProfile.lastName }}
                                    {% else %}
                                        —
                                    {% endif %}
                                </dd>
                                <dd class="text-gray-500">{{ property.host ? property.host.email : '—' }}</dd>
                            </div>
                        </div>
                    {% endif %}
                </dl>
            </div>

            {% if reservation.statusHistory|length > 0 %}
                <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
                    <h3 class="font-bold text-gray-900 mb-4">Historique des statuts</h3>
                    <div class="space-y-3">
                        {% for history in reservation.statusHistory %}
                            <div class="flex items-center justify-between text-sm border-b border-gray-100 pb-3 last:border-0 last:pb-0">
                                <div>
                                    <span class="font-medium text-gray-900">
                                        {{ history.oldStatus ? statusLabels[history.oldStatus]|default(history.oldStatus) ~ ' → ' : '' }}
                                        {{ statusLabels[history.newStatus]|default(history.newStatus) }}
                                    </span>
                                    {% if history.changedBy %}
                                        <p class="text-xs text-gray-400 mt-0.5">Par {{ history.changedBy.email }}</p>
                                    {% endif %}
                                </div>
                                <span class="text-xs text-gray-400">{{ history.createdAt|date('d/m/Y H:i') }}</span>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            {{ include('admin_reservation/_disputes_section.html.twig') }}

            {{ include('admin_reservation/_financial_section.html.twig') }}
        </div>

        <div class="sticky top-6 space-y-3">
            <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
                <h3 class="font-bold text-gray-900 mb-4">Récapitulatif</h3>
                <dl class="space-y-3 text-sm">
                    <div class="flex justify-between">
                        <dt class="text-gray-500">Prix total</dt>
                        <dd class="font-semibold">{{ reservation.totalPrice|number_format(2, ',', ' ') }} {{ reservation.currency|default('EUR') }}</dd>
                    </div>
                    {% if reservation.cleaningFee %}
                        <div class="flex justify-between">
                            <dt class="text-gray-500">Ménage</dt>
                            <dd class="font-medium">{{ reservation.cleaningFee|number_format(2, ',', ' ') }} {{ reservation.currency|default('EUR') }}</dd>
                        </div>
                    {% endif %}
                    {% if reservation.serviceFee %}
                        <div class="flex justify-between">
                            <dt class="text-gray-500">Frais de service</dt>
                            <dd class="font-medium">{{ reservation.serviceFee|number_format(2, ',', ' ') }} {{ reservation.currency|default('EUR') }}</dd>
                        </div>
                    {% endif %}
                    {% if reservation.securityDeposit %}
                        <div class="flex justify-between">
                            <dt class="text-gray-500">Caution</dt>
                            <dd class="font-medium">{{ reservation.securityDeposit|number_format(2, ',', ' ') }} {{ reservation.currency|default('EUR') }}</dd>
                        </div>
                    {% endif %}
                </dl>

                <div class="mt-6 pt-6 border-t border-gray-200">
                    <dt class="text-gray-400 text-xs uppercase mb-1">Référence</dt>
                    <dd class="font-mono text-xs text-gray-600 break-all">{{ reservation.id }}</dd>
                </div>
            </div>

            <div class="flex flex-col gap-2">
                <a href="{{ path('app_admin_reservation_edit', { id: reservation.id }) }}" class="w-full text-center bg-gray-900 hover:bg-gray-700 text-white font-semibold text-sm px-4 py-2.5 rounded-lg transition">
                    Modifier la réservation
                </a>
                <a href="{{ path('app_reservation_show', { id: reservation.id }) }}" target="_blank" class="w-full text-center border border-gray-200 hover:bg-gray-50 text-gray-700 font-semibold text-sm px-4 py-2.5 rounded-lg transition">
                    Vue voyageur
                </a>
                {{ include('admin_reservation/_delete_form.html.twig') }}
            </div>
        </div>
    </div>
{% endblock %}
