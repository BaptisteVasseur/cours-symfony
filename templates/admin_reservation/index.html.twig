{% extends 'layouts/user.html.twig' %}

{% block title %}Gestion des réservations{% endblock %}

{% block content %}
    <main class="min-h-screen bg-neutral-50 px-6 py-10">
        <div class="mx-auto max-w-7xl">
            <div class="mb-8 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
                <div>
                    <p class="text-sm font-bold uppercase tracking-wide text-rose-600">
                        Administration
                    </p>

                    <h1 class="mt-2 text-4xl font-bold text-neutral-900">
                        Réservations
                    </h1>

                    <p class="mt-2 text-neutral-500">
                        Gérez les réservations enregistrées sur la plateforme.
                    </p>
                </div>

                <a
                    href="{{ path('app_admin_reservation_new') }}"
                    class="w-fit rounded-xl bg-rose-600 px-5 py-3 font-bold text-white hover:bg-rose-700"
                >
                    Créer une réservation
                </a>
            </div>

            <div class="mb-6 grid grid-cols-1 gap-4 md:grid-cols-4">
                <div class="rounded-3xl bg-white p-5 shadow-sm">
                    <p class="text-sm font-semibold text-neutral-500">
                        Total
                    </p>

                    <p class="mt-2 text-3xl font-bold">
                        {{ reservations|length }}
                    </p>
                </div>

                <div class="rounded-3xl bg-white p-5 shadow-sm">
                    <p class="text-sm font-semibold text-neutral-500">
                        Confirmées
                    </p>

                    <p class="mt-2 text-3xl font-bold">
                        {{ reservations|filter(reservation => reservation.status == 'confirmed')|length }}
                    </p>
                </div>

                <div class="rounded-3xl bg-white p-5 shadow-sm">
                    <p class="text-sm font-semibold text-neutral-500">
                        En attente
                    </p>

                    <p class="mt-2 text-3xl font-bold">
                        {{ reservations|filter(reservation => reservation.status == 'pending')|length }}
                    </p>
                </div>

                <div class="rounded-3xl bg-white p-5 shadow-sm">
                    <p class="text-sm font-semibold text-neutral-500">
                        Annulées
                    </p>

                    <p class="mt-2 text-3xl font-bold">
                        {{ reservations|filter(reservation => reservation.status == 'cancelled')|length }}
                    </p>
                </div>
            </div>

            <div class="overflow-hidden rounded-3xl bg-white shadow-sm">
                <div class="border-b border-neutral-200 px-6 py-5">
                    <h2 class="text-xl font-bold">
                        Liste des réservations
                    </h2>
                </div>

                {% if reservations is empty %}
                    <div class="p-10 text-center">
                        <div
                            class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-neutral-100 text-3xl">
                            📅
                        </div>

                        <h2 class="text-xl font-semibold">
                            Aucune réservation trouvée
                        </h2>

                        <p class="mt-2 text-neutral-500">
                            Créez une réservation pour commencer.
                        </p>

                        <a
                            href="{{ path('app_admin_reservation_new') }}"
                            class="mt-6 inline-block rounded-xl bg-rose-600 px-5 py-3 font-bold text-white hover:bg-rose-700"
                        >
                            Créer une réservation
                        </a>
                    </div>
                {% else %}
                    <div class="overflow-x-auto">
                        <table class="w-full min-w-[1100px] text-left text-sm">
                            <thead class="bg-neutral-100 text-xs uppercase text-neutral-500">
                            <tr>
                                <th class="px-6 py-4 font-bold">Réservation</th>
                                <th class="px-6 py-4 font-bold">Séjour</th>
                                <th class="px-6 py-4 font-bold">Voyageurs</th>
                                <th class="px-6 py-4 font-bold">Statut</th>
                                <th class="px-6 py-4 font-bold">Prix</th>
                                <th class="px-6 py-4 font-bold">Frais</th>
                                <th class="px-6 py-4 font-bold">Annulation</th>
                                <th class="px-6 py-4 font-bold">Créée le</th>
                                <th class="px-6 py-4 text-right font-bold">Actions</th>
                            </tr>
                            </thead>

                            <tbody class="divide-y divide-neutral-200">
                            {% for reservation in reservations %}
                                {% set property = reservation.property %}
                                {% set cover = property and property.media ? property.media|first : null %}

                                <tr class="hover:bg-neutral-50">
                                    <td class="px-6 py-5">
                                        <div class="flex items-center gap-4">
                                            <img
                                                src="{{ cover ? cover.fileUrl : 'https://images.unsplash.com/photo-1540541338287-41700207dee6?auto=format&fit=crop&w=120&q=80' }}"
                                                alt="{{ property ? property.title : 'Réservation' }}"
                                                class="h-16 w-20 rounded-2xl object-cover"
                                            />

                                            <div>
                                                <p class="max-w-[260px] truncate font-bold text-neutral-900">
                                                    {{ property ? property.title : 'Logement supprimé' }}
                                                </p>

                                                <p class="mt-1 text-neutral-500">
                                                    ID : {{ reservation.id }}
                                                </p>

                                                {% if reservation.guest %}
                                                    <p class="mt-1 max-w-[260px] truncate text-neutral-500">
                                                        {{ reservation.guest.email }}
                                                    </p>
                                                {% endif %}
                                            </div>
                                        </div>
                                    </td>

                                    <td class="px-6 py-5 text-neutral-600">
                                        <p>
                                            Arrivée :
                                            <span class="font-semibold text-neutral-900">
													{{ reservation.checkinDate ? reservation.checkinDate|date('d/m/Y') : '—' }}
												</span>
                                        </p>

                                        <p>
                                            Départ :
                                            <span class="font-semibold text-neutral-900">
													{{ reservation.checkoutDate ? reservation.checkoutDate|date('d/m/Y') : '—' }}
												</span>
                                        </p>
                                    </td>

                                    <td class="px-6 py-5">
											<span class="rounded-full bg-neutral-100 px-3 py-1 font-semibold">
												{{ reservation.guestsCount }} voyageur{{ reservation.guestsCount > 1 ? 's' : '' }}
											</span>
                                    </td>

                                    <td class="px-6 py-5">
											<span class="rounded-full px-3 py-1 text-xs font-bold
												{% if reservation.status == 'confirmed' %}
													bg-green-100 text-green-700
												{% elseif reservation.status == 'pending' %}
													bg-yellow-100 text-yellow-700
												{% elseif reservation.status == 'cancelled' %}
													bg-red-100 text-red-700
												{% elseif reservation.status == 'completed' %}
													bg-blue-100 text-blue-700
												{% else %}
													bg-neutral-100 text-neutral-700
												{% endif %}
											">
												{{ reservation.status|capitalize }}
											</span>
                                    </td>

                                    <td class="px-6 py-5">
                                        <p class="font-bold">
                                            {{ reservation.totalPrice }} {{ reservation.currency }}
                                        </p>

                                        <p class="text-neutral-500">
                                            total
                                        </p>
                                    </td>

                                    <td class="px-6 py-5 text-neutral-600">
                                        <p>
                                            Ménage :
                                            <span class="font-semibold text-neutral-900">
													{{ reservation.cleaningFee ? reservation.cleaningFee ~ ' ' ~ reservation.currency : '—' }}
												</span>
                                        </p>

                                        <p>
                                            Service :
                                            <span class="font-semibold text-neutral-900">
													{{ reservation.serviceFee ? reservation.serviceFee ~ ' ' ~ reservation.currency : '—' }}
												</span>
                                        </p>

                                        <p>
                                            Caution :
                                            <span class="font-semibold text-neutral-900">
													{{ reservation.securityDeposit ? reservation.securityDeposit ~ ' ' ~ reservation.currency : '—' }}
												</span>
                                        </p>
                                    </td>

                                    <td class="px-6 py-5">
                                        {% if reservation.cancellationReason %}
                                            <p class="max-w-[220px] truncate text-red-600">
                                                {{ reservation.cancellationReason }}
                                            </p>
                                        {% else %}
                                            <span class="text-neutral-400">—</span>
                                        {% endif %}
                                    </td>

                                    <td class="px-6 py-5 text-neutral-600">
                                        {{ reservation.createdAt ? reservation.createdAt|date('d/m/Y') : '—' }}

                                        {% if reservation.createdAt %}
                                            <p class="mt-1 text-xs text-neutral-400">
                                                {{ reservation.createdAt|date('H:i') }}
                                            </p>
                                        {% endif %}
                                    </td>

                                    <td class="px-6 py-5">
                                        <div class="flex justify-end gap-2">
                                            <a
                                                href="{{ path('app_admin_reservation_show', {'id': reservation.id}) }}"
                                                class="rounded-xl border border-neutral-300 px-4 py-2 font-semibold hover:bg-neutral-100"
                                            >
                                                Voir
                                            </a>

                                            <a
                                                href="{{ path('app_admin_reservation_edit', {'id': reservation.id}) }}"
                                                class="rounded-xl bg-neutral-900 px-4 py-2 font-semibold text-white hover:bg-neutral-700"
                                            >
                                                Modifier
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>
        </div>
    </main>
{% endblock %}
