{% extends 'layout/user.html.twig' %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-7xl mx-auto w-full">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 px-4 py-3 rounded-lg text-sm font-medium {{ label == 'success' ? 'bg-emerald-50 text-emerald-800 border border-emerald-200' : 'bg-red-50 text-red-800 border border-red-200' }}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        <a href="{{ path('app_host_calendar_index') }}" class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-gray-900 mb-6">
            <i class="fa-solid fa-arrow-left"></i>
            Retour aux calendriers
        </a>

        <div class="mb-8 flex flex-col md:flex-row md:items-end md:justify-between gap-4">
            <div>
                <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">{{ property.title }}</h1>
                {% if property.address %}
                    <p class="text-gray-500 mt-1">{{ property.address.city }}, {{ property.address.country }}</p>
                {% endif %}
            </div>
            <a href="{{ path('app_logement_detail', { id: property.id }) }}" class="inline-flex items-center gap-2 text-sm font-semibold text-gray-700 hover:text-gray-900">
                <i class="fa-solid fa-arrow-up-right-from-square"></i>
                Voir l'annonce
            </a>
        </div>

        <div class="grid grid-cols-1 xl:grid-cols-4 gap-8">
            <div class="xl:col-span-1 space-y-6">
                <section class="bg-white border border-gray-200 rounded-xl p-6 shadow-sm">
                    <h2 class="text-lg font-semibold text-gray-900 mb-2">Bloquer une periode</h2>
                    <p class="text-sm text-gray-500 mb-5">Cliquez sur une premiere nuit puis sur une derniere nuit dans le calendrier.</p>

                    {{ form_start(availabilityForm) }}
                        {{ form_errors(availabilityForm) }}

                        <div class="space-y-4">
                            {{ form_row(availabilityForm.startDate) }}
                            {{ form_row(availabilityForm.endDate) }}
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                {{ form_row(availabilityForm.priceOverride) }}
                                {{ form_row(availabilityForm.minimumStay) }}
                            </div>
                        </div>

                        <p data-calendar-selection-label class="mt-4 text-sm text-gray-500">Aucune periode selectionnee.</p>

                        <button type="submit" class="mt-6 w-full bg-brand hover:bg-brandHover text-white font-semibold py-3 rounded-lg transition">
                            Bloquer les dates
                        </button>
                    {{ form_end(availabilityForm) }}
                </section>

                <section class="bg-white border border-gray-200 rounded-xl p-6 shadow-sm">
                    <h2 class="text-lg font-semibold text-gray-900 mb-5">Export iCal</h2>

                    {% if property.iCalExportToken %}
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Lien prive</label>
                        <input type="text" readonly value="{{ absolute_url(path('app_property_calendar_export', { id: property.id, token: property.iCalExportToken })) }}" class="w-full rounded-lg border-gray-300 text-sm text-gray-700">
                        <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-3">
                            <form method="post" action="{{ path('app_host_property_calendar_export_token', { id: property.id }) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('host_ical_token' ~ property.id) }}">
                                <button type="submit" class="w-full inline-flex justify-center items-center gap-2 border border-gray-300 text-gray-700 hover:bg-gray-50 font-semibold text-sm px-4 py-2.5 rounded-lg transition">
                                    <i class="fa-solid fa-rotate"></i>
                                    Regenerer
                                </button>
                            </form>
                            <form method="post" action="{{ path('app_host_property_calendar_revoke_export_token', { id: property.id }) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('host_ical_revoke' ~ property.id) }}">
                                <button type="submit" class="w-full inline-flex justify-center items-center gap-2 border border-red-200 text-red-700 hover:bg-red-50 font-semibold text-sm px-4 py-2.5 rounded-lg transition">
                                    <i class="fa-solid fa-link-slash"></i>
                                    Revoquer
                                </button>
                            </form>
                        </div>
                    {% else %}
                        <p class="text-sm text-gray-500 mb-4">Aucun lien d'export actif.</p>
                        <form method="post" action="{{ path('app_host_property_calendar_export_token', { id: property.id }) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('host_ical_token' ~ property.id) }}">
                            <button type="submit" class="w-full bg-brand hover:bg-brandHover text-white font-semibold py-3 rounded-lg transition">
                                Generer un lien iCal
                            </button>
                        </form>
                    {% endif %}
                </section>

                <section class="bg-white border border-gray-200 rounded-xl p-6 shadow-sm">
                    <h2 class="text-lg font-semibold text-gray-900 mb-5">Import iCal</h2>

                    {{ form_start(syncForm, { action: path('app_host_property_calendar_import_add', { id: property.id }) }) }}
                        <input type="hidden" name="_token" value="{{ csrf_token('host_ical_import' ~ property.id) }}">
                        <div class="space-y-4">
                            {{ form_row(syncForm.providerName) }}
                            {{ form_row(syncForm.iCalUrl) }}
                        </div>
                        <button type="submit" class="mt-6 w-full bg-gray-900 hover:bg-gray-800 text-white font-semibold py-3 rounded-lg transition">
                            Ajouter le flux
                        </button>
                    {{ form_end(syncForm) }}

                    <div class="mt-6 divide-y divide-gray-100">
                        {% for sync in iCalSyncs %}
                            <div class="py-4 space-y-3">
                                <div class="min-w-0">
                                    <p class="font-semibold text-gray-900 truncate">{{ sync.providerName }}</p>
                                    <p class="text-xs text-gray-500 truncate">{{ sync.iCalUrl }}</p>
                                    <p class="text-xs text-gray-400 mt-1">
                                        {% if sync.lastSyncAt %}
                                            Derniere synchro le {{ sync.lastSyncAt|date('d/m/Y H:i') }}
                                        {% else %}
                                            Jamais synchronise
                                        {% endif %}
                                    </p>
                                </div>
                                <div class="grid grid-cols-2 gap-2">
                                    <form method="post" action="{{ path('app_host_property_calendar_import_sync', { id: property.id, syncId: sync.id }) }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('host_ical_sync_now' ~ sync.id) }}">
                                        <button type="submit" class="w-full inline-flex justify-center items-center gap-2 border border-gray-300 text-gray-700 hover:bg-gray-50 font-semibold text-sm px-3 py-2.5 rounded-lg transition">
                                            <i class="fa-solid fa-arrows-rotate"></i>
                                            Sync
                                        </button>
                                    </form>
                                    <form method="post" action="{{ path('app_host_property_calendar_import_delete', { id: property.id, syncId: sync.id }) }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('host_ical_delete' ~ sync.id) }}">
                                        <button type="submit" class="w-full inline-flex justify-center items-center gap-2 border border-gray-300 text-gray-600 hover:bg-gray-50 font-semibold text-sm px-3 py-2.5 rounded-lg transition">
                                            <i class="fa-solid fa-trash"></i>
                                            Retirer
                                        </button>
                                    </form>
                                </div>
                            </div>
                        {% else %}
                            <p class="text-sm text-gray-500 pt-1">Aucun flux importe.</p>
                        {% endfor %}
                    </div>
                </section>
            </div>

            <section class="xl:col-span-3 bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
                <div class="px-6 py-4 border-b border-gray-200 flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
                    <div>
                        <h2 class="font-semibold text-gray-900">Calendrier</h2>
                        <p class="text-sm text-gray-500">{{ calendarMonth|date('m/Y') }}</p>
                    </div>
                    <div class="flex flex-wrap items-center gap-2">
                        <a href="{{ path('app_host_property_calendar', { id: property.id, month: previousMonth|date('Y-m') }) }}" class="inline-flex items-center justify-center border border-gray-300 text-gray-700 hover:bg-gray-50 font-semibold text-sm px-3 py-2 rounded-lg transition">
                            <i class="fa-solid fa-chevron-left"></i>
                        </a>
                        <a href="{{ path('app_host_property_calendar', { id: property.id }) }}" class="inline-flex items-center justify-center border border-gray-300 text-gray-700 hover:bg-gray-50 font-semibold text-sm px-4 py-2 rounded-lg transition">
                            Aujourd'hui
                        </a>
                        <a href="{{ path('app_host_property_calendar', { id: property.id, month: nextMonth|date('Y-m') }) }}" class="inline-flex items-center justify-center border border-gray-300 text-gray-700 hover:bg-gray-50 font-semibold text-sm px-3 py-2 rounded-lg transition">
                            <i class="fa-solid fa-chevron-right"></i>
                        </a>
                    </div>
                </div>

                <div class="px-6 pt-5 flex flex-wrap gap-3 text-xs text-gray-600">
                    <span class="inline-flex items-center gap-2"><span class="w-3 h-3 rounded bg-emerald-100 border border-emerald-200"></span>Libre</span>
                    <span class="inline-flex items-center gap-2"><span class="w-3 h-3 rounded bg-gray-200 border border-gray-300"></span>Bloque manuel ou iCal</span>
                    <span class="inline-flex items-center gap-2"><span class="w-3 h-3 rounded bg-rose-100 border border-rose-200"></span>Reservation confirmee</span>
                    <span class="inline-flex items-center gap-2"><span class="w-3 h-3 rounded bg-amber-100 border border-amber-200"></span>Demande pending</span>
                    <span class="inline-flex items-center gap-2"><span class="w-3 h-3 rounded bg-brand"></span>Selection</span>
                </div>

                <div class="p-4 md:p-6">
                    <div class="grid grid-cols-7 text-center text-xs font-semibold text-gray-500 mb-2">
                        <div class="py-2">Lun</div>
                        <div class="py-2">Mar</div>
                        <div class="py-2">Mer</div>
                        <div class="py-2">Jeu</div>
                        <div class="py-2">Ven</div>
                        <div class="py-2">Sam</div>
                        <div class="py-2">Dim</div>
                    </div>

                    <div class="grid grid-cols-7 border-l border-t border-gray-200">
                        {% for day in calendarDays %}
                            {% set confirmed = false %}
                            {% set pending = false %}
                            {% for reservation in day.reservations %}
                                {% if reservation.status == 'confirmed' %}
                                    {% set confirmed = true %}
                                {% elseif reservation.status == 'pending' %}
                                    {% set pending = true %}
                                {% endif %}
                            {% endfor %}

                            {% set disabled = day.isPast or confirmed %}
                            {% set cellClass = 'min-h-28 border-r border-b border-gray-200 p-2 text-left transition flex flex-col gap-1 ' %}
                            {% set cellClass = cellClass ~ (day.isCurrentMonth ? 'bg-white ' : 'bg-gray-50 text-gray-400 ') %}
                            {% set cellClass = cellClass ~ (day.isBlocked ? 'bg-gray-100 ' : '') %}
                            {% set cellClass = cellClass ~ (confirmed ? 'bg-rose-50 ' : '') %}
                            {% set cellClass = cellClass ~ (pending and not confirmed ? 'bg-amber-50 ' : '') %}
                            {% set cellClass = cellClass ~ (disabled ? 'cursor-not-allowed opacity-75 ' : 'hover:bg-emerald-50 cursor-pointer ') %}

                            <button
                                type="button"
                                class="{{ cellClass }}"
                                data-calendar-day="{{ day.key }}"
                                data-calendar-disabled="{{ disabled ? '1' : '0' }}"
                            >
                                <span class="flex items-center justify-between gap-2">
                                    <span class="inline-flex items-center justify-center w-7 h-7 rounded-full text-sm font-semibold {{ day.isToday ? 'bg-gray-900 text-white' : 'text-gray-900' }}">{{ day.dayNumber }}</span>
                                    {% if not disabled %}
                                        <span class="text-[10px] uppercase tracking-wide text-emerald-700">select</span>
                                    {% endif %}
                                </span>

                                {% if confirmed %}
                                    <span class="text-xs font-semibold rounded bg-rose-100 text-rose-800 px-2 py-1">Confirmee</span>
                                {% elseif pending %}
                                    <span class="text-xs font-semibold rounded bg-amber-100 text-amber-800 px-2 py-1">Pending</span>
                                {% endif %}

                                {% if day.isBlocked %}
                                    <span class="text-xs font-semibold rounded bg-gray-200 text-gray-800 px-2 py-1">Bloque</span>
                                {% elseif not confirmed and not day.isPast %}
                                    <span class="text-xs rounded bg-emerald-100 text-emerald-800 px-2 py-1">Libre</span>
                                {% endif %}
                            </button>
                        {% endfor %}
                    </div>
                </div>

                <div class="px-6 py-4 border-t border-gray-200">
                    <h3 class="font-semibold text-gray-900">Dates indisponibles</h3>
                    <p class="text-sm text-gray-500 mb-3">{{ blockedDates|length }} nuit{{ blockedDates|length > 1 ? 's' : '' }} bloquee{{ blockedDates|length > 1 ? 's' : '' }}</p>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                        {% for availability in blockedDates|slice(0, 8) %}
                            <div class="border border-gray-200 rounded-lg p-3 flex items-center justify-between gap-3">
                                <div>
                                    <p class="font-semibold text-gray-900">{{ availability.availableDate|date('d/m/Y') }}</p>
                                    <p class="text-xs text-gray-500">Indisponible</p>
                                </div>
                                <form method="post" action="{{ path('app_host_property_calendar_unblock', { id: property.id, availabilityId: availability.id }) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('host_unblock' ~ availability.id) }}">
                                    <button type="submit" class="inline-flex justify-center items-center border border-gray-300 text-gray-700 hover:bg-gray-50 p-2.5 rounded-lg transition" title="Rendre disponible">
                                        <i class="fa-solid fa-unlock"></i>
                                    </button>
                                </form>
                            </div>
                        {% else %}
                            <div class="md:col-span-2 px-6 py-10 text-center text-gray-500 border border-dashed border-gray-200 rounded-lg">
                                <p class="font-semibold text-gray-900">Aucune date bloquee</p>
                                <p class="text-sm mt-1">Le logement est disponible selon les reservations confirmees.</p>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </section>
        </div>
    </main>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        (() => {
            let start = null;
            let end = null;

            const nextDay = (value) => {
                const parts = value.split('-').map(Number);
                const date = new Date(Date.UTC(parts[0], parts[1] - 1, parts[2] + 1));
                return date.toISOString().slice(0, 10);
            };

            const formatDate = (value) => {
                return new Intl.DateTimeFormat('fr-FR', {
                    day: '2-digit',
                    month: '2-digit',
                    year: 'numeric',
                    timeZone: 'UTC',
                }).format(new Date(`${value}T00:00:00Z`));
            };

            const refresh = () => {
                const startInput = document.querySelector('[data-calendar-start]');
                const endInput = document.querySelector('[data-calendar-end]');
                const label = document.querySelector('[data-calendar-selection-label]');
                const buttons = Array.from(document.querySelectorAll('[data-calendar-day]'));

                buttons.forEach((button) => {
                    const value = button.dataset.calendarDay;
                    const selected = start !== null && value >= start && value <= (end ?? start);
                    button.classList.toggle('ring-2', selected);
                    button.classList.toggle('ring-brand', selected);
                    button.classList.toggle('shadow-inner', selected);
                });

                if (startInput && start) {
                    startInput.value = start;
                }

                if (endInput && start) {
                    endInput.value = nextDay(end ?? start);
                }

                if (label) {
                    label.textContent = start
                        ? `Selection : ${formatDate(start)} au ${formatDate(nextDay(end ?? start))} (depart)`
                        : 'Aucune periode selectionnee.';
                }
            };

            document.addEventListener('click', (event) => {
                const button = event.target.closest('[data-calendar-day]');
                if (!button || button.dataset.calendarDisabled === '1') {
                    return;
                }

                const value = button.dataset.calendarDay;

                if (start === null || end !== null || value < start) {
                    start = value;
                    end = null;
                } else {
                    end = value;
                }

                refresh();
            });
        })();
    </script>
{% endblock %}
