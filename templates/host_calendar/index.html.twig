{% extends 'layout/user.html.twig' %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-6xl mx-auto w-full">
        <div class="mb-8 flex flex-col md:flex-row md:items-end md:justify-between gap-4">
            <div>
                <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">Calendriers</h1>
                <p class="text-gray-500 mt-1">Gérez les indisponibilités de vos logements.</p>
            </div>
            <a href="{{ path('app_host_reservation_index') }}" class="inline-flex items-center gap-2 text-sm font-semibold text-gray-700 hover:text-gray-900">
                <i class="fa-solid fa-clock"></i>
                Demandes en attente
            </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5">
            {% for property in properties %}
                {% set cover = property.coverMedia %}
                <article class="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm">
                    <div class="h-44 bg-gray-100">
                        {% if cover %}
                            <img src="{{ cover.fileUrl }}" alt="{{ property.title }}" class="w-full h-full object-cover">
                        {% else %}
                            <div class="w-full h-full flex items-center justify-center text-gray-300">
                                <i class="fa-solid fa-house text-4xl"></i>
                            </div>
                        {% endif %}
                    </div>
                    <div class="p-5">
                        <div class="flex items-start justify-between gap-3">
                            <div>
                                <h2 class="font-semibold text-gray-900">{{ property.title }}</h2>
                                {% if property.address %}
                                    <p class="text-sm text-gray-500 mt-1">{{ property.address.city }}, {{ property.address.country }}</p>
                                {% endif %}
                            </div>
                            <span class="text-xs font-semibold px-2.5 py-1 rounded-full {{ property.status == 'published' ? 'bg-emerald-50 text-emerald-700' : 'bg-gray-100 text-gray-600' }}">
                                {{ property.status }}
                            </span>
                        </div>
                        <a href="{{ path('app_host_property_calendar', { id: property.id }) }}" class="mt-5 w-full inline-flex justify-center items-center gap-2 bg-brand hover:bg-brandHover text-white font-semibold text-sm px-4 py-3 rounded-lg transition">
                            <i class="fa-solid fa-calendar-days"></i>
                            Gérer le calendrier
                        </a>
                    </div>
                </article>
            {% else %}
                <div class="md:col-span-2 xl:col-span-3 text-center py-16 border border-dashed border-gray-200 rounded-xl bg-white">
                    <i class="fa-solid fa-house-circle-xmark text-4xl text-gray-300 mb-4"></i>
                    <p class="font-semibold text-gray-900">Aucun logement hôte</p>
                    <p class="text-sm text-gray-500 mt-1">Vos logements apparaîtront ici dès qu’ils seront créés.</p>
                </div>
            {% endfor %}
        </div>
    </main>
{% endblock %}
