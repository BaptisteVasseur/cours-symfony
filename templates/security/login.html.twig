{% extends 'layouts/base.html.twig' %}

{% block title %}Connexion — Airstay{% endblock %}

{% block header %}
    {% include 'components/_header_user.html.twig' %}
{% endblock %}

{% block body %}
    <section class="max-w-md mx-auto px-6 py-12">
        <h1 class="text-2xl font-bold mb-6 text-center">Connexion</h1>

        {% if error %}
            <div class="mb-4 p-3 rounded-lg bg-red-50 text-red-700 text-sm">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        {% if app.user %}
            <div class="mb-4 p-3 rounded-lg bg-gray-50 text-sm text-center">
                Connecté en tant que <span class="font-semibold">{{ app.user.userIdentifier }}</span> —
                <a href="{{ path('app_logout') }}" class="text-rausch hover:underline">Déconnexion</a>
            </div>
        {% endif %}

        <form method="post" class="space-y-4">
            <div>
                <label for="username" class="block text-sm font-medium mb-1">Adresse e-mail</label>
                <input type="email" value="{{ last_username }}" name="_username" id="username"
                       autocomplete="email" required autofocus
                       class="w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-rausch">
            </div>

            <div>
                <label for="password" class="block text-sm font-medium mb-1">Mot de passe</label>
                <input type="password" name="_password" id="password"
                       autocomplete="current-password" required
                       class="w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-rausch">
            </div>

            <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

            <button type="submit"
                    class="w-full py-3 bg-rausch hover:bg-rausch-dark text-white font-semibold rounded-lg transition">
                Se connecter
            </button>
        </form>

        <p class="text-center text-sm text-gray-600 mt-6">
            Pas encore de compte ?
            <a href="{{ path('app_register') }}" class="text-rausch font-medium hover:underline">Inscription</a>
        </p>
    </section>
{% endblock %}
