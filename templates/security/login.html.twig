{% extends 'layout/base.html.twig' %}

{% block title %}Connexion — HomeStay{% endblock %}

{% block body %}
<div class="max-w-md mx-auto px-4 py-12">
    <div class="bg-white border border-gray-200 rounded-2xl shadow-sm p-8">
        <h1 class="text-2xl font-bold text-gray-900 mb-6">Se connecter</h1>

        {% if error %}
            <div class="mb-4 px-4 py-3 rounded-lg bg-red-100 text-red-800 text-sm">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        <form method="post">
            <label for="inputEmail" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
            <input type="email" value="{{ last_username }}" name="_username" id="inputEmail"
                   class="w-full mb-4 px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#FF385C] focus:border-transparent"
                   autocomplete="email" required autofocus>

            <label for="inputPassword" class="block text-sm font-medium text-gray-700 mb-1">Mot de passe</label>
            <input type="password" name="_password" id="inputPassword"
                   class="w-full mb-4 px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-[#FF385C] focus:border-transparent"
                   autocomplete="current-password" required>

            <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

            <button type="submit"
                    class="w-full py-2.5 bg-[#FF385C] text-white font-semibold rounded-lg hover:bg-[#E11D48] transition">
                Connexion
            </button>
        </form>

        <p class="mt-6 text-sm text-center text-gray-500">
            Pas encore de compte ?
            <a href="{{ path('app_register') }}" class="text-[#FF385C] font-medium hover:underline">S'inscrire</a>
        </p>

        <div class="mt-6 pt-6 border-t border-gray-100 text-xs text-gray-400">
            <p class="font-medium mb-1">Comptes de démonstration (mot de passe : <code>password123</code>) :</p>
            <p>admin : frank@example.com — hôte : alice@example.com — voyageur : carol@example.com</p>
        </div>
    </div>
</div>
{% endblock %}
