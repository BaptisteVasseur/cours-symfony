{% extends 'layout/base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
<div class="min-h-screen flex items-center justify-center px-4 py-16">
    <div class="w-full max-w-md">
        <div class="text-center mb-8">
            <h1 class="text-3xl font-bold text-gray-900">Connexion</h1>
            <p class="text-gray-500 mt-2">Accédez à votre compte Airbnb</p>
        </div>

        <div class="bg-white border border-gray-200 rounded-2xl p-8 shadow-sm">
            {% if error %}
                <div class="mb-4 bg-red-50 text-red-600 px-4 py-3 rounded-lg text-sm">
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            <form method="POST" action="{{ path('app_login') }}" class="space-y-5">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('login') }}">

                <div>
                    <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                    <input type="email" id="email" name="_username" value="{{ last_username }}" autocomplete="email" required
                           class="w-full border border-gray-300 rounded-lg px-4 py-2.5 outline-none focus:ring-2 focus:ring-rose-400 focus:border-transparent">
                </div>

                <div>
                    <label for="password" class="block text-sm font-medium text-gray-700 mb-1">Mot de passe</label>
                    <input type="password" id="password" name="_password" autocomplete="current-password" required
                           class="w-full border border-gray-300 rounded-lg px-4 py-2.5 outline-none focus:ring-2 focus:ring-rose-400 focus:border-transparent">
                </div>

                <button type="submit" class="w-full bg-rose-500 hover:bg-rose-600 text-white font-semibold py-3 rounded-xl transition">
                    Se connecter
                </button>
            </form>

            <p class="text-center text-sm text-gray-500 mt-6">
                Pas encore de compte ?
                <a href="{{ path('app_register') }}" class="text-rose-500 hover:underline font-medium">S'inscrire</a>
            </p>
        </div>
    </div>
</div>
{% endblock %}
