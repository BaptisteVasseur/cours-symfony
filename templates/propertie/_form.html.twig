{{ form_start(form, { attr: { class: 'space-y-5' } }) }}

    <div class="flex flex-col gap-1.5">
        {{ form_label(form.title, 'Titre', { label_attr: { class: 'text-sm font-semibold text-gray-700' } }) }}
        {{ form_widget(form.title, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[#FF385C] focus:border-transparent transition' } }) }}
        {{ form_errors(form.title) }}
    </div>

    <div class="flex flex-col gap-1.5">
        {{ form_label(form.description, 'Description', { label_attr: { class: 'text-sm font-semibold text-gray-700' } }) }}
        {{ form_widget(form.description, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[#FF385C] focus:border-transparent transition resize-none', rows: 4 } }) }}
        {{ form_errors(form.description) }}
    </div>

    <div class="grid grid-cols-2 gap-4">
        <div class="flex flex-col gap-1.5">
            {{ form_label(form.propertyType, 'Type', { label_attr: { class: 'text-sm font-semibold text-gray-700' } }) }}
            {{ form_widget(form.propertyType, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[#FF385C] transition' } }) }}
        </div>
        <div class="flex flex-col gap-1.5">
            {{ form_label(form.status, 'Statut', { label_attr: { class: 'text-sm font-semibold text-gray-700' } }) }}
            {{ form_widget(form.status, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[#FF385C] transition' } }) }}
        </div>
    </div>

    <div class="grid grid-cols-2 gap-4">
        <div class="flex flex-col gap-1.5">
            {{ form_label(form.pricePerNight, 'Prix / nuit (€)', { label_attr: { class: 'text-sm font-semibold text-gray-700' } }) }}
            {{ form_widget(form.pricePerNight, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[#FF385C] transition' } }) }}
        </div>
        <div class="flex flex-col gap-1.5">
            {{ form_label(form.cleaningFee, 'Frais ménage (€)', { label_attr: { class: 'text-sm font-semibold text-gray-700' } }) }}
            {{ form_widget(form.cleaningFee, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[#FF385C] transition' } }) }}
        </div>
    </div>

    <div class="grid grid-cols-4 gap-4">
        <div class="flex flex-col gap-1.5">
            {{ form_label(form.maxGuests, 'Voyageurs', { label_attr: { class: 'text-sm font-semibold text-gray-700' } }) }}
            {{ form_widget(form.maxGuests, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[#FF385C] transition' } }) }}
        </div>
        <div class="flex flex-col gap-1.5">
            {{ form_label(form.bedrooms, 'Chambres', { label_attr: { class: 'text-sm font-semibold text-gray-700' } }) }}
            {{ form_widget(form.bedrooms, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[#FF385C] transition' } }) }}
        </div>
        <div class="flex flex-col gap-1.5">
            {{ form_label(form.beds, 'Lits', { label_attr: { class: 'text-sm font-semibold text-gray-700' } }) }}
            {{ form_widget(form.beds, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[#FF385C] transition' } }) }}
        </div>
        <div class="flex flex-col gap-1.5">
            {{ form_label(form.bathrooms, 'S. de bain', { label_attr: { class: 'text-sm font-semibold text-gray-700' } }) }}
            {{ form_widget(form.bathrooms, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-[#FF385C] transition' } }) }}
        </div>
    </div>

    <div class="flex items-center gap-3 pt-2 border-t border-gray-100">
        <button type="submit" class="bg-[#FF385C] hover:bg-[#E31C5F] text-white font-semibold px-6 py-3 rounded-xl transition-colors text-sm">
            {{ button_label|default('Enregistrer') }}
        </button>
        <a href="" class="text-sm text-gray-500 hover:underline">
            Annuler
        </a>
    </div>

{{ form_end(form) }}