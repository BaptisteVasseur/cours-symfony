{% extends 'layout/admin.html.twig' %}

{% block title %}{{ property.title }}{% endblock %}

{% block breadcrumb %}
    <span class="text-gray-300">/</span>
    <a href="" class="text-gray-500 hover:text-gray-700">Logements</a>
    <span class="text-gray-300">/</span>
    <span class="text-gray-900 font-medium truncate">{{ property.title }}</span>
{% endblock %}

{% block body %}
<div class="flex items-center justify-between mb-6">
    <h1 class="text-xl font-bold text-gray-900">{{ property.title }}</h1>
    <div class="flex items-center gap-3">
        <a href=""
           class="flex items-center gap-2 px-4 py-2 text-sm font-semibold border border-gray-300 rounded-xl hover:bg-gray-50 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931z"/>
            </svg>
            Modifier
        </a>
        <form method="post" action=""
              onsubmit="return confirm('Supprimer ce logement ?')">
            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ property.id) }}">
            <button type="submit" class="flex items-center gap-2 px-4 py-2 text-sm font-semibold bg-red-50 text-red-600 border border-red-200 rounded-xl hover:bg-red-100 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0"/>
                </svg>
                Supprimer
            </button>
        </form>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

    {# Infos principales #}
    <div class="lg:col-span-2 space-y-6">
        <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100">
                <h2 class="text-sm font-semibold text-gray-900">Informations générales</h2>
            </div>
            <div class="divide-y divide-gray-100">
                <div class="flex justify-between px-6 py-3 text-sm">
                    <span class="text-gray-500">Titre</span>
                    <span class="font-medium text-gray-900">{{ property.title }}</span>
                </div>
                <div class="flex justify-between px-6 py-3 text-sm">
                    <span class="text-gray-500">Type</span>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-700">{{ property.propertyType }}</span>
                </div>
                <div class="flex justify-between px-6 py-3 text-sm">
                    <span class="text-gray-500">Statut</span>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold
                        {% if property.status == 'active' %}bg-green-100 text-green-700
                        {% else %}bg-gray-100 text-gray-500{% endif %}">
                        {{ property.status }}
                    </span>
                </div>
                <div class="px-6 py-3 text-sm">
                    <span class="text-gray-500 block mb-1">Description</span>
                    <p class="text-gray-900 leading-relaxed">{{ property.description ?? '—' }}</p>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100">
                <h2 class="text-sm font-semibold text-gray-900">Capacité</h2>
            </div>
            <div class="grid grid-cols-2 divide-x divide-y divide-gray-100">
                <div class="px-6 py-4 text-sm">
                    <p class="text-gray-400 text-xs mb-1">Voyageurs max</p>
                    <p class="font-bold text-gray-900 text-lg">{{ property.maxGuests }}</p>
                </div>
                <div class="px-6 py-4 text-sm">
                    <p class="text-gray-400 text-xs mb-1">Chambres</p>
                    <p class="font-bold text-gray-900 text-lg">{{ property.bedrooms }}</p>
                </div>
                <div class="px-6 py-4 text-sm">
                    <p class="text-gray-400 text-xs mb-1">Lits</p>
                    <p class="font-bold text-gray-900 text-lg">{{ property.beds }}</p>
                </div>
                <div class="px-6 py-4 text-sm">
                    <p class="text-gray-400 text-xs mb-1">Salles de bain</p>
                    <p class="font-bold text-gray-900 text-lg">{{ property.bathrooms }}</p>
                </div>
            </div>
        </div>
    </div>

    {# Sidebar #}
    <div class="space-y-6">
        <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100">
                <h2 class="text-sm font-semibold text-gray-900">Tarifs</h2>
            </div>
            <div class="divide-y divide-gray-100">
                <div class="flex justify-between px-6 py-3 text-sm">
                    <span class="text-gray-500">Prix / nuit</span>
                    <span class="font-bold text-gray-900">{{ property.pricePerNight }} €</span>
                </div>
                <div class="flex justify-between px-6 py-3 text-sm">
                    <span class="text-gray-500">Frais ménage</span>
                    <span class="text-gray-900">{{ property.cleaningFee ? property.cleaningFee ~ ' €' : '—' }}</span>
                </div>
                <div class="flex justify-between px-6 py-3 text-sm">
                    <span class="text-gray-500">Caution</span>
                    <span class="text-gray-900">{{ property.securityDeposit ? property.securityDeposit ~ ' €' : '—' }}</span>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100">
                <h2 class="text-sm font-semibold text-gray-900">Check-in / Check-out</h2>
            </div>
            <div class="divide-y divide-gray-100">
                <div class="flex justify-between px-6 py-3 text-sm">
                    <span class="text-gray-500">Arrivée</span>
                    <span class="text-gray-900">{{ property.checkinTime ? property.checkinTime|date('H:i') : '—' }}</span>
                </div>
                <div class="flex justify-between px-6 py-3 text-sm">
                    <span class="text-gray-500">Départ</span>
                    <span class="text-gray-900">{{ property.checkoutTime ? property.checkoutTime|date('H:i') : '—' }}</span>
                </div>
                <div class="flex justify-between px-6 py-3 text-sm">
                    <span class="text-gray-500">Réservation instantanée</span>
                    <span class="font-medium {% if property.instantBooking %}text-green-600{% else %}text-gray-400{% endif %}">
                        {{ property.instantBooking ? 'Oui' : 'Non' }}
                    </span>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-2xl border border-gray-200 overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100">
                <h2 class="text-sm font-semibold text-gray-900">Métadonnées</h2>
            </div>
            <div class="divide-y divide-gray-100">
                <div class="flex justify-between px-6 py-3 text-sm">
                    <span class="text-gray-500">Créé le</span>
                    <span class="text-gray-900">{{ property.createdAt|date('d/m/Y') }}</span>
                </div>
                <div class="flex justify-between px-6 py-3 text-sm">
                    <span class="text-gray-500">Modifié le</span>
                    <span class="text-gray-900">{{ property.updatedAt ? property.updatedAt|date('d/m/Y') : '—' }}</span>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}