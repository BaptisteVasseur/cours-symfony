{% extends 'layout/base.html.twig' %}

{% block title %}Notifications - StayShare{% endblock %}

{% block body %}
    <main class="mx-auto max-w-5xl px-4 py-10 sm:px-6 lg:px-8">
        <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <p class="text-sm font-semibold uppercase tracking-wide text-rose-600">Centre d'activite</p>
                <h1 class="text-3xl font-bold text-gray-950">Notifications</h1>
                <p class="mt-2 text-gray-600">{{ non_lues }} notification{{ non_lues > 1 ? 's' : '' }} non lue{{ non_lues > 1 ? 's' : '' }}.</p>
            </div>

            {% if non_lues > 0 %}
                <form method="post" action="{{ path('app_notification_read_all') }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('notification_read_all') }}">
                    <button class="rounded-md border border-gray-300 px-4 py-2 text-sm font-semibold text-gray-800 hover:bg-gray-50" type="submit">Tout marquer comme lu</button>
                </form>
            {% endif %}
        </div>

        {% if notifications is empty %}
            <section class="rounded-lg border border-dashed border-gray-300 bg-gray-50 p-8 text-center">
                <h2 class="text-xl font-semibold text-gray-950">Aucune notification</h2>
                <p class="mt-2 text-gray-600">Les demandes, validations et paiements importants apparaitront ici.</p>
            </section>
        {% else %}
            <div class="space-y-4">
                {% for notification in notifications %}
                    <article class="rounded-lg border {{ notification.statut.value == 'non_lue' ? 'border-rose-200 bg-rose-50' : 'border-gray-200 bg-white' }} p-5 shadow-sm">
                        <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
                            <div>
                                <div class="flex flex-wrap items-center gap-2">
                                    <h2 class="text-lg font-semibold text-gray-950">{{ notification.titre }}</h2>
                                    {% if notification.statut.value == 'non_lue' %}
                                        <span class="rounded-full bg-rose-600 px-2 py-1 text-xs font-semibold text-white">Nouveau</span>
                                    {% endif %}
                                </div>
                                <p class="mt-2 text-sm text-gray-700">{{ notification.contenu }}</p>
                                <p class="mt-3 text-xs text-gray-500">{{ notification.dateCreation|date('d/m/Y H:i') }}</p>
                            </div>

                            <form method="post" action="{{ path('app_notification_read', { id: notification.id }) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('notification_read_' ~ notification.id) }}">
                                <button class="rounded-md bg-gray-950 px-4 py-2 text-sm font-semibold text-white hover:bg-gray-800" type="submit">
                                    {{ notification.lienAction ? 'Ouvrir' : 'Marquer comme lu' }}
                                </button>
                            </form>
                        </div>
                    </article>
                {% endfor %}
            </div>
        {% endif %}
    </main>
{% endblock %}
