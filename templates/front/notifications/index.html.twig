{% extends 'layout/app.html.twig' %}

{% block title %}Notifications{% endblock %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-3xl mx-auto w-full">
        <h1 class="text-2xl font-semibold text-gray-900 mb-6">Notifications</h1>

        {% if notifications is empty %}
            <div class="text-center py-16 text-gray-400">
                <i class="fa-solid fa-bell-slash text-4xl mb-4 block"></i>
                <p class="text-lg">Aucune notification pour le moment.</p>
            </div>
        {% else %}
            <ul class="space-y-3">
                {% for notification in notifications %}
                    {% set iconMap = {
                        'reservation_pending': 'fa-clock text-yellow-500',
                        'reservation_confirmed': 'fa-circle-check text-green-500',
                        'reservation_cancelled': 'fa-circle-xmark text-red-500',
                        'checkin_reminder': 'fa-calendar-day text-blue-500',
                    } %}
                    <li class="flex items-start gap-4 p-4 rounded-xl border border-gray-200 {{ notification.isRead ? 'bg-white' : 'bg-blue-50 border-blue-100' }}">
                        <div class="shrink-0 mt-0.5 text-xl">
                            <i class="fa-solid {{ iconMap[notification.type]|default('fa-bell text-gray-400') }}"></i>
                        </div>
                        <div class="flex-1 min-w-0">
                            <p class="text-sm font-semibold text-gray-900">{{ notification.title }}</p>
                            {% if notification.content %}
                                <p class="text-sm text-gray-500 mt-0.5">{{ notification.content }}</p>
                            {% endif %}
                            <p class="text-xs text-gray-400 mt-1">{{ notification.createdAt|date('d/m/Y à H:i') }}</p>
                        </div>
                        {% if not notification.isRead %}
                            <span class="shrink-0 w-2 h-2 bg-brand rounded-full mt-2"></span>
                        {% endif %}
                    </li>
                {% endfor %}
            </ul>
        {% endif %}
    </main>
{% endblock %}
