{% extends 'layout/app.html.twig' %}

{% block title %}Recherche{% endblock %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-5xl mx-auto w-full">

        {# Barre de recherche #}
        <form method="get" action="{{ path('app_search') }}" class="flex flex-wrap gap-3 mb-8 bg-white border border-gray-200 rounded-2xl p-4 shadow-sm" data-turbo="false">
            <div class="flex-1 min-w-[140px]">
                <label class="block text-xs text-gray-500 mb-1">Destination</label>
                <input type="text" name="destination" value="{{ destination }}" placeholder="Ville, adresse…" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
            </div>
            <div>
                <label class="block text-xs text-gray-500 mb-1">Arrivée</label>
                <input type="date" name="checkin" value="{{ checkin ? checkin|date('Y-m-d') : '' }}" class="border border-gray-300 rounded-lg px-3 py-2 text-sm">
            </div>
            <div>
                <label class="block text-xs text-gray-500 mb-1">Départ</label>
                <input type="date" name="checkout" value="{{ checkout ? checkout|date('Y-m-d') : '' }}" class="border border-gray-300 rounded-lg px-3 py-2 text-sm">
            </div>
            <div>
                <label class="block text-xs text-gray-500 mb-1">Voyageurs</label>
                <input type="number" name="guests" value="{{ guests }}" min="1" placeholder="1" class="w-24 border border-gray-300 rounded-lg px-3 py-2 text-sm">
            </div>
            <div class="flex items-end">
                <button type="submit" class="bg-brand hover:bg-brandHover text-white font-semibold px-5 py-2 rounded-lg text-sm transition">
                    <i class="fa-solid fa-magnifying-glass mr-1"></i> Rechercher
                </button>
            </div>
        </form>

        {# Titre résultats #}
        <div class="mb-6">
            <h1 class="text-xl font-semibold text-gray-900">
                {% if destination %}« {{ destination }} »{% else %}Tous les logements{% endif %}
            </h1>
            <p class="text-sm text-gray-500 mt-1">
                {{ properties|length }} logement{{ properties|length > 1 ? 's' : '' }} disponible{{ properties|length > 1 ? 's' : '' }}
                {% if checkin and checkout %} · {{ checkin|date('d/m') }} → {{ checkout|date('d/m/Y') }}{% endif %}
                {% if guests %} · {{ guests }} voyageur{{ guests > 1 ? 's' : '' }}{% endif %}
            </p>
        </div>

        {# Résultats #}
        {% if properties|length == 0 %}
            <div class="text-center py-16 border border-dashed border-gray-200 rounded-xl">
                <i class="fa-solid fa-magnifying-glass text-4xl text-gray-300 mb-4"></i>
                <p class="text-gray-500">Aucun logement disponible pour ces critères.</p>
                <a href="{{ path('app_search') }}" class="mt-4 inline-block text-sm text-brand hover:underline">Effacer les filtres</a>
            </div>
        {% else %}
            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-6 gap-y-10">
                {% for property in properties %}
                    {% include 'components/card.html.twig' with { property: property } %}
                {% endfor %}
            </div>
        {% endif %}

    </main>
{% endblock %}