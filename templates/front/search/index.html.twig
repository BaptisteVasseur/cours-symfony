{% extends 'layout/app.html.twig' %}

{% block title %}Résultats de recherche{% endblock %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-6xl mx-auto w-full">
        {# Formulaire de recherche / d'affinage #}
        <form action="{{ path('app_search') }}" method="get" class="bg-white border border-gray-200 rounded-2xl p-4 shadow-sm mb-8 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-3 items-end">
            <div class="lg:col-span-2">
                <label class="block text-xs font-semibold text-gray-700 mb-1">Destination</label>
                <input type="text" name="destination" value="{{ destination }}" placeholder="Ville, adresse…" class="w-full border border-gray-300 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:border-gray-900">
            </div>
            <div>
                <label class="block text-xs font-semibold text-gray-700 mb-1">Arrivée</label>
                <input type="date" name="checkin" value="{{ checkin ? checkin|date('Y-m-d') : '' }}" class="w-full border border-gray-300 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:border-gray-900">
            </div>
            <div>
                <label class="block text-xs font-semibold text-gray-700 mb-1">Départ</label>
                <input type="date" name="checkout" value="{{ checkout ? checkout|date('Y-m-d') : '' }}" class="w-full border border-gray-300 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:border-gray-900">
            </div>
            <div class="flex gap-3">
                <div class="flex-1">
                    <label class="block text-xs font-semibold text-gray-700 mb-1">Voyageurs</label>
                    <input type="number" name="guests" value="{{ guests > 0 ? guests : '' }}" min="1" max="16" placeholder="1" class="w-full border border-gray-300 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:border-gray-900">
                </div>
                <button type="submit" class="shrink-0 self-end h-[42px] px-4 bg-brand hover:bg-brandHover text-white font-semibold rounded-xl transition" aria-label="Rechercher">
                    <i class="fa-solid fa-magnifying-glass"></i>
                </button>
            </div>
        </form>

        <h1 class="text-2xl md:text-3xl font-semibold text-gray-900 mb-2">
            {{ properties|length }} logement{{ properties|length > 1 ? 's' : '' }} trouvé{{ properties|length > 1 ? 's' : '' }}
        </h1>

        {# Récapitulatif des critères de recherche #}
        {% if destination or (checkin and checkout) or guests > 0 %}
            <div class="flex flex-wrap items-center gap-2 mb-8">
                {% if destination %}
                    <span class="inline-flex items-center gap-2 text-sm bg-gray-100 text-gray-700 rounded-full px-3 py-1.5">
                        <i class="fa-solid fa-location-dot text-gray-400"></i> {{ destination }}
                    </span>
                {% endif %}
                {% if checkin and checkout %}
                    <span class="inline-flex items-center gap-2 text-sm bg-gray-100 text-gray-700 rounded-full px-3 py-1.5">
                        <i class="fa-regular fa-calendar text-gray-400"></i> {{ checkin|date('d/m/Y') }} → {{ checkout|date('d/m/Y') }}
                    </span>
                {% endif %}
                {% if guests > 0 %}
                    <span class="inline-flex items-center gap-2 text-sm bg-gray-100 text-gray-700 rounded-full px-3 py-1.5">
                        <i class="fa-solid fa-user-group text-gray-400"></i> {{ guests }} voyageur{{ guests > 1 ? 's' : '' }}
                    </span>
                {% endif %}
            </div>
        {% endif %}

        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-6 gap-y-10">
            {% for property in properties %}
                {% include 'components/card.html.twig' with { property: property, checkin: checkin, checkout: checkout } %}
            {% else %}
                <div class="col-span-full text-center py-16 border border-dashed border-gray-200 rounded-xl">
                    <i class="fa-solid fa-magnifying-glass text-4xl text-gray-300 mb-4"></i>
                    <p class="text-gray-500">Aucun logement ne correspond à votre recherche.</p>
                    <a href="{{ path('app_home') }}" class="inline-block mt-4 text-sm font-semibold text-brand hover:underline">Voir tous les logements</a>
                </div>
            {% endfor %}
        </div>
    </main>
{% endblock %}
