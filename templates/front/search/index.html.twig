{% extends 'layout/app.html.twig' %}

{% block title %}Recherche{% endblock %}

{% block content %}
<main class="flex-grow px-6 md:px-12 py-8 max-w-5xl mx-auto w-full">
    <h1 class="text-2xl md:text-3xl font-semibold text-gray-900 mb-2">Résultats de recherche</h1>

    {# Filtres actifs #}
    <div class="flex flex-wrap gap-2 mb-6 text-sm text-gray-600">
        {% if destination %}
            <span class="bg-gray-100 px-3 py-1 rounded-full"><i class="fa-solid fa-location-dot mr-1"></i>{{ destination }}</span>
        {% endif %}
        {% if checkin and checkout %}
            <span class="bg-gray-100 px-3 py-1 rounded-full"><i class="fa-regular fa-calendar mr-1"></i>{{ checkin|date('d/m/Y') }} → {{ checkout|date('d/m/Y') }}</span>
        {% endif %}
        {% if guests > 0 %}
            <span class="bg-gray-100 px-3 py-1 rounded-full"><i class="fa-solid fa-user mr-1"></i>{{ guests }} voyageur{{ guests > 1 ? 's' }}</span>
        {% endif %}
        {% if destination or checkin or guests > 0 %}
            <a href="{{ path('app_search') }}" class="text-brand hover:underline ml-1">Effacer les filtres</a>
        {% endif %}
    </div>

    <p class="text-gray-500 mb-6">{{ properties|length }} logement{{ properties|length != 1 ? 's' }} trouvé{{ properties|length != 1 ? 's' }}</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-6 gap-y-10">
        {% for property in properties %}
            {% include 'components/card.html.twig' with { property: property } %}
        {% else %}
            <p class="col-span-full text-gray-500">Aucun logement disponible pour ces critères.</p>
        {% endfor %}
    </div>
</main>
{% endblock %}
