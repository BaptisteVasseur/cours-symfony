{% extends 'layout/app.html.twig' %}

{% block title %}Recherche{% if destination %} — {{ destination }}{% endif %}{% endblock %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-6xl mx-auto w-full">

        <form method="GET" action="{{ path('app_search') }}" class="bg-white border border-gray-200 rounded-2xl shadow-sm p-4 mb-8">
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
                <div>
                    <label class="block text-[10px] font-bold uppercase text-gray-500 mb-1">Destination</label>
                    <input type="text" name="destination" value="{{ destination }}"
                           placeholder="Ville, adresse..."
                           class="w-full border border-gray-300 rounded-xl px-3 py-2 text-sm outline-none focus:ring-2 focus:ring-brand">
                </div>
                <div>
                    <label class="block text-[10px] font-bold uppercase text-gray-500 mb-1">Arrivée</label>
                    <input type="date" name="checkin" value="{{ checkin ? checkin|date('Y-m-d') : '' }}"
                           min="{{ "now"|date('Y-m-d') }}"
                           class="w-full border border-gray-300 rounded-xl px-3 py-2 text-sm outline-none focus:ring-2 focus:ring-brand">
                </div>
                <div>
                    <label class="block text-[10px] font-bold uppercase text-gray-500 mb-1">Départ</label>
                    <input type="date" name="checkout" value="{{ checkout ? checkout|date('Y-m-d') : '' }}"
                           min="{{ "now"|date('Y-m-d') }}"
                           class="w-full border border-gray-300 rounded-xl px-3 py-2 text-sm outline-none focus:ring-2 focus:ring-brand">
                </div>
                <div>
                    <label class="block text-[10px] font-bold uppercase text-gray-500 mb-1">Voyageurs</label>
                    <div class="flex gap-2">
                        <input type="number" name="guests" value="{{ guests }}" min="1" placeholder="1"
                               class="flex-1 border border-gray-300 rounded-xl px-3 py-2 text-sm outline-none focus:ring-2 focus:ring-brand">
                        <button type="submit"
                                class="px-4 py-2 bg-brand hover:bg-brandHover text-white text-sm font-semibold rounded-xl transition">
                            <i class="fa-solid fa-magnifying-glass"></i>
                        </button>
                    </div>
                </div>
            </div>
        </form>

        <div class="flex items-center justify-between mb-4">
            <div>
                <h1 class="text-xl font-bold text-gray-900">
                    {% if destination %}
                        Résultats pour « {{ destination }} »
                    {% else %}
                        Tous les logements disponibles
                    {% endif %}
                </h1>
                <p class="text-sm text-gray-500 mt-0.5">
                    {{ properties|length }} logement{{ properties|length != 1 ? 's' : '' }} trouvé{{ properties|length != 1 ? 's' : '' }}
                    {% if checkin and checkout %}
                        · du {{ checkin|date('d/m/Y') }} au {{ checkout|date('d/m/Y') }}
                    {% endif %}
                    {% if guests %}
                        · {{ guests }} voyageur{{ guests > 1 ? 's' : '' }}
                    {% endif %}
                </p>
            </div>
            {% if destination or checkin or checkout or guests %}
                <a href="{{ path('app_search') }}" class="text-sm text-gray-500 hover:text-gray-900 underline">
                    Effacer les filtres
                </a>
            {% endif %}
        </div>

        {% if properties|length > 0 %}
            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-6 gap-y-10">
                {% for property in properties %}
                    {% set bookingUrl = checkin and checkout
                        ? path('app_booking_checkout', { id: property.id, checkin: checkin|date('Y-m-d'), checkout: checkout|date('Y-m-d'), guests: guests })
                        : path('app_logement_detail', { id: property.id }) %}
                    {% include 'components/card.html.twig' with { property: property, bookingUrl: bookingUrl } %}
                {% endfor %}
            </div>
        {% else %}
            <div class="text-center py-20">
                <i class="fa-solid fa-magnifying-glass text-4xl text-gray-300 mb-4"></i>
                <p class="text-lg font-medium text-gray-700">Aucun logement disponible</p>
                <p class="text-sm text-gray-500 mt-1">
                    {% if checkin and checkout %}
                        Aucun logement n'est libre pour ces dates.
                    {% else %}
                        Essayez d'autres critères de recherche.
                    {% endif %}
                </p>
                <a href="{{ path('app_search') }}" class="inline-block mt-4 px-5 py-2 border border-gray-300 rounded-xl text-sm font-semibold hover:bg-gray-50 transition">
                    Voir tous les logements
                </a>
            </div>
        {% endif %}
    </main>
{% endblock %}
