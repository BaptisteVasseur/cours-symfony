{% extends 'layout/app.html.twig' %}

{% block title %}Recherche{% if destination %} — {{ destination }}{% endif %}{% endblock %}

{% block content %}
<main class="flex-grow px-4 md:px-10 py-8 max-w-7xl mx-auto w-full">

    {# ===== Barre de filtres appliqués ===== #}
    <div class="mb-6">
        <h1 class="text-2xl md:text-3xl font-semibold text-gray-900 mb-3">
            {% if destination %}
                Logements à <span class="text-brand">{{ destination }}</span>
            {% else %}
                Tous les logements disponibles
            {% endif %}
        </h1>

        {# Résumé des filtres actifs #}
        <div class="flex flex-wrap items-center gap-2 text-sm">
            {% if checkin and checkout %}
                <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-brand/10 text-brand rounded-full font-medium">
                    <i class="fa-regular fa-calendar text-xs"></i>
                    {{ checkin|date('d/m/Y') }} → {{ checkout|date('d/m/Y') }}
                </span>
            {% endif %}
            {% if guests %}
                <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-brand/10 text-brand rounded-full font-medium">
                    <i class="fa-regular fa-user text-xs"></i>
                    {{ guests }} voyageur{{ guests > 1 ? 's' : '' }}
                </span>
            {% endif %}

            <span class="text-gray-500 ml-auto">
                <strong class="text-gray-900">{{ totalResults }}</strong>
                logement{{ totalResults > 1 ? 's' : '' }} trouvé{{ totalResults > 1 ? 's' : '' }}
            </span>
        </div>

        {# Formulaire de recherche pour affiner les filtres #}
        <form method="GET" action="{{ path('app_search') }}"
              class="mt-4 flex flex-col sm:flex-row gap-2 bg-white border border-gray-200 rounded-2xl shadow-sm p-3">
            <div class="flex-1">
                <label class="block text-xs font-medium text-gray-500 mb-1 px-1">Destination</label>
                <input type="text" name="destination" value="{{ destination }}"
                       placeholder="Ville, adresse…"
                       class="w-full px-3 py-2 text-sm border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent transition">
            </div>
            <div>
                <label class="block text-xs font-medium text-gray-500 mb-1 px-1">Arrivée</label>
                <input type="date" name="checkin" value="{{ checkin ? checkin|date('Y-m-d') : '' }}"
                       class="w-full px-3 py-2 text-sm border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent transition">
            </div>
            <div>
                <label class="block text-xs font-medium text-gray-500 mb-1 px-1">Départ</label>
                <input type="date" name="checkout" value="{{ checkout ? checkout|date('Y-m-d') : '' }}"
                       class="w-full px-3 py-2 text-sm border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent transition">
            </div>
            <div class="w-28">
                <label class="block text-xs font-medium text-gray-500 mb-1 px-1">Voyageurs</label>
                <input type="number" name="guests" value="{{ guests }}" min="1" max="30"
                       placeholder="1"
                       class="w-full px-3 py-2 text-sm border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent transition">
            </div>
            <div class="flex items-end">
                <button type="submit"
                        class="w-full sm:w-auto px-5 py-2.5 bg-brand hover:bg-brandHover text-white text-sm font-semibold rounded-xl transition shadow-sm flex items-center gap-2 justify-center">
                    <i class="fa-solid fa-magnifying-glass"></i> Rechercher
                </button>
            </div>
        </form>
    </div>

    {# ===== Grille de résultats ===== #}
    {% if properties|length > 0 %}
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-6 gap-y-10">
            {% for property in properties %}
                {% include 'components/card.html.twig' with { property: property, checkin: checkin, checkout: checkout } %}
            {% endfor %}
        </div>
    {% else %}
        <div class="text-center py-20 border border-dashed border-gray-200 rounded-2xl">
            <i class="fa-regular fa-face-frown-open text-5xl text-gray-300 mb-4 block"></i>
            <p class="text-gray-700 font-semibold text-lg mb-1">Aucun logement disponible</p>
            <p class="text-gray-500 text-sm">
                {% if checkin and checkout %}
                    Aucun logement n'est disponible pour ces dates
                    {% if destination %} à <strong>{{ destination }}</strong>{% endif %}
                    {% if guests %} pour {{ guests }} voyageur{{ guests > 1 ? 's' : '' }}{% endif %}.
                {% elseif destination %}
                    Aucun logement trouvé pour « <strong>{{ destination }}</strong> ».
                {% else %}
                    Essayez d'affiner vos critères.
                {% endif %}
            </p>
            <a href="{{ path('app_search') }}"
               class="inline-block mt-4 text-brand font-semibold hover:underline text-sm">
                Voir tous les logements
            </a>
        </div>
    {% endif %}

</main>
{% endblock %}
