{% extends 'layout/app.html.twig' %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-6xl mx-auto w-full">
        <form method="GET" action="{{ path('app_search') }}" class="mb-8 p-4 border border-gray-200 rounded-xl bg-gray-50 flex flex-wrap gap-3 items-end">
            <div class="flex-1 min-w-40">
                <label class="block text-xs font-semibold text-gray-500 mb-1 uppercase tracking-wide">Destination</label>
                <input type="text" name="destination" value="{{ destination|default('') }}" placeholder="Ville, adresse..."
                    class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm bg-white">
            </div>
            <div class="min-w-36">
                <label class="block text-xs font-semibold text-gray-500 mb-1 uppercase tracking-wide">Arrivée</label>
                <input type="date" name="checkin" value="{{ checkin ? checkin|date('Y-m-d') : '' }}"
                    class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm bg-white">
            </div>
            <div class="min-w-36">
                <label class="block text-xs font-semibold text-gray-500 mb-1 uppercase tracking-wide">Départ</label>
                <input type="date" name="checkout" value="{{ checkout ? checkout|date('Y-m-d') : '' }}"
                    class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm bg-white">
            </div>
            <div class="min-w-24">
                <label class="block text-xs font-semibold text-gray-500 mb-1 uppercase tracking-wide">Voyageurs</label>
                <input type="number" name="guests" min="1" value="{{ guests|default('') }}" placeholder="1"
                    class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm bg-white">
            </div>
            <button type="submit" class="px-6 py-2 bg-brand text-white font-semibold rounded-lg hover:opacity-90 transition text-sm shrink-0">
                <i class="fa-solid fa-magnifying-glass mr-1"></i> Rechercher
            </button>
        </form>

        <div class="mb-6 flex flex-wrap items-center justify-between gap-2">
            <div>
                <h1 class="text-xl font-semibold text-gray-900">
                    {% if destination %}Logements à « {{ destination }} »{% else %}Tous les logements disponibles{% endif %}
                    <span class="text-sm font-normal text-gray-400 ml-1">({{ properties|length }} résultat{{ properties|length != 1 ? 's' }})</span>
                </h1>
                {% if checkin and checkout %}
                    <p class="text-sm text-gray-500">{{ checkin|date('d/m/Y') }} → {{ checkout|date('d/m/Y') }}{% if guests %} · {{ guests }} voyageur{{ guests > 1 ? 's' }}{% endif %}</p>
                {% endif %}
            </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-6 gap-y-10">
            {% for property in properties %}
                {% include 'components/card.html.twig' with { property: property } %}
            {% else %}
                <div class="col-span-full text-center py-16 border border-dashed border-gray-200 rounded-xl">
                    <p class="text-gray-500">Aucun logement disponible pour ces critères.</p>
                    <a href="{{ path('app_search') }}" class="text-brand hover:underline text-sm mt-2 inline-block">Effacer les filtres</a>
                </div>
            {% endfor %}
        </div>
    </main>
{% endblock %}
