{% extends 'layout/app.html.twig' %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8">

        {% include 'components/search_bar.html.twig' with {
            variant: 'hero',
            destination: destination,
            checkin: checkin,
            checkout: checkout,
            guests: guests
        } %}

        <div class="mb-6">
            <h1 class="text-xl font-bold text-gray-900">
                {% if total == 0 %}
                    Aucun logement trouvé
                {% else %}
                    {{ total }} logement{{ total > 1 ? 's' : '' }} disponible{{ total > 1 ? 's' : '' }}
                    {% if destination %} à <span class="capitalize">{{ destination }}</span>{% endif %}
                {% endif %}
            </h1>

            {% set hasFilers = destination or checkin or (guests > 1) %}
            {% if hasFilers %}
                <div class="flex flex-wrap items-center gap-2 mt-2">
                    {% if checkinDate and checkoutDate %}
                        <span class="inline-flex items-center gap-1.5 bg-gray-100 text-gray-700 text-xs font-medium px-3 py-1.5 rounded-full">
                            <i class="fa-regular fa-calendar text-gray-400"></i>
                            {{ checkinDate|date('d/m/Y') }} → {{ checkoutDate|date('d/m/Y') }}
                        </span>
                    {% endif %}
                    {% if guests > 1 %}
                        <span class="inline-flex items-center gap-1.5 bg-gray-100 text-gray-700 text-xs font-medium px-3 py-1.5 rounded-full">
                            <i class="fa-solid fa-user text-gray-400"></i>
                            {{ guests }} voyageur{{ guests > 1 ? 's' : '' }}
                        </span>
                    {% endif %}
                    <a href="{{ path('app_search') }}" class="text-xs text-brand hover:underline font-medium">
                        Réinitialiser
                    </a>
                </div>
            {% endif %}
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-6 gap-y-10">
            {% for property in properties %}
                {% include 'components/card.html.twig' with { property: property } %}
            {% else %}
                <div class="col-span-full py-16 text-center">
                    <i class="fa-solid fa-magnifying-glass text-3xl text-gray-200 mb-4"></i>
                    <p class="text-gray-500 font-medium">Aucun logement ne correspond à votre recherche.</p>
                    <p class="text-sm text-gray-400 mt-1">Essayez d'ajuster vos dates ou votre destination.</p>
                    <a href="{{ path('app_search') }}" class="inline-block mt-4 text-sm font-semibold text-brand hover:underline">
                        Voir tous les logements
                    </a>
                </div>
            {% endfor %}
        </div>

    </main>
{% endblock %}
