{% extends 'layout/app.html.twig' %}

{% block title %}
    {% if destination %}{{ destination }} — {% endif %}Recherche de logements
{% endblock %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-7xl mx-auto w-full">

        {# Barre de recherche compacte pré-remplie #}
        {% include 'components/search_bar.html.twig' with {
            variant: 'compact',
            destination: destination,
            checkin: checkin ? checkin|date('Y-m-d') : '',
            checkout: checkout ? checkout|date('Y-m-d') : '',
            guests: guests
        } %}

        {# En-tête résultats #}
        <div class="flex flex-wrap items-center gap-3 mb-6">
            <h1 class="text-xl font-semibold text-gray-900">
                {{ properties|length }} logement{{ properties|length > 1 ? 's' : '' }} trouvé{{ properties|length > 1 ? 's' : '' }}
            </h1>

            {# Filtres actifs #}
            <div class="flex flex-wrap gap-2">
                {% if destination %}
                    <span class="inline-flex items-center gap-1.5 bg-gray-900 text-white text-xs font-semibold px-3 py-1.5 rounded-full">
                        <i class="fa-solid fa-location-dot text-[10px]"></i>
                        {{ destination }}
                    </span>
                {% endif %}
                {% if checkin and checkout %}
                    <span class="inline-flex items-center gap-1.5 bg-gray-900 text-white text-xs font-semibold px-3 py-1.5 rounded-full">
                        <i class="fa-regular fa-calendar text-[10px]"></i>
                        {{ checkin|date('d/m/Y') }} → {{ checkout|date('d/m/Y') }}
                    </span>
                {% endif %}
                {% if guests > 1 %}
                    <span class="inline-flex items-center gap-1.5 bg-gray-900 text-white text-xs font-semibold px-3 py-1.5 rounded-full">
                        <i class="fa-solid fa-user text-[10px]"></i>
                        {{ guests }} voyageur{{ guests > 1 ? 's' : '' }}
                    </span>
                {% endif %}
                {% if destination or checkin or guests > 1 %}
                    <a href="{{ path('app_search') }}" class="inline-flex items-center gap-1.5 border border-gray-300 text-gray-600 text-xs font-semibold px-3 py-1.5 rounded-full hover:border-gray-900 hover:text-gray-900 transition">
                        <i class="fa-solid fa-xmark text-[10px]"></i>
                        Effacer
                    </a>
                {% endif %}
            </div>
        </div>

        {# Grille de résultats #}
        {% if properties|length > 0 %}
            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-6 gap-y-10">
                {% for property in properties %}
                    {% include 'components/card.html.twig' with { property: property } %}
                {% endfor %}
            </div>
        {% else %}
            <div class="flex flex-col items-center justify-center py-24 text-center">
                <div class="w-20 h-20 bg-gray-100 rounded-full flex items-center justify-center mb-5">
                    <i class="fa-solid fa-house-crack text-3xl text-gray-300"></i>
                </div>
                <h2 class="text-lg font-semibold text-gray-900 mb-2">Aucun logement disponible</h2>
                <p class="text-sm text-gray-500 max-w-xs mb-6">
                    {% if checkin and checkout %}
                        Aucun logement libre sur ces dates
                        {% if destination %} à <strong>{{ destination }}</strong>{% endif %}
                        pour {{ guests }} voyageur{{ guests > 1 ? 's' : '' }}.
                    {% elseif destination %}
                        Aucun logement trouvé à <strong>{{ destination }}</strong>.
                    {% else %}
                        Essayez d'élargir vos critères de recherche.
                    {% endif %}
                </p>
                <a href="{{ path('app_search') }}" class="text-sm font-semibold text-brand hover:underline">
                    Voir tous les logements disponibles
                </a>
            </div>
        {% endif %}

    </main>
{% endblock %}
