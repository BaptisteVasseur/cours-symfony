{% extends 'layout/app.html.twig' %}

{% block title %}Recherche de logements{% endblock %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-6xl mx-auto w-full">
        <h1 class="text-2xl md:text-3xl font-semibold text-gray-900 mb-6">Rechercher un logement</h1>

        {# ----- Barre de filtres ----- #}
        <form method="get" action="{{ path('app_search') }}"
              class="grid grid-cols-1 md:grid-cols-12 gap-3 bg-white border border-gray-200 rounded-2xl p-4 shadow-sm mb-8">
            <div class="md:col-span-4">
                <label for="destination" class="block text-xs font-semibold text-gray-500 uppercase mb-1">Destination</label>
                <input type="text" id="destination" name="destination" value="{{ destination }}" placeholder="Ville, pays..."
                       class="w-full border border-gray-300 rounded-xl px-3 py-2.5 text-sm">
            </div>
            <div class="md:col-span-3">
                <label for="checkin" class="block text-xs font-semibold text-gray-500 uppercase mb-1">Arrivée</label>
                <input type="date" id="checkin" name="checkin" value="{{ checkin ? checkin|date('Y-m-d') }}"
                       class="w-full border border-gray-300 rounded-xl px-3 py-2.5 text-sm">
            </div>
            <div class="md:col-span-3">
                <label for="checkout" class="block text-xs font-semibold text-gray-500 uppercase mb-1">Départ</label>
                <input type="date" id="checkout" name="checkout" value="{{ checkout ? checkout|date('Y-m-d') }}"
                       class="w-full border border-gray-300 rounded-xl px-3 py-2.5 text-sm">
            </div>
            <div class="md:col-span-2">
                <label for="guests" class="block text-xs font-semibold text-gray-500 uppercase mb-1">Voyageurs</label>
                <input type="number" id="guests" name="guests" min="1" value="{{ guests > 0 ? guests : '' }}" placeholder="1"
                       class="w-full border border-gray-300 rounded-xl px-3 py-2.5 text-sm">
            </div>
            <div class="md:col-span-12 flex justify-end gap-2">
                <a href="{{ path('app_search') }}" class="px-4 py-2.5 rounded-xl border border-gray-300 text-sm font-medium text-gray-700 hover:bg-gray-50">Réinitialiser</a>
                <button type="submit" class="px-6 py-2.5 rounded-xl bg-brand hover:bg-brandHover text-white text-sm font-semibold">
                    <i class="fa-solid fa-magnifying-glass mr-1.5"></i>Rechercher
                </button>
            </div>
        </form>

        {% if datesInvalid %}
            <div class="mb-6 px-4 py-3 rounded-xl text-sm bg-red-50 text-red-800">La date de départ doit être postérieure à la date d'arrivée.</div>
        {% endif %}

        <div class="flex items-center justify-between mb-4">
            <p class="text-gray-500 text-sm">
                {{ properties|length }} logement{{ properties|length > 1 ? 's' }}
                {% if checkin and checkout and not datesInvalid %}
                    disponible{{ properties|length > 1 ? 's' }} du {{ checkin|date('d/m/Y') }} au {{ checkout|date('d/m/Y') }}
                {% endif %}
            </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-6 gap-y-10">
            {% for property in properties %}
                {% include 'components/card.html.twig' with { property: property, checkin: checkin, checkout: checkout } %}
            {% else %}
                <p class="col-span-full text-gray-500">Aucun logement ne correspond à votre recherche.</p>
            {% endfor %}
        </div>
    </main>
{% endblock %}
