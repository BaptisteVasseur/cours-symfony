{% extends 'layout/app.html.twig' %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-5xl mx-auto w-full" data-realtime-view="search-results">
        <a href="{{ path('app_home') }}" class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-gray-900 mb-6">
            <i class="fa-solid fa-arrow-left"></i> Retour à l'accueil
        </a>
        {% include 'components/search_bar.html.twig' with {
            destination: destination,
            checkin: checkin,
            checkout: checkout,
            guests: guests,
            category: category
        } %}

        {% include 'components/category_filters.html.twig' with {
            category: category,
            filter_route: 'app_search',
            filter_base_query: {
                destination: destination,
                checkin: checkin,
                checkout: checkout,
                guests: guests
            }
        } %}

        <h1 class="text-2xl md:text-3xl font-semibold text-gray-900 mb-2">Résultats de recherche</h1>

        {% set categoryLabels = {
            seaside: 'Bord de mer',
            iconic: 'Iconiques',
            trending: 'Tendances',
            camping: 'Campings'
        } %}

        <div class="text-gray-500 mb-8 space-y-1">
            {% if category %}
                <p>Filtre : {{ categoryLabels[category] }}</p>
            {% endif %}
            {% if destination %}
                <p>Destination : {{ destination }}</p>
            {% endif %}
            {% if checkin and checkout and not dateError %}
                <p>Dates : {{ checkin|date('d/m/Y') }} au {{ checkout|date('d/m/Y') }}</p>
            {% endif %}
            <p>{{ guests }} voyageur{{ guests > 1 ? 's' : '' }}</p>
        </div>

        {% if dateError %}
            <div class="mb-8 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
                {{ dateError }}
            </div>
        {% endif %}

        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-6 gap-y-10">
            {% for property in properties %}
                {% include 'components/card.html.twig' with { property: property } %}
            {% else %}
                <p class="col-span-full text-gray-500">Aucun logement trouvé.</p>
            {% endfor %}
        </div>
    </main>
{% endblock %}
