{% extends 'layout/app.html.twig' %}

{% block title %}
    {% if destination %}{{ destination }} — {% endif %}Recherche — StayNest
{% endblock %}

{% block content %}
<main class="flex-grow max-w-screen-xl mx-auto w-full px-4 md:px-8 py-8">

    {# Search bar #}
    <div class="mb-8">
        <form action="{{ path('app_search') }}" method="get">
            <div class="bg-white border border-gray-200 rounded-2xl shadow-card p-3 flex flex-col sm:flex-row gap-2">
                <div class="flex-1 px-3 py-2">
                    <p class="text-[10px] font-bold uppercase text-gray-400 mb-1">Destination</p>
                    <input type="text" name="destination" value="{{ destination }}"
                        placeholder="Ville, région…"
                        class="w-full text-sm text-gray-800 placeholder-gray-400 focus:outline-none font-medium">
                </div>
                <div class="hidden sm:block w-px bg-gray-100 my-1"></div>
                <div class="sm:w-36 px-3 py-2">
                    <p class="text-[10px] font-bold uppercase text-gray-400 mb-1">Arrivée</p>
                    <input type="date" name="checkin" value="{{ checkin ? checkin|date('Y-m-d') : '' }}"
                        class="w-full text-sm text-gray-600 focus:outline-none bg-transparent">
                </div>
                <div class="hidden sm:block w-px bg-gray-100 my-1"></div>
                <div class="sm:w-36 px-3 py-2">
                    <p class="text-[10px] font-bold uppercase text-gray-400 mb-1">Départ</p>
                    <input type="date" name="checkout" value="{{ checkout ? checkout|date('Y-m-d') : '' }}"
                        class="w-full text-sm text-gray-600 focus:outline-none bg-transparent">
                </div>
                <div class="hidden sm:block w-px bg-gray-100 my-1"></div>
                <div class="sm:w-28 px-3 py-2">
                    <p class="text-[10px] font-bold uppercase text-gray-400 mb-1">Voyageurs</p>
                    <input type="number" name="guests" value="{{ guests > 0 ? guests : '' }}"
                        min="1" max="20" placeholder="Tous"
                        class="w-full text-sm text-gray-600 focus:outline-none bg-transparent">
                </div>
                <button type="submit"
                    class="flex items-center justify-center gap-2 bg-brand hover:bg-brandHover text-white font-semibold text-sm px-6 py-3 rounded-xl transition self-center shrink-0">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    Rechercher
                </button>
            </div>
        </form>
    </div>

    {# Active filters summary #}
    {% set hasFilters = destination or checkin or checkout or guests > 0 %}
    {% if hasFilters %}
        <div class="flex flex-wrap items-center gap-2 mb-6">
            <span class="text-xs text-gray-400 font-medium">Filtres actifs :</span>
            {% if destination %}
                <span class="inline-flex items-center gap-1.5 bg-gray-100 text-gray-700 text-xs font-semibold px-3 py-1.5 rounded-full">
                    <i class="fa-solid fa-location-dot text-brand text-[10px]"></i>
                    {{ destination }}
                </span>
            {% endif %}
            {% if checkin and checkout %}
                <span class="inline-flex items-center gap-1.5 bg-gray-100 text-gray-700 text-xs font-semibold px-3 py-1.5 rounded-full">
                    <i class="fa-regular fa-calendar text-[10px]"></i>
                    {{ checkin|date('d/m') }} → {{ checkout|date('d/m/Y') }}
                </span>
            {% endif %}
            {% if guests > 0 %}
                <span class="inline-flex items-center gap-1.5 bg-gray-100 text-gray-700 text-xs font-semibold px-3 py-1.5 rounded-full">
                    <i class="fa-solid fa-user-group text-[10px]"></i>
                    {{ guests }} voyageur{{ guests > 1 ? 's' : '' }}
                </span>
            {% endif %}
            <a href="{{ path('app_search') }}" class="text-xs text-brand hover:underline font-semibold ml-1">
                Tout effacer
            </a>
        </div>
    {% endif %}

    {# Results header #}
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-lg font-bold text-gray-900">
            {% if properties|length > 0 %}
                {{ properties|length }} logement{{ properties|length > 1 ? 's' : '' }}
                {% if destination %} à <span class="text-brand">{{ destination }}</span>{% endif %}
            {% else %}
                Aucun résultat
            {% endif %}
        </h1>
    </div>

    {# Grid #}
    {% if properties|length > 0 %}
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 xl:grid-cols-4 gap-x-6 gap-y-10">
            {% for property in properties %}
                {% include 'components/card.html.twig' with {
                    property: property,
                    checkin: checkin,
                    checkout: checkout
                } %}
            {% endfor %}
        </div>
    {% else %}
        <div class="py-24 flex flex-col items-center text-center bg-surface rounded-3xl">
            <div class="w-20 h-20 bg-white rounded-full flex items-center justify-center mb-5 shadow-card">
                <i class="fa-solid fa-magnifying-glass text-3xl text-gray-300"></i>
            </div>
            <h3 class="text-lg font-bold text-gray-800 mb-2">Aucun logement trouvé</h3>
            <p class="text-gray-400 text-sm max-w-xs mb-6">
                Essayez d'élargir vos critères de recherche ou de modifier les dates.
            </p>
            <a href="{{ path('app_search') }}"
               class="inline-flex items-center gap-2 border border-gray-200 text-gray-700 font-semibold text-sm px-5 py-2.5 rounded-xl hover:bg-surface transition">
                Voir tous les logements
            </a>
        </div>
    {% endif %}

</main>
{% endblock %}
