{% extends 'layout/app.html.twig' %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-5xl mx-auto w-full">
        <h1 class="text-2xl md:text-3xl font-semibold text-gray-900 mb-2">Résultats de recherche</h1>

        {# Récapitulatif des filtres actifs #}
        {% if destination or checkin or guests > 0 %}
            <div class="flex flex-wrap gap-2 mb-6">
                {% if destination %}
                    <span class="px-3 py-1 bg-gray-100 text-gray-700 rounded-full text-sm">
                        <i class="fa-solid fa-location-dot mr-1"></i>{{ destination }}
                    </span>
                {% endif %}
                {% if checkin and checkout %}
                    <span class="px-3 py-1 bg-gray-100 text-gray-700 rounded-full text-sm">
                        <i class="fa-regular fa-calendar mr-1"></i>{{ checkinStr }} → {{ checkoutStr }}
                    </span>
                {% endif %}
                {% if guests > 0 %}
                    <span class="px-3 py-1 bg-gray-100 text-gray-700 rounded-full text-sm">
                        <i class="fa-solid fa-user mr-1"></i>{{ guests }} voyageur(s)
                    </span>
                {% endif %}
                <a href="{{ path('app_search') }}" class="px-3 py-1 text-sm text-red-600 hover:text-red-800">
                    Effacer les filtres
                </a>
            </div>
        {% endif %}

        {# Formulaire de recherche rapide #}
        <form method="get" action="{{ path('app_search') }}" class="flex flex-wrap gap-3 mb-8 p-4 bg-gray-50 rounded-xl border border-gray-200">
            <input type="text" name="destination" value="{{ destination }}" placeholder="Destination, ville..."
                class="flex-1 min-w-40 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand">
            <input type="date" name="checkin" value="{{ checkinStr }}"
                class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand">
            <input type="date" name="checkout" value="{{ checkoutStr }}"
                class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand">
            <input type="number" name="guests" value="{{ guests > 0 ? guests : '' }}" min="1" placeholder="Voyageurs"
                class="w-28 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand">
            <button type="submit" class="px-5 py-2 bg-brand text-white rounded-lg text-sm font-semibold hover:bg-brand/90">
                Rechercher
            </button>
        </form>

        <p class="text-sm text-gray-500 mb-6">{{ properties|length }} logement(s) trouvé(s)</p>

        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-6 gap-y-10">
            {% for property in properties %}
                {% include 'components/card.html.twig' with { property: property } %}
            {% else %}
                <p class="col-span-full text-gray-500">Aucun logement disponible pour ces critères.</p>
            {% endfor %}
        </div>
    </main>
{% endblock %}
