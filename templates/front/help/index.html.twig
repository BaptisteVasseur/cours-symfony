{% extends 'layout/app.html.twig' %}

{% block title %}Centre d'aide{% endblock %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-3xl mx-auto w-full">
        <h1 class="text-2xl md:text-3xl font-semibold text-gray-900 mb-2">Centre d'aide</h1>
        <p class="text-gray-500 mb-10">Réponses aux questions les plus fréquentes</p>

        <div class="space-y-4">
            <details class="bg-white border border-gray-200 rounded-xl p-5 group" open>
                <summary class="font-semibold text-gray-900 cursor-pointer list-none flex items-center justify-between">
                    Comment réserver un logement ?
                    <i class="fa-solid fa-chevron-down text-gray-400 group-open:rotate-180 transition"></i>
                </summary>
                <p class="text-sm text-gray-600 mt-3 leading-relaxed">
                    Connectez-vous, consultez une annonce publiée puis cliquez sur « Réserver ». Indiquez vos dates et le nombre de voyageurs pour confirmer.
                </p>
            </details>

            <details class="bg-white border border-gray-200 rounded-xl p-5 group">
                <summary class="font-semibold text-gray-900 cursor-pointer list-none flex items-center justify-between">
                    Où voir mes réservations ?
                    <i class="fa-solid fa-chevron-down text-gray-400 group-open:rotate-180 transition"></i>
                </summary>
                <p class="text-sm text-gray-600 mt-3 leading-relaxed">
                    Rendez-vous dans <a href="{{ path('app_reservation_index') }}" class="text-brand font-semibold hover:underline">Mes réservations</a> depuis le menu de votre profil.
                </p>
            </details>

            <details class="bg-white border border-gray-200 rounded-xl p-5 group">
                <summary class="font-semibold text-gray-900 cursor-pointer list-none flex items-center justify-between">
                    Comment contacter mon hôte ?
                    <i class="fa-solid fa-chevron-down text-gray-400 group-open:rotate-180 transition"></i>
                </summary>
                <p class="text-sm text-gray-600 mt-3 leading-relaxed">
                    Après une réservation, une conversation est disponible dans <a href="{{ path('app_messages_index') }}" class="text-brand font-semibold hover:underline">Mes messages</a>.
                </p>
            </details>

            <details class="bg-white border border-gray-200 rounded-xl p-5 group">
                <summary class="font-semibold text-gray-900 cursor-pointer list-none flex items-center justify-between">
                    Comment devenir hôte ?
                    <i class="fa-solid fa-chevron-down text-gray-400 group-open:rotate-180 transition"></i>
                </summary>
                <p class="text-sm text-gray-600 mt-3 leading-relaxed">
                    Contactez l'équipe d'administration pour obtenir le rôle hôte et publier vos annonces.
                </p>
            </details>
        </div>
    </main>
{% endblock %}
