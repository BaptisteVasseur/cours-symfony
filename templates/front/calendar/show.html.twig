{% extends 'layout/app.html.twig' %}

{% set monthNames = ['', 'Janvier', 'Février', 'Mars', 'Avril', 'Mai', 'Juin', 'Juillet', 'Août', 'Septembre', 'Octobre', 'Novembre', 'Décembre'] %}
{% set prevMonth = month - 1 %}
{% set prevYear = year %}
{% if prevMonth < 1 %}{% set prevMonth = 12 %}{% set prevYear = year - 1 %}{% endif %}
{% set nextMonth = month + 1 %}
{% set nextYear = year %}
{% if nextMonth > 12 %}{% set nextMonth = 1 %}{% set nextYear = year + 1 %}{% endif %}

{% block content %}
<main class="flex-grow px-6 md:px-12 py-8 max-w-4xl mx-auto w-full">
    <a href="{{ path('app_account_properties') }}" class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-gray-900 mb-6">
        <i class="fa-solid fa-arrow-left"></i> Mes logements
    </a>

    <div class="mb-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-semibold">Calendrier</h1>
            <p class="text-gray-500 text-sm">{{ property.title }}</p>
        </div>
        <div class="flex items-center gap-3">
            <a href="{{ path('app_calendar_show', { id: property.id, year: prevYear, month: prevMonth }) }}"
               class="p-2 rounded-lg border border-gray-200 hover:bg-gray-100">
                <i class="fa-solid fa-chevron-left text-gray-600"></i>
            </a>
            <span class="font-semibold text-gray-900 min-w-32 text-center">{{ monthNames[month] }} {{ year }}</span>
            <a href="{{ path('app_calendar_show', { id: property.id, year: nextYear, month: nextMonth }) }}"
               class="p-2 rounded-lg border border-gray-200 hover:bg-gray-100">
                <i class="fa-solid fa-chevron-right text-gray-600"></i>
            </a>
        </div>
    </div>

    {% for type, messages in app.flashes %}
        {% for msg in messages %}
            <div class="mb-4 px-4 py-3 rounded-lg {{ type == 'success' ? 'bg-green-50 text-green-800' : 'bg-red-50 text-red-800' }}">{{ msg }}</div>
        {% endfor %}
    {% endfor %}

    {# Légende #}
    <div class="flex gap-4 text-xs mb-4 flex-wrap">
        <span class="flex items-center gap-1"><span class="w-4 h-4 rounded bg-white border border-gray-200 inline-block"></span> Disponible</span>
        <span class="flex items-center gap-1"><span class="w-4 h-4 rounded bg-red-200 inline-block"></span> Bloqué manuellement</span>
        <span class="flex items-center gap-1"><span class="w-4 h-4 rounded bg-gray-400 inline-block"></span> Réservé</span>
    </div>

    {# Grille calendrier #}
    <div class="grid grid-cols-7 gap-1 mb-8">
        {% for dayName in ['Lun', 'Mar', 'Mer', 'Jeu', 'Ven', 'Sam', 'Dim'] %}
            <div class="text-center text-xs font-semibold text-gray-500 py-2">{{ dayName }}</div>
        {% endfor %}

        {# Cellules vides avant le 1er #}
        {% for i in 1..(firstDayOfWeek - 1) %}
            <div></div>
        {% endfor %}

        {% for day in 1..daysInMonth %}
            {% set dateStr = year ~ '-' ~ '%02d'|format(month) ~ '-' ~ '%02d'|format(day) %}
            {% set state = occupied[dateStr]|default('free') %}
            {% set bgClass = state == 'blocked' ? 'bg-red-200 text-red-800' : (state == 'reserved' ? 'bg-gray-400 text-white' : 'bg-white hover:bg-gray-50 text-gray-900') %}
            <div class="aspect-square flex items-center justify-center rounded-lg border border-gray-100 text-sm font-medium {{ bgClass }}">
                {{ day }}
            </div>
        {% endfor %}
    </div>

    {# Formulaire bloquer une période #}
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <section class="border border-gray-200 rounded-xl p-6">
            <h2 class="text-base font-semibold mb-4">Bloquer une période</h2>
            <form method="post" action="{{ path('app_calendar_block', { id: property.id }) }}" class="space-y-3">
                <div>
                    <label class="block text-sm text-gray-600 mb-1">Du</label>
                    <input type="date" name="from" required class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
                </div>
                <div>
                    <label class="block text-sm text-gray-600 mb-1">Au</label>
                    <input type="date" name="to" required class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
                </div>
                <button type="submit" class="w-full bg-gray-900 text-white py-2 rounded-lg text-sm font-semibold hover:bg-gray-700">
                    Bloquer
                </button>
            </form>
        </section>

        <section class="border border-gray-200 rounded-xl p-6">
            <h2 class="text-base font-semibold mb-4">Débloquer une période</h2>
            <form method="post" action="{{ path('app_calendar_unblock', { id: property.id }) }}" class="space-y-3">
                <div>
                    <label class="block text-sm text-gray-600 mb-1">Du</label>
                    <input type="date" name="from" required class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
                </div>
                <div>
                    <label class="block text-sm text-gray-600 mb-1">Au</label>
                    <input type="date" name="to" required class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
                </div>
                <button type="submit" class="w-full bg-red-600 text-white py-2 rounded-lg text-sm font-semibold hover:bg-red-700">
                    Débloquer
                </button>
            </form>
        </section>
    </div>
</main>
{% endblock %}
