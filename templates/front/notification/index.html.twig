{% extends 'layout/app.html.twig' %}

{% block title %}Mes notifications{% endblock %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-3xl mx-auto w-full">
        <div class="flex items-center justify-between mb-8">
            <div>
                <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">Notifications</h1>
                <p class="text-gray-500 mt-1">Vos dernières alertes</p>
            </div>
            {% if notifications|length > 0 %}
                <form method="post" action="{{ path('app_notifications_read_all') }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('notifications-read-all') }}">
                    <button type="submit" class="text-sm font-semibold text-brand hover:underline">Tout marquer comme lu</button>
                </form>
            {% endif %}
        </div>

        {% if notifications|length > 0 %}
            <div class="space-y-2">
                {% for notification in notifications %}
                    <a href="{{ path('app_notification_open', { id: notification.id }) }}"
                       class="flex gap-4 p-4 rounded-xl border transition hover:shadow-sm {{ notification.isRead ? 'border-gray-100 bg-white' : 'border-brand/20 bg-brand/5' }}">
                        <div class="w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center shrink-0">
                            <i class="fa-regular fa-bell text-gray-500"></i>
                        </div>
                        <div class="min-w-0 flex-1">
                            <div class="flex items-center gap-2">
                                <p class="font-semibold text-gray-900">{{ notification.title }}</p>
                                {% if not notification.isRead %}<span class="w-2 h-2 rounded-full bg-brand"></span>{% endif %}
                            </div>
                            <p class="text-sm text-gray-600">{{ notification.content }}</p>
                            <p class="text-xs text-gray-400 mt-1">{{ notification.createdAt|date('d/m/Y à H:i') }}</p>
                        </div>
                    </a>
                {% endfor %}
            </div>
        {% else %}
            <div class="text-center py-16 border border-dashed border-gray-200 rounded-xl">
                <i class="fa-regular fa-bell-slash text-4xl text-gray-300 mb-4"></i>
                <p class="text-gray-500">Aucune notification pour le moment.</p>
            </div>
        {% endif %}
    </main>
{% endblock %}
