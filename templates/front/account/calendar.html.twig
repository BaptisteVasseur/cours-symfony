{% extends 'layout/app.html.twig' %}

{% block title %}Calendrier — {{ property.title }}{% endblock %}

{% block content %}
<main class="flex-grow px-4 md:px-12 py-8 max-w-5xl mx-auto w-full">

    <div class="mb-6">
        <a href="{{ path('app_account_properties') }}"
           class="inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-gray-800 mb-4 transition-colors">
            <i class="fa-solid fa-arrow-left text-xs"></i>
            Mes propriétés
        </a>
        <h1 class="text-2xl font-semibold text-gray-900 truncate">{{ property.title }}</h1>
        <p class="text-gray-400 text-sm mt-0.5">Calendrier de disponibilité</p>
    </div>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="mb-5 px-4 py-3 rounded-xl text-sm flex items-center gap-2
                        {{ label == 'success' ? 'bg-emerald-50 text-emerald-800 border border-emerald-200' : 'bg-red-50 text-red-800 border border-red-200' }}">
                <i class="fa-solid {{ label == 'success' ? 'fa-circle-check' : 'fa-circle-exclamation' }} shrink-0"></i>
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    {# Navigation mois #}
    <div class="flex items-center justify-between mb-6">
        <a href="{{ path('app_account_property_calendar', {id: property.id, year: prevYear, month: prevMonth}) }}"
           class="flex items-center justify-center w-10 h-10 rounded-full border border-gray-200 hover:border-gray-400 hover:bg-gray-50 transition text-gray-600">
            <i class="fa-solid fa-chevron-left text-sm"></i>
        </a>
        <h2 class="text-xl font-semibold text-gray-900">{{ monthLabel }}</h2>
        <a href="{{ path('app_account_property_calendar', {id: property.id, year: nextYear, month: nextMonth}) }}"
           class="flex items-center justify-center w-10 h-10 rounded-full border border-gray-200 hover:border-gray-400 hover:bg-gray-50 transition text-gray-600">
            <i class="fa-solid fa-chevron-right text-sm"></i>
        </a>
    </div>

    {# Légende #}
    <div class="flex flex-wrap gap-4 mb-5 text-sm">
        <span class="flex items-center gap-2">
            <span class="w-3 h-3 rounded-full bg-emerald-400 shrink-0"></span>
            <span class="text-gray-600">Disponible</span>
        </span>
        <span class="flex items-center gap-2">
            <span class="w-3 h-3 rounded-full bg-red-400 shrink-0"></span>
            <span class="text-gray-600">Réservé</span>
        </span>
        <span class="flex items-center gap-2">
            <span class="w-3 h-3 rounded-full bg-amber-400 shrink-0"></span>
            <span class="text-gray-600">En attente</span>
        </span>
        <span class="flex items-center gap-2">
            <span class="w-3 h-3 rounded-full bg-violet-400 shrink-0"></span>
            <span class="text-gray-600">Indisponible (hôte)</span>
        </span>
        <span class="flex items-center gap-2">
            <span class="w-3 h-3 rounded-full bg-gray-400 shrink-0"></span>
            <span class="text-gray-600">Bloqué</span>
        </span>
    </div>

    {# Grille calendrier #}
    <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden shadow-sm mb-8">

        <div class="grid grid-cols-7 border-b border-gray-200 bg-gray-50">
            {% for dayLabel in ['Lun', 'Mar', 'Mer', 'Jeu', 'Ven', 'Sam', 'Dim'] %}
                <div class="py-3 text-center text-xs font-semibold text-gray-400 uppercase tracking-wider">
                    {{ dayLabel }}
                </div>
            {% endfor %}
        </div>

        {% for week in calendar %}
            <div class="grid grid-cols-7 border-b border-gray-100 last:border-0">
                {% for cell in week %}
                    {% if cell is null %}
                        <div class="min-h-[88px] bg-gray-50 border-r border-gray-100 last:border-0"></div>
                    {% else %}
                        {% set status  = cell.data.status %}
                        {% set isToday = cell.key == today %}

                        {% if status == 'reserved' %}
                            {% set bg    = 'bg-red-50' %}
                            {% set dot   = 'bg-red-400' %}
                            {% set badge = 'text-red-600 bg-red-100' %}
                            {% set lbl   = 'Réservé' %}
                        {% elseif status == 'pending' %}
                            {% set bg    = 'bg-amber-50' %}
                            {% set dot   = 'bg-amber-400' %}
                            {% set badge = 'text-amber-700 bg-amber-100' %}
                            {% set lbl   = 'En attente' %}
                        {% elseif status == 'blocked_period' %}
                            {% set bg    = 'bg-violet-50' %}
                            {% set dot   = 'bg-violet-400' %}
                            {% set badge = 'text-violet-700 bg-violet-100' %}
                            {% set reasonMap = {maintenance: 'Travaux', personal: 'Usage perso.', other: 'Bloqué'} %}
                            {% set lbl   = reasonMap[cell.data.period.reason] ?? 'Bloqué' %}
                        {% elseif status == 'blocked' %}
                            {% set bg    = 'bg-gray-100' %}
                            {% set dot   = 'bg-gray-400' %}
                            {% set badge = 'text-gray-500 bg-gray-200' %}
                            {% set lbl   = 'Bloqué' %}
                        {% else %}
                            {% set bg    = 'bg-emerald-50' %}
                            {% set dot   = 'bg-emerald-400' %}
                            {% set badge = 'text-emerald-700 bg-emerald-100' %}
                            {% set lbl   = 'Disponible' %}
                        {% endif %}

                        <div class="min-h-[88px] border-r border-gray-100 last:border-0 p-2 flex flex-col gap-1 {{ bg }} {{ isToday ? 'ring-2 ring-inset ring-gray-900' : '' }}">

                            <span class="text-sm font-semibold {{ isToday ? 'w-6 h-6 flex items-center justify-center rounded-full bg-gray-900 text-white text-xs' : 'text-gray-700' }}">
                                {{ cell.day }}
                            </span>

                            <span class="inline-flex items-center gap-1 text-xs font-medium px-1.5 py-0.5 rounded-full w-fit {{ badge }}">
                                <span class="w-1.5 h-1.5 rounded-full {{ dot }}"></span>
                                {{ lbl }}
                            </span>

                            {% if cell.data.reservation is not null %}
                                {% set res = cell.data.reservation %}
                                {% if res.guest.profile is not null and res.guest.profile.firstName is not null %}
                                    <span class="text-xs text-gray-500 truncate leading-tight">
                                        {{ res.guest.profile.firstName }}
                                    </span>
                                {% endif %}
                            {% endif %}

                        </div>
                    {% endif %}
                {% endfor %}
            </div>
        {% endfor %}

    </div>

    {# Lien mois courant #}
    <div class="mb-10 text-center">
        <a href="{{ path('app_account_property_calendar', {id: property.id, year: 'now'|date('Y'), month: 'now'|date('n')}) }}"
           class="text-sm text-gray-400 hover:text-gray-700 underline underline-offset-2 transition-colors">
            Revenir au mois en cours
        </a>
    </div>

    {# ===== Synchronisation iCal ===== #}
    <div class="mb-8 bg-white border border-gray-200 rounded-2xl p-6 shadow-sm">
        <div class="flex items-center justify-between flex-wrap gap-4 mb-4">
            <div>
                <h2 class="text-base font-semibold text-gray-900 flex items-center gap-2">
                    <i class="fa-regular fa-calendar-days text-indigo-500"></i>
                    Synchronisation iCal
                </h2>
                <p class="text-sm text-gray-400 mt-0.5">
                    Synchronisez vos réservations confirmées avec Google Calendar, Outlook ou Apple Calendar.
                </p>
            </div>
        </div>

        {% if property.icalToken %}
            {# Token existant — afficher l'URL #}
            {% set icalUrl = url('app_property_ical_export', {id: property.id}) ~ '?token=' ~ property.icalToken %}

            <div class="bg-indigo-50 border border-indigo-200 rounded-xl p-4 mb-4">
                <p class="text-xs font-semibold text-indigo-700 uppercase tracking-wider mb-2">
                    <i class="fa-solid fa-link mr-1"></i> Votre URL de synchronisation
                </p>
                <div class="flex items-center gap-2">
                    <input type="text" id="ical-url" readonly value="{{ icalUrl }}"
                           class="flex-1 bg-white border border-indigo-200 rounded-lg px-3 py-2 text-xs text-gray-700 font-mono focus:outline-none cursor-text select-all">
                    <button type="button" onclick="copyIcal()"
                            class="shrink-0 px-3 py-2 bg-indigo-600 text-white text-xs font-semibold rounded-lg hover:bg-indigo-700 transition flex items-center gap-1.5">
                        <i class="fa-regular fa-copy"></i>
                        <span id="copy-label">Copier</span>
                    </button>
                    <a href="{{ icalUrl }}" download
                       class="shrink-0 px-3 py-2 bg-white border border-indigo-200 text-indigo-700 text-xs font-semibold rounded-lg hover:bg-indigo-50 transition flex items-center gap-1.5">
                        <i class="fa-solid fa-download"></i>
                        .ics
                    </a>
                </div>
                <p class="text-xs text-indigo-500 mt-2">
                    <i class="fa-solid fa-shield-halved mr-1"></i>
                    Ce lien est secret — ne le partagez qu'avec vos applications de calendrier.
                </p>
            </div>

            <div class="flex flex-wrap gap-3">
                {# Régénérer #}
                <form method="POST" action="{{ path('app_host_ical_generate', {id: property.id}) }}"
                      onsubmit="return confirm('Régénérer le lien invalidera l\'ancienne URL. Continuer ?')">
                    <input type="hidden" name="_token" value="{{ csrf_token('ical_token_' ~ property.id) }}">
                    <button type="submit"
                            class="inline-flex items-center gap-2 px-4 py-2 bg-white border border-gray-200 text-sm text-gray-700 rounded-lg hover:border-gray-400 hover:bg-gray-50 transition">
                        <i class="fa-solid fa-rotate text-gray-400"></i>
                        Régénérer le lien
                    </button>
                </form>
                {# Révoquer #}
                <form method="POST" action="{{ path('app_host_ical_revoke', {id: property.id}) }}"
                      onsubmit="return confirm('Révoquer ce lien ? Vos calendriers ne seront plus synchronisés.')">
                    <input type="hidden" name="_token" value="{{ csrf_token('ical_revoke_' ~ property.id) }}">
                    <button type="submit"
                            class="inline-flex items-center gap-2 px-4 py-2 bg-white border border-red-200 text-sm text-red-600 rounded-lg hover:bg-red-50 transition">
                        <i class="fa-solid fa-ban"></i>
                        Révoquer l'accès
                    </button>
                </form>
            </div>

        {% else %}
            {# Pas encore de token #}
            <div class="flex items-center gap-4 p-4 bg-gray-50 border border-dashed border-gray-300 rounded-xl">
                <div class="w-10 h-10 rounded-full bg-indigo-100 flex items-center justify-center shrink-0">
                    <i class="fa-solid fa-calendar-plus text-indigo-500"></i>
                </div>
                <div class="flex-1">
                    <p class="text-sm font-medium text-gray-800">Aucun lien iCal généré</p>
                    <p class="text-xs text-gray-400">Générez un lien secret pour connecter vos applications de calendrier.</p>
                </div>
                <form method="POST" action="{{ path('app_host_ical_generate', {id: property.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('ical_token_' ~ property.id) }}">
                    <button type="submit"
                            class="inline-flex items-center gap-2 px-4 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-lg transition">
                        <i class="fa-solid fa-link"></i>
                        Générer le lien iCal
                    </button>
                </form>
            </div>
        {% endif %}
    </div>

    {# ===== Gestion des indisponibilités ===== #}
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8">

        {# Formulaire de création #}
        <div class="lg:col-span-2">
            <div class="bg-white border border-gray-200 rounded-2xl p-6 shadow-sm">
                <h3 class="font-semibold text-gray-900 mb-1 flex items-center gap-2">
                    <i class="fa-solid fa-ban text-violet-400 text-sm"></i>
                    Déclarer une indisponibilité
                </h3>
                <p class="text-xs text-gray-400 mb-5">Blocage visible sur le calendrier et pris en compte lors des réservations.</p>

                <form method="POST"
                      action="{{ path('app_host_blocked_period_create', {id: property.id}) }}"
                      class="space-y-4">
                    <input type="hidden" name="_token" value="{{ csrf_token('blocked_period_' ~ property.id) }}">

                    <div class="grid grid-cols-2 gap-3">
                        <div>
                            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5">
                                Début
                            </label>
                            <input type="date" name="start_date" required
                                   min="{{ 'now'|date('Y-m-d') }}"
                                   class="w-full border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-violet-400 transition">
                        </div>
                        <div>
                            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5">
                                Fin
                            </label>
                            <input type="date" name="end_date" required
                                   min="{{ 'now'|date('Y-m-d') }}"
                                   class="w-full border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-violet-400 transition">
                        </div>
                    </div>

                    <div>
                        <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5">
                            Motif
                        </label>
                        <select name="reason"
                                class="w-full border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-violet-400 transition bg-white">
                            <option value="personal">Usage personnel</option>
                            <option value="maintenance">Travaux</option>
                            <option value="other">Autre</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5">
                            Note <span class="font-normal text-gray-400">(optionnel)</span>
                        </label>
                        <textarea name="note" rows="2" placeholder="Précision optionnelle…"
                                  class="w-full border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-violet-400 transition resize-none"></textarea>
                    </div>

                    <button type="submit"
                            class="w-full bg-violet-600 hover:bg-violet-700 text-white font-semibold py-3 rounded-xl transition text-sm">
                        <i class="fa-solid fa-plus mr-1.5 text-xs"></i>
                        Bloquer cette période
                    </button>
                </form>
            </div>
        </div>

        {# Liste des périodes existantes #}
        <div class="lg:col-span-3">
            <div class="bg-white border border-gray-200 rounded-2xl overflow-hidden shadow-sm">
                <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
                    <h3 class="font-semibold text-gray-900 flex items-center gap-2">
                        <i class="fa-regular fa-calendar-xmark text-violet-400 text-sm"></i>
                        Périodes déclarées
                    </h3>
                    {% if allPeriods|length > 0 %}
                        <span class="text-xs font-semibold text-gray-400 bg-gray-100 px-2 py-0.5 rounded-full">
                            {{ allPeriods|length }}
                        </span>
                    {% endif %}
                </div>

                {% if allPeriods|length == 0 %}
                    <div class="px-6 py-10 text-center">
                        <i class="fa-regular fa-calendar-check text-3xl text-gray-200 mb-3 block"></i>
                        <p class="text-sm text-gray-400">Aucune période d'indisponibilité déclarée.</p>
                    </div>
                {% else %}
                    <ul class="divide-y divide-gray-100">
                        {% for period in allPeriods %}
                            {% set isPast = period.endDate < date('now') %}
                            <li class="px-6 py-4 flex items-start justify-between gap-4 {{ isPast ? 'opacity-50' : '' }}">
                                <div class="flex items-start gap-3 min-w-0">
                                    <span class="mt-0.5 w-8 h-8 rounded-full bg-violet-100 text-violet-600 flex items-center justify-center shrink-0 text-xs">
                                        {% if period.reason == 'maintenance' %}
                                            <i class="fa-solid fa-wrench"></i>
                                        {% elseif period.reason == 'personal' %}
                                            <i class="fa-solid fa-house"></i>
                                        {% else %}
                                            <i class="fa-solid fa-ban"></i>
                                        {% endif %}
                                    </span>
                                    <div class="min-w-0">
                                        <p class="text-sm font-semibold text-gray-800">
                                            {{ period.reasonLabel }}
                                            {% if isPast %}
                                                <span class="ml-1 text-[11px] font-normal text-gray-400">(passée)</span>
                                            {% endif %}
                                        </p>
                                        <p class="text-xs text-gray-500 mt-0.5">
                                            {{ period.startDate|date('d/m/Y') }}
                                            {% if period.startDate|date('Y-m-d') != period.endDate|date('Y-m-d') %}
                                                → {{ period.endDate|date('d/m/Y') }}
                                            {% endif %}
                                        </p>
                                        {% if period.note %}
                                            <p class="text-xs text-gray-400 mt-1 truncate">{{ period.note }}</p>
                                        {% endif %}
                                    </div>
                                </div>

                                {% if not isPast %}
                                    <form method="POST"
                                          action="{{ path('app_host_blocked_period_delete', {id: property.id, pid: period.id}) }}"
                                          onsubmit="return confirm('Supprimer cette période d\'indisponibilité ?')">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_period_' ~ period.id) }}">
                                        <button type="submit"
                                                class="shrink-0 flex items-center justify-center w-8 h-8 rounded-full border border-gray-200 text-gray-400 hover:border-red-300 hover:text-red-500 hover:bg-red-50 transition">
                                            <i class="fa-solid fa-trash-can text-xs"></i>
                                        </button>
                                    </form>
                                {% endif %}
                            </li>
                        {% endfor %}
                    </ul>
                {% endif %}
            </div>
        </div>

    </div>

</main>

<script>
    // Synchronise la date de fin >= date de début dans le formulaire
    const startInput = document.querySelector('input[name="start_date"]');
    const endInput   = document.querySelector('input[name="end_date"]');
    if (startInput && endInput) {
        startInput.addEventListener('change', () => {
            if (endInput.value && endInput.value < startInput.value) {
                endInput.value = startInput.value;
            }
            endInput.min = startInput.value;
        });
    }

    function copyIcal() {
        const input = document.getElementById('ical-url');
        if (!input) return;
        navigator.clipboard.writeText(input.value).then(() => {
            const label = document.getElementById('copy-label');
            if (label) {
                label.textContent = 'Copié !';
                setTimeout(() => { label.textContent = 'Copier'; }, 2000);
            }
        });
    }
</script>
{% endblock %}

