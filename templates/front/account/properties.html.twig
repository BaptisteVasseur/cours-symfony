{% extends 'layout/app.html.twig' %}

{% block title %}Mes proprietes{% endblock %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-5xl mx-auto w-full">
        <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-8">
            <div>
                <h1 class="text-2xl md:text-3xl font-semibold text-gray-900 mb-2">Mes proprietes</h1>
                <p class="text-gray-500">Annonces dont vous etes l'hote</p>
            </div>
            {% if is_granted('ROLE_HOST') %}
                <a href="{{ path('app_host_reservation_index') }}" class="inline-flex items-center gap-2 text-sm font-semibold text-brand hover:underline">
                    <i class="fa-solid fa-calendar-check"></i>
                    Voir les demandes en attente
                </a>
            {% endif %}
        </div>

        {% if properties|length > 0 %}
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                {% for property in properties %}
                    <div class="space-y-3">
                        {% include 'components/card.html.twig' with { property: property } %}
                        <div class="grid grid-cols-1 gap-3">
                            <a href="{{ path('app_host_property_availability_show', { id: property.id }) }}" class="inline-flex items-center justify-center gap-2 px-4 py-2.5 rounded-xl bg-brand hover:bg-brandHover text-white text-sm font-semibold transition">
                                <i class="fa-solid fa-calendar-days"></i>
                                Gerer les disponibilites
                            </a>
                            <a href="{{ path('app_logement_detail', { id: property.id }) }}" class="inline-flex items-center justify-center gap-2 px-4 py-2.5 rounded-xl border border-gray-200 text-sm font-semibold text-gray-700 hover:bg-gray-50 transition">
                                <i class="fa-solid fa-eye"></i>
                                Voir l'annonce
                            </a>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="text-center py-16 border border-dashed border-gray-200 rounded-xl">
                <i class="fa-solid fa-house text-4xl text-gray-300 mb-4"></i>
                <p class="text-gray-500">Vous n'avez pas encore d'annonce publiee.</p>
            </div>
        {% endif %}
    </main>
{% endblock %}
