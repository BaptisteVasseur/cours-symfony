{% extends 'layout/app.html.twig' %}

{% block title %}Mes propriétés{% endblock %}

{% block content %}
    <div class="flex-grow bg-gray-50/50">
        <main class="px-6 md:px-12 py-10 max-w-6xl mx-auto w-full">
            <a href="{{ path('app_home') }}" class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-gray-900 mb-6">
                <i class="fa-solid fa-arrow-left"></i> Retour à l'accueil
            </a>
            {% if is_granted('ROLE_HOST') %}
                <div class="flex items-center gap-6 border-b border-gray-200 mb-8 pb-1">
                    <a href="{{ path('app_host_dashboard') }}" class="text-sm font-medium pb-4 border-b-2 border-transparent text-gray-500 hover:text-gray-900 transition">
                        Tableau de bord
                    </a>
                    <a href="{{ path('app_host_reservations') }}" class="text-sm font-medium pb-4 border-b-2 border-transparent text-gray-500 hover:text-gray-900 transition">
                        Réservations reçues
                    </a>
                    <a href="{{ path('app_account_properties') }}" class="text-sm font-semibold pb-4 border-b-2 border-brand text-gray-900">
                        Mes propriétés
                    </a>
                </div>
            {% endif %}

            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
                <div>
                    <h1 class="text-2xl md:text-3xl font-semibold text-gray-900 mb-2">Mes propriétés</h1>
                    <p class="text-gray-500">Annonces dont vous êtes l'hôte</p>
                </div>
                {% if is_granted('ROLE_HOST') %}
                    <div>
                        <a href="{{ path('app_host_property_new') }}" class="inline-flex items-center gap-2 bg-brand hover:bg-brandHover text-white font-semibold text-sm px-4 py-2.5 rounded-lg shadow-sm transition">
                            <i class="fa-solid fa-plus text-xs"></i>
                            Ajouter une propriété
                        </a>
                    </div>
                {% endif %}
            </div>

            {% if properties|length > 0 %}
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                    {% for property in properties %}
                        <div>
                            {% include 'components/card.html.twig' with { property: property } %}
                            <a href="{{ path('app_host_calendar', { id: property.id }) }}" class="mt-3 inline-flex w-full items-center justify-center gap-2 rounded-lg border border-gray-200 px-3 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-50">
                                <i class="fa-solid fa-calendar-days"></i>
                                Gérer le calendrier
                            </a>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="text-center py-16 border border-dashed border-gray-200 rounded-xl bg-white">
                    <i class="fa-solid fa-house text-4xl text-gray-300 mb-4"></i>
                    <p class="text-gray-500">Vous n'avez pas encore d'annonce publiée.</p>
                </div>
            {% endif %}
        </main>
    </div>
{% endblock %}
