{% extends 'layout/app.html.twig' %}

{% block title %}Mes propriétés{% endblock %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-5xl mx-auto w-full">
        <div class="flex items-center justify-between mb-2">
            <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">Mes propriétés</h1>
            <a href="{{ path('app_host_property_new') }}"
               class="inline-flex items-center gap-2 bg-brand hover:bg-brandHover text-white text-sm font-semibold px-4 py-2 rounded-xl">
                <i class="fa-solid fa-plus"></i> Nouvelle annonce
            </a>
        </div>
        <p class="text-gray-500 mb-8">Annonces dont vous êtes l'hôte</p>

        {% if properties|length > 0 %}
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                {% for property in properties %}
                    <div class="flex flex-col gap-2">
                        {% include 'components/card.html.twig' with { property: property } %}
                        <div class="flex items-center gap-2 text-xs px-1">
                            <a href="{{ path('app_host_property_edit', { id: property.id }) }}"
                               class="flex-1 text-center border border-gray-200 rounded-lg py-1.5 text-gray-600 hover:border-gray-900 hover:text-gray-900 transition">
                                <i class="fa-solid fa-pen text-[10px] mr-1"></i>Modifier
                            </a>
                            <a href="{{ path('app_host_property_unavailability', { id: property.id }) }}"
                               class="flex-1 text-center border border-gray-200 rounded-lg py-1.5 text-gray-600 hover:border-gray-900 hover:text-gray-900 transition">
                                <i class="fa-regular fa-calendar-xmark text-[10px] mr-1"></i>Indispos
                            </a>
                            <a href="{{ path('app_host_property_edit', { id: property.id }) }}#ical"
                               class="flex-1 text-center border border-{{ property.calendarToken ? 'brand text-brand' : 'gray-200 text-gray-600 hover:border-gray-900 hover:text-gray-900' }} rounded-lg py-1.5 transition">
                                <i class="fa-regular fa-calendar text-[10px] mr-1"></i>iCal
                            </a>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="text-center py-16 border border-dashed border-gray-200 rounded-xl">
                <i class="fa-solid fa-house text-4xl text-gray-300 mb-4"></i>
                <p class="text-gray-500">Vous n'avez pas encore d'annonce publiée.</p>
            </div>
        {% endif %}
    </main>
{% endblock %}
