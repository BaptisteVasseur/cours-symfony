{% extends 'layout/app.html.twig' %}

{% block title %}Mes propriétés{% endblock %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-5xl mx-auto w-full">
        <div class="flex flex-wrap items-start justify-between gap-4 mb-8">
            <div>
                <h1 class="text-2xl md:text-3xl font-semibold text-gray-900 mb-2">Mes propriétés</h1>
                <p class="text-gray-500">Annonces dont vous êtes l'hôte</p>
            </div>
            <a href="{{ path('app_account_property_new') }}" class="inline-flex items-center gap-2 bg-brand hover:bg-brandHover text-white font-semibold px-5 py-2.5 rounded-xl text-sm">
                <i class="fa-solid fa-plus"></i> Créer une annonce
            </a>
        </div>

        {% if properties|length > 0 %}
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                {% for property in properties %}
                    <div>
                        {% include 'components/card.html.twig' with { property: property } %}
                        <a href="{{ path('app_host_calendar', { id: property.id }) }}" class="mt-2 inline-flex items-center gap-2 text-sm font-semibold text-brand hover:underline">
                            <i class="fa-solid fa-calendar-days"></i> Gérer le calendrier
                        </a>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="text-center py-16 border border-dashed border-gray-200 rounded-xl">
                <i class="fa-solid fa-house text-4xl text-gray-300 mb-4"></i>
                <p class="text-gray-500 mb-4">Vous n'avez pas encore d'annonce.</p>
                <a href="{{ path('app_account_property_new') }}" class="inline-flex items-center gap-2 bg-brand hover:bg-brandHover text-white font-semibold px-5 py-2.5 rounded-xl text-sm">
                    <i class="fa-solid fa-plus"></i> Créer ma première annonce
                </a>
            </div>
        {% endif %}
    </main>
{% endblock %}
