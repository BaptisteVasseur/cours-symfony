{% extends 'layout/app.html.twig' %}

{% block title %}Mes propriétés{% endblock %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-5xl mx-auto w-full">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
            <div>
                <h1 class="text-2xl md:text-3xl font-semibold text-gray-900 mb-2">Mes propriétés</h1>
                <p class="text-gray-500">Annonces dont vous êtes l'hôte</p>
            </div>
            <a href="{{ path('app_host_property_new') }}"
               class="inline-flex items-center justify-center gap-2 bg-brand hover:bg-brandHover text-white font-semibold text-sm px-5 py-2.5 rounded-xl transition shrink-0">
                <i class="fa-solid fa-plus"></i>
                Publier une annonce
            </a>
        </div>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 px-4 py-3 rounded-xl text-sm font-medium bg-emerald-50 text-emerald-800 border border-emerald-200">{{ message }}</div>
            {% endfor %}
        {% endfor %}

        {% if properties|length > 0 %}
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                {% for property in properties %}
                    <div class="space-y-3">
                        {% include 'components/card.html.twig' with { property: property } %}
                        <div class="flex flex-wrap items-center gap-4 text-sm">
                            <a href="{{ path('app_host_property_edit', { id: property.id }) }}"
                               class="inline-flex items-center gap-2 font-medium text-gray-700 hover:text-gray-900">
                                <i class="fa-solid fa-pen"></i> Modifier
                            </a>
                            <a href="{{ path('app_property_calendar', { id: property.id }) }}"
                               class="inline-flex items-center gap-2 font-medium text-brand hover:text-brandHover">
                                <i class="fa-regular fa-calendar"></i> Calendrier
                            </a>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="text-center py-16 border border-dashed border-gray-200 rounded-xl">
                <i class="fa-solid fa-house text-4xl text-gray-300 mb-4"></i>
                <p class="text-gray-500 mb-6">Vous n'avez pas encore publié d'annonce.</p>
                <a href="{{ path('app_host_property_new') }}"
                   class="inline-flex items-center gap-2 bg-brand hover:bg-brandHover text-white font-semibold text-sm px-5 py-2.5 rounded-xl transition">
                    <i class="fa-solid fa-plus"></i>
                    Publier ma première annonce
                </a>
            </div>
        {% endif %}
    </main>
{% endblock %}
