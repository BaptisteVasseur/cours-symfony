{% extends 'layout/app.html.twig' %}

{% block title %}Mes propriétés{% endblock %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-5xl mx-auto w-full">
        <div class="flex items-center justify-between gap-4 mb-8">
            <div>
                <h1 class="text-2xl md:text-3xl font-semibold text-gray-900 mb-2">Mes propriétés</h1>
                <p class="text-gray-500">Annonces dont vous êtes l'hôte</p>
            </div>
            <a href="{{ path('app_host_reservation_index') }}" class="shrink-0 inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 rounded-lg hover:bg-gray-200 transition">
                <i class="fa-regular fa-calendar-check"></i>
                Demandes reçues
            </a>
        </div>

        {% if properties|length > 0 %}
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                {% for property in properties %}
                    <div class="flex flex-col gap-3">
                        {% include 'components/card.html.twig' with { property: property } %}
                        <a href="{{ path('app_host_availability_index', { id: property.id }) }}"
                           class="inline-flex items-center justify-center gap-2 px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 rounded-lg hover:bg-gray-200 transition">
                            <i class="fa-regular fa-calendar"></i>
                            Gérer les disponibilités
                        </a>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="text-center py-16 border border-dashed border-gray-200 rounded-xl">
                <i class="fa-solid fa-house text-4xl text-gray-300 mb-4"></i>
                <p class="text-gray-500">Vous n'avez pas encore d'annonce publiée.</p>
            </div>
        {% endif %}
    </main>
{% endblock %}
