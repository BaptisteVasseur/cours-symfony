{% extends 'layout/app.html.twig' %}

{% block title %}Mes propriétés{% endblock %}

{% block content %}
<main class="flex-grow px-6 md:px-12 py-8 max-w-5xl mx-auto w-full">
    <div class="flex items-center justify-between mb-2">
        <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">Mes propriétés</h1>
        <a href="{{ path('app_host_property_new') }}"
           class="inline-flex items-center gap-2 bg-brand hover:bg-brandHover text-white text-sm font-semibold px-5 py-2.5 rounded-xl transition">
            <i class="fa-solid fa-plus"></i> Ajouter un logement
        </a>
    </div>
    <p class="text-gray-500 mb-8">Annonces dont vous êtes l'hôte</p>

    {% set statusLabels = { 'published': 'Publiée', 'draft': 'Brouillon', 'pending': 'En attente' } %}
    {% set statusColors = { 'published': 'bg-green-100 text-green-800', 'draft': 'bg-gray-100 text-gray-600', 'pending': 'bg-yellow-100 text-yellow-800' } %}

    {% if properties|length > 0 %}
        <div class="space-y-4">
            {% for property in properties %}
                {% set cover = property.coverMedia %}
                {% set placeholder = 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=400&q=60' %}
                <div class="border border-gray-200 rounded-2xl overflow-hidden flex flex-col sm:flex-row shadow-sm hover:shadow-md transition">
                    {# Photo #}
                    <div class="sm:w-52 h-40 sm:h-auto shrink-0">
                        <img src="{{ cover ? cover.fileUrl : placeholder }}"
                             alt="{{ property.title }}"
                             class="w-full h-full object-cover"
                             onerror="this.src='{{ placeholder }}'">
                    </div>

                    {# Infos #}
                    <div class="flex-1 p-5 flex flex-col justify-between gap-4">
                        <div>
                            <div class="flex items-start justify-between gap-3 flex-wrap">
                                <div>
                                    <h2 class="font-semibold text-gray-900 text-base">{{ property.title }}</h2>
                                    {% if property.address %}
                                        <p class="text-sm text-gray-500 mt-0.5">
                                            {{ property.address.city }}{% if property.address.country %}, {{ property.address.country }}{% endif %}
                                        </p>
                                    {% endif %}
                                </div>
                                <span class="text-xs font-semibold px-2.5 py-1 rounded-full {{ statusColors[property.status]|default('bg-gray-100 text-gray-600') }}">
                                    {{ statusLabels[property.status]|default(property.status) }}
                                </span>
                            </div>
                            <p class="text-sm text-gray-500 mt-2">
                                {{ property.pricePerNight|number_format(0, ',', ' ') }} € / nuit
                                · {{ property.maxGuests }} voyageur{{ property.maxGuests > 1 ? 's' : '' }}
                                · {{ property.bedrooms }} chambre{{ property.bedrooms > 1 ? 's' : '' }}
                            </p>
                        </div>

                        {# Actions #}
                        <div class="flex flex-wrap gap-2 text-sm">
                            <a href="{{ path('app_logement_detail', { id: property.id }) }}"
                               class="inline-flex items-center gap-1.5 border border-gray-300 rounded-lg px-3 py-1.5 text-gray-700 hover:bg-gray-50 transition font-medium">
                                <i class="fa-solid fa-eye text-xs"></i> Voir l'annonce
                            </a>
                            <a href="{{ path('app_host_calendar', { id: property.id }) }}"
                               class="inline-flex items-center gap-1.5 border border-gray-300 rounded-lg px-3 py-1.5 text-gray-700 hover:bg-gray-50 transition font-medium">
                                <i class="fa-solid fa-calendar-days text-xs"></i> Calendrier
                            </a>
                            <a href="{{ path('app_host_reservations') }}"
                               class="inline-flex items-center gap-1.5 border border-gray-300 rounded-lg px-3 py-1.5 text-gray-700 hover:bg-gray-50 transition font-medium">
                                <i class="fa-solid fa-suitcase text-xs"></i> Réservations
                            </a>
                            {% if property.calendarToken %}
                            <a href="{{ path('api_property_ical', { id: property.id }) }}?token={{ property.calendarToken }}"
                               class="inline-flex items-center gap-1.5 border border-brand/30 text-brand rounded-lg px-3 py-1.5 hover:bg-brand/5 transition font-medium"
                               download="calendar.ics" title="Télécharger le flux iCal">
                                <i class="fa-solid fa-download text-xs"></i> Export iCal
                            </a>
                            <button type="button"
                                onclick="navigator.clipboard.writeText('{{ url('api_property_ical', { id: property.id }) }}?token={{ property.calendarToken }}').then(()=>this.textContent='✓ Copié !').catch(()=>{})"
                                class="inline-flex items-center gap-1.5 border border-gray-300 rounded-lg px-3 py-1.5 text-gray-600 hover:bg-gray-50 transition font-medium text-xs">
                                <i class="fa-solid fa-link text-xs"></i> Copier URL iCal
                            </button>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="text-center py-16 border border-dashed border-gray-200 rounded-xl">
            <i class="fa-solid fa-house text-4xl text-gray-300 mb-4"></i>
            <p class="text-gray-500 mb-4">Vous n'avez pas encore d'annonce.</p>
            <a href="{{ path('app_host_property_new') }}"
               class="inline-flex items-center gap-2 bg-brand hover:bg-brandHover text-white text-sm font-semibold px-5 py-3 rounded-xl transition">
                <i class="fa-solid fa-plus"></i> Créer mon premier logement
            </a>
        </div>
    {% endif %}
</main>
{% endblock %}
