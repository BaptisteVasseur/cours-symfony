{% extends 'layout/app.html.twig' %}

{% block title %}Mes propriétés & réservations{% endblock %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-5xl mx-auto w-full">
        <h1 class="text-2xl md:text-3xl font-semibold text-gray-900 mb-2">Mes propriétés & réservations</h1>
        <p class="text-gray-500 mb-8">Annonces dont vous êtes l'hôte</p>



        {% if properties|length > 0 %}
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                {% for property in properties %}
                    <div class="flex flex-col gap-2">
                        {% include 'components/card.html.twig' with { property: property } %}
                        <a href="{{ path('app_account_property_calendar', {id: property.id}) }}"
                           class="flex items-center justify-center gap-2 w-full py-2 rounded-xl border border-gray-200 text-sm text-gray-600 hover:border-gray-400 hover:bg-gray-50 transition-colors">
                            <i class="fa-regular fa-calendar text-xs"></i>
                            Voir le calendrier
                        </a>
                    </div>
                {% endfor %}
            </div>
        {# Demandes en attente #}
        <div class="bg-white rounded-xl border border-amber-200 shadow-sm overflow-hidden mb-10 mt-10">
            <div class="px-6 py-4 border-b border-amber-100 bg-amber-50 flex items-center gap-3">
                <span class="w-2 h-2 rounded-full bg-amber-400 animate-pulse shrink-0"></span>
                <h2 class="font-bold text-gray-900">Demandes en attente</h2>
                {% if pendingReservations|length > 0 %}
                    <span class="ml-auto text-xs font-semibold text-amber-700 bg-amber-100 border border-amber-200 px-2.5 py-0.5 rounded-full">
                        {{ pendingReservations|length }}
                    </span>
                {% endif %}
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse text-sm">
                    <thead>
                        <tr class="bg-gray-50 text-gray-400 font-semibold border-b border-gray-200 uppercase text-[11px] tracking-wider">
                            <th class="px-6 py-3">Voyageur</th>
                            <th class="px-6 py-3">Logement</th>
                            <th class="px-6 py-3">Dates</th>
                            <th class="px-6 py-3">Voyageurs</th>
                            <th class="px-6 py-3">Montant</th>
                            <th class="px-6 py-3 text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        {% for reservation in pendingReservations %}
                            {% set guestProfile = reservation.guest ? reservation.guest.profile : null %}
                            <tr class="hover:bg-gray-50/70 transition">
                                <td class="px-6 py-4">
                                    {% if guestProfile and (guestProfile.firstName or guestProfile.lastName) %}
                                        <p class="font-medium text-gray-900">{{ guestProfile.firstName }} {{ guestProfile.lastName|first }}.</p>
                                    {% else %}
                                        <p class="font-medium text-gray-900">{{ reservation.guest ? reservation.guest.email : '—' }}</p>
                                    {% endif %}
                                </td>
                                <td class="px-6 py-4 text-gray-700 font-medium">
                                    {{ reservation.property ? reservation.property.title : '—' }}
                                </td>
                                <td class="px-6 py-4 text-gray-500 whitespace-nowrap">
                                    {{ reservation.checkinDate|date('d/m/Y') }} → {{ reservation.checkoutDate|date('d/m/Y') }}
                                </td>
                                <td class="px-6 py-4 text-gray-500 text-center">
                                    {{ reservation.guestsCount }}
                                </td>
                                <td class="px-6 py-4 font-semibold text-gray-900">
                                    {{ reservation.totalPrice|number_format(0, ',', ' ') }} €
                                </td>
                                <td class="px-6 py-4">
                                    <div class="flex items-center gap-2 justify-end">
                                        <form method="POST" action="{{ path('app_host_reservation_confirm', {id: reservation.id}) }}">
                                            <input type="hidden" name="_token" value="{{ csrf_token('confirm_reservation_' ~ reservation.id) }}">
                                            <button type="submit"
                                                    class="inline-flex items-center gap-1.5 text-xs font-semibold text-emerald-700 hover:text-white px-3 py-1.5 rounded-lg border border-emerald-300 hover:bg-emerald-600 transition">
                                                <i class="fa-solid fa-check text-[10px]"></i> Accepter
                                            </button>
                                        </form>
                                        <form method="POST" action="{{ path('app_host_reservation_reject', {id: reservation.id}) }}">
                                            <input type="hidden" name="_token" value="{{ csrf_token('reject_reservation_' ~ reservation.id) }}">
                                            <button type="submit"
                                                    class="inline-flex items-center gap-1.5 text-xs font-semibold text-red-600 hover:text-white px-3 py-1.5 rounded-lg border border-red-200 hover:bg-red-500 transition">
                                                <i class="fa-solid fa-xmark text-[10px]"></i> Refuser
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="6" class="px-6 py-8 text-center text-gray-400 text-sm">
                                    <i class="fa-regular fa-circle-check text-lg mb-2 block text-gray-300"></i>
                                    Aucune demande en attente.
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
        {% else %}

            <div class="text-center py-16 border border-dashed border-gray-200 rounded-xl">
                <i class="fa-solid fa-house text-4xl text-gray-300 mb-4"></i>
                <p class="text-gray-500">Vous n'avez pas encore d'annonce publiée.</p>
            </div>
        {% endif %}
    </main>
{% endblock %}
