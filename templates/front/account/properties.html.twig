{% extends 'layout/app.html.twig' %}

{% block title %}Mes propriétés{% endblock %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-5xl mx-auto w-full">
        <div class="flex flex-wrap items-center justify-between gap-4 mb-2">
            <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">Mes propriétés</h1>
            <a href="{{ path('app_host_reservations_index') }}"
               class="inline-flex items-center gap-2 px-4 py-2 border border-gray-300 rounded-xl text-sm font-semibold hover:bg-gray-50 transition">
                <i class="fa-solid fa-inbox"></i> Demandes de réservation
            </a>
        </div>
        <p class="text-gray-500 mb-8">Annonces dont vous êtes l'hôte</p>

        {% if properties|length > 0 %}
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                {% for property in properties %}
                    <div class="flex flex-col">
                        {% include 'components/card.html.twig' with { property: property } %}
                        <div class="flex gap-2 mt-3">
                            <a href="{{ path('app_host_availability_index', { id: property.id }) }}"
                               class="flex-1 text-center text-xs font-semibold border border-gray-300 rounded-xl py-2 hover:bg-gray-50 transition">
                                <i class="fa-regular fa-calendar mr-1"></i> Calendrier
                            </a>
                            <a href="{{ path('app_logement_detail', { id: property.id }) }}"
                               class="flex-1 text-center text-xs font-semibold border border-gray-300 rounded-xl py-2 hover:bg-gray-50 transition">
                                <i class="fa-regular fa-eye mr-1"></i> Voir l'annonce
                            </a>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="text-center py-16 border border-dashed border-gray-200 rounded-xl">
                <i class="fa-solid fa-house text-4xl text-gray-300 mb-4"></i>
                <p class="text-gray-500">Vous n'avez pas encore d'annonce publiée.</p>
            </div>
        {% endif %}
    </main>
{% endblock %}
