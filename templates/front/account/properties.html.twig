{% extends 'layout/app.html.twig' %}

{% block title %}Mes propriétés{% endblock %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-5xl mx-auto w-full">
        <h1 class="text-2xl md:text-3xl font-semibold text-gray-900 mb-2">Mes propriétés</h1>
        <p class="text-gray-500 mb-8">Annonces dont vous êtes l'hôte</p>

        {% if properties|length > 0 %}
            <div class="space-y-4">
                {% for property in properties %}
                    <div class="border border-gray-200 rounded-xl overflow-hidden">
                        {% include 'components/card.html.twig' with { property: property } %}
                        <div class="px-4 py-3 bg-gray-50 border-t border-gray-200 flex flex-wrap gap-3">
                            <a href="{{ path('app_availability_calendar', {id: property.id}) }}"
                               class="inline-flex items-center gap-1.5 text-sm font-semibold text-brand hover:underline">
                                <i class="fa-solid fa-calendar-days"></i> Gérer le calendrier
                            </a>
                            <a href="{{ path('app_account_ical', {id: property.id}) }}"
                               class="inline-flex items-center gap-1.5 text-sm font-semibold text-gray-600 hover:text-gray-900 hover:underline">
                                <i class="fa-solid fa-calendar-check"></i> Flux iCal
                            </a>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="text-center py-16 border border-dashed border-gray-200 rounded-xl">
                <i class="fa-solid fa-house text-4xl text-gray-300 mb-4"></i>
                <p class="text-gray-500">Vous n'avez pas encore d'annonce publiée.</p>
            </div>
        {% endif %}
    </main>
{% endblock %}
