{% extends 'layout/app.html.twig' %}

{% block title %}Mes annonces{% endblock %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-5xl mx-auto w-full">
        <div class="flex items-center justify-between mb-2">
            <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">Mes annonces</h1>
            {% if is_granted('ROLE_HOST') %}
                <a href="{{ path('app_host_property_new') }}"
                   class="inline-flex items-center gap-2 bg-brand hover:bg-brandHover text-white text-sm font-semibold px-5 py-2.5 rounded-xl transition">
                    <i class="fa-solid fa-plus"></i> Créer une annonce
                </a>
            {% endif %}
        </div>
        <p class="text-gray-500 mb-8">Annonces dont vous êtes l'hôte</p>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 px-4 py-3 rounded-xl text-sm font-medium {{ label == 'success' ? 'bg-emerald-50 text-emerald-800 border border-emerald-200' : 'bg-red-50 text-red-800 border border-red-200' }}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        {% if properties|length > 0 %}
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                {% for property in properties %}
                    <div class="relative group">
                        {% include 'components/card.html.twig' with { property: property } %}
                        {% if is_granted('ROLE_HOST') %}
                            <div class="absolute top-3 right-3 flex gap-2 opacity-0 group-hover:opacity-100 transition">
                                <a href="{{ path('app_host_property_edit', { id: property.id }) }}"
                                   class="bg-white text-gray-700 hover:text-brand text-xs font-semibold px-3 py-1.5 rounded-lg shadow-sm border border-gray-200 transition">
                                    <i class="fa-solid fa-pen mr-1"></i> Modifier
                                </a>
                            </div>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="text-center py-16 border border-dashed border-gray-200 rounded-xl">
                <i class="fa-solid fa-house text-4xl text-gray-300 mb-4"></i>
                <p class="text-gray-500 mb-4">Vous n'avez pas encore d'annonce.</p>
                {% if is_granted('ROLE_HOST') %}
                    <a href="{{ path('app_host_property_new') }}"
                       class="inline-flex items-center gap-2 bg-brand hover:bg-brandHover text-white text-sm font-semibold px-5 py-2.5 rounded-xl transition">
                        <i class="fa-solid fa-plus"></i> Créer ma première annonce
                    </a>
                {% endif %}
            </div>
        {% endif %}
    </main>
{% endblock %}
