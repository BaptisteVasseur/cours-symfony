{% extends 'layout/app.html.twig' %}

{% block title %}Réservations reçues{% endblock %}

{% set statusLabels = {
    'confirmed': 'Confirmée',
    'completed': 'Terminée',
    'pending': 'En attente',
    'cancelled': 'Annulée',
} %}
{% set statusColors = {
    'confirmed': 'bg-green-100 text-green-800',
    'completed': 'bg-blue-100 text-blue-800',
    'pending': 'bg-yellow-100 text-yellow-800',
    'cancelled': 'bg-red-100 text-red-800',
} %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-5xl mx-auto w-full">
        <h1 class="text-2xl md:text-3xl font-semibold text-gray-900 mb-2">Réservations reçues</h1>
        <p class="text-gray-500 mb-8">Réservations sur vos logements</p>

        {% if reservations|length > 0 %}
            <div class="overflow-x-auto">
                <table class="w-full text-sm text-left">
                    <thead class="text-xs uppercase text-gray-500 border-b border-gray-200">
                        <tr>
                            <th class="py-3 px-4">Logement</th>
                            <th class="py-3 px-4">Voyageur</th>
                            <th class="py-3 px-4">Dates</th>
                            <th class="py-3 px-4">Statut</th>
                            <th class="py-3 px-4">Total</th>
                            <th class="py-3 px-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        {% for reservation in reservations %}
                            {% set property = reservation.property %}
                            {% set guestProfile = reservation.guest ? reservation.guest.profile : null %}
                            <tr class="hover:bg-gray-50">
                                <td class="py-3 px-4 font-medium">
                                    {{ property ? property.title|length > 30 ? property.title|slice(0, 30) ~ '…' : property.title : '—' }}
                                </td>
                                <td class="py-3 px-4">
                                    {% if guestProfile %}
                                        {{ guestProfile.firstName }} {{ guestProfile.lastName }}
                                    {% else %}
                                        {{ reservation.guest ? reservation.guest.email : '—' }}
                                    {% endif %}
                                </td>
                                <td class="py-3 px-4 whitespace-nowrap">
                                    {{ reservation.checkinDate|date('d/m/Y') }} → {{ reservation.checkoutDate|date('d/m/Y') }}
                                </td>
                                <td class="py-3 px-4">
                                    <span class="text-xs font-semibold px-2 py-1 rounded-full {{ statusColors[reservation.status]|default('bg-gray-100 text-gray-800') }}">
                                        {{ statusLabels[reservation.status]|default(reservation.status) }}
                                    </span>
                                </td>
                                <td class="py-3 px-4 font-semibold">
                                    {{ reservation.totalPrice|number_format(2, ',', ' ') }} €
                                </td>
                                <td class="py-3 px-4">
                                    <div class="flex items-center gap-2">
                                        <a href="{{ path('app_reservation_show', { id: reservation.id }) }}" class="text-brand hover:underline text-xs font-semibold">Voir</a>
                                        {% if reservation.status == 'pending' %}
                                            <form action="{{ path('app_reservation_confirm', { id: reservation.id }) }}" method="post" class="inline">
                                                <input type="hidden" name="_token" value="{{ csrf_token('reservation_confirm' ~ reservation.id) }}">
                                                <button type="submit" class="text-xs font-semibold text-green-700 hover:underline">Accepter</button>
                                            </form>
                                            <form action="{{ path('app_reservation_cancel', { id: reservation.id }) }}" method="post" class="inline">
                                                <input type="hidden" name="_token" value="{{ csrf_token('reservation_cancel' ~ reservation.id) }}">
                                                <input type="hidden" name="cancellation_reason" value="Refusée par l'hôte">
                                                <button type="submit" class="text-xs font-semibold text-red-700 hover:underline">Refuser</button>
                                            </form>
                                        {% endif %}
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% else %}
            <div class="text-center py-16 border border-dashed border-gray-200 rounded-xl">
                <i class="fa-solid fa-calendar-check text-4xl text-gray-300 mb-4"></i>
                <p class="text-gray-500">Aucune réservation reçue pour le moment.</p>
            </div>
        {% endif %}
    </main>
{% endblock %}
