{% extends 'layout/app.html.twig' %}

{% block title %}Disponibilités — {{ property.title }}{% endblock %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-4xl mx-auto w-full">
        <a href="{{ path('app_account_properties') }}" class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-gray-900 mb-6">
            <i class="fa-solid fa-arrow-left"></i> Retour à mes propriétés
        </a>

        <h1 class="text-2xl font-semibold text-gray-900 mb-2">Gestion des disponibilités</h1>
        <p class="text-gray-500 mb-8">{{ property.title }}</p>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 px-4 py-3 rounded-xl text-sm {{ label == 'success' ? 'bg-emerald-50 text-emerald-800' : 'bg-red-50 text-red-800' }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}

        <section class="border border-gray-200 rounded-xl p-6 mb-8">
            <h2 class="text-lg font-semibold mb-4">Bloquer une période</h2>
            <form method="POST" action="{{ path('app_availability_block', { id: property.id }) }}" class="flex flex-wrap gap-4 items-end">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Date de début</label>
                    <input type="date" name="start_date" required class="border border-gray-300 rounded-lg px-4 py-2 text-sm">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Date de fin (exclue)</label>
                    <input type="date" name="end_date" required class="border border-gray-300 rounded-lg px-4 py-2 text-sm">
                </div>
                <button type="submit" class="bg-gray-900 text-white font-semibold px-5 py-2 rounded-lg text-sm hover:bg-gray-700 transition">
                    Bloquer
                </button>
            </form>
        </section>

        <section class="border border-gray-200 rounded-xl p-6">
            <h2 class="text-lg font-semibold mb-4">Dates bloquées</h2>
            {% if blocked|length > 0 %}
                <div class="space-y-2">
                    {% for availability in blocked %}
                        <div class="flex items-center justify-between py-2 border-b border-gray-100">
                            <span class="text-sm text-gray-700">{{ availability.availableDate|date('d/m/Y') }}</span>
                            <form method="POST" action="{{ path('app_availability_unblock', { id: property.id, availabilityId: availability.id }) }}">
                                <button type="submit" class="text-xs text-red-600 hover:underline">Débloquer</button>
                            </form>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <p class="text-gray-500 text-sm">Aucune date bloquée.</p>
            {% endif %}
        </section>
    </main>
{% endblock %}