{% extends 'layout/app.html.twig' %}

{% block title %}Paramètres du compte{% endblock %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-2xl mx-auto w-full">
        <a href="{{ path('app_home') }}" class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-gray-900 mb-6">
            <i class="fa-solid fa-arrow-left"></i> Retour à l'accueil
        </a>
        <h1 class="text-2xl md:text-3xl font-semibold text-gray-900 mb-2">Paramètres du compte</h1>
        <p class="text-gray-500 mb-2">{{ user.email }}</p>
        <p class="text-gray-500 mb-8">Gérez vos préférences et votre sécurité</p>


        <div class="bg-white border border-gray-200 rounded-2xl p-6 shadow-sm">
            {{ form_start(form, { attr: { class: 'space-y-5' } }) }}
                {{ form_row(form.phone, { row_attr: { class: 'space-y-2' }, label_attr: { class: 'block text-sm font-semibold text-gray-900' }, attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm' } }) }}
                {{ form_row(form.preferredLanguage, { row_attr: { class: 'space-y-2' }, label_attr: { class: 'block text-sm font-semibold text-gray-900' }, attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm' } }) }}
                {{ form_row(form.preferredCurrency, { row_attr: { class: 'space-y-2' }, label_attr: { class: 'block text-sm font-semibold text-gray-900' }, attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm' } }) }}
                {{ form_row(form.plainPassword, { row_attr: { class: 'space-y-2' }, label_attr: { class: 'block text-sm font-semibold text-gray-900' }, attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm' } }) }}
                <button type="submit" class="bg-brand hover:bg-brandHover text-white font-semibold px-6 py-3 rounded-xl transition">Enregistrer</button>
            {{ form_end(form) }}
        </div>

        {% if is_granted('ROLE_HOST') %}
            <div class="mt-8 bg-red-50 border border-red-200 rounded-2xl p-6 shadow-sm">
                <h2 class="text-lg font-semibold text-red-900 mb-2">Zone de danger : Désactiver le statut d'hôte</h2>
                <p class="text-sm text-red-700 mb-6">
                    En désactivant le statut d'hôte, toutes vos annonces (ainsi que toutes leurs réservations, avis et historiques associés) seront définitivement supprimées. Cette action est irréversible.
                </p>
                <form action="{{ path('app_account_deactivate_host') }}" method="POST" onsubmit="return confirm('Êtes-vous sûr de vouloir redevenir un utilisateur simple ? Toutes vos annonces seront définitivement supprimées.');">
                    <input type="hidden" name="_token" value="{{ csrf_token('deactivate_host') }}">
                    <button type="submit" class="bg-red-600 hover:bg-red-700 text-white font-semibold px-6 py-3 rounded-xl transition">
                        Désactiver le mode hôte et supprimer mes annonces
                    </button>
                </form>
            </div>
        {% endif %}
    </main>
{% endblock %}
