{% extends 'layout/app.html.twig' %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-5xl mx-auto w-full">
        <h1 class="text-2xl md:text-3xl font-semibold text-gray-900 mb-2">Demandes en attente</h1>
        <p class="text-gray-500 mb-8">Acceptez ou refusez les demandes de réservation sur vos logements.</p>

        {% if reservations|length > 0 %}
            <div class="space-y-4">
                {% for reservation in reservations %}
                    {% set property = reservation.property %}
                    {% set guest = reservation.guest %}
                    {% set guestProfile = guest ? guest.profile : null %}
                    <article class="border border-gray-200 rounded-xl p-5 flex flex-col md:flex-row md:items-center gap-4">
                        <div class="flex-1">
                            <h2 class="font-semibold text-lg">{{ property ? property.title : 'Logement' }}</h2>
                            <p class="text-sm text-gray-600 mt-1">
                                {{ guestProfile ? (guestProfile.firstName ~ ' ' ~ guestProfile.lastName)|trim : guest.email }}
                                · {{ reservation.checkinDate|date('d/m/Y') }} → {{ reservation.checkoutDate|date('d/m/Y') }}
                                · {{ reservation.guestsCount }} voyageur(s)
                            </p>
                            <p class="text-sm font-semibold mt-2">{{ reservation.totalPrice|number_format(2, ',', ' ') }} {{ reservation.currency }}</p>
                        </div>
                        <div class="flex gap-2 shrink-0">
                            <form method="post" action="{{ path('app_host_reservation_accept', { id: reservation.id }) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('accept' ~ reservation.id) }}">
                                <button type="submit" class="px-4 py-2 bg-brand text-white rounded-lg text-sm font-semibold hover:bg-brandHover transition">
                                    Accepter
                                </button>
                            </form>
                            <a href="{{ path('app_host_reservation_reject', { id: reservation.id }) }}"
                               class="px-4 py-2 border border-gray-300 rounded-lg text-sm font-semibold hover:bg-gray-50 transition">
                                Refuser
                            </a>
                        </div>
                    </article>
                {% endfor %}
            </div>
        {% else %}
            <div class="text-center py-16 border border-dashed border-gray-200 rounded-xl">
                <p class="text-gray-500">Aucune demande en attente pour le moment.</p>
            </div>
        {% endif %}
    </main>
{% endblock %}
