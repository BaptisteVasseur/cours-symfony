{% extends 'layout/app.html.twig' %}

{% block title %}Creer une annonce{% endblock %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-4xl mx-auto w-full">
        <a href="{{ path('app_account_properties') }}" class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-gray-900 mb-6">
            <i class="fa-solid fa-arrow-left"></i> Mes proprietes
        </a>

        <div class="mb-8">
            <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">Creer une annonce</h1>
            <p class="text-gray-500 mt-1">Ajoutez les informations principales du logement.</p>
        </div>

        <div class="border border-gray-200 rounded-xl p-6 bg-white">
            {{ form_start(form, { attr: { class: 'space-y-6' } }) }}
                <section>
                    <h2 class="text-lg font-semibold text-gray-900 mb-4">Logement</h2>
                    <div class="space-y-4">
                        {{ form_row(form.title, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm' } }) }}
                        {{ form_row(form.description, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm min-h-28' } }) }}
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                            {{ form_row(form.addressLine1, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm' } }) }}
                            {{ form_row(form.city, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm' } }) }}
                            {{ form_row(form.country, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm' } }) }}
                        </div>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            {{ form_row(form.propertyType, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm' } }) }}
                            {{ form_row(form.cancellationPolicy, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm' } }) }}
                        </div>
                    </div>
                </section>

                <section>
                    <h2 class="text-lg font-semibold text-gray-900 mb-4">Capacite et prix</h2>
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                        {{ form_row(form.maxGuests, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm' } }) }}
                        {{ form_row(form.bedrooms, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm' } }) }}
                        {{ form_row(form.beds, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm' } }) }}
                        {{ form_row(form.bathrooms, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm' } }) }}
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-4">
                        {{ form_row(form.pricePerNight, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm' } }) }}
                        {{ form_row(form.cleaningFee, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm' } }) }}
                        {{ form_row(form.securityDeposit, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm' } }) }}
                    </div>
                </section>

                <section>
                    <h2 class="text-lg font-semibold text-gray-900 mb-4">Reservation</h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        {{ form_row(form.checkinTime, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm' } }) }}
                        {{ form_row(form.checkoutTime, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm' } }) }}
                    </div>
                    <div class="mt-4">
                        {{ form_row(form.instantBooking) }}
                    </div>
                </section>

                <button type="submit" class="w-full bg-brand hover:bg-brandHover text-white font-semibold py-3 rounded-xl">Creer l'annonce</button>
            {{ form_end(form) }}
        </div>
    </main>
{% endblock %}
