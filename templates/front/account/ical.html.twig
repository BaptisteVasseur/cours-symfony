{% extends 'layout/app.html.twig' %}

{% block title %}Flux iCal — {{ property.title }}{% endblock %}

{% block content %}
<main class="flex-grow px-6 md:px-12 py-8 max-w-3xl mx-auto w-full">
    <a href="{{ path('app_account_properties') }}" class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-gray-900 mb-6">
        <i class="fa-solid fa-arrow-left"></i> Mes propriétés
    </a>

    <div class="mb-8">
        <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">Synchronisation iCal</h1>
        <p class="text-gray-500 mt-1">{{ property.title }}</p>
    </div>

    {% for label, messages in app.flashes %}
        {% for msg in messages %}
            <div class="mb-4 px-4 py-3 rounded-lg text-sm font-medium {{ label == 'success' ? 'bg-green-50 text-green-800 border border-green-200' : 'bg-red-50 text-red-800 border border-red-200' }}">
                {{ msg }}
            </div>
        {% endfor %}
    {% endfor %}

    <div class="border border-gray-200 rounded-xl p-6 space-y-6">
        <div>
            <h2 class="text-base font-semibold text-gray-900 mb-2">Votre flux iCal</h2>
            <p class="text-sm text-gray-500 mb-4">
                Ce lien vous permet de synchroniser vos réservations confirmées avec des applications comme Google Agenda, Apple Calendrier ou Outlook.
                Le lien est sécurisé par un token secret — ne le partagez qu'avec des applications de confiance.
            </p>

            {% if feedUrl %}
                <div class="bg-gray-50 border border-gray-200 rounded-lg p-3 flex items-center gap-3 mb-4">
                    <code class="flex-1 text-xs text-gray-700 break-all select-all">{{ feedUrl }}</code>
                    <button type="button"
                            onclick="navigator.clipboard.writeText('{{ feedUrl }}').then(() => this.textContent = 'Copié !')"
                            class="shrink-0 text-xs font-semibold text-brand hover:underline">
                        Copier
                    </button>
                </div>
                <p class="text-xs text-gray-500 mb-4">
                    <i class="fa-solid fa-circle-info mr-1"></i>
                    Ajoutez cette URL dans votre application agenda via "Abonnement à un calendrier" ou "Calendrier depuis une URL".
                </p>
            {% else %}
                <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 text-sm text-yellow-800 mb-4">
                    <i class="fa-solid fa-triangle-exclamation mr-1"></i>
                    Aucun lien iCal généré pour ce logement. Cliquez sur "Générer un lien" ci-dessous.
                </div>
            {% endif %}
        </div>

        <div class="border-t border-gray-200 pt-6">
            <h3 class="text-sm font-semibold text-gray-900 mb-2">
                {{ feedUrl ? 'Révoquer et régénérer le lien' : 'Générer un lien iCal' }}
            </h3>
            {% if feedUrl %}
                <p class="text-sm text-gray-500 mb-4">
                    Générer un nouveau lien invalidera l'ancien. Les applications utilisant l'ancien lien devront être mises à jour.
                </p>
            {% endif %}
            <form method="POST"
                  action="{{ path('app_account_ical_regenerate', {id: property.id}) }}"
                  {% if feedUrl %}onsubmit="return confirm('Ceci invalidera votre lien actuel. Continuer ?')"{% endif %}>
                <button type="submit"
                        class="inline-flex items-center gap-2 {{ feedUrl ? 'border border-red-300 text-red-600 hover:bg-red-50' : 'bg-brand text-white hover:bg-brandHover' }} text-sm font-semibold px-4 py-2 rounded-lg transition">
                    <i class="fa-solid fa-rotate-right"></i>
                    {{ feedUrl ? 'Révoquer et régénérer' : 'Générer un lien iCal' }}
                </button>
            </form>
        </div>
    </div>
</main>
{% endblock %}
