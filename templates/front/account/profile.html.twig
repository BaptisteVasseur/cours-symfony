{% extends 'layout/app.html.twig' %}

{% block title %}Mon profil — StayNest{% endblock %}

{% block content %}
<main class="flex-grow max-w-4xl mx-auto w-full px-4 py-10">

    {# Page header #}
    <div class="mb-8">
        <h1 class="text-2xl font-bold text-gray-900">Mon compte</h1>
        <p class="text-gray-400 text-sm mt-1">Gérez votre profil et vos préférences</p>
    </div>

    <div class="flex flex-col md:flex-row gap-8">

        {# Sidebar nav #}
        <nav class="md:w-52 shrink-0">
            <ul class="space-y-1">
                <li>
                    <a href="{{ path('app_account_profile') }}"
                       class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-semibold bg-surface text-gray-900">
                        <i class="fa-solid fa-user w-4 text-center text-brand"></i>
                        Profil
                    </a>
                </li>
                <li>
                    <a href="{{ path('app_account_settings') }}"
                       class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-medium text-gray-500 hover:bg-surface hover:text-gray-900 transition">
                        <i class="fa-solid fa-gear w-4 text-center text-gray-400"></i>
                        Paramètres
                    </a>
                </li>
                <li>
                    <a href="{{ path('app_reservation_index') }}"
                       class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-medium text-gray-500 hover:bg-surface hover:text-gray-900 transition">
                        <i class="fa-solid fa-suitcase-rolling w-4 text-center text-gray-400"></i>
                        Mes réservations
                    </a>
                </li>
                {% if is_granted('ROLE_HOST') %}
                <li>
                    <a href="{{ path('app_host_reservation_index') }}"
                       class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-medium text-gray-500 hover:bg-surface hover:text-gray-900 transition">
                        <i class="fa-solid fa-house-chimney-user w-4 text-center text-gray-400"></i>
                        Dashboard hôte
                    </a>
                </li>
                {% endif %}
                <li class="pt-2 border-t border-gray-100">
                    <a href="{{ path('app_logout') }}"
                       class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-medium text-red-500 hover:bg-red-50 transition">
                        <i class="fa-solid fa-right-from-bracket w-4 text-center"></i>
                        Se déconnecter
                    </a>
                </li>
            </ul>
        </nav>

        {# Content #}
        <div class="flex-1 min-w-0">

            {# Avatar block #}
            {% set profile = user.profile %}
            {% if profile %}
            <div class="flex items-center gap-5 mb-8 p-5 bg-surface rounded-2xl">
                <div class="w-16 h-16 rounded-full overflow-hidden bg-brand text-white flex items-center justify-center font-bold text-2xl shrink-0">
                    {% if profile.avatarUrl %}
                        <img src="{{ profile.avatarUrl }}" alt="{{ profile.firstName }}" class="w-full h-full object-cover">
                    {% else %}
                        {{ profile.firstName ? profile.firstName|first|upper : user.email|first|upper }}
                    {% endif %}
                </div>
                <div>
                    <p class="font-bold text-gray-900">{{ profile.firstName }} {{ profile.lastName }}</p>
                    <p class="text-sm text-gray-400">{{ user.email }}</p>
                    {% if profile.identityStatus == 'verified' %}
                        <span class="inline-flex items-center gap-1 text-xs text-emerald-600 font-semibold mt-1">
                            <i class="fa-solid fa-circle-check text-[10px]"></i> Identité vérifiée
                        </span>
                    {% endif %}
                </div>
            </div>
            {% endif %}

            <div class="bg-white border border-gray-100 rounded-2xl shadow-card p-6">
                <h2 class="text-base font-bold text-gray-900 mb-6">Informations personnelles</h2>

                {{ form_start(form, { attr: { class: 'space-y-5' } }) }}

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                        {{ form_row(form.firstName, {
                            label_attr: { class: 'block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1.5' },
                            attr: { class: 'w-full border border-gray-200 bg-surface rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand/20 focus:border-brand transition' }
                        }) }}
                        {{ form_row(form.lastName, {
                            label_attr: { class: 'block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1.5' },
                            attr: { class: 'w-full border border-gray-200 bg-surface rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand/20 focus:border-brand transition' }
                        }) }}
                    </div>

                    {{ form_row(form.birthDate, {
                        label_attr: { class: 'block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1.5' },
                        attr: { class: 'w-full border border-gray-200 bg-surface rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand/20 focus:border-brand transition' }
                    }) }}

                    {{ form_row(form.avatarUrl, {
                        label_attr: { class: 'block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1.5' },
                        attr: { class: 'w-full border border-gray-200 bg-surface rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand/20 focus:border-brand transition', placeholder: 'https://...' }
                    }) }}

                    {{ form_row(form.bio, {
                        label_attr: { class: 'block text-xs font-semibold text-gray-600 uppercase tracking-wide mb-1.5' },
                        attr: { class: 'w-full border border-gray-200 bg-surface rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand/20 focus:border-brand transition resize-none', rows: 4, placeholder: 'Parlez un peu de vous…' }
                    }) }}

                    <div class="pt-2 flex justify-end">
                        <button type="submit"
                            class="bg-brand hover:bg-brandHover text-white font-semibold px-7 py-3 rounded-xl transition text-sm shadow-sm">
                            Enregistrer les modifications
                        </button>
                    </div>

                {{ form_end(form) }}
            </div>
        </div>

    </div>
</main>
{% endblock %}
