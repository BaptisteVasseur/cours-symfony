{% extends 'layout/app.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block content %}
    <div class="flex-grow flex items-center justify-center px-4 py-12 md:py-16">
        <div class="w-full max-w-5xl grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
            <div class="hidden lg:block relative rounded-3xl overflow-hidden shadow-2xl h-[560px]">
                <img src="https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=900&q=80" alt="Logement" class="absolute inset-0 w-full h-full object-cover">
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent"></div>
                <div class="absolute bottom-0 left-0 right-0 p-10 text-white">
                    <p class="text-sm font-semibold uppercase tracking-wider text-white/80 mb-2">Bienvenue</p>
                    <h2 class="text-3xl font-bold leading-tight">Des logements uniques,<br>des expériences inoubliables.</h2>
                </div>
            </div>
            <div class="w-full max-w-md mx-auto lg:max-w-none">
                <div class="text-center lg:text-left mb-8">
                    <h1 class="text-2xl md:text-3xl font-bold text-gray-900">Bon retour parmi nous</h1>
                    <p class="text-gray-500 text-sm mt-2">Connectez-vous pour gérer vos réservations et vos annonces.</p>
                </div>
                {% if app.user %}
                    <div class="bg-white rounded-2xl border border-gray-200 shadow-xl p-8 text-center">
                        <p class="font-semibold mb-4">Vous êtes déjà connecté</p>
                        <a href="{{ path('app_home') }}" class="px-6 py-3 bg-brand text-white font-semibold rounded-xl">Accueil</a>
                    </div>
                {% else %}
                    <div class="bg-white rounded-2xl border border-gray-200 shadow-xl p-8">
                        {% if error %}
                            <div class="mb-6 px-4 py-3 rounded-xl text-sm bg-red-50 text-red-800 border border-red-200">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                        {% endif %}
                        <form method="post" class="space-y-5">
                            <div>
                                <label for="username" class="block text-sm font-semibold mb-2">Email</label>
                                <input type="email" id="username" name="_username" value="{{ last_username }}" required autofocus class="w-full border border-gray-300 rounded-xl px-4 py-3 text-sm">
                            </div>
                            <div>
                                <label for="password" class="block text-sm font-semibold mb-2">Mot de passe</label>
                                <input type="password" id="password" name="_password" required class="w-full border border-gray-300 rounded-xl px-4 py-3 text-sm">
                            </div>
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                            <button type="submit" class="w-full bg-brand hover:bg-brandHover text-white font-semibold py-3 rounded-xl">Se connecter</button>
                        </form>
                        <p class="text-center text-sm text-gray-600 mt-6">Pas encore de compte ? <a href="{{ path('app_register') }}" class="text-brand font-semibold">Inscrivez-vous</a></p>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}
