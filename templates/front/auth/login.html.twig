{% extends 'layout/app.html.twig' %}

{% block title %}Connexion — Airbnb{% endblock %}

{% block content %}
<div class="flex-grow flex items-stretch min-h-[calc(100vh-64px)]">

    {# Left panel: image   #}
    <div class="hidden lg:block lg:w-1/2 xl:w-3/5 relative">
        <img
            src="https://images.unsplash.com/photo-1613490493576-7fde63acd811?auto=format&fit=crop&w=1200&q=80"
            alt="Logement"
            class="absolute inset-0 w-full h-full object-cover"
        >
        <div class="absolute inset-0 bg-gradient-to-br from-gray-900/70 via-gray-900/40 to-transparent"></div>
        <div class="absolute inset-0 flex flex-col justify-end p-12">
            <div class="text-white max-w-md">
                <div class="flex items-center gap-1 mb-6">
                    {% for i in 1..5 %}<i class="fa-solid fa-star text-red-400 text-sm"></i>{% endfor %}
                    <span class="text-white/70 text-sm ml-2">5.0 · 48 avis</span>
                </div>
                <p class="text-xl font-semibold leading-relaxed mb-4">
                    "Un séjour parfait, le logement était exactement comme sur les photos. L'hôte a été aux petits soins."
                </p>
                <p class="text-white/70 text-sm">— Sophie M., Paris</p>
            </div>
        </div>
    </div>

    {# Right panel: form   #}
    <div class="w-full lg:w-1/2 xl:w-2/5 flex items-center justify-center px-6 py-12 bg-white">
        <div class="w-full max-w-sm">

            <a href="{{ path('app_home') }}" class="inline-flex items-center gap-1.5 text-brand font-extrabold text-xl mb-10">
                <svg width="22" height="22" viewBox="0 0 32 32" fill="currentColor">
                    <path d="M16 1C10.2 1 5.5 6 5.5 12.2c0 7.8 10.5 18.8 10.5 18.8s10.5-11 10.5-18.8C26.5 6 21.8 1 16 1zm0 15a4.5 4.5 0 1 1 0-9 4.5 4.5 0 0 1 0 9z"/>
                </svg>
                Airbnb
            </a>

            {% if app.user %}
                <div class="text-center">
                    <p class="text-gray-600 mb-4">Vous êtes déjà connecté.</p>
                    <a href="{{ path('app_home') }}" class="inline-block bg-brand text-white font-semibold px-6 py-3 rounded-2xl">Retour à l'accueil</a>
                </div>
            {% else %}
                <h1 class="text-2xl font-bold text-gray-900 mb-1">Bon retour</h1>
                <p class="text-gray-500 text-sm mb-8">Connectez-vous pour continuer</p>

                {% if error %}
                    <div class="flex items-center gap-3 mb-6 px-4 py-3 rounded-xl bg-red-50 text-red-800 border border-red-200 text-sm">
                        <i class="fa-solid fa-circle-xmark text-red-400 shrink-0"></i>
                        {{ error.messageKey|trans(error.messageData, 'security') }}
                    </div>
                {% endif %}

                <form method="post" class="space-y-4">
                    <div>
                        <label for="username" class="block text-xs font-semibold text-gray-700 mb-1.5 uppercase tracking-wide">Adresse email</label>
                        <input type="email" id="username" name="_username" value="{{ last_username }}"
                            required autofocus
                            class="w-full border border-gray-200 bg-surface rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand/30 focus:border-brand transition">
                    </div>
                    <div>
                        <div class="flex justify-between mb-1.5">
                            <label for="password" class="block text-xs font-semibold text-gray-700 uppercase tracking-wide">Mot de passe</label>
                            <a href="#" class="text-xs text-brand hover:underline">Oublié ?</a>
                        </div>
                        <input type="password" id="password" name="_password"
                            required
                            class="w-full border border-gray-200 bg-surface rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-brand/30 focus:border-brand transition">
                    </div>
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                    <button type="submit"
                        class="w-full bg-brand hover:bg-brandHover text-white font-bold py-3.5 rounded-xl transition shadow-sm mt-2">
                        Se connecter
                    </button>
                </form>

                <p class="text-center text-sm text-gray-500 mt-6">
                    Pas encore de compte ?
                    <a href="{{ path('app_register') }}" class="text-brand font-semibold hover:underline">Créer un compte</a>
                </p>
            {% endif %}
        </div>
    </div>

</div>
{% endblock %}
