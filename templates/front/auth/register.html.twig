{% extends 'layout/app.html.twig' %}

{% block title %}Créer un compte — StayNest{% endblock %}

{% block content %}
<div class="flex-grow flex items-stretch min-h-[calc(100vh-64px)]">

    {# Left panel   #}
    <div class="hidden lg:block lg:w-1/2 xl:w-3/5 relative">
        <img
            src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&w=1200&q=80"
            alt="Logement"
            class="absolute inset-0 w-full h-full object-cover"
        >
        <div class="absolute inset-0 bg-gradient-to-br from-gray-900/70 via-gray-900/40 to-transparent"></div>
        <div class="absolute inset-0 flex flex-col justify-end p-12">
            <div class="text-white max-w-md">
                <h2 class="text-2xl font-bold mb-3">Rejoignez la communauté</h2>
                <p class="text-white/70 text-sm leading-relaxed">Des milliers de voyageurs font confiance à StayNest pour trouver des logements uniques aux quatre coins de la France.</p>
            </div>
        </div>
    </div>

    {# Right panel   #}
    <div class="w-full lg:w-1/2 xl:w-2/5 flex items-center justify-center px-6 py-12 bg-white">
        <div class="w-full max-w-sm">

            <a href="{{ path('app_home') }}" class="inline-flex items-center gap-1.5 text-brand font-extrabold text-xl mb-10">
                <svg width="22" height="22" viewBox="0 0 32 32" fill="currentColor">
                    <path d="M16 1C10.2 1 5.5 6 5.5 12.2c0 7.8 10.5 18.8 10.5 18.8s10.5-11 10.5-18.8C26.5 6 21.8 1 16 1zm0 15a4.5 4.5 0 1 1 0-9 4.5 4.5 0 0 1 0 9z"/>
                </svg>
                StayNest
            </a>

            <h1 class="text-2xl font-bold text-gray-900 mb-1">Créer un compte</h1>
            <p class="text-gray-500 text-sm mb-8">C'est gratuit et ça prend moins d'une minute.</p>

            {{ form_start(form, { attr: { class: 'space-y-4' } }) }}
                {{ form_row(form.firstName, {
                    row_attr: { class: '' },
                    label_attr: { class: 'block text-xs font-semibold text-gray-700 mb-1.5 uppercase tracking-wide' },
                    attr: { class: 'w-full border border-gray-200 bg-surface rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:border-brand transition' }
                }) }}
                {{ form_row(form.lastName, {
                    row_attr: { class: '' },
                    label_attr: { class: 'block text-xs font-semibold text-gray-700 mb-1.5 uppercase tracking-wide' },
                    attr: { class: 'w-full border border-gray-200 bg-surface rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:border-brand transition' }
                }) }}
                {{ form_row(form.email, {
                    row_attr: { class: '' },
                    label_attr: { class: 'block text-xs font-semibold text-gray-700 mb-1.5 uppercase tracking-wide' },
                    attr: { class: 'w-full border border-gray-200 bg-surface rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:border-brand transition' }
                }) }}
                {{ form_row(form.plainPassword.first, {
                    row_attr: { class: '' },
                    label_attr: { class: 'block text-xs font-semibold text-gray-700 mb-1.5 uppercase tracking-wide' },
                    attr: { class: 'w-full border border-gray-200 bg-surface rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:border-brand transition' }
                }) }}
                {{ form_row(form.plainPassword.second, {
                    row_attr: { class: '' },
                    label_attr: { class: 'block text-xs font-semibold text-gray-700 mb-1.5 uppercase tracking-wide' },
                    attr: { class: 'w-full border border-gray-200 bg-surface rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:border-brand transition' }
                }) }}
                <button type="submit"
                    class="w-full bg-brand hover:bg-brandHover text-white font-bold py-3.5 rounded-xl transition shadow-sm mt-2">
                    Créer mon compte
                </button>
            {{ form_end(form) }}

            <p class="text-center text-sm text-gray-500 mt-6">
                Déjà un compte ?
                <a href="{{ path('app_login') }}" class="text-brand font-semibold hover:underline">Se connecter</a>
            </p>
        </div>
    </div>

</div>
{% endblock %}
