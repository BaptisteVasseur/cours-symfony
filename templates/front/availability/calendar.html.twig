{% extends 'layout/app.html.twig' %}

{% set monthNames = ['Janvier','Février','Mars','Avril','Mai','Juin','Juillet','Août','Septembre','Octobre','Novembre','Décembre'] %}
{% set dayNames = ['Lun','Mar','Mer','Jeu','Ven','Sam','Dim'] %}

{% block title %}Calendrier — {{ property.title }}{% endblock %}

{% block content %}
<main class="flex-grow px-6 md:px-12 py-8 max-w-4xl mx-auto w-full">
    <a href="{{ path('app_account_properties') }}" class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-gray-900 mb-6">
        <i class="fa-solid fa-arrow-left"></i> Mes propriétés
    </a>

    <div class="mb-8">
        <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">Gestion du calendrier</h1>
        <p class="text-gray-500 mt-1">{{ property.title }}</p>
    </div>

    {% for label, messages in app.flashes %}
        {% for msg in messages %}
            <div class="mb-4 px-4 py-3 rounded-lg text-sm font-medium {{ label == 'success' ? 'bg-green-50 text-green-800 border border-green-200' : 'bg-red-50 text-red-800 border border-red-200' }}">
                {{ msg }}
            </div>
        {% endfor %}
    {% endfor %}

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Calendar -->
        <div class="lg:col-span-2">
            <div class="border border-gray-200 rounded-xl overflow-hidden">
                <!-- Month navigation -->
                <div class="flex items-center justify-between px-6 py-4 bg-gray-50 border-b border-gray-200">
                    <a href="{{ path('app_availability_calendar', {id: property.id, year: prevYear, month: prevMonth}) }}"
                       class="p-2 text-gray-500 hover:text-gray-900 hover:bg-gray-100 rounded-lg transition">
                        <i class="fa-solid fa-chevron-left"></i>
                    </a>
                    <h2 class="text-base font-semibold text-gray-900">
                        {{ monthNames[month - 1] }} {{ year }}
                    </h2>
                    <a href="{{ path('app_availability_calendar', {id: property.id, year: nextYear, month: nextMonth}) }}"
                       class="p-2 text-gray-500 hover:text-gray-900 hover:bg-gray-100 rounded-lg transition">
                        <i class="fa-solid fa-chevron-right"></i>
                    </a>
                </div>

                <!-- Day headers -->
                <div class="grid grid-cols-7 border-b border-gray-200">
                    {% for day in dayNames %}
                        <div class="py-2 text-center text-xs font-semibold text-gray-500">{{ day }}</div>
                    {% endfor %}
                </div>

                <!-- Calendar grid -->
                {% set firstDayOfMonth = (year ~ '-' ~ month|format('%02d') ~ '-01')|date('N') %}
                {% set daysInMonth = calendar|length %}
                <div class="grid grid-cols-7 gap-px bg-gray-100">
                    <!-- Empty cells before first day (Monday = 1) -->
                    {% for i in 1..(firstDayOfMonth - 1) %}
                        <div class="bg-white py-2"></div>
                    {% endfor %}

                    {% for dateStr, isAvailable in calendar %}
                        {% set dayNum = dateStr|date('j') %}
                        {% set isPast = dateStr < 'now'|date('Y-m-d') %}
                        <div class="bg-white p-1 min-h-[3rem] flex flex-col items-center justify-start pt-2
                            {{ isPast ? 'opacity-40' : '' }}">
                            <span class="text-xs font-medium mb-1
                                {{ isAvailable ? 'text-gray-700' : 'text-red-500 line-through' }}">
                                {{ dayNum }}
                            </span>
                            {% if not isPast %}
                                <button type="button"
                                    data-date="{{ dateStr }}"
                                    data-property="{{ property.id }}"
                                    onclick="toggleDate('{{ dateStr }}', '{{ property.id }}')"
                                    class="text-[10px] px-1.5 py-0.5 rounded font-medium transition
                                        {{ isAvailable
                                            ? 'bg-green-100 text-green-700 hover:bg-red-100 hover:text-red-700'
                                            : 'bg-red-100 text-red-700 hover:bg-green-100 hover:text-green-700'
                                        }}"
                                    title="{{ isAvailable ? 'Bloquer cette date' : 'Débloquer cette date' }}">
                                    {{ isAvailable ? 'Libre' : 'Bloqué' }}
                                </button>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>

                <!-- Legend -->
                <div class="flex items-center gap-6 px-6 py-3 border-t border-gray-200 bg-gray-50 text-xs text-gray-500">
                    <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded bg-green-100 inline-block"></span> Disponible</span>
                    <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded bg-red-100 inline-block"></span> Bloqué / Réservé</span>
                </div>
            </div>
        </div>

        <!-- Sidebar: Block range form -->
        <aside class="space-y-6">
            <div class="border border-gray-200 rounded-xl p-6">
                <h3 class="text-base font-semibold text-gray-900 mb-4">Bloquer une période</h3>
                <form action="{{ path('app_availability_block_range', {id: property.id}) }}" method="POST" class="space-y-4">
                    <input type="hidden" name="action" value="block">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Début</label>
                        <input type="date" name="start" required
                               min="{{ 'now'|date('Y-m-d') }}"
                               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Fin</label>
                        <input type="date" name="end" required
                               min="{{ 'now'|date('Y-m-d') }}"
                               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand">
                    </div>
                    <button type="submit"
                            class="w-full bg-gray-900 text-white py-2 px-4 rounded-lg text-sm font-semibold hover:bg-gray-700 transition">
                        Bloquer
                    </button>
                </form>
            </div>

            <div class="border border-gray-200 rounded-xl p-6">
                <h3 class="text-base font-semibold text-gray-900 mb-4">Débloquer une période</h3>
                <form action="{{ path('app_availability_block_range', {id: property.id}) }}" method="POST" class="space-y-4">
                    <input type="hidden" name="action" value="unblock">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Début</label>
                        <input type="date" name="start" required
                               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Fin</label>
                        <input type="date" name="end" required
                               class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand">
                    </div>
                    <button type="submit"
                            class="w-full border border-gray-300 text-gray-700 py-2 px-4 rounded-lg text-sm font-semibold hover:bg-gray-50 transition">
                        Débloquer
                    </button>
                </form>
            </div>
        </aside>
    </div>
</main>

<script>
async function toggleDate(date, propertyId) {
    const res = await fetch(`/logement/${propertyId}/disponibilites/toggle`, {
        method: 'POST',
        headers: {'Content-Type': 'application/x-www-form-urlencoded'},
        body: new URLSearchParams({date}),
    });
    if (res.ok) {
        // Reload page to reflect the change
        window.location.reload();
    }
}
</script>
{% endblock %}
