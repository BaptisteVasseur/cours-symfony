{% extends 'layout/app.html.twig' %}

{% block title %}Calendrier — {{ property.title }}{% endblock %}

{% set monthNames = {
    1: 'Janvier', 2: 'Février', 3: 'Mars', 4: 'Avril',
    5: 'Mai', 6: 'Juin', 7: 'Juillet', 8: 'Août',
    9: 'Septembre', 10: 'Octobre', 11: 'Novembre', 12: 'Décembre'
} %}

{% set dayNames = ['Lun', 'Mar', 'Mer', 'Jeu', 'Ven', 'Sam', 'Dim'] %}

{% block content %}
<main class="flex-grow px-6 md:px-12 py-8 max-w-5xl mx-auto w-full">

    <a href="{{ path('app_account_properties') }}" class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-gray-900 mb-6">
        <i class="fa-solid fa-arrow-left"></i> Mes propriétés
    </a>

    <h1 class="text-2xl font-bold text-gray-900 mb-1">Gestion des disponibilités</h1>
    <p class="text-gray-500 text-sm mb-8">{{ property.title }}</p>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="mb-4 px-4 py-3 rounded-xl text-sm {{ label == 'success' ? 'bg-emerald-50 text-emerald-800' : 'bg-red-50 text-red-800' }}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

        {# Calendrier #}
        <div class="lg:col-span-2">
            <div class="bg-white border border-gray-200 rounded-2xl p-6 shadow-sm">

                {# Navigation mois #}
                <div class="flex items-center justify-between mb-6">
                    <a href="{{ path('app_host_availability_index', { id: property.id, year: month == 1 ? year - 1 : year, month: month == 1 ? 12 : month - 1 }) }}"
                       class="p-2 rounded-full hover:bg-gray-100 text-gray-500">
                        <i class="fa-solid fa-chevron-left"></i>
                    </a>
                    <h2 class="text-lg font-semibold text-gray-900">
                        {{ monthNames[month] }} {{ year }}
                    </h2>
                    <a href="{{ path('app_host_availability_index', { id: property.id, year: month == 12 ? year + 1 : year, month: month == 12 ? 1 : month + 1 }) }}"
                       class="p-2 rounded-full hover:bg-gray-100 text-gray-500">
                        <i class="fa-solid fa-chevron-right"></i>
                    </a>
                </div>

                {# En-tête jours #}
                <div class="grid grid-cols-7 mb-2">
                    {% for day in dayNames %}
                        <div class="text-center text-xs font-medium text-gray-400 py-1">{{ day }}</div>
                    {% endfor %}
                </div>

                {# Grille jours #}
                {% set firstDayOfMonth = (year ~ '-' ~ month ~ '-01')|date('N') %}
                <div class="grid grid-cols-7 gap-1">
                    {# Cases vides avant le premier jour #}
                    {% for i in 1..firstDayOfMonth - 1 %}
                        <div></div>
                    {% endfor %}

                    {% for iso, status in calendarDays %}
                        {% set dayNum = iso|date('j') %}
                        {% if status == 'blocked' %}
                            {% set bg = 'bg-gray-200 text-gray-500' %}
                            {% set title = 'Bloqué par l\'hôte' %}
                        {% elseif status == 'confirmed' %}
                            {% set bg = 'bg-red-100 text-red-700' %}
                            {% set title = 'Réservé (confirmé)' %}
                        {% elseif status == 'pending' %}
                            {% set bg = 'bg-yellow-100 text-yellow-700' %}
                            {% set title = 'Réservation en attente' %}
                        {% else %}
                            {% set bg = 'bg-emerald-50 text-emerald-700' %}
                            {% set title = 'Disponible' %}
                        {% endif %}
                        <div class="aspect-square flex items-center justify-center rounded-lg text-sm font-medium {{ bg }} cursor-default"
                             title="{{ title }}">
                            {{ dayNum }}
                        </div>
                    {% endfor %}
                </div>

                {# Légende #}
                <div class="flex flex-wrap gap-4 mt-6 pt-4 border-t border-gray-100 text-xs text-gray-600">
                    <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded bg-emerald-100 inline-block"></span> Disponible</span>
                    <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded bg-red-100 inline-block"></span> Réservé</span>
                    <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded bg-yellow-100 inline-block"></span> En attente</span>
                    <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded bg-gray-200 inline-block"></span> Bloqué</span>
                </div>
            </div>
        </div>

        {# Panneau latéral #}
        <div class="space-y-6">

            {# Formulaire de blocage #}
            <div class="bg-white border border-gray-200 rounded-2xl p-5 shadow-sm">
                <h3 class="font-semibold text-gray-900 mb-4">Bloquer une période</h3>
                {{ form_start(form, { attr: { class: 'space-y-4' } }) }}
                    {{ form_row(form.startDate, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-2.5 text-sm' } }) }}
                    {{ form_row(form.endDate, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-2.5 text-sm' } }) }}
                    {{ form_row(form.reason, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-2.5 text-sm' } }) }}
                    <button type="submit" class="w-full bg-gray-900 hover:bg-gray-700 text-white font-semibold py-2.5 rounded-xl text-sm">
                        Bloquer cette période
                    </button>
                {{ form_end(form) }}
            </div>

            {# Liste des blocages #}
            {% if blocks|length > 0 %}
            <div class="bg-white border border-gray-200 rounded-2xl p-5 shadow-sm">
                <h3 class="font-semibold text-gray-900 mb-4">Périodes bloquées</h3>
                <ul class="space-y-3">
                    {% for block in blocks %}
                    <li class="flex items-start justify-between gap-3 text-sm">
                        <div>
                            <p class="font-medium text-gray-800">
                                {{ block.startDate|date('d/m/Y') }} → {{ block.endDate|date('d/m/Y') }}
                            </p>
                            {% if block.reason %}
                                <p class="text-gray-500 text-xs mt-0.5">{{ block.reason }}</p>
                            {% endif %}
                        </div>
                        <form method="post"
                              action="{{ path('app_host_availability_delete', { id: property.id, blockId: block.id }) }}"
                              onsubmit="return confirm('Supprimer ce blocage ?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_block_' ~ block.id) }}">
                            <button type="submit" class="text-red-400 hover:text-red-600" title="Supprimer">
                                <i class="fa-solid fa-trash text-xs"></i>
                            </button>
                        </form>
                    </li>
                    {% endfor %}
                </ul>
            </div>
            {% endif %}

        </div>

        <div class="mt-8 border border-gray-200 rounded-2xl p-6">
            <h3 class="font-semibold text-gray-900 mb-1">Synchronisation iCal</h3>
            <p class="text-sm text-gray-500 mb-4">Exportez vos réservations confirmées vers Google Calendar, Outlook ou tout autre agenda compatible.</p>

            {% if property.icalToken %}
                {% set icalUrl = absolute_url(path('api_property_ical', { id: property.id })) ~ '?token=' ~ property.icalToken %}
                <div class="bg-gray-50 border border-gray-200 rounded-xl px-4 py-3 mb-4 flex items-center gap-3">
                    <code class="text-xs text-gray-700 break-all flex-1">{{ icalUrl }}</code>
                    <a href="{{ icalUrl }}" download="calendar.ics"
                       class="shrink-0 text-xs font-semibold text-brand hover:underline">
                        <i class="fa-solid fa-download mr-1"></i> .ics
                    </a>
                </div>
            {% else %}
                <p class="text-sm text-amber-700 bg-amber-50 border border-amber-200 rounded-xl px-4 py-3 mb-4">
                    Aucun token généré. Cliquez ci-dessous pour créer votre lien iCal sécurisé.
                </p>
            {% endif %}

            <form method="POST"
                  action="{{ path('app_host_availability_ical_generate', { id: property.id }) }}"
                  onsubmit="return property.icalToken ? confirm('Régénérer le token ? L\'ancien lien sera invalidé.') : true">
                <input type="hidden" name="_token" value="{{ csrf_token('ical_generate_' ~ property.id) }}">
                <button type="submit"
                        class="px-4 py-2 border border-gray-300 rounded-xl text-sm font-semibold hover:bg-gray-50 transition">
                    <i class="fa-solid fa-rotate mr-1"></i>
                    {{ property.icalToken ? 'Régénérer le token' : 'Générer le lien iCal' }}
                </button>
            </form>
        </div>

    </div>
</main>
{% endblock %}
