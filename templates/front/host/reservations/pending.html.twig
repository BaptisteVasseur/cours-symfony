{% extends 'layout/app.html.twig' %}

{% block title %}Demandes en attente — Mes logements{% endblock %}

{% block content %}
<main class="flex-grow px-6 md:px-12 py-8 max-w-5xl mx-auto w-full">
    <div class="mb-8">
        <a href="{{ path('app_host_reservations') }}" class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-gray-900 mb-4">
            <i class="fa-solid fa-arrow-left"></i> Retour aux réservations
        </a>
        <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">Demandes en attente</h1>
        <p class="text-gray-500 mt-1">Ces réservations nécessitent votre réponse dans les 24 heures.</p>
    </div>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="mb-4 px-4 py-3 rounded-xl text-sm {{ label == 'success' ? 'bg-emerald-50 text-emerald-800' : label == 'error' ? 'bg-red-50 text-red-800' : 'bg-yellow-50 text-yellow-800' }}">{{ message }}</div>
        {% endfor %}
    {% endfor %}

    {% if reservations|length > 0 %}
        <div class="space-y-4">
            {% for reservation in reservations %}
                <div class="flex flex-col sm:flex-row gap-4 p-4 border border-gray-200 rounded-xl bg-white">
                    {% set property = reservation.property %}
                    {% set cover = property ? property.coverMedia : null %}
                    {% set placeholderImage = 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=400&q=80' %}
                    <div class="w-full sm:w-40 h-32 sm:h-28 shrink-0 rounded-lg overflow-hidden">
                        <img src="{{ cover ? cover.fileUrl : placeholderImage }}" alt="{{ property ? property.title : '' }}" class="w-full h-full object-cover">
                    </div>
                    <div class="flex-grow min-w-0">
                        <h2 class="font-semibold text-gray-900 truncate">{{ property ? property.title : 'Logement supprimé' }}</h2>
                        {% set guestProfile = reservation.guest ? reservation.guest.profile : null %}
                        <p class="text-sm text-gray-500 mt-1">
                            Voyageur : {{ guestProfile ? guestProfile.firstName ~ ' ' ~ guestProfile.lastName : reservation.guest.email }}
                        </p>
                        <p class="text-sm text-gray-700 mt-1">
                            {{ reservation.checkinDate|date('d/m/Y') }} → {{ reservation.checkoutDate|date('d/m/Y') }}
                            · {{ reservation.guestsCount }} voyageur{{ reservation.guestsCount > 1 ? 's' : '' }}
                        </p>
                        <p class="text-sm font-semibold mt-1">{{ reservation.totalPrice|number_format(0, ',', ' ') }} {{ reservation.currency|default('EUR') }}</p>
                    </div>
                    <div class="flex sm:flex-col gap-2 shrink-0 sm:w-32">
                        <form action="{{ path('app_host_reservation_accept', { id: reservation.id }) }}" method="post" class="flex-1">
                            <input type="hidden" name="_token" value="{{ csrf_token('accept' ~ reservation.id) }}">
                            <button type="submit" class="w-full bg-emerald-600 hover:bg-emerald-700 text-white font-semibold py-2 px-4 rounded-lg text-sm transition">
                                Accepter
                            </button>
                        </form>
                        <a href="{{ path('app_host_reservation_reject', { id: reservation.id }) }}" class="flex-1">
                            <button type="button" class="w-full bg-red-50 hover:bg-red-100 text-red-700 font-semibold py-2 px-4 rounded-lg text-sm transition border border-red-200">
                                Refuser
                            </button>
                        </a>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="text-center py-16 border border-dashed border-gray-200 rounded-xl">
            <i class="fa-solid fa-check-circle text-4xl text-gray-300 mb-4"></i>
            <p class="text-gray-500">Aucune demande en attente pour le moment.</p>
        </div>
    {% endif %}
</main>
{% endblock %}
