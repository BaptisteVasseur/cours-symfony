{% extends 'layout/app.html.twig' %}

{% block title %}Refuser la réservation{% endblock %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-2xl mx-auto w-full">
        <a href="{{ path('app_host_reservations_index') }}" class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-gray-900 mb-6">
            <i class="fa-solid fa-arrow-left"></i> Retour aux demandes
        </a>

        {% set property = reservation.property %}
        {% set guest = reservation.guest %}
        {% set guestProfile = guest ? guest.profile : null %}

        <h1 class="text-2xl font-bold text-gray-900 mb-2">Refuser la demande</h1>
        <p class="text-gray-500 text-sm mb-6">
            Réservation de
            {% if guestProfile %}{{ guestProfile.firstName }} {{ guestProfile.lastName }}{% else %}{{ guest.email }}{% endif %}
            pour <strong>{{ property.title }}</strong>
            du {{ reservation.checkinDate|date('d/m/Y') }} au {{ reservation.checkoutDate|date('d/m/Y') }}.
        </p>

        <div class="bg-amber-50 border border-amber-200 text-amber-800 rounded-xl px-4 py-3 text-sm mb-6">
            Le voyageur recevra un e-mail l'informant du refus avec le motif que vous indiquez.
        </div>

        <div class="bg-white border border-gray-200 rounded-2xl p-6 shadow-sm">
            {{ form_start(form, { attr: { class: 'space-y-5' } }) }}
                {{ form_errors(form) }}
                {{ form_row(form.reason) }}
                <div class="flex gap-3 pt-2">
                    <button type="submit" class="px-6 py-3 bg-red-600 hover:bg-red-700 text-white font-semibold rounded-xl transition">
                        Confirmer le refus
                    </button>
                    <a href="{{ path('app_host_reservations_index') }}" class="px-6 py-3 border border-gray-300 text-gray-700 hover:bg-gray-50 font-semibold rounded-xl transition">
                        Annuler
                    </a>
                </div>
            {{ form_end(form) }}
        </div>
    </main>
{% endblock %}
