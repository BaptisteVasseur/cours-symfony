{% extends 'layout/app.html.twig' %}

{% block title %}Refuser la demande{% endblock %}

{% block content %}
<main class="flex-grow px-4 md:px-10 py-8 max-w-2xl mx-auto w-full">

    <nav class="text-sm text-gray-400 mb-6 flex items-center gap-2">
        <a href="{{ path('app_host_requests') }}" class="hover:text-brand transition">Demandes en attente</a>
        <i class="fa-solid fa-chevron-right text-xs"></i>
        <span class="text-gray-600 font-medium">Refuser la demande</span>
    </nav>

    {% set guest = reservation.guest %}
    {% set property = reservation.property %}
    {% set nights = reservation.checkinDate.diff(reservation.checkoutDate).days %}

    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6 mb-6">
        <h2 class="text-base font-semibold text-gray-900 mb-1">{{ property.title }}</h2>
        <p class="text-sm text-gray-500">
            <i class="fa-regular fa-calendar mr-1"></i>
            {{ reservation.checkinDate|date('d/m/Y') }} → {{ reservation.checkoutDate|date('d/m/Y') }}
            — {{ nights }} nuit{{ nights > 1 ? 's' : '' }}
            — {{ reservation.guestsCount }} voyageur{{ reservation.guestsCount > 1 ? 's' : '' }}
        </p>
        <p class="text-sm text-gray-500 mt-1">
            <i class="fa-regular fa-circle-user mr-1"></i>
            {{ guest.profile ? (guest.profile.firstName ~ ' ' ~ guest.profile.lastName) : guest.email }}
        </p>
    </div>

    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
        <h1 class="text-xl font-semibold text-gray-900 mb-1">
            <i class="fa-solid fa-xmark mr-2 text-red-500"></i>
            Refuser cette demande
        </h1>
        <p class="text-sm text-gray-500 mb-6">
            Le voyageur sera notifié par email avec votre motif. Cette action est irréversible.
        </p>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 px-4 py-3 rounded-xl text-sm font-medium
                    {{ label == 'success' ? 'bg-emerald-50 text-emerald-800 border border-emerald-200' : 'bg-red-50 text-red-800 border border-red-200' }}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        {{ form_start(form, {attr: {class: 'space-y-5'}}) }}

            <div>
                {{ form_label(form.reason, null, {label_attr: {class: 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.reason, {attr: {class: 'w-full px-4 py-3 border border-gray-300 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent transition'}}) }}
                {{ form_errors(form.reason) }}
            </div>

            <div class="flex gap-3 pt-2">
                <button type="submit"
                        class="flex items-center gap-2 px-5 py-2.5 bg-red-600 hover:bg-red-700 text-white text-sm font-semibold rounded-xl transition shadow-sm"
                        onclick="return confirm('Confirmer le refus de cette demande ?')">
                    <i class="fa-solid fa-xmark"></i> Confirmer le refus
                </button>
                <a href="{{ path('app_host_requests') }}"
                   class="flex items-center gap-2 px-5 py-2.5 bg-white border border-gray-200 hover:bg-gray-50 text-gray-700 text-sm font-semibold rounded-xl transition shadow-sm">
                    Annuler
                </a>
            </div>

        {{ form_end(form) }}
    </div>

</main>
{% endblock %}
