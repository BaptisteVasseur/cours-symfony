{% extends 'layout/app.html.twig' %}

{% block title %}Demandes de réservation{% endblock %}

{% block content %}
<main class="flex-grow px-4 md:px-10 py-8 max-w-5xl mx-auto w-full">

    <div class="mb-8">
        <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">
            <i class="fa-regular fa-clock-rotate-left mr-2 text-brand"></i>
            Demandes en attente
        </h1>
        <p class="text-gray-500 mt-1">Acceptez ou refusez les demandes de réservation reçues pour vos logements.</p>
    </div>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="mb-4 px-4 py-3 rounded-xl text-sm font-medium
                {{ label == 'success' ? 'bg-emerald-50 text-emerald-800 border border-emerald-200' : 'bg-red-50 text-red-800 border border-red-200' }}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    {% if reservations|length > 0 %}
        <div class="space-y-4">
            {% for reservation in reservations %}
                {% set guest = reservation.guest %}
                {% set property = reservation.property %}
                {% set nights = reservation.checkinDate.diff(reservation.checkoutDate).days %}

                <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
                    <div class="flex flex-col md:flex-row items-start md:items-center gap-4 p-5">

                        {# Photo du logement #}
                        <div class="w-full md:w-28 h-24 flex-shrink-0 rounded-xl overflow-hidden bg-gray-100">
                            {% set cover = property.media|filter(m => m.isCover)|first %}
                            {% if cover %}
                                <img src="{{ cover.url }}" alt="{{ property.title }}" class="w-full h-full object-cover">
                            {% else %}
                                <div class="w-full h-full flex items-center justify-center text-gray-300">
                                    <i class="fa-regular fa-image text-3xl"></i>
                                </div>
                            {% endif %}
                        </div>

                        {# Informations réservation #}
                        <div class="flex-1 min-w-0">
                            <div class="flex items-center gap-2 mb-1">
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-semibold bg-amber-100 text-amber-800">
                                    <i class="fa-solid fa-clock text-[10px]"></i> En attente
                                </span>
                                <span class="text-xs text-gray-400">reçue le {{ reservation.createdAt|date('d/m/Y à H:i') }}</span>
                            </div>

                            <h2 class="text-base font-semibold text-gray-900 truncate">{{ property.title }}</h2>

                            <div class="flex flex-wrap gap-x-4 gap-y-1 mt-2 text-sm text-gray-600">
                                <span><i class="fa-regular fa-calendar mr-1 text-gray-400"></i>
                                    {{ reservation.checkinDate|date('d/m/Y') }} → {{ reservation.checkoutDate|date('d/m/Y') }}
                                    <span class="text-gray-400">({{ nights }} nuit{{ nights > 1 ? 's' : '' }})</span>
                                </span>
                                <span><i class="fa-regular fa-user mr-1 text-gray-400"></i>
                                    {{ reservation.guestsCount }} voyageur{{ reservation.guestsCount > 1 ? 's' : '' }}
                                </span>
                                <span class="font-semibold text-gray-900">
                                    {{ reservation.totalPrice|number_format(2, ',', ' ') }} {{ reservation.currency }}
                                </span>
                            </div>

                            <div class="flex items-center gap-2 mt-2 text-sm text-gray-500">
                                <i class="fa-regular fa-circle-user text-gray-400"></i>
                                {{ guest.profile ? (guest.profile.firstName ~ ' ' ~ guest.profile.lastName) : guest.email }}
                            </div>
                        </div>

                        {# Actions #}
                        <div class="flex flex-col sm:flex-row gap-2 mt-4 md:mt-0 w-full md:w-auto">
                            <form method="POST"
                                  action="{{ path('app_host_request_accept', {id: reservation.id}) }}"
                                  onsubmit="return confirm('Confirmer l\'acceptation de cette demande ?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('accept_reservation_' ~ reservation.id) }}">
                                <button type="submit"
                                        class="w-full sm:w-auto flex items-center justify-center gap-2 px-4 py-2 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-semibold rounded-xl transition shadow-sm">
                                    <i class="fa-solid fa-check"></i> Accepter
                                </button>
                            </form>

                            <a href="{{ path('app_host_request_reject', {id: reservation.id}) }}"
                               class="w-full sm:w-auto flex items-center justify-center gap-2 px-4 py-2 bg-white border border-red-300 hover:bg-red-50 text-red-700 text-sm font-semibold rounded-xl transition shadow-sm">
                                <i class="fa-solid fa-xmark"></i> Refuser
                            </a>
                        </div>

                    </div>

                    {% if reservation.expiresAt %}
                        <div class="px-5 pb-3 text-xs text-amber-600 flex items-center gap-1">
                            <i class="fa-regular fa-hourglass-half"></i>
                            Expire le {{ reservation.expiresAt|date('d/m/Y à H:i') }}
                        </div>
                    {% endif %}
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="text-center py-20 border border-dashed border-gray-200 rounded-2xl">
            <i class="fa-regular fa-calendar-check text-5xl text-gray-300 mb-4 block"></i>
            <p class="text-gray-500 font-medium">Aucune demande en attente pour le moment.</p>
            <p class="text-gray-400 text-sm mt-1">Les nouvelles demandes de vos voyageurs apparaîtront ici.</p>
        </div>
    {% endif %}

</main>
{% endblock %}
