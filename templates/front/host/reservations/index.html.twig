{% extends 'layout/app.html.twig' %}

{% block title %}Réservations — Mes logements{% endblock %}

{% block content %}
<main class="flex-grow px-6 md:px-12 py-8 max-w-5xl mx-auto w-full">
    <div class="flex flex-wrap items-center justify-between gap-4 mb-8">
        <div>
            <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">Réservations</h1>
            <p class="text-gray-500 mt-1">Demandes pour vos logements</p>
        </div>
        <div class="flex gap-2">
            <a href="{{ path('app_host_reservations') }}" class="px-4 py-2 text-sm font-semibold rounded-full border border-gray-200 hover:bg-gray-50 transition">
                Toutes
            </a>
            <a href="{{ path('app_host_reservations_pending') }}" class="px-4 py-2 text-sm font-semibold rounded-full bg-yellow-100 text-yellow-800 hover:bg-yellow-200 transition">
                En attente
            </a>
            <a href="{{ path('app_account_properties') }}" class="px-4 py-2 text-sm font-semibold rounded-full border border-gray-200 hover:bg-gray-50 transition">
                Mes logements
            </a>
        </div>
    </div>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="mb-4 px-4 py-3 rounded-xl text-sm {{ label == 'success' ? 'bg-emerald-50 text-emerald-800' : label == 'error' ? 'bg-red-50 text-red-800' : 'bg-yellow-50 text-yellow-800' }}">{{ message }}</div>
        {% endfor %}
    {% endfor %}

    {% if reservations|length > 0 %}
        <div class="space-y-4">
            {% for reservation in reservations %}
                {% include 'components/reservation_row.html.twig' with { reservation: reservation } %}
            {% endfor %}
        </div>
    {% else %}
        <div class="text-center py-16 border border-dashed border-gray-200 rounded-xl">
            <i class="fa-solid fa-calendar text-4xl text-gray-300 mb-4"></i>
            <p class="text-gray-500">Aucune réservation pour le moment.</p>
        </div>
    {% endif %}
</main>
{% endblock %}
