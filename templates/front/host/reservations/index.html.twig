{% extends 'layout/app.html.twig' %}

{% block content %}
<main class="flex-grow px-6 md:px-12 py-8 max-w-4xl mx-auto w-full">

    <div class="mb-8">
        <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">Demandes en attente</h1>
        <p class="text-gray-500 mt-1">{{ reservations|length }} demande{{ reservations|length > 1 ? 's' : '' }} à traiter</p>
    </div>

    {% for message in app.flashes('success') %}
        <div class="mb-4 p-3 bg-green-50 border border-green-200 rounded-xl text-green-800 text-sm">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-xl text-red-800 text-sm">{{ message }}</div>
    {% endfor %}

    {% if reservations|length > 0 %}
        <div class="space-y-4">
        {% for reservation in reservations %}
            {% set property    = reservation.property %}
            {% set cover       = property ? property.coverMedia : null %}
            {% set guestProfile = reservation.guest ? reservation.guest.profile : null %}
            {% set nights = reservation.checkinDate | date('U') is same as(reservation.checkoutDate | date('U')) ? 1 : ((reservation.checkoutDate.timestamp - reservation.checkinDate.timestamp) / 86400)|round %}

            <div class="border border-gray-200 rounded-2xl overflow-hidden bg-white">
                <div class="flex flex-col sm:flex-row">
                    <div class="sm:w-48 h-40 sm:h-auto shrink-0">
                        <img src="{{ cover ? cover.fileUrl : 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=400&q=80' }}"
                             alt="{{ property ? property.title : '' }}" class="w-full h-full object-cover">
                    </div>
                    <div class="flex-grow p-5">
                        <div class="flex flex-wrap items-start justify-between gap-2 mb-3">
                            <div>
                                <h2 class="font-semibold text-gray-900">{{ property ? property.title : 'Logement supprimé' }}</h2>
                                {% if property and property.address %}
                                    <p class="text-sm text-gray-500">{{ property.address.city }}, {{ property.address.country }}</p>
                                {% endif %}
                            </div>
                            <span class="text-xs font-semibold px-2.5 py-1 rounded-full bg-yellow-100 text-yellow-800">En attente</span>
                        </div>
                        <dl class="grid grid-cols-2 sm:grid-cols-4 gap-3 text-sm mb-4">
                            <div>
                                <dt class="text-gray-500 text-xs">Arrivée</dt>
                                <dd class="font-semibold">{{ reservation.checkinDate|date('d/m/Y') }}</dd>
                            </div>
                            <div>
                                <dt class="text-gray-500 text-xs">Départ</dt>
                                <dd class="font-semibold">{{ reservation.checkoutDate|date('d/m/Y') }}</dd>
                            </div>
                            <div>
                                <dt class="text-gray-500 text-xs">Voyageurs</dt>
                                <dd class="font-semibold">{{ reservation.guestsCount }}</dd>
                            </div>
                            <div>
                                <dt class="text-gray-500 text-xs">Total</dt>
                                <dd class="font-semibold">{{ reservation.totalPrice|number_format(0, ',', ' ') }} {{ reservation.currency }}</dd>
                            </div>
                        </dl>
                        {% if guestProfile %}
                            <p class="text-sm text-gray-600 mb-4">
                                <i class="fa-solid fa-user text-gray-400 mr-1"></i>
                                {{ guestProfile.firstName }} {{ guestProfile.lastName }}
                                <span class="text-gray-400 ml-2">{{ reservation.guest.email }}</span>
                            </p>
                        {% endif %}

                        <div class="flex flex-wrap gap-3 items-end">
                            <form method="post" action="{{ path('app_host_reservation_accept', {id: reservation.id}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('moderation_' ~ reservation.id) }}">
                                <button type="submit" class="bg-brand text-white rounded-xl px-5 py-2 text-sm font-semibold hover:bg-brandHover transition">
                                    <i class="fa-solid fa-check mr-1"></i> Accepter
                                </button>
                            </form>

                            <form method="post" action="{{ path('app_host_reservation_reject', {id: reservation.id}) }}" class="flex gap-2 items-center flex-wrap">
                                <input type="hidden" name="_token" value="{{ csrf_token('moderation_' ~ reservation.id) }}">
                                <input type="text" name="reason" required placeholder="Motif du refus (obligatoire)"
                                       class="border border-gray-300 rounded-xl px-3 py-2 text-sm focus:outline-none focus:border-gray-900 w-64">
                                <button type="submit" class="border border-gray-300 text-gray-700 rounded-xl px-5 py-2 text-sm font-semibold hover:bg-gray-50 transition">
                                    <i class="fa-solid fa-xmark mr-1"></i> Refuser
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        {% endfor %}
        </div>
    {% else %}
        <div class="text-center py-16 border border-dashed border-gray-200 rounded-2xl">
            <i class="fa-solid fa-inbox text-4xl text-gray-300 mb-4"></i>
            <p class="text-gray-500">Aucune demande en attente.</p>
        </div>
    {% endif %}

</main>
{% endblock %}
