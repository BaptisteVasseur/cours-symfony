{% extends 'layout/app.html.twig' %}

{% block title %}Créer une annonce{% endblock %}

{% set inputClass = 'w-full border border-gray-300 rounded-xl px-4 py-2.5 text-sm' %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-3xl mx-auto w-full">
        <a href="{{ path('app_account_properties') }}" class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-gray-900 mb-6">
            <i class="fa-solid fa-arrow-left"></i> Mes propriétés
        </a>

        <h1 class="text-2xl md:text-3xl font-semibold text-gray-900 mb-2">Créer une annonce</h1>
        <p class="text-gray-500 mb-8">Votre annonce sera soumise à validation avant d'être publiée.</p>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 px-4 py-3 rounded-xl text-sm {{ label == 'success' ? 'bg-emerald-50 text-emerald-800' : 'bg-red-50 text-red-800' }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}

        {{ form_start(form, { attr: { class: 'space-y-6' } }) }}
            {% if not form.vars.valid %}
                <div class="px-4 py-3 rounded-xl text-sm bg-red-50 text-red-800">{{ form_errors(form) }}Veuillez corriger les champs ci-dessous.</div>
            {% endif %}
            <section class="bg-white border border-gray-200 rounded-2xl p-6 space-y-4">
                <h2 class="font-semibold text-gray-900">Logement</h2>
                {{ form_row(form.title, { attr: { class: inputClass } }) }}
                {{ form_row(form.description, { attr: { class: inputClass, rows: 4 } }) }}
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    {{ form_row(form.propertyType, { attr: { class: inputClass } }) }}
                    {{ form_row(form.cancellationPolicy, { attr: { class: inputClass } }) }}
                </div>
            </section>

            <section class="bg-white border border-gray-200 rounded-2xl p-6 space-y-4">
                <h2 class="font-semibold text-gray-900">Adresse</h2>
                {{ form_row(form.address.addressLine1, { attr: { class: inputClass } }) }}
                {{ form_row(form.address.addressLine2, { attr: { class: inputClass } }) }}
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                    {{ form_row(form.address.postalCode, { attr: { class: inputClass } }) }}
                    {{ form_row(form.address.city, { attr: { class: inputClass } }) }}
                    {{ form_row(form.address.country, { attr: { class: inputClass } }) }}
                </div>
            </section>

            <section class="bg-white border border-gray-200 rounded-2xl p-6 space-y-4">
                <h2 class="font-semibold text-gray-900">Capacité &amp; tarifs</h2>
                <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
                    {{ form_row(form.maxGuests, { attr: { class: inputClass, min: 1 } }) }}
                    {{ form_row(form.bedrooms, { attr: { class: inputClass, min: 0 } }) }}
                    {{ form_row(form.beds, { attr: { class: inputClass, min: 1 } }) }}
                    {{ form_row(form.bathrooms, { attr: { class: inputClass, min: 1 } }) }}
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                    {{ form_row(form.pricePerNight, { attr: { class: inputClass } }) }}
                    {{ form_row(form.cleaningFee, { attr: { class: inputClass } }) }}
                    {{ form_row(form.securityDeposit, { attr: { class: inputClass } }) }}
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    {{ form_row(form.checkinTime, { attr: { class: inputClass } }) }}
                    {{ form_row(form.checkoutTime, { attr: { class: inputClass } }) }}
                </div>
                <label class="flex items-center gap-3 text-sm">
                    {{ form_widget(form.instantBooking) }}
                    {{ form_label(form.instantBooking) }}
                </label>
            </section>

            <button type="submit" class="w-full bg-brand hover:bg-brandHover text-white font-semibold py-3 rounded-xl">
                Publier l'annonce
            </button>
        {{ form_end(form) }}
    </main>
{% endblock %}
