{% extends 'layout/app.html.twig' %}

{% block title %}Mes demandes de réservation{% endblock %}

{% set statusLabels = {
    'confirmed': 'Confirmée',
    'pending': 'En attente',
    'cancelled': 'Annulée',
    'completed': 'Terminée',
} %}
{% set statusColors = {
    'confirmed': 'bg-green-100 text-green-800',
    'pending': 'bg-yellow-100 text-yellow-800',
    'cancelled': 'bg-red-100 text-red-800',
    'completed': 'bg-blue-100 text-blue-800',
} %}

{% macro reservation_row(res, statusLabels, statusColors) %}
    {% set property = res.property %}
    {% set guest = res.guest %}
    {% set guestProfile = guest ? guest.profile : null %}
    <div class="border border-gray-200 rounded-xl p-5 bg-white">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3">
            <div>
                <p class="font-semibold text-gray-900">{{ property ? property.title : '—' }}</p>
                <p class="text-sm text-gray-500 mt-0.5">
                    {{ res.checkinDate|date('d/m/Y') }} → {{ res.checkoutDate|date('d/m/Y') }}
                    · {{ res.guestsCount }} voyageur{{ res.guestsCount > 1 ? 's' }}
                </p>
                <p class="text-sm text-gray-500">
                    Voyageur : {{ guestProfile ? guestProfile.firstName ~ ' ' ~ guestProfile.lastName : guest.email }}
                </p>
                <p class="font-semibold text-gray-900 mt-1">{{ res.totalPrice|number_format(2, ',', ' ') }} €</p>
            </div>
            <span class="text-xs font-semibold px-3 py-1 rounded-full self-start {{ statusColors[res.status]|default('bg-gray-100 text-gray-800') }}">
                {{ statusLabels[res.status]|default(res.status) }}
            </span>
        </div>
    </div>
{% endmacro %}

{% block content %}
<main class="flex-grow px-6 md:px-12 py-8 max-w-4xl mx-auto w-full">
    <h1 class="text-2xl md:text-3xl font-semibold text-gray-900 mb-8">Demandes de réservation</h1>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="mb-4 px-4 py-3 rounded-xl text-sm {{ label == 'success' ? 'bg-emerald-50 text-emerald-800' : 'bg-red-50 text-red-800' }}">{{ message }}</div>
        {% endfor %}
    {% endfor %}

    {# Demandes en attente #}
    <section class="mb-10">
        <h2 class="text-lg font-semibold text-gray-800 mb-4">
            En attente
            {% if pendingReservations|length > 0 %}
                <span class="ml-2 text-sm font-semibold bg-yellow-100 text-yellow-800 px-2 py-0.5 rounded-full">{{ pendingReservations|length }}</span>
            {% endif %}
        </h2>

        {% if pendingReservations|length > 0 %}
            <div class="space-y-4">
                {% for res in pendingReservations %}
                    {% set property = res.property %}
                    {% set guest = res.guest %}
                    {% set guestProfile = guest ? guest.profile : null %}
                    <div class="border border-yellow-200 rounded-xl p-5 bg-yellow-50">
                        <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4">
                            <div>
                                <p class="font-semibold text-gray-900">{{ property ? property.title : '—' }}</p>
                                <p class="text-sm text-gray-600 mt-0.5">
                                    {{ res.checkinDate|date('d/m/Y') }} → {{ res.checkoutDate|date('d/m/Y') }}
                                    · {{ res.guestsCount }} voyageur{{ res.guestsCount > 1 ? 's' }}
                                </p>
                                <p class="text-sm text-gray-600">
                                    Voyageur : <strong>{{ guestProfile ? guestProfile.firstName ~ ' ' ~ guestProfile.lastName : guest.email }}</strong>
                                </p>
                                <p class="font-bold text-gray-900 mt-1">{{ res.totalPrice|number_format(2, ',', ' ') }} €</p>
                            </div>
                            <div class="flex flex-col gap-2 min-w-[180px]">
                                <form method="POST" action="{{ path('app_host_reservation_accept', {id: res.id}) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('accept_' ~ res.id) }}">
                                    <button type="submit" class="w-full bg-green-600 hover:bg-green-700 text-white text-sm font-semibold py-2 px-4 rounded-xl">
                                        <i class="fa-solid fa-check mr-1"></i> Accepter
                                    </button>
                                </form>
                                <form method="POST" action="{{ path('app_host_reservation_refuse', {id: res.id}) }}" class="flex flex-col gap-2">
                                    <input type="hidden" name="_token" value="{{ csrf_token('refuse_' ~ res.id) }}">
                                    <input type="text" name="cancellationReason" placeholder="Motif du refus…" required
                                           class="w-full border border-gray-300 rounded-xl px-3 py-2 text-sm">
                                    <button type="submit" class="w-full bg-red-500 hover:bg-red-600 text-white text-sm font-semibold py-2 px-4 rounded-xl">
                                        <i class="fa-solid fa-xmark mr-1"></i> Refuser
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <p class="text-gray-400 text-sm">Aucune demande en attente.</p>
        {% endif %}
    </section>

    {# Réservations à venir #}
    <section>
        <h2 class="text-lg font-semibold text-gray-800 mb-4">À venir (confirmées)</h2>
        {% if upcomingReservations|length > 0 %}
            <div class="space-y-3">
                {% for res in upcomingReservations %}
                    {% set property = res.property %}
                    {% set guest = res.guest %}
                    {% set guestProfile = guest ? guest.profile : null %}
                    <div class="border border-gray-200 rounded-xl p-5 bg-white">
                        <p class="font-semibold text-gray-900">{{ property ? property.title : '—' }}</p>
                        <p class="text-sm text-gray-500 mt-0.5">
                            {{ res.checkinDate|date('d/m/Y') }} → {{ res.checkoutDate|date('d/m/Y') }}
                            · {{ res.guestsCount }} voyageur{{ res.guestsCount > 1 ? 's' }}
                            · <strong>{{ guestProfile ? guestProfile.firstName ~ ' ' ~ guestProfile.lastName : guest.email }}</strong>
                        </p>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <p class="text-gray-400 text-sm">Aucune réservation confirmée à venir.</p>
        {% endif %}
    </section>
</main>
{% endblock %}
