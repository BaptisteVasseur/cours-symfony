{% extends 'layout/app.html.twig' %}

{% block title %}Demandes de reservation{% endblock %}

{% set statusLabels = {
    'pending': 'En attente',
    'confirmed': 'Confirmee',
    'cancelled': 'Annulee',
    'completed': 'Terminee',
} %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-5xl mx-auto w-full">
        <div class="mb-8">
            <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">Demandes en attente</h1>
            <p class="text-gray-500 mt-1">Reservations a accepter ou refuser.</p>
        </div>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 px-4 py-3 rounded-xl text-sm {{ label == 'success' ? 'bg-emerald-50 text-emerald-800' : 'bg-red-50 text-red-800' }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}

        {% if rows|length > 0 %}
            <div class="space-y-4">
                {% for row in rows %}
                    {% set reservation = row.reservation %}
                    {% set property = reservation.property %}
                    {% set profile = reservation.guest ? reservation.guest.profile : null %}
                    <article class="border border-gray-200 rounded-xl bg-white p-5">
                        <div class="flex flex-col md:flex-row gap-5 md:items-start md:justify-between">
                            <div>
                                <div class="flex flex-wrap items-center gap-3 mb-2">
                                    <h2 class="font-semibold text-gray-900">{{ property ? property.title : 'Logement supprime' }}</h2>
                                    <span class="text-xs font-semibold px-2.5 py-1 rounded-full bg-yellow-100 text-yellow-800">{{ statusLabels[reservation.status]|default(reservation.status) }}</span>
                                </div>
                                <p class="text-sm text-gray-700">{{ reservation.checkinDate|date('d/m/Y') }} au {{ reservation.checkoutDate|date('d/m/Y') }} · {{ reservation.guestsCount }} voyageur{{ reservation.guestsCount > 1 ? 's' : '' }}</p>
                                <p class="text-sm text-gray-500 mt-1">Voyageur : {{ profile ? profile.firstName ~ ' ' ~ profile.lastName : reservation.guest.email }}</p>
                                <p class="text-sm font-semibold text-gray-900 mt-2">{{ reservation.totalPrice|number_format(2, ',', ' ') }} {{ reservation.currency|default('EUR') }}</p>
                            </div>

                            <div class="w-full md:w-80 space-y-3">
                                <form method="post" action="{{ path('app_host_reservation_accept', { id: reservation.id }) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('host_accept_' ~ reservation.id) }}">
                                    <button type="submit" class="w-full bg-brand hover:bg-brandHover text-white font-semibold py-3 rounded-xl">Accepter</button>
                                </form>

                                {{ form_start(row.declineForm, { attr: { class: 'space-y-3' } }) }}
                                    {{ form_widget(row.declineForm.reason, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm min-h-24', placeholder: 'Motif du refus' } }) }}
                                    <button type="submit" class="w-full border border-red-200 text-red-700 font-semibold py-3 rounded-xl hover:bg-red-50">Refuser</button>
                                {{ form_end(row.declineForm) }}
                            </div>
                        </div>
                    </article>
                {% endfor %}
            </div>
        {% else %}
            <div class="text-center py-16 border border-dashed border-gray-200 rounded-xl">
                <p class="text-gray-500">Aucune demande en attente.</p>
            </div>
        {% endif %}
    </main>
{% endblock %}
