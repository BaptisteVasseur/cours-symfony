{% extends 'layout/app.html.twig' %}

{% block title %}Demandes en attente{% endblock %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-4xl mx-auto w-full">
        <h1 class="text-2xl font-semibold text-gray-900 mb-2">Demandes en attente</h1>
        <p class="text-gray-500 mb-8">Réservations nécessitant votre validation</p>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 px-4 py-3 rounded-xl text-sm {{ label == 'success' ? 'bg-emerald-50 text-emerald-800' : 'bg-red-50 text-red-800' }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}

        {% if reservations|length == 0 %}
            <div class="text-center py-16 border border-dashed border-gray-200 rounded-xl">
                <i class="fa-regular fa-calendar-check text-4xl text-gray-300 mb-4"></i>
                <p class="text-gray-500">Aucune demande en attente.</p>
            </div>
        {% else %}
            <div class="space-y-4">
                {% for reservation in reservations %}
                    {% set guest = reservation.guest %}
                    {% set guestProfile = guest ? guest.profile : null %}
                    <div class="border border-gray-200 rounded-xl p-6">
                        <div class="flex flex-wrap items-start justify-between gap-4">
                            <div>
                                <p class="font-semibold text-gray-900">{{ reservation.property.title }}</p>
                                <p class="text-sm text-gray-500 mt-1">
                                    {{ reservation.checkinDate|date('d/m/Y') }} → {{ reservation.checkoutDate|date('d/m/Y') }}
                                    · {{ reservation.guestsCount }} voyageur{{ reservation.guestsCount > 1 ? 's' : '' }}
                                </p>
                                <p class="text-sm text-gray-500 mt-1">
                                    Voyageur : <span class="font-medium text-gray-700">
                                        {{ guestProfile and guestProfile.firstName ? guestProfile.firstName ~ ' ' ~ guestProfile.lastName : guest.email }}
                                    </span>
                                </p>
                                <p class="text-sm font-semibold text-gray-900 mt-2">{{ reservation.totalPrice|number_format(2, ',', ' ') }} €</p>
                                <p class="text-xs text-gray-400 mt-1">Demande reçue le {{ reservation.createdAt|date('d/m/Y à H:i') }}</p>
                            </div>
                            <div class="flex flex-col gap-2 min-w-[180px]">
                                {# Accepter #}
                                <form method="post" action="{{ path('app_host_reservation_accept', {id: reservation.id}) }}" data-turbo="false">
                                    <input type="hidden" name="_token" value="{{ csrf_token('host_reservation_' ~ reservation.id) }}">
                                    <button type="submit" class="w-full bg-brand hover:bg-brandHover text-white text-sm font-semibold py-2 px-4 rounded-lg transition">
                                        <i class="fa-solid fa-check mr-1"></i> Accepter
                                    </button>
                                </form>

                                {# Refuser #}
                                <details class="group">
                                    <summary class="w-full border border-gray-300 hover:bg-gray-50 text-sm font-semibold py-2 px-4 rounded-lg cursor-pointer list-none text-center text-gray-700">
                                        <i class="fa-solid fa-xmark mr-1"></i> Refuser
                                    </summary>
                                    <form method="post" action="{{ path('app_host_reservation_refuse', {id: reservation.id}) }}" class="mt-2 space-y-2" data-turbo="false">
                                        <input type="hidden" name="_token" value="{{ csrf_token('host_reservation_' ~ reservation.id) }}">
                                        <textarea name="reason" rows="2" required placeholder="Motif du refus (obligatoire)" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm resize-none"></textarea>
                                        <button type="submit" class="w-full bg-red-500 hover:bg-red-600 text-white text-sm font-semibold py-2 px-4 rounded-lg transition">
                                            Confirmer le refus
                                        </button>
                                    </form>
                                </details>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </main>
{% endblock %}