{% extends 'layout/app.html.twig' %}

{% block title %}Demandes de réservation{% endblock %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-4xl mx-auto w-full">
        <a href="{{ path('app_host_index') }}" class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-gray-800 mb-4">
            <i class="fa-solid fa-arrow-left"></i> Retour à l'espace hôte
        </a>

        <h1 class="text-2xl md:text-3xl font-semibold text-gray-900 mb-2">Demandes de réservation</h1>
        <p class="text-gray-500 mb-8">Confirmez ou refusez les réservations « sur demande » de vos logements.</p>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 px-4 py-3 rounded-xl text-sm font-medium {{ label == 'success' ? 'bg-emerald-50 text-emerald-800 border border-emerald-200' : 'bg-red-50 text-red-800 border border-red-200' }}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        {% set statusMeta = {
            'pending':   { label: 'En attente',  class: 'bg-amber-50 text-amber-700' },
            'confirmed': { label: 'Confirmée',   class: 'bg-emerald-50 text-emerald-700' },
            'cancelled': { label: 'Annulée',     class: 'bg-red-50 text-red-700' },
            'completed': { label: 'Terminée',    class: 'bg-gray-100 text-gray-600' }
        } %}

        {% if reservations|length > 0 %}
            <div class="space-y-4">
                {% for reservation in reservations %}
                    {% set guestProfile = reservation.guest.profile %}
                    {% set guestName = guestProfile and (guestProfile.firstName or guestProfile.lastName)
                        ? (guestProfile.firstName ~ ' ' ~ guestProfile.lastName)|trim
                        : reservation.guest.email %}
                    {% set meta = statusMeta[reservation.status] ?? { label: reservation.status, class: 'bg-gray-100 text-gray-600' } %}

                    <div class="bg-white border border-gray-200 rounded-2xl p-5 shadow-sm">
                        <div class="flex items-start justify-between gap-3">
                            <div>
                                <h3 class="font-semibold text-gray-900">{{ reservation.property.title }}</h3>
                                <p class="text-sm text-gray-500">
                                    {{ reservation.checkinDate|date('d/m/Y') }} → {{ reservation.checkoutDate|date('d/m/Y') }}
                                    · {{ reservation.guestsCount }} voyageur{{ reservation.guestsCount > 1 ? 's' : '' }}
                                </p>
                                <p class="text-sm text-gray-600 mt-1">
                                    <i class="fa-solid fa-user text-gray-400 mr-1"></i> {{ guestName }}
                                </p>
                            </div>
                            <div class="text-right shrink-0">
                                <span class="text-xs font-semibold px-2.5 py-1 rounded-full {{ meta.class }}">{{ meta.label }}</span>
                                <p class="text-lg font-bold text-gray-900 mt-2">{{ reservation.totalPrice|number_format(2, ',', ' ') }} {{ reservation.currency }}</p>
                            </div>
                        </div>

                        {% if reservation.status in ['pending', 'confirmed'] %}
                            <div class="flex flex-wrap items-center gap-3 mt-4 pt-4 border-t border-gray-100">
                                {% if reservation.status == 'pending' %}
                                    <form method="post" action="{{ path('app_host_reservation_confirm', { id: reservation.id }) }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('reservation_manage_' ~ reservation.id) }}">
                                        <button type="submit" class="inline-flex items-center gap-2 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-semibold px-4 py-2 rounded-xl transition">
                                            <i class="fa-solid fa-check"></i> Confirmer
                                        </button>
                                    </form>
                                {% endif %}
                                <form method="post" action="{{ path('app_host_reservation_cancel', { id: reservation.id }) }}" class="flex items-center gap-2">
                                    <input type="hidden" name="_token" value="{{ csrf_token('reservation_manage_' ~ reservation.id) }}">
                                    <input type="text" name="reason" required placeholder="Motif (obligatoire)" class="border border-gray-300 rounded-xl px-3 py-2 text-sm w-56 max-w-full">
                                    <button type="submit" class="inline-flex items-center gap-2 border border-red-300 text-red-600 hover:bg-red-50 text-sm font-semibold px-4 py-2 rounded-xl transition">
                                        <i class="fa-solid fa-xmark"></i> {{ reservation.status == 'pending' ? 'Refuser' : 'Annuler' }}
                                    </button>
                                </form>
                            </div>
                        {% elseif reservation.status == 'cancelled' and reservation.cancellationReason %}
                            <p class="text-sm text-gray-500 mt-3 pt-3 border-t border-gray-100">
                                <i class="fa-solid fa-circle-info text-gray-400 mr-1"></i> Motif : {{ reservation.cancellationReason }}
                            </p>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="text-center py-16 border border-dashed border-gray-200 rounded-xl">
                <i class="fa-solid fa-inbox text-4xl text-gray-300 mb-4"></i>
                <p class="text-gray-500">Aucune réservation sur vos logements pour le moment.</p>
            </div>
        {% endif %}
    </main>
{% endblock %}
