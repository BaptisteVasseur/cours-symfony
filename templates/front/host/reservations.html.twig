{% extends 'layout/app.html.twig' %}

{% block title %}Demandes reçues{% endblock %}

{% macro reservation_card(reservation) %}
    {% set property = reservation.property %}
    {% set cover = property ? property.coverMedia : null %}
    {% set guestProfile = reservation.guest ? reservation.guest.profile : null %}
    {% set placeholderImage = 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=400&q=80' %}
    <div class="flex flex-col sm:flex-row gap-4 p-4 border border-gray-200 rounded-xl bg-white">
        <div class="w-full sm:w-40 h-32 sm:h-28 shrink-0 rounded-lg overflow-hidden">
            <img src="{{ cover ? cover.fileUrl : placeholderImage }}" alt="{{ property ? property.title : 'Logement' }}" class="w-full h-full object-cover">
        </div>
        <div class="flex-grow min-w-0">
            <h3 class="font-semibold text-gray-900 truncate">{{ property ? property.title : 'Logement' }}</h3>
            <p class="text-sm text-gray-700 mt-1">
                {{ reservation.checkinDate|date('d/m/Y') }} → {{ reservation.checkoutDate|date('d/m/Y') }}
                · {{ reservation.guestsCount }} voyageur{{ reservation.guestsCount > 1 ? 's' : '' }}
            </p>
            {% if guestProfile %}
                <p class="text-xs text-gray-500 mt-1">Voyageur : {{ guestProfile.firstName }} {{ guestProfile.lastName }}</p>
            {% endif %}
            <p class="text-sm font-semibold text-gray-900 mt-1">{{ reservation.totalPrice|number_format(0, ',', ' ') }} {{ reservation.currency|default('EUR') }}</p>
        </div>
        <div class="shrink-0 w-full sm:w-64">
            {{ _self.actions(reservation) }}
        </div>
    </div>
{% endmacro %}

{% macro actions(reservation) %}
    {% if reservation.status == 'pending' %}
        <div class="flex gap-2">
            <form method="post" action="{{ path('app_host_reservation_accept', { id: reservation.id }) }}" class="flex-1">
                <input type="hidden" name="_token" value="{{ csrf_token('accept-' ~ reservation.id) }}">
                <button type="submit" class="w-full bg-brand hover:bg-brandHover text-white text-sm font-semibold py-2 rounded-lg transition">
                    <i class="fa-solid fa-check mr-1"></i> Accepter
                </button>
            </form>
            {{ _self.cancel_modal(
                path('app_host_reservation_refuse', { id: reservation.id }),
                csrf_token('refuse-' ~ reservation.id),
                'Refuser',
                'Refuser la demande',
                'Indiquez le motif du refus, il sera transmis au voyageur.',
                'Confirmer le refus'
            ) }}
        </div>
    {% else %}
        {{ _self.cancel_modal(
            path('app_reservation_cancel', { id: reservation.id }),
            csrf_token('cancel-' ~ reservation.id),
            'Annuler',
            'Annuler la réservation',
            'Cette action libère immédiatement les dates. Indiquez le motif.',
            'Confirmer l\'annulation'
        ) }}
    {% endif %}
{% endmacro %}

{% macro cancel_modal(action, token, triggerLabel, title, description, confirmLabel) %}
    <div data-controller="modal" class="flex-1">
        <button type="button" data-action="modal#open" class="w-full bg-gray-100 hover:bg-gray-200 text-gray-800 text-sm font-semibold py-2 rounded-lg transition">
            <i class="fa-solid fa-ban mr-1"></i> {{ triggerLabel }}
        </button>
        <div data-modal-target="dialog" class="hidden fixed inset-0 z-[80] bg-black/50 flex items-center justify-center p-4"
             data-action="click->modal#closeOnBackdrop keydown@window->modal#closeOnEsc">
            <div class="bg-white rounded-2xl shadow-xl w-full max-w-md p-6">
                <h3 class="text-lg font-semibold text-gray-900">{{ title }}</h3>
                <p class="text-sm text-gray-500 mt-1">{{ description }}</p>
                <form method="post" action="{{ action }}" class="mt-4 space-y-2">
                    <input type="hidden" name="_token" value="{{ token }}">
                    <textarea name="reason" rows="3" required minlength="10" placeholder="Motif (10 caractères minimum)" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm"></textarea>
                    <p class="text-xs text-gray-400">Au moins 10 caractères.</p>
                    <div class="flex gap-3 pt-2">
                        <button type="button" data-action="modal#close" class="flex-1 bg-gray-100 hover:bg-gray-200 text-gray-800 text-sm font-semibold py-2.5 rounded-lg transition">Retour</button>
                        <button type="submit" class="flex-1 bg-red-600 hover:bg-red-700 text-white text-sm font-semibold py-2.5 rounded-lg transition">{{ confirmLabel }}</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
{% endmacro %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-5xl mx-auto w-full">
        <div class="mb-8">
            <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">Demandes reçues</h1>
            <p class="text-gray-500 mt-1">Modérez les réservations de vos logements</p>
        </div>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 px-4 py-3 rounded-xl text-sm font-medium border
                    {{ label == 'error' ? 'bg-red-50 text-red-800 border-red-200' : 'bg-emerald-50 text-emerald-800 border-emerald-200' }}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        <section class="mb-12">
            <h2 class="text-lg font-semibold text-gray-900 mb-4">
                En attente
                <span class="ml-2 text-sm font-semibold px-2.5 py-0.5 rounded-full bg-yellow-100 text-yellow-800">{{ pending|length }}</span>
            </h2>
            {% if pending|length > 0 %}
                <div class="space-y-4">
                    {% for reservation in pending %}
                        {{ _self.reservation_card(reservation) }}
                    {% endfor %}
                </div>
            {% else %}
                <div class="text-center py-12 border border-dashed border-gray-200 rounded-xl">
                    <p class="text-gray-500">Aucune demande en attente.</p>
                </div>
            {% endif %}
        </section>

        <section>
            <h2 class="text-lg font-semibold text-gray-900 mb-4">Réservations confirmées</h2>
            {% if confirmed|length > 0 %}
                <div class="space-y-4">
                    {% for reservation in confirmed %}
                        {{ _self.reservation_card(reservation) }}
                    {% endfor %}
                </div>
            {% else %}
                <p class="text-gray-500 text-sm">Aucune réservation confirmée à venir.</p>
            {% endif %}
        </section>
    </main>
{% endblock %}
