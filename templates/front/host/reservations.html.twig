{% extends 'layout/app.html.twig' %}

{% set statusLabels = {
    'confirmed': 'Confirmée',
    'completed': 'Terminée',
    'pending': 'En attente',
    'cancelled': 'Annulée',
} %}
{% set statusColors = {
    'confirmed': 'bg-green-100 text-green-800',
    'completed': 'bg-blue-100 text-blue-800',
    'pending': 'bg-yellow-100 text-yellow-800',
    'cancelled': 'bg-red-100 text-red-800',
} %}

{% block title %}Réservations de mes logements{% endblock %}

{% block content %}
<main class="flex-grow px-6 md:px-12 py-8 max-w-5xl mx-auto w-full">
    <div class="mb-8">
        <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">Réservations de mes logements</h1>
        <p class="text-gray-500 mt-1">Gérez les demandes et confirmations pour vos propriétés.</p>
    </div>

    {% for label, messages in app.flashes %}
        {% for msg in messages %}
            <div class="mb-4 px-4 py-3 rounded-lg text-sm font-medium {{ label == 'success' ? 'bg-green-50 text-green-800 border border-green-200' : 'bg-red-50 text-red-800 border border-red-200' }}">
                {{ msg }}
            </div>
        {% endfor %}
    {% endfor %}

    <!-- Pending requests -->
    <section class="mb-10">
        <h2 class="text-lg font-semibold text-gray-900 mb-4 flex items-center gap-2">
            <span class="w-2.5 h-2.5 rounded-full bg-yellow-400 inline-block"></span>
            Demandes en attente
            {% if pendingReservations|length > 0 %}
                <span class="text-sm font-normal bg-yellow-100 text-yellow-800 px-2 py-0.5 rounded-full">{{ pendingReservations|length }}</span>
            {% endif %}
        </h2>

        {% if pendingReservations|length > 0 %}
            <div class="space-y-4">
                {% for reservation in pendingReservations %}
                    {% set property = reservation.property %}
                    {% set cover = property ? property.coverMedia : null %}
                    {% set guestProfile = reservation.guest ? reservation.guest.profile : null %}
                    <div class="border border-yellow-200 rounded-xl overflow-hidden bg-yellow-50/30">
                        <div class="flex flex-col sm:flex-row">
                            <div class="sm:w-36 h-32 sm:h-auto shrink-0">
                                <img src="{{ cover ? cover.fileUrl : 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=400&q=60' }}"
                                     alt="{{ property ? property.title : '' }}"
                                     class="w-full h-full object-cover">
                            </div>
                            <div class="flex-1 p-5 flex flex-col justify-between">
                                <div class="flex flex-wrap items-start justify-between gap-3">
                                    <div>
                                        <p class="font-semibold text-gray-900">{{ property ? property.title : '—' }}</p>
                                        <p class="text-sm text-gray-500 mt-0.5">
                                            Du <strong>{{ reservation.checkinDate|date('d/m/Y') }}</strong>
                                            au <strong>{{ reservation.checkoutDate|date('d/m/Y') }}</strong>
                                            · {{ reservation.guestsCount }} voyageur{{ reservation.guestsCount > 1 ? 's' : '' }}
                                        </p>
                                        <p class="text-sm text-gray-500">
                                            Voyageur :
                                            <strong>{{ guestProfile ? guestProfile.firstName ~ ' ' ~ guestProfile.lastName : reservation.guest.email }}</strong>
                                        </p>
                                    </div>
                                    <p class="text-lg font-bold text-gray-900">{{ reservation.totalPrice|number_format(2, ',', ' ') }} €</p>
                                </div>
                                <div class="mt-4 flex flex-wrap gap-3">
                                    <!-- Accept -->
                                    <form method="POST" action="{{ path('app_host_reservation_confirm', {id: reservation.id}) }}">
                                        <button type="submit"
                                                class="inline-flex items-center gap-2 bg-green-600 hover:bg-green-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition">
                                            <i class="fa-solid fa-check"></i> Accepter
                                        </button>
                                    </form>
                                    <!-- Reject (inline modal) -->
                                    <button type="button"
                                            onclick="document.getElementById('reject-modal-{{ reservation.id }}').classList.remove('hidden')"
                                            class="inline-flex items-center gap-2 border border-red-300 text-red-600 hover:bg-red-50 text-sm font-semibold px-4 py-2 rounded-lg transition">
                                        <i class="fa-solid fa-xmark"></i> Refuser
                                    </button>
                                    <a href="{{ path('app_reservation_show', {id: reservation.id}) }}"
                                       class="inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-gray-900">
                                        Détail <i class="fa-solid fa-arrow-right text-xs"></i>
                                    </a>
                                </div>
                            </div>
                        </div>

                        <!-- Reject modal (inline, hidden by default) -->
                        <div id="reject-modal-{{ reservation.id }}" class="hidden border-t border-yellow-200 bg-white px-5 py-4">
                            <form method="POST" action="{{ path('app_host_reservation_reject', {id: reservation.id}) }}" class="flex flex-col sm:flex-row gap-3">
                                <textarea name="reason" required minlength="5" maxlength="2000"
                                          placeholder="Motif du refus (obligatoire)…"
                                          class="flex-1 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-brand resize-none h-20"></textarea>
                                <div class="flex flex-col gap-2">
                                    <button type="submit"
                                            class="bg-red-600 hover:bg-red-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition">
                                        Confirmer le refus
                                    </button>
                                    <button type="button"
                                            onclick="document.getElementById('reject-modal-{{ reservation.id }}').classList.add('hidden')"
                                            class="text-sm text-gray-500 hover:text-gray-900 text-center">
                                        Annuler
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="text-center py-10 border border-dashed border-gray-200 rounded-xl text-gray-400 text-sm">
                Aucune demande en attente.
            </div>
        {% endif %}
    </section>

    <!-- All active reservations -->
    <section>
        <h2 class="text-lg font-semibold text-gray-900 mb-4 flex items-center gap-2">
            <span class="w-2.5 h-2.5 rounded-full bg-green-400 inline-block"></span>
            Toutes les réservations actives
        </h2>

        {% if activeReservations|length > 0 %}
            <div class="space-y-3">
                {% for reservation in activeReservations %}
                    {% set property = reservation.property %}
                    {% set guestProfile = reservation.guest ? reservation.guest.profile : null %}
                    <div class="border border-gray-200 rounded-xl p-4 flex flex-wrap items-center justify-between gap-4">
                        <div>
                            <p class="font-medium text-gray-900 text-sm">{{ property ? property.title : '—' }}</p>
                            <p class="text-xs text-gray-500">
                                {{ reservation.checkinDate|date('d/m/Y') }} → {{ reservation.checkoutDate|date('d/m/Y') }}
                                · {{ guestProfile ? guestProfile.firstName ~ ' ' ~ guestProfile.lastName : reservation.guest.email }}
                            </p>
                        </div>
                        <div class="flex items-center gap-3">
                            <span class="text-sm font-bold text-gray-900">{{ reservation.totalPrice|number_format(2, ',', ' ') }} €</span>
                            <span class="text-xs font-semibold px-2 py-1 rounded-full {{ statusColors[reservation.status]|default('bg-gray-100 text-gray-800') }}">
                                {{ statusLabels[reservation.status]|default(reservation.status) }}
                            </span>
                            <a href="{{ path('app_reservation_show', {id: reservation.id}) }}"
                               class="text-xs text-brand hover:underline font-semibold">Voir</a>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="text-center py-10 border border-dashed border-gray-200 rounded-xl text-gray-400 text-sm">
                Aucune réservation active.
            </div>
        {% endif %}
    </section>
</main>
{% endblock %}
