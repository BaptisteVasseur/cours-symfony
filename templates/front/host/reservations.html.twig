{% extends 'layout/app.html.twig' %}

{% set statusLabels = {
    'confirmed': 'Confirmée',
    'completed': 'Terminée',
    'pending': 'En attente',
    'cancelled': 'Annulée',
} %}
{% set statusColors = {
    'confirmed': 'bg-green-100 text-green-800',
    'completed': 'bg-blue-100 text-blue-800',
    'pending': 'bg-yellow-100 text-yellow-800',
    'cancelled': 'bg-red-100 text-red-800',
} %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-5xl mx-auto w-full">
        <div class="mb-8">
            <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">Demandes en attente</h1>
            <p class="text-gray-500 mt-1">Réservations à modérer pour vos logements</p>
        </div>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 px-4 py-3 rounded-xl text-sm {{ label == 'success' ? 'bg-emerald-50 text-emerald-800' : 'bg-red-50 text-red-800' }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}

        {% if reservations|length > 0 %}
            <div class="space-y-4">
                {% for reservation in reservations %}
                    {% set property = reservation.property %}
                    {% set guest = reservation.guest %}
                    {% set guestProfile = guest ? guest.profile : null %}
                    {% set cover = property ? property.coverMedia : null %}
                    {% set placeholderImage = 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=800&q=80' %}

                    <div class="border border-gray-200 rounded-xl overflow-hidden">
                        <div class="flex flex-col sm:flex-row">
                            <div class="sm:w-40 h-32 sm:h-auto shrink-0">
                                <img src="{{ cover ? cover.fileUrl : placeholderImage }}" alt="{{ property.title }}" class="w-full h-full object-cover">
                            </div>
                            <div class="flex-1 p-5">
                                <div class="flex flex-wrap items-start justify-between gap-3">
                                    <div>
                                        <h2 class="text-base font-semibold text-gray-900">{{ property.title }}</h2>
                                        <p class="text-sm text-gray-500 mt-1">
                                            {{ reservation.checkinDate|date('d/m/Y') }} → {{ reservation.checkoutDate|date('d/m/Y') }}
                                            · {{ reservation.guestsCount }} voyageur(s)
                                        </p>
                                        <p class="text-sm text-gray-500">
                                            Voyageur : <span class="font-medium text-gray-700">
                                                {{ guestProfile ? guestProfile.firstName ~ ' ' ~ guestProfile.lastName : guest.email }}
                                            </span>
                                        </p>
                                        <p class="text-sm font-semibold text-gray-900 mt-1">
                                            {{ reservation.totalPrice|number_format(2, ',', ' ') }} EUR
                                        </p>
                                    </div>
                                    <span class="text-xs font-semibold px-3 py-1 rounded-full {{ statusColors[reservation.status]|default('bg-gray-100 text-gray-800') }}">
                                        {{ statusLabels[reservation.status]|default(reservation.status) }}
                                    </span>
                                </div>

                                <div class="flex flex-wrap gap-3 mt-4">
                                    <form method="POST" action="{{ path('app_host_reservation_confirm', { id: reservation.id }) }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('confirm_' ~ reservation.id) }}">
                                        <button type="submit" class="bg-gray-900 hover:bg-gray-700 text-white font-semibold px-4 py-2 rounded-lg text-sm transition">
                                            Accepter
                                        </button>
                                    </form>

                                    <div x-data="{ open: false }">
                                        <button type="button" x-on:click="open = !open" class="border border-red-300 text-red-600 hover:bg-red-50 font-semibold px-4 py-2 rounded-lg text-sm transition">
                                            Refuser
                                        </button>
                                        <div x-show="open" x-cloak class="mt-3">
                                            <form method="POST" action="{{ path('app_host_reservation_refuse', { id: reservation.id }) }}" class="space-y-2">
                                                <input type="hidden" name="_token" value="{{ csrf_token('refuse_' ~ reservation.id) }}">
                                                <textarea name="reason" rows="2" placeholder="Motif du refus..." class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-gray-900"></textarea>
                                                <button type="submit" class="bg-red-600 hover:bg-red-700 text-white font-semibold px-4 py-2 rounded-lg text-sm transition">
                                                    Confirmer le refus
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="text-center py-16 border border-dashed border-gray-200 rounded-xl">
                <p class="text-gray-500">Aucune demande en attente.</p>
            </div>
        {% endif %}
    </main>
{% endblock %}