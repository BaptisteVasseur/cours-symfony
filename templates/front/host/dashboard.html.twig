{% extends 'layout/app.html.twig' %}

{% block title %}Espace hôte{% endblock %}

{% set statusLabels = { 'confirmed': 'Confirmée', 'completed': 'Terminée', 'pending': 'En attente', 'cancelled': 'Annulée' } %}
{% set statusColors = { 'confirmed': 'bg-green-100 text-green-800', 'completed': 'bg-blue-100 text-blue-800', 'pending': 'bg-yellow-100 text-yellow-800', 'cancelled': 'bg-red-100 text-red-800' } %}

{% block content %}
<main class="flex-grow px-6 md:px-12 py-8 max-w-5xl mx-auto w-full">
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="mb-4 px-4 py-3 rounded-xl text-sm {{ label == 'success' ? 'bg-emerald-50 text-emerald-800' : 'bg-red-50 text-red-800' }}">{{ message }}</div>
        {% endfor %}
    {% endfor %}

    <div class="mb-8">
        <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">Espace hôte</h1>
        <p class="text-gray-500 mt-1">Gérez vos demandes de réservation</p>
    </div>

    {% if pending|length > 0 %}
    <section class="mb-10">
        <h2 class="text-lg font-semibold text-gray-900 mb-4 flex items-center gap-2">
            <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-yellow-100 text-yellow-800 text-xs font-bold">{{ pending|length }}</span>
            Demandes en attente
        </h2>
        <div class="space-y-4">
            {% for reservation in pending %}
            <div class="border border-yellow-200 bg-yellow-50 rounded-xl p-5">
                <div class="flex flex-wrap items-start justify-between gap-4">
                    <div>
                        <p class="font-semibold text-gray-900">{{ reservation.property.title }}</p>
                        <p class="text-sm text-gray-600 mt-1">
                            {{ reservation.checkinDate|date('d/m/Y') }} → {{ reservation.checkoutDate|date('d/m/Y') }}
                            · {{ reservation.guestsCount }} voyageur{{ reservation.guestsCount > 1 ? 's' : '' }}
                        </p>
                        <p class="text-sm text-gray-500 mt-0.5">
                            Voyageur : {{ reservation.guest.email }}
                        </p>
                        <p class="text-sm font-semibold text-gray-900 mt-1">{{ reservation.totalPrice|number_format(2, ',', ' ') }} €</p>
                    </div>
                    <div class="flex flex-col gap-2 shrink-0">
                        <form action="{{ path('app_host_reservation_accept', { id: reservation.id }) }}" method="POST">
                            <input type="hidden" name="_token" value="{{ csrf_token('accept' ~ reservation.id) }}">
                            <button type="submit" class="w-full px-4 py-2 bg-green-600 hover:bg-green-700 text-white text-sm font-semibold rounded-lg transition">
                                Accepter
                            </button>
                        </form>
                        <details class="relative">
                            <summary class="px-4 py-2 bg-red-600 hover:bg-red-700 text-white text-sm font-semibold rounded-lg transition cursor-pointer list-none text-center">
                                Refuser
                            </summary>
                            <div class="absolute right-0 mt-2 w-72 bg-white border border-gray-200 rounded-xl shadow-lg p-4 z-10">
                                <form action="{{ path('app_host_reservation_refuse', { id: reservation.id }) }}" method="POST">
                                    <input type="hidden" name="_token" value="{{ csrf_token('refuse' ~ reservation.id) }}">
                                    <label class="block text-sm font-medium text-gray-700 mb-1">Motif de refus</label>
                                    <textarea name="reason" rows="3" required class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm" placeholder="Expliquez le motif…"></textarea>
                                    <button type="submit" class="mt-2 w-full px-4 py-2 bg-red-600 text-white text-sm font-semibold rounded-lg">
                                        Confirmer le refus
                                    </button>
                                </form>
                            </div>
                        </details>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    </section>
    {% else %}
    <div class="mb-10 border border-dashed border-gray-200 rounded-xl p-8 text-center text-gray-400 text-sm">
        Aucune demande en attente.
    </div>
    {% endif %}

    <section>
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Toutes les réservations de mes logements</h2>
        {% if all|length > 0 %}
        <div class="overflow-x-auto">
            <table class="w-full text-sm text-left border border-gray-200 rounded-xl overflow-hidden">
                <thead class="bg-gray-50 text-gray-600 text-xs uppercase">
                    <tr>
                        <th class="px-4 py-3">Logement</th>
                        <th class="px-4 py-3">Voyageur</th>
                        <th class="px-4 py-3">Dates</th>
                        <th class="px-4 py-3">Montant</th>
                        <th class="px-4 py-3">Statut</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    {% for r in all %}
                    <tr class="hover:bg-gray-50">
                        <td class="px-4 py-3 font-medium">{{ r.property.title }}</td>
                        <td class="px-4 py-3 text-gray-500">{{ r.guest.email }}</td>
                        <td class="px-4 py-3 text-gray-500">{{ r.checkinDate|date('d/m/Y') }} → {{ r.checkoutDate|date('d/m/Y') }}</td>
                        <td class="px-4 py-3">{{ r.totalPrice|number_format(2, ',', ' ') }} €</td>
                        <td class="px-4 py-3">
                            <span class="text-xs font-semibold px-2 py-1 rounded-full {{ statusColors[r.status]|default('bg-gray-100 text-gray-600') }}">
                                {{ statusLabels[r.status]|default(r.status) }}
                            </span>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% else %}
        <p class="text-gray-500 text-sm">Aucune réservation pour vos logements.</p>
        {% endif %}
    </section>
</main>
{% endblock %}
