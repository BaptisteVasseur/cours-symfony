{% extends 'layout/app.html.twig' %}

{% block title %}Espace hôte — Demandes de réservation{% endblock %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-5xl mx-auto w-full">
        <h1 class="text-2xl md:text-3xl font-semibold text-gray-900 mb-2">Demandes en attente</h1>
        <p class="text-gray-500 mb-8">Acceptez ou refusez les demandes de réservation de vos logements.</p>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 px-4 py-3 rounded-xl text-sm {{ label == 'success' ? 'bg-emerald-50 text-emerald-800' : 'bg-red-50 text-red-800' }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}

        {% if pendingReservations is empty %}
            <div class="border border-dashed border-gray-300 rounded-2xl p-10 text-center text-gray-500">
                Aucune demande en attente pour le moment.
            </div>
        {% else %}
            <div class="space-y-5">
                {% for reservation in pendingReservations %}
                    {% set property = reservation.property %}
                    {% set guestProfile = reservation.guest ? reservation.guest.profile : null %}
                    {% set guestName = guestProfile and (guestProfile.firstName or guestProfile.lastName)
                        ? (guestProfile.firstName ~ ' ' ~ guestProfile.lastName)|trim
                        : (reservation.guest ? reservation.guest.email : 'Voyageur') %}
                    <div class="border border-gray-200 rounded-2xl p-5 shadow-sm" data-reservation>
                        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
                            <div>
                                <h2 class="font-semibold text-gray-900">{{ property ? property.title : 'Logement' }}</h2>
                                <p class="text-sm text-gray-500 mt-1">
                                    {{ reservation.checkinDate|date('d/m/Y') }} → {{ reservation.checkoutDate|date('d/m/Y') }}
                                    · {{ reservation.guestsCount }} voyageur(s)
                                </p>
                                <p class="text-sm text-gray-500">Demande de {{ guestName }}</p>
                            </div>
                            <div class="text-right">
                                <p class="text-lg font-bold">{{ reservation.totalPrice|number_format(2, ',', ' ') }} {{ reservation.currency|default('EUR') }}</p>
                            </div>
                        </div>

                        <div class="flex flex-wrap items-center gap-3 mt-4">
                            <form method="post" action="{{ path('app_host_reservation_accept', { id: reservation.id }) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('accept' ~ reservation.id) }}">
                                <button type="submit" class="bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-semibold px-4 py-2 rounded-xl">
                                    Accepter
                                </button>
                            </form>
                            <button type="button" class="text-sm font-semibold px-4 py-2 rounded-xl border border-gray-300 hover:bg-gray-50" data-reject-toggle>
                                Refuser
                            </button>
                        </div>

                        <form method="post" action="{{ path('app_host_reservation_reject', { id: reservation.id }) }}" class="hidden mt-4" data-reject-form>
                            <input type="hidden" name="reject[_token]" value="{{ csrf_token('reject') }}">
                            <label class="block text-sm font-medium text-gray-700 mb-1">Motif du refus</label>
                            <textarea name="reject[reason]" rows="2" required class="w-full border border-gray-300 rounded-xl px-4 py-2 text-sm"></textarea>
                            <button type="submit" class="mt-2 bg-red-600 hover:bg-red-700 text-white text-sm font-semibold px-4 py-2 rounded-xl">
                                Confirmer le refus
                            </button>
                        </form>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </main>

    <script>
        document.querySelectorAll('[data-reservation]').forEach((card) => {
            const toggle = card.querySelector('[data-reject-toggle]');
            const form = card.querySelector('[data-reject-form]');
            toggle?.addEventListener('click', () => form?.classList.toggle('hidden'));
        });
    </script>
{% endblock %}
