{% extends 'layout/app.html.twig' %}

{% block title %}Réservations à modérer{% endblock %}

{% set statusLabels = {
    'confirmed': 'Confirmée',
    'completed': 'Terminée',
    'pending': 'En attente',
    'cancelled': 'Annulée / Refusée',
} %}
{% set statusColors = {
    'confirmed': 'bg-green-100 text-green-800',
    'completed': 'bg-blue-100 text-blue-800',
    'pending': 'bg-yellow-100 text-yellow-800',
    'cancelled': 'bg-red-100 text-red-800',
} %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-5xl mx-auto w-full">
        <div class="mb-8">
            <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">Réservations sur mes logements</h1>
            <p class="text-gray-500 mt-1">Acceptez ou refusez les demandes en attente.</p>
        </div>

        <section class="mb-10">
            <div class="flex items-center gap-3 mb-4">
                <h2 class="text-lg font-semibold text-gray-900">Demandes en attente</h2>
                <span class="text-xs font-semibold px-2 py-0.5 rounded-full bg-yellow-100 text-yellow-800">{{ pendingReservations|length }}</span>
            </div>
            {% if pendingReservations|length > 0 %}
                <div class="space-y-3">
                    {% for reservation in pendingReservations %}
                        {% set property = reservation.property %}
                        {% set guest = reservation.guest %}
                        {% set guestProfile = guest ? guest.profile : null %}
                        {% set guestName = guestProfile and (guestProfile.firstName or guestProfile.lastName)
                            ? (guestProfile.firstName ~ ' ' ~ guestProfile.lastName)|trim
                            : (guest ? guest.email : 'Voyageur supprimé') %}
                        <a href="{{ path('app_host_booking_moderate', { id: reservation.id }) }}"
                           class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 p-4 border border-gray-200 rounded-xl hover:shadow-md transition bg-white">
                            <div class="min-w-0">
                                <p class="font-semibold text-gray-900 truncate">{{ property ? property.title : 'Logement supprimé' }}</p>
                                <p class="text-sm text-gray-600 mt-1">
                                    {{ reservation.checkinDate|date('d/m/Y') }} → {{ reservation.checkoutDate|date('d/m/Y') }}
                                    · {{ reservation.guestsCount }} voyageur{{ reservation.guestsCount > 1 ? 's' : '' }}
                                </p>
                                <p class="text-xs text-gray-500 mt-1">Voyageur : {{ guestName }}</p>
                            </div>
                            <div class="text-right">
                                <p class="font-semibold text-gray-900">{{ reservation.totalPrice|number_format(0, ',', ' ') }} {{ reservation.currency|default('EUR') }}</p>
                                <span class="inline-block mt-1 text-xs font-semibold px-2.5 py-1 rounded-full bg-yellow-100 text-yellow-800">À traiter</span>
                            </div>
                        </a>
                    {% endfor %}
                </div>
            {% else %}
                <div class="text-center py-10 border border-dashed border-gray-200 rounded-xl">
                    <p class="text-gray-500">Aucune demande en attente.</p>
                </div>
            {% endif %}
        </section>

        <section>
            <h2 class="text-lg font-semibold text-gray-900 mb-4">Historique</h2>
            {% if otherReservations|length > 0 %}
                <div class="space-y-3">
                    {% for reservation in otherReservations %}
                        {% set property = reservation.property %}
                        <a href="{{ path('app_host_booking_moderate', { id: reservation.id }) }}"
                           class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 p-4 border border-gray-200 rounded-xl hover:shadow-sm transition bg-white">
                            <div class="min-w-0">
                                <p class="font-semibold text-gray-900 truncate">{{ property ? property.title : 'Logement supprimé' }}</p>
                                <p class="text-sm text-gray-600 mt-1">
                                    {{ reservation.checkinDate|date('d/m/Y') }} → {{ reservation.checkoutDate|date('d/m/Y') }}
                                </p>
                            </div>
                            <span class="text-xs font-semibold px-2.5 py-1 rounded-full {{ statusColors[reservation.status]|default('bg-gray-100 text-gray-800') }}">
                                {{ statusLabels[reservation.status]|default(reservation.status) }}
                            </span>
                        </a>
                    {% endfor %}
                </div>
            {% else %}
                <div class="text-center py-10 border border-dashed border-gray-200 rounded-xl">
                    <p class="text-gray-500">Aucune réservation à afficher.</p>
                </div>
            {% endif %}
        </section>
    </main>
{% endblock %}
