{% extends 'layout/app.html.twig' %}

{% set monthLabels = {
    1: 'Janvier', 2: 'Février', 3: 'Mars', 4: 'Avril', 5: 'Mai', 6: 'Juin',
    7: 'Juillet', 8: 'Août', 9: 'Septembre', 10: 'Octobre', 11: 'Novembre', 12: 'Décembre'
} %}

{% block title %}Calendrier — {{ property.title }}{% endblock %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-5xl mx-auto w-full">
        <a href="{{ path('app_account_properties') }}" class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-gray-900 mb-6">
            <i class="fa-solid fa-arrow-left"></i> Retour à mes propriétés
        </a>

        <div class="mb-8">
            <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">Calendrier</h1>
            <p class="text-gray-500">{{ property.title }}</p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <section class="lg:col-span-2 space-y-6">
                <div class="border border-gray-200 rounded-xl p-6">
                    <div class="flex items-center justify-between mb-6">
                        <a href="{{ path('app_host_calendar', { id: property.id, year: prevMonth.format('Y'), month: prevMonth.format('n') }) }}"
                           class="inline-flex items-center justify-center w-10 h-10 rounded-full border border-gray-200 hover:bg-gray-50">
                            <i class="fa-solid fa-chevron-left"></i>
                        </a>
                        <h2 class="text-lg font-semibold text-gray-900">{{ monthLabels[month] }} {{ year }}</h2>
                        <a href="{{ path('app_host_calendar', { id: property.id, year: nextMonth.format('Y'), month: nextMonth.format('n') }) }}"
                           class="inline-flex items-center justify-center w-10 h-10 rounded-full border border-gray-200 hover:bg-gray-50">
                            <i class="fa-solid fa-chevron-right"></i>
                        </a>
                    </div>

                    <div class="grid grid-cols-7 gap-1 text-center text-xs font-semibold text-gray-500 mb-2">
                        <div>Lun</div><div>Mar</div><div>Mer</div><div>Jeu</div><div>Ven</div><div>Sam</div><div>Dim</div>
                    </div>

                    <div class="grid grid-cols-7 gap-1">
                        {% for cell in cells %}
                            {% if cell.type == 'empty' %}
                                <div class="aspect-square"></div>
                            {% else %}
                                {% set base = 'aspect-square rounded-lg border flex flex-col items-center justify-center text-sm relative' %}
                                {% if cell.blocking %}
                                    {% set classes = base ~ ' bg-red-50 border-red-200 text-red-800' %}
                                    {% set tooltip = 'Bloqué : ' ~ (cell.blocking.reason ?: 'sans motif') %}
                                {% elseif cell.reservation %}
                                    {% if cell.reservation.status == 'confirmed' %}
                                        {% set classes = base ~ ' bg-blue-50 border-blue-200 text-blue-800' %}
                                        {% set tooltip = 'Réservé (confirmé)' %}
                                    {% else %}
                                        {% set classes = base ~ ' bg-yellow-50 border-yellow-200 text-yellow-800' %}
                                        {% set tooltip = 'Demande en attente' %}
                                    {% endif %}
                                {% elseif cell.isPast %}
                                    {% set classes = base ~ ' bg-gray-50 border-gray-100 text-gray-400' %}
                                    {% set tooltip = 'Date passée' %}
                                {% else %}
                                    {% set classes = base ~ ' bg-white border-gray-200 text-gray-800' %}
                                    {% set tooltip = 'Disponible' %}
                                {% endif %}
                                <div class="{{ classes }}{% if cell.isToday %} ring-2 ring-brand{% endif %}" title="{{ tooltip }}">
                                    <span class="font-semibold">{{ cell.day }}</span>
                                </div>
                            {% endif %}
                        {% endfor %}
                    </div>

                    <div class="mt-6 flex flex-wrap gap-4 text-xs text-gray-600">
                        <span class="inline-flex items-center gap-2"><span class="inline-block w-3 h-3 rounded bg-white border border-gray-300"></span> Disponible</span>
                        <span class="inline-flex items-center gap-2"><span class="inline-block w-3 h-3 rounded bg-blue-100 border border-blue-300"></span> Réservé</span>
                        <span class="inline-flex items-center gap-2"><span class="inline-block w-3 h-3 rounded bg-yellow-100 border border-yellow-300"></span> En attente</span>
                        <span class="inline-flex items-center gap-2"><span class="inline-block w-3 h-3 rounded bg-red-100 border border-red-300"></span> Bloqué</span>
                        <span class="inline-flex items-center gap-2"><span class="inline-block w-3 h-3 rounded bg-gray-100 border border-gray-200"></span> Passé</span>
                    </div>
                </div>

                <div class="border border-gray-200 rounded-xl p-6">
                    <h2 class="text-lg font-semibold mb-4">Périodes bloquées à venir</h2>
                    {% if upcomingUnavailabilities|length == 0 %}
                        <p class="text-sm text-gray-500">Aucune période bloquée pour le moment.</p>
                    {% else %}
                        <ul class="divide-y divide-gray-100">
                            {% for u in upcomingUnavailabilities %}
                                <li class="py-3 flex items-start justify-between gap-4">
                                    <div>
                                        <p class="font-semibold text-gray-900">
                                            Du {{ u.startDate|date('d/m/Y') }} au {{ u.endDate|date('d/m/Y') }}
                                        </p>
                                        {% if u.reason %}
                                            <p class="text-sm text-gray-500">{{ u.reason }}</p>
                                        {% endif %}
                                        <p class="text-xs text-gray-400 mt-1">
                                            Source : {{ u.source == 'ical_import' ? 'Import iCal' : 'Manuelle' }}
                                        </p>
                                    </div>
                                    {% if u.source == 'manual' %}
                                        <form method="post" action="{{ path('app_host_calendar_unblock', { id: property.id, unavId: u.id }) }}"
                                              onsubmit="return confirm('Supprimer ce blocage ?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('unavailability_unblock_' ~ u.id) }}">
                                            <button type="submit" class="text-sm font-semibold text-red-600 hover:text-red-700">
                                                <i class="fa-solid fa-xmark"></i> Supprimer
                                            </button>
                                        </form>
                                    {% endif %}
                                </li>
                            {% endfor %}
                        </ul>
                    {% endif %}
                </div>
            </section>

            <aside>
                <div class="border border-gray-200 rounded-xl p-6 sticky top-28">
                    <h2 class="text-lg font-semibold mb-4">Bloquer une période</h2>
                    <p class="text-sm text-gray-600 mb-4">
                        Marquez des dates comme indisponibles. Aucune réservation ne pourra être créée sur cette plage.
                    </p>
                    {{ form_start(form, { attr: { class: 'space-y-4' } }) }}
                        {{ form_row(form.startDate) }}
                        {{ form_row(form.endDate) }}
                        {{ form_row(form.reason) }}
                        <button type="submit" class="w-full inline-flex items-center justify-center gap-2 bg-brand hover:bg-brandHover text-white font-semibold rounded-xl py-3 transition">
                            <i class="fa-solid fa-ban"></i> Bloquer ces dates
                        </button>
                    {{ form_end(form) }}
                </div>

                <div class="border border-gray-200 rounded-xl p-6 sticky top-28 mt-6">
                    <h2 class="text-lg font-semibold mb-2">Export iCal</h2>
                    <p class="text-sm text-gray-600 mb-4">
                        Synchronisez ce calendrier avec Google Agenda, Airbnb ou tout autre outil compatible iCal.
                    </p>
                    {% if property.icalToken %}
                        {% set icalUrl = url('app_ical_export', { id: property.id }) ~ '?token=' ~ property.icalToken %}
                        <div class="bg-gray-50 border border-gray-200 rounded-lg p-3 mb-3 break-all text-xs text-gray-700">{{ icalUrl }}</div>
                        <div class="flex flex-wrap gap-2">
                            <a href="{{ icalUrl }}" class="inline-flex items-center gap-2 text-sm font-semibold border border-gray-200 rounded-lg px-4 py-2 hover:bg-gray-50">
                                <i class="fa-solid fa-download"></i> Télécharger
                            </a>
                            <form method="post" action="{{ path('app_host_calendar_ical_revoke', { id: property.id }) }}"
                                  onsubmit="return confirm('Révoquer cette URL ? Les agendas synchronisés cesseront de fonctionner.');">
                                <input type="hidden" name="_token" value="{{ csrf_token('ical_token_' ~ property.id) }}">
                                <button type="submit" class="inline-flex items-center gap-2 text-sm font-semibold text-red-600 hover:text-red-700 border border-red-200 rounded-lg px-4 py-2">
                                    <i class="fa-solid fa-rotate"></i> Révoquer / régénérer
                                </button>
                            </form>
                        </div>
                    {% else %}
                        <form method="post" action="{{ path('app_host_calendar_ical_generate', { id: property.id }) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('ical_token_' ~ property.id) }}">
                            <button type="submit" class="w-full inline-flex items-center justify-center gap-2 border border-gray-200 rounded-xl py-3 text-sm font-semibold hover:bg-gray-50">
                                <i class="fa-solid fa-link"></i> Générer l'URL iCal
                            </button>
                        </form>
                    {% endif %}
                </div>
            </aside>
        </div>
    </main>
{% endblock %}
