{% extends 'layout/app.html.twig' %}

{% block content %}
<main class="flex-grow px-6 md:px-12 py-8 max-w-3xl mx-auto w-full">
    <a href="{{ path('app_host_reservation_index') }}" class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-gray-900 mb-6">
        <i class="fa-solid fa-arrow-left"></i> Retour aux réservations
    </a>
    <h1 class="text-2xl font-semibold text-gray-900 mb-1">Calendrier — {{ property.title }}</h1>
    <p class="text-sm text-gray-500 mb-6">Cliquez sur un jour pour le bloquer ou le débloquer.</p>

    {% for message in app.flashes('success') %}
        <div class="mb-4 p-4 bg-green-50 border border-green-200 text-green-800 rounded-xl">{{ message }}</div>
    {% endfor %}

    {# Navigation mois #}
    <div class="flex items-center justify-between mb-4">
        <a href="{{ path('app_host_calendar', {id: property.id, year: prevMonth.format('Y'), month: prevMonth.format('n')}) }}"
           class="p-2 rounded-lg hover:bg-gray-100 text-gray-600">
            <i class="fa-solid fa-chevron-left"></i>
        </a>
        <h2 class="text-lg font-semibold text-gray-900">
            {{ firstDay|date('MMMM Y', locale='fr') }}
        </h2>
        <a href="{{ path('app_host_calendar', {id: property.id, year: nextMonth.format('Y'), month: nextMonth.format('n')}) }}"
           class="p-2 rounded-lg hover:bg-gray-100 text-gray-600">
            <i class="fa-solid fa-chevron-right"></i>
        </a>
    </div>

    {# Grille calendrier #}
    <div class="border border-gray-200 rounded-xl overflow-hidden">
        <div class="grid grid-cols-7 bg-gray-50 border-b border-gray-200">
            {% for day in ['Lun', 'Mar', 'Mer', 'Jeu', 'Ven', 'Sam', 'Dim'] %}
                <div class="py-2 text-center text-xs font-semibold text-gray-500">{{ day }}</div>
            {% endfor %}
        </div>

        {# Calcul du décalage : lundi = 0, ISO weekday de lundi = 1 #}
        {% set startOffset = (firstDay.format('N') | number_format - 1) %}
        {% set daysInMonth = lastDay.format('j') | number_format %}
        {% set totalCells = startOffset + daysInMonth %}
        {% set rows = (totalCells / 7) | round(0, 'ceil') %}

        <div class="grid grid-cols-7" id="calendar-grid" data-csrf="{{ csrf_token('calendar_toggle') }}" data-url="{{ path('app_host_calendar_toggle', {id: property.id}) }}">
            {% for cell in 0..(rows * 7 - 1) %}
                {% set dayNum = cell - startOffset + 1 %}
                {% if dayNum < 1 or dayNum > daysInMonth %}
                    <div class="h-12 bg-gray-50 border-b border-r border-gray-100"></div>
                {% else %}
                    {% set dateStr = year ~ '-' ~ month|format_number({minimumIntegerDigits: 2}) ~ '-' ~ dayNum|format_number({minimumIntegerDigits: 2}) %}
                    {% set isBlocked = dateStr in blockedDates %}
                    {% set today = 'now'|date('Y-m-d') %}
                    {% set isPast = dateStr < today %}
                    <button
                        type="button"
                        data-date="{{ dateStr }}"
                        class="h-12 flex items-center justify-center text-sm font-medium border-b border-r border-gray-100 transition-colors
                            {% if isPast %}text-gray-300 cursor-not-allowed bg-white
                            {% elseif isBlocked %}bg-red-100 text-red-700 hover:bg-red-200
                            {% else %}bg-white text-gray-800 hover:bg-gray-50{% endif %}"
                        {% if isPast %}disabled{% endif %}
                    >
                        {{ dayNum }}
                        {% if isBlocked and not isPast %}<span class="ml-1 text-xs">✕</span>{% endif %}
                    </button>
                {% endif %}
            {% endfor %}
        </div>
    </div>

    <div class="mt-4 flex gap-4 text-sm text-gray-500">
        <span class="flex items-center gap-1"><span class="w-4 h-4 bg-red-100 rounded border border-red-200 inline-block"></span> Bloqué</span>
        <span class="flex items-center gap-1"><span class="w-4 h-4 bg-white rounded border border-gray-200 inline-block"></span> Disponible</span>
    </div>
</main>

<script>
document.addEventListener('DOMContentLoaded', function () {
    const grid = document.getElementById('calendar-grid');
    if (!grid) return;

    grid.addEventListener('click', function (e) {
        const btn = e.target.closest('button[data-date]');
        if (!btn || btn.disabled) return;

        const date = btn.dataset.date;
        const csrf = grid.dataset.csrf;
        const url = grid.dataset.url;

        const body = new URLSearchParams({ date, _token: csrf });

        fetch(url, { method: 'POST', body, headers: { 'X-Requested-With': 'XMLHttpRequest' } })
            .then(r => r.json())
            .then(data => {
                if (data.blocked) {
                    btn.classList.add('bg-red-100', 'text-red-700', 'hover:bg-red-200');
                    btn.classList.remove('bg-white', 'text-gray-800', 'hover:bg-gray-50');
                    if (!btn.querySelector('span')) {
                        btn.insertAdjacentHTML('beforeend', '<span class="ml-1 text-xs">✕</span>');
                    }
                } else {
                    btn.classList.remove('bg-red-100', 'text-red-700', 'hover:bg-red-200');
                    btn.classList.add('bg-white', 'text-gray-800', 'hover:bg-gray-50');
                    const mark = btn.querySelector('span');
                    if (mark) mark.remove();
                }
            });
    });
});
</script>
{% endblock %}
