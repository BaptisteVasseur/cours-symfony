{% extends 'layout/app.html.twig' %}

{% block title %}Demandes reçues — Espace hôte{% endblock %}

{% set statusLabels = {
    'confirmed': 'Confirmée',
    'completed': 'Terminée',
    'pending': 'En attente',
    'cancelled': 'Annulée',
} %}
{% set statusColors = {
    'confirmed': 'bg-green-100 text-green-800',
    'completed': 'bg-blue-100 text-blue-800',
    'pending': 'bg-yellow-100 text-yellow-800',
    'cancelled': 'bg-red-100 text-red-800',
} %}

{% macro reservation_card(reservation, statusLabels, statusColors) %}
    {% set property = reservation.property %}
    {% set cover = property ? property.coverMedia : null %}
    {% set guest = reservation.guest %}
    {% set guestProfile = guest ? guest.profile : null %}
    {% set placeholder = 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=400&q=80' %}

    <a href="{{ path('app_host_reservation_show', { id: reservation.id }) }}"
       class="flex flex-col sm:flex-row gap-4 p-4 border border-gray-200 rounded-xl hover:shadow-md transition bg-white group">

        <div class="w-full sm:w-36 h-28 shrink-0 rounded-lg overflow-hidden">
            <img src="{{ cover ? cover.fileUrl : placeholder }}"
                 alt="{{ property ? property.title : 'Logement' }}"
                 class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300">
        </div>

        <div class="flex-grow min-w-0">
            <div class="flex flex-wrap items-start justify-between gap-2 mb-1">
                <h3 class="font-semibold text-gray-900 truncate">{{ property ? property.title : 'Logement supprimé' }}</h3>
                <span class="text-xs font-semibold px-2.5 py-1 rounded-full {{ statusColors[reservation.status]|default('bg-gray-100 text-gray-800') }}">
                    {{ statusLabels[reservation.status]|default(reservation.status) }}
                </span>
            </div>

            {% if property and property.address %}
                <p class="text-xs text-gray-400 mb-2">{{ property.address.city }}, {{ property.address.country }}</p>
            {% endif %}

            <div class="flex flex-wrap gap-x-4 gap-y-1 text-sm text-gray-600">
                <span><i class="fa-regular fa-calendar-check mr-1 text-gray-400"></i>{{ reservation.checkinDate|date('d/m/Y') }}</span>
                <span class="text-gray-300">→</span>
                <span><i class="fa-regular fa-calendar-xmark mr-1 text-gray-400"></i>{{ reservation.checkoutDate|date('d/m/Y') }}</span>
                <span><i class="fa-solid fa-user-group mr-1 text-gray-400"></i>{{ reservation.guestsCount }} voyageur{{ reservation.guestsCount > 1 ? 's' : '' }}</span>
            </div>

            <div class="flex items-center gap-2 mt-2">
                <div class="w-6 h-6 rounded-full bg-gray-200 flex items-center justify-center text-xs font-bold text-gray-600 shrink-0">
                    {{ guestProfile and guestProfile.firstName ? guestProfile.firstName|first|upper : (guest ? guest.email|first|upper : '?') }}
                </div>
                <span class="text-xs text-gray-500">
                    {% if guestProfile and (guestProfile.firstName or guestProfile.lastName) %}
                        {{ guestProfile.firstName }} {{ guestProfile.lastName }}
                    {% else %}
                        {{ guest ? guest.email : 'Voyageur inconnu' }}
                    {% endif %}
                </span>
            </div>
        </div>

        <div class="sm:text-right shrink-0 flex flex-col justify-between">
            <p class="font-bold text-gray-900">{{ reservation.totalPrice|number_format(0, ',', ' ') }} {{ reservation.currency|default('EUR') }}</p>
            <p class="text-xs text-gray-400 mt-1">{{ reservation.createdAt|date('d/m/Y') }}</p>
            <span class="mt-2 text-xs text-brand font-semibold group-hover:underline">Voir le détail →</span>
        </div>
    </a>
{% endmacro %}

{% block content %}
<main class="flex-grow px-6 md:px-12 py-8 max-w-5xl mx-auto w-full">

    {# ── En-tête ── #}
    <div class="mb-8 flex flex-wrap items-center justify-between gap-4">
        <div>
            <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">Demandes reçues</h1>
            <p class="text-gray-500 mt-1">Gérez les réservations sur vos logements</p>
        </div>
        {% set totalPending = pending|length %}
        {% if totalPending > 0 %}
            <span class="inline-flex items-center gap-2 bg-yellow-50 border border-yellow-200 text-yellow-800 text-sm font-semibold px-4 py-2 rounded-full">
                <i class="fa-solid fa-clock"></i>
                {{ totalPending }} demande{{ totalPending > 1 ? 's' : '' }} en attente
            </span>
        {% endif %}
    </div>

    {# ── Section : En attente ── #}
    {% if pending|length > 0 %}
        <section class="mb-10">
            <h2 class="text-base font-semibold text-gray-700 mb-3 flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-yellow-400 inline-block"></span>
                En attente de confirmation
                <span class="text-xs font-normal text-gray-400 ml-1">({{ pending|length }})</span>
            </h2>
            <div class="space-y-3">
                {% for reservation in pending %}
                    {{ _self.reservation_card(reservation, statusLabels, statusColors) }}
                {% endfor %}
            </div>
        </section>
    {% endif %}

    {# ── Section : Confirmées ── #}
    {% if confirmed|length > 0 %}
        <section class="mb-10">
            <h2 class="text-base font-semibold text-gray-700 mb-3 flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-green-400 inline-block"></span>
                Confirmées
                <span class="text-xs font-normal text-gray-400 ml-1">({{ confirmed|length }})</span>
            </h2>
            <div class="space-y-3">
                {% for reservation in confirmed %}
                    {{ _self.reservation_card(reservation, statusLabels, statusColors) }}
                {% endfor %}
            </div>
        </section>
    {% endif %}

    {# ── Section : Historique ── #}
    {% if others|length > 0 %}
        <section class="mb-10">
            <h2 class="text-base font-semibold text-gray-700 mb-3 flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-gray-300 inline-block"></span>
                Historique
                <span class="text-xs font-normal text-gray-400 ml-1">({{ others|length }})</span>
            </h2>
            <div class="space-y-3">
                {% for reservation in others %}
                    {{ _self.reservation_card(reservation, statusLabels, statusColors) }}
                {% endfor %}
            </div>
        </section>
    {% endif %}

    {# ── État vide ── #}
    {% if pending|length == 0 and confirmed|length == 0 and others|length == 0 %}
        <div class="text-center py-20 border border-dashed border-gray-200 rounded-2xl">
            <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <i class="fa-solid fa-house text-2xl text-gray-400"></i>
            </div>
            <p class="text-gray-500 font-medium">Aucune réservation reçue pour le moment.</p>
            <p class="text-sm text-gray-400 mt-1">Vos demandes apparaîtront ici dès qu'un voyageur réservera l'un de vos logements.</p>
            <a href="{{ path('app_account_properties') }}" class="inline-block mt-5 text-brand font-semibold hover:underline text-sm">
                Gérer mes logements
            </a>
        </div>
    {% endif %}

</main>
{% endblock %}
