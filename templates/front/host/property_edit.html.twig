{% extends 'layout/app.html.twig' %}

{% block title %}Gérer l'annonce — {{ property.title }}{% endblock %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-2xl mx-auto w-full">
        <a href="{{ path('app_account_properties') }}" class="text-sm text-gray-500 hover:text-gray-900">
            <i class="fa-solid fa-arrow-left mr-1"></i> Mes propriétés
        </a>

        <div class="flex flex-wrap items-center justify-between gap-3 mt-3 mb-8">
            <div>
                <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">Gérer l'annonce</h1>
                <p class="text-gray-500">{{ property.title }}</p>
            </div>
            <a href="{{ path('app_host_calendar', { id: property.id }) }}"
               class="inline-flex items-center gap-2 text-sm font-medium text-gray-700 hover:text-brand">
                <i class="fa-regular fa-calendar"></i> Calendrier
            </a>
        </div>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 px-4 py-3 rounded-xl text-sm font-medium border
                    {{ label == 'error' ? 'bg-red-50 text-red-800 border-red-200' : 'bg-emerald-50 text-emerald-800 border-emerald-200' }}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        <div class="bg-white border border-gray-200 rounded-2xl p-6 shadow-sm">
            {{ form_start(form, { attr: { class: 'space-y-5' } }) }}
                {{ form_row(form.title, { row_attr: { class: 'space-y-2' }, label_attr: { class: 'block text-sm font-semibold text-gray-900' }, attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm' } }) }}
                {{ form_row(form.pricePerNight, { row_attr: { class: 'space-y-2' }, label_attr: { class: 'block text-sm font-semibold text-gray-900' }, attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm' } }) }}

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    {{ form_row(form.checkoutTime, { row_attr: { class: 'space-y-2' }, label_attr: { class: 'block text-sm font-semibold text-gray-900' }, attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm' } }) }}
                    {{ form_row(form.checkinTime, { row_attr: { class: 'space-y-2' }, label_attr: { class: 'block text-sm font-semibold text-gray-900' }, attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm' } }) }}
                </div>

                <div class="rounded-xl border border-gray-200 p-4">
                    <label class="flex items-start gap-3 cursor-pointer">
                        {{ form_widget(form.instantBooking, { attr: { class: 'mt-1 h-4 w-4 rounded border-gray-300 text-brand' } }) }}
                        <span>
                            <span class="block text-sm font-semibold text-gray-900">Réservation instantanée</span>
                            <span class="block text-xs text-gray-500">Les réservations sont confirmées automatiquement, sans validation de votre part.</span>
                        </span>
                    </label>
                    {{ form_errors(form.instantBooking) }}
                </div>

                <div class="rounded-xl border border-gray-200 p-4">
                    <label class="flex items-start gap-3 cursor-pointer">
                        {{ form_widget(form.allowSameDayBooking, { attr: { class: 'mt-1 h-4 w-4 rounded border-gray-300 text-brand' } }) }}
                        <span>
                            <span class="block text-sm font-semibold text-gray-900">Autoriser une arrivée le jour d'un départ</span>
                            <span class="block text-xs text-gray-500">Nécessite au moins 3 heures d'écart entre l'heure de départ et l'heure d'arrivée.</span>
                        </span>
                    </label>
                    {{ form_errors(form.allowSameDayBooking) }}
                </div>

                {{ form_row(form.minimumStay, { row_attr: { class: 'space-y-2' }, label_attr: { class: 'block text-sm font-semibold text-gray-900' }, help_attr: { class: 'text-xs text-gray-500' }, attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm' } }) }}

                <button type="submit" class="bg-brand hover:bg-brandHover text-white font-semibold px-6 py-3 rounded-xl transition">Enregistrer</button>
            {{ form_end(form) }}
        </div>

        <div class="bg-white border border-gray-200 rounded-2xl p-6 shadow-sm mt-6">
            <h2 class="text-lg font-semibold text-gray-900">Synchronisation du calendrier (iCal)</h2>
            <p class="text-sm text-gray-500 mt-1">Importez les séjours confirmés dans Google Calendar, Outlook, etc. Ce lien est secret : ne le partagez pas.</p>

            {% if property.icalToken %}
                <label class="block text-sm font-semibold text-gray-900 mt-4 mb-1">Lien d'abonnement</label>
                <input type="text" readonly onclick="this.select()"
                       value="{{ url('app_property_ical', { id: property.id, token: property.icalToken }) }}"
                       class="w-full border border-gray-300 rounded-xl px-4 py-3 text-xs bg-gray-50 font-mono">
                <div class="flex flex-wrap gap-4 mt-3">
                    <form method="post" action="{{ path('app_host_ical_generate', { id: property.id }) }}"
                          onsubmit="return confirm('Régénérer le lien ? L\'ancien cessera immédiatement de fonctionner.');">
                        <input type="hidden" name="_token" value="{{ csrf_token('ical-' ~ property.id) }}">
                        <button type="submit" class="text-sm font-semibold text-gray-700 hover:text-brand"><i class="fa-solid fa-rotate mr-1"></i>Régénérer</button>
                    </form>
                    <form method="post" action="{{ path('app_host_ical_revoke', { id: property.id }) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('ical-' ~ property.id) }}">
                        <button type="submit" class="text-sm font-semibold text-red-600 hover:text-red-700"><i class="fa-solid fa-ban mr-1"></i>Désactiver</button>
                    </form>
                </div>
            {% else %}
                <form method="post" action="{{ path('app_host_ical_generate', { id: property.id }) }}" class="mt-4">
                    <input type="hidden" name="_token" value="{{ csrf_token('ical-' ~ property.id) }}">
                    <button type="submit" class="bg-gray-900 hover:bg-black text-white font-semibold px-5 py-2.5 rounded-xl transition text-sm">
                        <i class="fa-solid fa-link mr-1"></i> Générer le lien de synchronisation
                    </button>
                </form>
            {% endif %}
        </div>

        <div class="bg-white border border-gray-200 rounded-2xl p-6 shadow-sm mt-6">
            <h2 class="text-lg font-semibold text-gray-900">Importer un calendrier externe</h2>
            <p class="text-sm text-gray-500 mt-1">Collez l'URL iCal d'un autre calendrier (Airbnb, Booking…) : les nuitées y figurant seront bloquées automatiquement à chaque synchronisation.</p>

            {% if property.iCalSyncs|length > 0 %}
                <ul class="mt-4 space-y-3">
                    {% for sync in property.iCalSyncs %}
                        <li class="flex items-start justify-between gap-3 text-sm border border-gray-100 rounded-xl p-3">
                            <div class="min-w-0">
                                <p class="font-medium text-gray-900">{{ sync.providerName }}</p>
                                <p class="text-gray-500 truncate">{{ sync.iCalUrl }}</p>
                                <p class="text-xs text-gray-400 mt-0.5">
                                    {% if sync.lastSyncAt %}Dernière synchro : {{ sync.lastSyncAt|date('d/m/Y H:i') }}{% else %}Jamais synchronisé{% endif %}
                                </p>
                            </div>
                            <form method="post" action="{{ path('app_host_ical_import_remove', { id: property.id, syncId: sync.id }) }}"
                                  onsubmit="return confirm('Supprimer ce calendrier et ses blocages importés ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('ical-import-del-' ~ sync.id) }}">
                                <button type="submit" class="text-gray-400 hover:text-red-600" aria-label="Supprimer"><i class="fa-solid fa-trash"></i></button>
                            </form>
                        </li>
                    {% endfor %}
                </ul>
            {% endif %}

            <form method="post" action="{{ path('app_host_ical_import_add', { id: property.id }) }}" class="mt-4 grid grid-cols-1 sm:grid-cols-3 gap-3">
                <input type="hidden" name="_token" value="{{ csrf_token('ical-import-' ~ property.id) }}">
                <input type="text" name="providerName" placeholder="Nom (ex. Airbnb)" required class="border border-gray-300 rounded-xl px-3 py-2.5 text-sm">
                <input type="url" name="icalUrl" placeholder="https://…/calendar.ics" required class="sm:col-span-2 border border-gray-300 rounded-xl px-3 py-2.5 text-sm">
                <button type="submit" class="sm:col-span-3 justify-self-start bg-gray-900 hover:bg-black text-white font-semibold px-5 py-2.5 rounded-xl transition text-sm">
                    <i class="fa-solid fa-plus mr-1"></i> Ajouter le calendrier
                </button>
            </form>
        </div>
    </main>
{% endblock %}
