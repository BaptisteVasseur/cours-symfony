{% extends 'layout/app.html.twig' %}

{% block title %}Indisponibilités — {{ property.title }}{% endblock %}

{% block content %}
<main class="flex-grow px-6 md:px-12 py-8 max-w-3xl mx-auto w-full">

    <div class="mb-8 flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-semibold text-gray-900">Dates bloquées</h1>
            <p class="text-gray-500 mt-1">{{ property.title }}</p>
        </div>
        <a href="{{ path('app_host_property_edit', { id: property.id }) }}"
           class="text-sm font-semibold text-brand hover:underline">
            ← Retour à l'annonce
        </a>
    </div>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="mb-4 px-4 py-3 rounded-xl text-sm {{ label == 'success' ? 'bg-emerald-50 text-emerald-800' : 'bg-red-50 text-red-800' }}">{{ message }}</div>
        {% endfor %}
    {% endfor %}

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">

        {# Formulaire d'ajout #}
        <div class="bg-white border border-gray-200 rounded-2xl p-6 shadow-sm">
            <h2 class="text-lg font-semibold mb-4">Bloquer une date</h2>
            {{ form_start(form, { attr: { class: 'space-y-4' } }) }}
                {{ form_row(form.availableDate, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm' } }) }}
                {{ form_row(form.priceOverride, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm' } }) }}
                {{ form_row(form.minimumStay, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm' } }) }}
                <button type="submit" class="w-full bg-brand hover:bg-brandHover text-white font-semibold py-3 rounded-xl text-sm">
                    Bloquer cette date
                </button>
            {{ form_end(form) }}
        </div>

        {# Liste des dates bloquées #}
        <div>
            <h2 class="text-lg font-semibold mb-4">Dates actuellement bloquées</h2>
            {% if unavailabilities|length == 0 %}
                <p class="text-gray-400 text-sm">Aucune date bloquée.</p>
            {% else %}
                <ul class="space-y-2">
                    {% for entry in unavailabilities %}
                        {% if not entry.isAvailable %}
                            <li class="flex items-center justify-between border border-red-100 bg-red-50 rounded-xl px-4 py-3">
                                <div>
                                    <span class="font-medium text-sm text-gray-800">{{ entry.availableDate|date('d/m/Y') }}</span>
                                    {% if entry.priceOverride %}
                                        <span class="ml-2 text-xs text-gray-500">{{ entry.priceOverride }} €</span>
                                    {% endif %}
                                    {% if entry.minimumStay %}
                                        <span class="ml-2 text-xs text-gray-500">min. {{ entry.minimumStay }} nuit(s)</span>
                                    {% endif %}
                                </div>
                                <form method="post" action="{{ path('app_host_unavailability_delete', { id: property.id, availId: entry.id }) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_unavailability' ~ entry.id) }}">
                                    <button type="submit" class="text-red-500 hover:text-red-700 text-sm font-medium">Supprimer</button>
                                </form>
                            </li>
                        {% endif %}
                    {% endfor %}
                </ul>
            {% endif %}
        </div>

    </div>

</main>
{% endblock %}
