{% extends 'layout/app.html.twig' %}

{% block title %}Modifier — {{ property.title }}{% endblock %}

{% block content %}
<main class="flex-grow px-6 md:px-12 py-8 max-w-3xl mx-auto w-full">

    <div class="mb-8 flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-semibold text-gray-900">Modifier l'annonce</h1>
            <p class="text-gray-500 mt-1">{{ property.title }}</p>
        </div>
        <a href="{{ path('app_host_property_unavailability', { id: property.id }) }}"
           class="text-sm font-semibold text-brand hover:underline">
            Gérer les indisponibilités →
        </a>
    </div>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="mb-4 px-4 py-3 rounded-xl text-sm {{ label == 'success' ? 'bg-emerald-50 text-emerald-800' : 'bg-red-50 text-red-800' }}">{{ message }}</div>
        {% endfor %}
    {% endfor %}

    <div class="bg-white border border-gray-200 rounded-2xl p-6 shadow-sm">
        {{ form_start(form, { attr: { class: 'space-y-5' } }) }}

            <div class="grid grid-cols-1 gap-5">
                {{ form_row(form.title, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm' } }) }}
                {{ form_row(form.description, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm', rows: 4 } }) }}
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                {{ form_row(form.propertyType, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm' } }) }}
                {{ form_row(form.cancellationPolicy, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm' } }) }}
            </div>

            <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
                {{ form_row(form.maxGuests, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm', min: 1 } }) }}
                {{ form_row(form.bedrooms, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm', min: 0 } }) }}
                {{ form_row(form.beds, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm', min: 1 } }) }}
                {{ form_row(form.bathrooms, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm', min: 0 } }) }}
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
                {{ form_row(form.pricePerNight, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm' } }) }}
                {{ form_row(form.cleaningFee, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm' } }) }}
                {{ form_row(form.securityDeposit, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm' } }) }}
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                {{ form_row(form.checkinTime, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm' } }) }}
                {{ form_row(form.checkoutTime, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm' } }) }}
            </div>

            <div class="flex items-center gap-3">
                {{ form_widget(form.instantBooking) }}
                {{ form_label(form.instantBooking) }}
            </div>

            <div class="border-t border-gray-100 pt-5">
                <h2 class="text-base font-semibold text-gray-800 mb-4">Adresse du logement</h2>
                <div class="grid grid-cols-1 gap-4">
                    {{ form_row(form.address.addressLine1, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm' } }) }}
                    {{ form_row(form.address.addressLine2, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm' } }) }}
                    <div class="grid grid-cols-2 gap-4">
                        {{ form_row(form.address.postalCode, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm' } }) }}
                        {{ form_row(form.address.city, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm' } }) }}
                    </div>
                    {{ form_row(form.address.country, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm' } }) }}
                </div>
            </div>

            <button type="submit" class="w-full bg-brand hover:bg-brandHover text-white font-semibold py-3 rounded-xl">
                Enregistrer les modifications
            </button>

        {{ form_end(form) }}
    </div>

    {# ── Synchronisation iCal ── #}
    <div id="ical" class="mt-8 bg-white border border-gray-200 rounded-2xl p-6 shadow-sm">
        <div class="flex items-center gap-2 mb-1">
            <i class="fa-regular fa-calendar text-gray-500"></i>
            <h2 class="text-base font-semibold text-gray-900">Synchronisation iCal</h2>
        </div>
        <p class="text-sm text-gray-500 mb-4">
            Importez ce lien dans Google Calendar, Outlook ou tout autre agenda compatible pour y voir vos réservations confirmées.
        </p>

        {% if property.calendarToken %}
            {% set icalUrl = url('app_ical_export', { id: property.id }) ~ '?token=' ~ property.calendarToken %}
            <div class="flex items-center gap-2 mb-4">
                <input type="text" readonly value="{{ icalUrl }}" id="ical-url"
                    class="flex-1 text-xs border border-gray-300 rounded-lg px-3 py-2 bg-gray-50 text-gray-600 font-mono truncate">
                <button type="button" onclick="navigator.clipboard.writeText('{{ icalUrl }}').then(() => this.textContent = 'Copié !')"
                    class="shrink-0 text-xs font-semibold px-3 py-2 border border-gray-300 rounded-lg hover:bg-gray-50 transition whitespace-nowrap">
                    Copier
                </button>
            </div>
            <form method="post" action="{{ path('app_host_ical_revoke', { id: property.id }) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('ical_revoke' ~ property.id) }}">
                <button type="submit"
                    class="text-xs text-red-500 hover:text-red-700 font-medium underline">
                    Révoquer le lien (désactive la synchronisation)
                </button>
            </form>
        {% else %}
            <p class="text-sm text-gray-400 mb-4 italic">Aucun lien iCal généré pour ce logement.</p>
            <form method="post" action="{{ path('app_host_ical_generate', { id: property.id }) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('ical_generate' ~ property.id) }}">
                <button type="submit"
                    class="inline-flex items-center gap-2 bg-gray-900 hover:bg-gray-700 text-white text-sm font-semibold px-4 py-2 rounded-lg transition">
                    <i class="fa-solid fa-link text-xs"></i>
                    Générer le lien iCal
                </button>
            </form>
        {% endif %}
    </div>

</main>
{% endblock %}
