{% extends 'layout/app.html.twig' %}

{% block title %}Disponibilités — {{ property.title }}{% endblock %}

{% block content %}
<main class="flex-grow px-6 md:px-12 py-8 max-w-4xl mx-auto w-full">
    <a href="{{ path('app_host_dashboard') }}" class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-gray-900 mb-6">
        <i class="fa-solid fa-arrow-left"></i> Retour au tableau de bord
    </a>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="mb-4 px-4 py-3 rounded-xl text-sm {{ label == 'success' ? 'bg-emerald-50 text-emerald-800' : 'bg-red-50 text-red-800' }}">{{ message }}</div>
        {% endfor %}
    {% endfor %}

    <div class="mb-8">
        <h1 class="text-2xl font-semibold text-gray-900">Gestion des disponibilités</h1>
        <p class="text-gray-500 mt-1">{{ property.title }}</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <div>
            <h2 class="text-base font-semibold text-gray-900 mb-4">Bloquer / débloquer un jour</h2>
            <p class="text-sm text-gray-500 mb-4">
                Les dates en rouge sont bloquées manuellement. Cliquez sur une date pour modifier sa disponibilité.
                Les réservations confirmées sont gérées automatiquement.
            </p>

            <form action="{{ path('app_host_availability_toggle', { id: property.id }) }}" method="POST" class="flex flex-col gap-3">
                <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ property.id) }}">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1" for="date">Date à modifier</label>
                    <input
                        type="date"
                        id="date"
                        name="date"
                        min="{{ from|date('Y-m-d') }}"
                        max="{{ to|date('Y-m-d') }}"
                        class="border border-gray-300 rounded-xl px-4 py-2 text-sm w-full"
                        required
                    >
                </div>
                <button type="submit" class="px-4 py-2 bg-gray-900 hover:bg-gray-700 text-white text-sm font-semibold rounded-xl transition">
                    Basculer la disponibilité
                </button>
            </form>

            {% if blockedDates|length > 0 %}
            <div class="mt-6">
                <h3 class="text-sm font-semibold text-gray-700 mb-2">Jours bloqués ({{ from|date('M Y') }} – {{ to|date('M Y') }})</h3>
                <ul class="space-y-1">
                    {% for d in blockedDates %}
                        <li class="text-sm text-red-600 flex items-center gap-2">
                            <i class="fa-solid fa-ban text-xs"></i>
                            {{ d|date('d/m/Y') }}
                        </li>
                    {% endfor %}
                </ul>
            </div>
            {% else %}
            <p class="mt-6 text-sm text-gray-400">Aucun jour bloqué manuellement sur cette période.</p>
            {% endif %}
        </div>

        <div>
            <h2 class="text-base font-semibold text-gray-900 mb-4">Lien de synchronisation iCal</h2>
            <p class="text-sm text-gray-500 mb-4">
                Partagez ce lien avec Google Calendar ou Outlook pour synchroniser vos réservations confirmées.
                Le token est révocable à tout moment.
            </p>

            {% if property.icalToken %}
                {% set icalUrl = url('api_property_ical', { id: property.id }) ~ '?token=' ~ property.icalToken %}
                <div class="bg-gray-50 border border-gray-200 rounded-xl p-4 mb-4">
                    <p class="text-xs text-gray-500 mb-1 font-medium uppercase">URL iCal</p>
                    <p class="text-xs font-mono break-all text-gray-800">{{ icalUrl }}</p>
                </div>
                <a href="{{ icalUrl }}" class="inline-flex items-center gap-2 text-sm text-brand font-semibold hover:underline mb-4">
                    <i class="fa-solid fa-download"></i> Télécharger le fichier .ics
                </a>
            {% else %}
                <p class="text-sm text-gray-400 mb-4">Aucun token généré. Générez-en un pour activer la synchronisation.</p>
            {% endif %}

            <form action="{{ path('app_host_ical_generate', { id: property.id }) }}" method="POST">
                <input type="hidden" name="_token" value="{{ csrf_token('ical' ~ property.id) }}">
                <button type="submit" class="px-4 py-2 bg-brand hover:bg-brandHover text-white text-sm font-semibold rounded-xl transition">
                    {{ property.icalToken ? 'Regénérer le token (révoque l\'ancien)' : 'Générer un token iCal' }}
                </button>
            </form>
        </div>
    </div>
</main>
{% endblock %}
