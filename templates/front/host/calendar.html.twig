{% extends 'layout/app.html.twig' %}

{% block title %}Calendrier - {{ property.title }}{% endblock %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-6xl mx-auto w-full">
        <a href="{{ path('app_account_properties') }}" class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-gray-900 mb-6">
            <i class="fa-solid fa-arrow-left"></i> Mes proprietes
        </a>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 px-4 py-3 rounded-xl text-sm {{ label == 'success' ? 'bg-emerald-50 text-emerald-800' : 'bg-red-50 text-red-800' }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}

        <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-6 mb-8">
            <div>
                <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">{{ property.title }}</h1>
                <p class="text-gray-500 mt-1">Calendrier des reservations confirmees et indisponibilites.</p>
            </div>
            <div class="flex items-center gap-2">
                <a href="{{ path('app_host_property_calendar', { id: property.id, month: previousMonth }) }}" class="px-4 py-2 border border-gray-200 rounded-xl text-sm font-semibold hover:bg-gray-50">Mois precedent</a>
                <a href="{{ path('app_host_property_calendar', { id: property.id, month: nextMonth }) }}" class="px-4 py-2 border border-gray-200 rounded-xl text-sm font-semibold hover:bg-gray-50">Mois suivant</a>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <section class="lg:col-span-2">
                <div class="flex items-center justify-between mb-4">
                    <h2 class="text-xl font-semibold text-gray-900">{{ monthStart|date('F Y') }}</h2>
                    <div class="flex items-center gap-4 text-xs text-gray-500">
                        <span class="inline-flex items-center gap-1"><span class="w-3 h-3 rounded-sm bg-green-100 border border-green-200"></span> Confirme</span>
                        <span class="inline-flex items-center gap-1"><span class="w-3 h-3 rounded-sm bg-red-100 border border-red-200"></span> Bloque</span>
                    </div>
                </div>

                <div class="grid grid-cols-7 border border-gray-200 rounded-xl overflow-hidden bg-white">
                    {% for label in ['Lun', 'Mar', 'Mer', 'Jeu', 'Ven', 'Sam', 'Dim'] %}
                        <div class="px-2 py-2 text-center text-xs font-semibold text-gray-500 bg-gray-50 border-b border-gray-200">{{ label }}</div>
                    {% endfor %}

                    {% for day in days %}
                        <div class="min-h-28 p-2 border-t border-gray-100 {{ loop.index % 7 != 0 ? 'border-r border-gray-100' : '' }} {{ day.currentMonth ? 'bg-white' : 'bg-gray-50 text-gray-400' }}">
                            <div class="text-sm font-semibold mb-2">{{ day.date|date('d') }}</div>
                            <div class="space-y-1">
                                {% for reservation in day.reservations %}
                                    <a href="{{ path('app_reservation_show', { id: reservation.id }) }}" class="block truncate rounded-md bg-green-100 text-green-800 px-2 py-1 text-xs">
                                        {{ reservation.guest.profile ? reservation.guest.profile.firstName : reservation.guest.email }}
                                    </a>
                                {% endfor %}
                                {% for block in day.blocks %}
                                    <div class="truncate rounded-md bg-red-100 text-red-800 px-2 py-1 text-xs">{{ block.reason|default('Indisponible') }}</div>
                                {% endfor %}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </section>

            <aside class="space-y-6">
                <section class="border border-gray-200 rounded-xl p-5 bg-white">
                    <h2 class="text-lg font-semibold text-gray-900 mb-4">Bloquer une periode</h2>
                    {{ form_start(form, { attr: { class: 'space-y-4' } }) }}
                        {{ form_row(form.dateStart, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm' } }) }}
                        {{ form_row(form.dateEnd, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm' } }) }}
                        {{ form_row(form.reason, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm min-h-24' } }) }}
                        <button type="submit" class="w-full bg-brand hover:bg-brandHover text-white font-semibold py-3 rounded-xl">Bloquer</button>
                    {{ form_end(form) }}
                </section>

                <section class="border border-gray-200 rounded-xl p-5 bg-white">
                    <h2 class="text-lg font-semibold text-gray-900 mb-3">Export iCal</h2>
                    <input type="text" readonly value="{{ iCalUrl }}" class="w-full border border-gray-300 rounded-xl px-3 py-2 text-xs text-gray-600">
                    <form method="post" action="{{ path('app_host_property_ical_regenerate', { id: property.id }) }}" class="mt-3">
                        <input type="hidden" name="_token" value="{{ csrf_token('regenerate_ical_' ~ property.id) }}">
                        <button type="submit" class="w-full border border-gray-200 text-gray-700 font-semibold py-3 rounded-xl hover:bg-gray-50">Regenerer le token</button>
                    </form>
                </section>

                <section class="border border-gray-200 rounded-xl p-5 bg-white">
                    <h2 class="text-lg font-semibold text-gray-900 mb-4">Periodes bloquees</h2>
                    <div class="space-y-3">
                        {% for block in blocks %}
                            <div class="border border-gray-100 rounded-xl p-3">
                                <p class="text-sm font-semibold text-gray-900">{{ block.dateStart|date('d/m/Y') }} au {{ block.dateEnd|date('d/m/Y') }}</p>
                                <p class="text-xs text-gray-500 mt-1">{{ block.reason|default('Indisponible') }}</p>
                                <form method="post" action="{{ path('app_host_property_availability_delete', { id: property.id, availability: block.id }) }}" class="mt-2">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_availability_' ~ block.id) }}">
                                    <button type="submit" class="text-xs font-semibold text-red-700 hover:underline">Debloquer</button>
                                </form>
                            </div>
                        {% else %}
                            <p class="text-sm text-gray-500">Aucune periode bloquee sur ce mois.</p>
                        {% endfor %}
                    </div>
                </section>
            </aside>
        </div>
    </main>
{% endblock %}
