{% extends 'layout/app.html.twig' %}

{% set monthNames = ['Janvier','Février','Mars','Avril','Mai','Juin','Juillet','Août','Septembre','Octobre','Novembre','Décembre'] %}
{% set today = 'now'|date('Y-m-d') %}

{% set prevMonth = month == 1 ? 12 : month - 1 %}
{% set prevYear = month == 1 ? year - 1 : year %}
{% set nextMonth = month == 12 ? 1 : month + 1 %}
{% set nextYear = month == 12 ? year + 1 : year %}

{% set firstDayOfMonth = (year ~ '-' ~ month ~ '-01')|date('N') %}
{% set daysInMonth = (year ~ '-' ~ month ~ '-01')|date('t') %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-4xl mx-auto w-full">
        <a href="{{ path('app_host_all_requests') }}" class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-gray-900 mb-6">
            <i class="fa-solid fa-arrow-left"></i> Tableau de bord
        </a>

        <div class="mb-6">
            <h1 class="text-2xl font-semibold text-gray-900">Calendrier — {{ property.title }}</h1>
        </div>

        {% for message in app.flashes('success') %}
            <div class="mb-4 p-4 bg-green-50 border border-green-200 text-green-800 rounded-xl text-sm">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="mb-4 p-4 bg-red-50 border border-red-200 text-red-800 rounded-xl text-sm">{{ message }}</div>
        {% endfor %}

        {# Calendar navigation #}
        <div class="flex items-center justify-between mb-4">
            <a href="{{ path('app_host_calendar', { id: property.id, year: prevYear, month: prevMonth }) }}" class="p-2 rounded-full hover:bg-gray-100">
                <i class="fa-solid fa-chevron-left"></i>
            </a>
            <h2 class="text-lg font-semibold">{{ monthNames[month - 1] }} {{ year }}</h2>
            <a href="{{ path('app_host_calendar', { id: property.id, year: nextYear, month: nextMonth }) }}" class="p-2 rounded-full hover:bg-gray-100">
                <i class="fa-solid fa-chevron-right"></i>
            </a>
        </div>

        {# Legend #}
        <div class="flex gap-4 mb-4 text-sm flex-wrap">
            <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-full bg-red-400 inline-block"></span> Réservé (confirmé)</span>
            <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-full bg-gray-400 inline-block"></span> Bloqué (manuel)</span>
            <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-full bg-green-200 inline-block"></span> Disponible</span>
        </div>

        {# Calendar grid #}
        <div class="border border-gray-200 rounded-xl overflow-hidden mb-8">
            <div class="grid grid-cols-7 bg-gray-50 border-b border-gray-200">
                {% for day in ['Lun', 'Mar', 'Mer', 'Jeu', 'Ven', 'Sam', 'Dim'] %}
                    <div class="py-2 text-center text-xs font-semibold text-gray-500">{{ day }}</div>
                {% endfor %}
            </div>
            <div class="grid grid-cols-7">
                {# Empty cells before first day #}
                {% for i in 1..(firstDayOfMonth - 1) %}
                    <div class="border-b border-r border-gray-100 p-2 min-h-12 bg-gray-50"></div>
                {% endfor %}

                {% for d in 1..daysInMonth %}
                    {% set dateStr = year ~ '-' ~ '%02d'|format(month) ~ '-' ~ '%02d'|format(d) %}
                    {% set isBlocked = blockedDates[dateStr] is defined %}
                    {% set isConfirmed = confirmedDates[dateStr] is defined %}
                    {% set isToday = dateStr == today %}

                    <div class="border-b border-r border-gray-100 p-2 min-h-12 relative
                        {% if isConfirmed %} bg-red-50
                        {% elseif isBlocked %} bg-gray-100
                        {% else %} bg-white hover:bg-green-50
                        {% endif %}">
                        <span class="text-xs font-medium
                            {% if isToday %} bg-brand text-white rounded-full w-5 h-5 flex items-center justify-center
                            {% elseif isConfirmed %} text-red-600
                            {% elseif isBlocked %} text-gray-400
                            {% else %} text-gray-700
                            {% endif %}">{{ d }}</span>
                        {% if isConfirmed %}
                            <span class="block w-2 h-2 rounded-full bg-red-400 mt-1 mx-auto"></span>
                        {% elseif isBlocked %}
                            <span class="block w-2 h-2 rounded-full bg-gray-400 mt-1 mx-auto"></span>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
        </div>

        {# Block dates form #}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
            <div class="border border-gray-200 rounded-xl p-6">
                <h3 class="font-semibold mb-4">Bloquer des dates</h3>
                <form method="POST" action="{{ path('app_host_calendar_block', { id: property.id }) }}" class="space-y-3">
                    <input type="hidden" name="_token" value="{{ csrf_token('host_calendar_' ~ property.id) }}">
                    <div>
                        <label class="block text-sm text-gray-600 mb-1">Du</label>
                        <input type="date" name="from" required class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm">
                    </div>
                    <div>
                        <label class="block text-sm text-gray-600 mb-1">Au (exclu)</label>
                        <input type="date" name="to" required class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm">
                    </div>
                    <button type="submit" class="w-full px-4 py-2 bg-gray-800 text-white text-sm font-semibold rounded-lg hover:bg-gray-900 transition">
                        Bloquer
                    </button>
                </form>
            </div>

            <div class="border border-gray-200 rounded-xl p-6">
                <h3 class="font-semibold mb-4">Débloquer des dates</h3>
                <form method="POST" action="{{ path('app_host_calendar_unblock', { id: property.id }) }}" class="space-y-3">
                    <input type="hidden" name="_token" value="{{ csrf_token('host_calendar_' ~ property.id) }}">
                    <div>
                        <label class="block text-sm text-gray-600 mb-1">Du</label>
                        <input type="date" name="from" required class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm">
                    </div>
                    <div>
                        <label class="block text-sm text-gray-600 mb-1">Au (exclu)</label>
                        <input type="date" name="to" required class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm">
                    </div>
                    <button type="submit" class="w-full px-4 py-2 bg-white border border-gray-200 text-gray-700 text-sm font-semibold rounded-lg hover:bg-gray-50 transition">
                        Débloquer
                    </button>
                </form>
            </div>
        </div>

        {# iCal export section #}
        <div class="border border-gray-200 rounded-xl p-6">
            <h3 class="font-semibold mb-2">Synchronisation iCal</h3>
            <p class="text-sm text-gray-500 mb-4">Partagez ce lien avec Google Calendar, Outlook ou tout autre outil compatible.</p>
            {% if property.icalToken %}
                <div class="flex items-center gap-2 mb-3">
                    <input type="text" readonly
                        value="{{ url('api_ical_export', { id: property.id }) ~ '?token=' ~ property.icalToken }}"
                        class="flex-1 border border-gray-200 rounded-lg px-3 py-2 text-xs text-gray-600 bg-gray-50"
                        onclick="this.select()">
                </div>
            {% else %}
                <p class="text-sm text-gray-400 mb-3">Aucun token généré. Cliquez ci-dessous pour en créer un.</p>
            {% endif %}
            <form method="POST" action="{{ path('app_host_ical_regenerate', { id: property.id }) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('ical_token_' ~ property.id) }}">
                <button type="submit" class="px-4 py-2 border border-gray-200 text-sm font-semibold rounded-lg hover:bg-gray-50 transition">
                    {{ property.icalToken ? 'Régénérer le token' : 'Générer un token iCal' }}
                </button>
            </form>
        </div>
    </main>
{% endblock %}
