{% extends 'layout/app.html.twig' %}

{% block title %}Calendrier — {{ property.title }}{% endblock %}

{% set weekDays = ['Lun', 'Mar', 'Mer', 'Jeu', 'Ven', 'Sam', 'Dim'] %}
{% set monthNames = ['', 'janvier', 'février', 'mars', 'avril', 'mai', 'juin', 'juillet', 'août', 'septembre', 'octobre', 'novembre', 'décembre'] %}
{% set today = 'now'|date('Y-m-d') %}
{% set icalUrl = property.calendarToken ? url('app_api_property_calendar', { id: property.id }) ~ '?token=' ~ property.calendarToken : null %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-5xl mx-auto w-full">
        <a href="{{ path('app_account_properties') }}" class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-gray-900 mb-6">
            <i class="fa-solid fa-arrow-left"></i> Mes propriétés
        </a>

        <h1 class="text-2xl md:text-3xl font-semibold text-gray-900 mb-2">Calendrier — {{ property.title }}</h1>
        <p class="text-gray-500 mb-8">Visualisez les réservations confirmées et déclarez vos périodes d'indisponibilité.</p>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 px-4 py-3 rounded-xl text-sm {{ label == 'success' ? 'bg-emerald-50 text-emerald-800' : 'bg-red-50 text-red-800' }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <section class="lg:col-span-2 border border-gray-200 rounded-2xl p-6">
                <div class="flex items-center justify-between mb-4">
                    <a href="{{ path('app_host_calendar', { id: property.id, month: prevMonth }) }}" class="px-3 py-1.5 rounded-lg border border-gray-200 hover:bg-gray-50 text-sm"><i class="fa-solid fa-chevron-left"></i></a>
                    <h2 class="font-semibold text-lg">{{ monthNames[month|date('n')] }} {{ month|date('Y') }}</h2>
                    <a href="{{ path('app_host_calendar', { id: property.id, month: nextMonth }) }}" class="px-3 py-1.5 rounded-lg border border-gray-200 hover:bg-gray-50 text-sm"><i class="fa-solid fa-chevron-right"></i></a>
                </div>

                <div class="grid grid-cols-7 gap-1 text-center text-xs font-semibold text-gray-400 mb-1">
                    {% for wd in weekDays %}<div>{{ wd }}</div>{% endfor %}
                </div>

                <div class="grid grid-cols-7 gap-1">
                    {% for i in 1..leadingBlanks %}<div></div>{% endfor %}
                    {% for d in 1..daysInMonth %}
                        {% set dayDate = month|date_modify((d - 1) ~ ' days') %}
                        {% set key = dayDate|date('Y-m-d') %}
                        {% set isPast = key < today %}
                        {% set isBooked = bookedDays[key] is defined %}
                        {% set isBlocked = blockedDays[key] is defined %}
                        {% set cellClass = 'bg-white text-gray-700' %}
                        {% if isPast %}{% set cellClass = 'bg-gray-50 text-gray-300' %}
                        {% elseif isBooked %}{% set cellClass = 'bg-red-100 text-red-700' %}
                        {% elseif isBlocked %}{% set cellClass = 'bg-gray-200 text-gray-500 line-through' %}
                        {% endif %}
                        <div class="aspect-square rounded-lg border border-gray-100 flex flex-col items-center justify-center text-sm {{ cellClass }}" title="{% if isBooked %}Réservé{% elseif isBlocked %}Bloqué{% else %}Disponible{% endif %}">
                            <span>{{ d }}</span>
                            {% if priceOverrides[key] is defined and not isPast %}
                                <span class="text-[10px] text-gray-400">{{ priceOverrides[key]|number_format(0, ',', ' ') }}€</span>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>

                <div class="flex flex-wrap items-center gap-4 mt-5 text-xs text-gray-500">
                    <span class="inline-flex items-center gap-1.5"><span class="w-3 h-3 rounded bg-red-100 border border-red-200"></span> Réservé</span>
                    <span class="inline-flex items-center gap-1.5"><span class="w-3 h-3 rounded bg-gray-200"></span> Bloqué</span>
                    <span class="inline-flex items-center gap-1.5"><span class="w-3 h-3 rounded bg-white border border-gray-200"></span> Disponible</span>
                </div>
            </section>

            <aside class="space-y-6">
                <div class="border border-gray-200 rounded-2xl p-6">
                    <h2 class="font-semibold mb-4">Bloquer une période</h2>
                    {{ form_start(blockForm, { attr: { class: 'space-y-4' } }) }}
                        {{ form_row(blockForm.startDate, { attr: { class: 'w-full border border-gray-300 rounded-xl px-3 py-2 text-sm' } }) }}
                        {{ form_row(blockForm.endDate, { attr: { class: 'w-full border border-gray-300 rounded-xl px-3 py-2 text-sm' } }) }}
                        {{ form_row(blockForm.reason, { attr: { class: 'w-full border border-gray-300 rounded-xl px-3 py-2 text-sm' } }) }}
                        <button type="submit" class="w-full bg-gray-900 hover:bg-black text-white text-sm font-semibold py-2.5 rounded-xl">Bloquer ces dates</button>
                    {{ form_end(blockForm) }}
                </div>

                <div class="border border-gray-200 rounded-2xl p-6">
                    <h2 class="font-semibold mb-2">Synchronisation iCal</h2>
                    <p class="text-sm text-gray-500 mb-4">Importez ce lien dans Google Calendar ou Outlook pour exporter vos séjours confirmés.</p>
                    {% if icalUrl %}
                        <input type="text" readonly value="{{ icalUrl }}" class="w-full border border-gray-300 rounded-xl px-3 py-2 text-xs text-gray-600 mb-3" onclick="this.select()">
                    {% else %}
                        <p class="text-sm text-gray-400 mb-3">Aucun lien généré pour le moment.</p>
                    {% endif %}
                    <form method="post" action="{{ path('app_host_calendar_token', { id: property.id }) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('ical-token' ~ property.id) }}">
                        <button type="submit" class="w-full border border-gray-300 hover:bg-gray-50 text-sm font-semibold py-2.5 rounded-xl">
                            {{ icalUrl ? 'Régénérer le lien' : 'Générer le lien' }}
                        </button>
                    </form>
                </div>
            </aside>
        </div>
    </main>
{% endblock %}
