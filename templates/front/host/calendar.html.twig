{% extends 'layout/app.html.twig' %}

{% block content %}
    {% set monthNames = ['Janvier','Février','Mars','Avril','Mai','Juin','Juillet','Août','Septembre','Octobre','Novembre','Décembre'] %}
    {% set dayNames = ['Lun','Mar','Mer','Jeu','Ven','Sam','Dim'] %}

    {# Calcul des jours de réservation confirmée #}
    {% set reservedDates = [] %}
    {% for reservation in reservations %}
        {% set d = reservation.checkinDate %}
        {% for i in 0..(reservation.checkoutDate|date_modify('-1 day')|date('j') - reservation.checkinDate|date('j')) %}
            {% set reservedDates = reservedDates|merge([d|date_modify('+' ~ i ~ ' days')|date('Y-m-d')]) %}
        {% endfor %}
    {% endfor %}

    <main class="flex-grow px-6 md:px-12 py-8 max-w-4xl mx-auto w-full">

        <a href="{{ path('app_account_properties') }}" class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-gray-900 mb-6">
            <i class="fa-solid fa-arrow-left"></i> Mes propriétés
        </a>

        <div class="flex flex-wrap items-center justify-between gap-4 mb-8">
            <div>
                <h1 class="text-2xl font-semibold text-gray-900">Calendrier</h1>
                <p class="text-gray-500 text-sm mt-1">{{ property.title }}</p>
            </div>
            <div class="flex items-center gap-3">
                <a href="{{ path('app_host_calendar', {id: property.id, month: prev}) }}" class="p-2 border border-gray-200 rounded-full hover:bg-gray-50">
                    <i class="fa-solid fa-chevron-left text-sm"></i>
                </a>
                <span class="font-semibold text-gray-900">{{ monthNames[month - 1] }} {{ year }}</span>
                <a href="{{ path('app_host_calendar', {id: property.id, month: next}) }}" class="p-2 border border-gray-200 rounded-full hover:bg-gray-50">
                    <i class="fa-solid fa-chevron-right text-sm"></i>
                </a>
            </div>
        </div>

        {# Légende #}
        <div class="flex gap-4 mb-4 text-sm">
            <span class="flex items-center gap-2"><span class="w-4 h-4 rounded bg-red-100 border border-red-300 inline-block"></span> Bloqué</span>
            <span class="flex items-center gap-2"><span class="w-4 h-4 rounded bg-green-100 border border-green-300 inline-block"></span> Réservé</span>
            <span class="flex items-center gap-2"><span class="w-4 h-4 rounded bg-white border border-gray-200 inline-block"></span> Disponible</span>
        </div>

        {# Grille calendrier #}
        <div class="border border-gray-200 rounded-xl overflow-hidden mb-8">
            <div class="grid grid-cols-7 bg-gray-50 border-b border-gray-200">
                {% for day in dayNames %}
                    <div class="text-center text-xs font-semibold text-gray-500 py-2">{{ day }}</div>
                {% endfor %}
            </div>
            <div class="grid grid-cols-7">
                {# Cases vides avant le 1er du mois (lundi = 1, aucune case si firstWeekday = 1) #}
                {% if firstWeekday > 1 %}
                    {% for i in 1..(firstWeekday - 1) %}
                        <div class="border-b border-r border-gray-100 h-16"></div>
                        {% endfor %}
                    {% endif %}

                {% for day in 1..daysInMonth %}{# daysInMonth vient du controller #}
                    {% set dateKey = year ~ '-' ~ '%02d'|format(month) ~ '-' ~ '%02d'|format(day) %}
                    {% set isBlocked = dateKey in blockedDates %}
                    {% set isReserved = dateKey in reservedDates %}
                    {% set cellClass = isReserved ? 'bg-green-50' : (isBlocked ? 'bg-red-50' : 'bg-white hover:bg-gray-50') %}

                    <div class="border-b border-r border-gray-100 h-16 p-1 {{ cellClass }} relative group">
                        <span class="text-xs font-medium text-gray-700">{{ day }}</span>

                        {% if isBlocked %}
                            <form method="post" action="{{ path('app_host_calendar_unblock', {id: property.id, date: dateKey}) }}" class="absolute inset-0 flex items-end justify-center pb-1 opacity-0 group-hover:opacity-100 transition">
                                <input type="hidden" name="_method" value="DELETE">
                                <button type="submit" class="text-xs text-red-600 hover:underline">Débloquer</button>
                            </form>
                        {% elseif not isReserved %}
                            <span class="absolute bottom-1 left-0 right-0 text-center text-xs text-gray-400 opacity-0 group-hover:opacity-100 transition">libre</span>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
        </div>

        {# Formulaire bloquer une période #}
        <div class="border border-gray-200 rounded-xl p-6">
            <h2 class="text-lg font-semibold mb-4">Bloquer une période</h2>
            <form method="post" action="{{ path('app_host_calendar_block', {id: property.id}) }}" class="flex flex-wrap gap-4 items-end">
                <input type="hidden" name="_token" value="{{ csrf_token('host_calendar') }}">
                <div>
                    <label class="block text-sm text-gray-600 mb-1">Du</label>
                    <input type="date" name="start" required class="border border-gray-300 rounded-lg px-3 py-2 text-sm">
                </div>
                <div>
                    <label class="block text-sm text-gray-600 mb-1">Au (exclu)</label>
                    <input type="date" name="end" required class="border border-gray-300 rounded-lg px-3 py-2 text-sm">
                </div>
                <button type="submit" class="bg-brand text-white px-5 py-2 rounded-lg text-sm font-semibold hover:bg-brandHover transition">
                    Bloquer
                </button>
            </form>
        </div>

    </main>
{% endblock %}
