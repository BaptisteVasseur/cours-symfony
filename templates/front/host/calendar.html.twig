{% extends 'layout/app.html.twig' %}

{% block title %}Calendrier — {{ property.title }}{% endblock %}

{% set monthNames = ['', 'Janvier', 'Février', 'Mars', 'Avril', 'Mai', 'Juin', 'Juillet', 'Août', 'Septembre', 'Octobre', 'Novembre', 'Décembre'] %}
{% set daysInMonth = date(year ~ '-' ~ month|format('%02d') ~ '-01')|date('t') %}
{% set firstDayOfWeek = date(year ~ '-' ~ month|format('%02d') ~ '-01')|date('N') %}

{# Build a set of all confirmed reserved date ranges #}
{% set reservedDates = {} %}
{% for res in confirmedReservations %}
    {% set d = res.checkinDate %}
    {% for i in 0..res.checkinDate.diff(res.checkoutDate).days - 1 %}
        {% set key = d|date('Y-m-d') %}
        {% set reservedDates = reservedDates|merge({ (key): true }) %}
        {% set d = d|date_modify('+1 day') %}
    {% endfor %}
{% endfor %}

{% set prevMonth = month - 1 %}
{% set prevYear  = year %}
{% if prevMonth < 1 %}{% set prevMonth = 12 %}{% set prevYear = year - 1 %}{% endif %}

{% set nextMonth = month + 1 %}
{% set nextYear  = year %}
{% if nextMonth > 12 %}{% set nextMonth = 1 %}{% set nextYear = year + 1 %}{% endif %}

{% block content %}
<main class="flex-grow px-6 md:px-12 py-8 max-w-3xl mx-auto w-full">
    <a href="{{ path('app_logement_detail', { id: property.id }) }}"
       class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-gray-900 mb-6">
        <i class="fa-solid fa-arrow-left"></i> Retour au logement
    </a>

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="mb-4 px-4 py-3 rounded-xl text-sm {{ label == 'success' ? 'bg-emerald-50 text-emerald-800' : 'bg-red-50 text-red-800' }}">{{ message }}</div>
        {% endfor %}
    {% endfor %}

    <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-semibold text-gray-900">Calendrier — {{ property.title }}</h1>
    </div>

    {# Month navigation #}
    <div class="flex items-center justify-between mb-4">
        <a href="{{ path('app_host_calendar', { id: property.id, year: prevYear, month: prevMonth }) }}"
           class="px-3 py-1 border border-gray-200 rounded-lg text-sm hover:bg-gray-50">← Précédent</a>
        <h2 class="text-lg font-semibold">{{ monthNames[month] }} {{ year }}</h2>
        <a href="{{ path('app_host_calendar', { id: property.id, year: nextYear, month: nextMonth }) }}"
           class="px-3 py-1 border border-gray-200 rounded-lg text-sm hover:bg-gray-50">Suivant →</a>
    </div>

    {# Calendar grid #}
    <div class="border border-gray-200 rounded-2xl overflow-hidden mb-8">
        <div class="grid grid-cols-7 bg-gray-50 text-xs font-semibold text-gray-500 text-center">
            {% for day in ['Lun', 'Mar', 'Mer', 'Jeu', 'Ven', 'Sam', 'Dim'] %}
                <div class="py-2">{{ day }}</div>
            {% endfor %}
        </div>
        <div class="grid grid-cols-7 text-sm">
            {% for blank in 1..(firstDayOfWeek - 1) %}
                <div class="h-12 border-t border-r border-gray-100 bg-gray-50"></div>
            {% endfor %}
            {% for day in 1..daysInMonth %}
                {% set dateKey = year ~ '-' ~ month|format('%02d') ~ '-' ~ day|format('%02d') %}
                {% set isBlocked  = blockedMap[dateKey] is defined %}
                {% set isReserved = reservedDates[dateKey] is defined %}
                {% set today = 'now'|date('Y-m-d') %}
                {% set isPast = dateKey < today %}
                <div class="h-12 border-t border-r border-gray-100 flex items-center justify-center relative
                    {{ isBlocked   ? 'bg-red-50' : '' }}
                    {{ isReserved  ? 'bg-green-50' : '' }}
                    {{ isPast and not isBlocked and not isReserved ? 'opacity-40' : '' }}">
                    <span class="text-xs font-medium {{ isBlocked ? 'text-red-600' : isReserved ? 'text-green-700' : 'text-gray-700' }}">{{ day }}</span>
                    {% if isBlocked %}
                        <span class="absolute bottom-1 left-1/2 -translate-x-1/2 text-[9px] text-red-400">Bloqué</span>
                    {% elseif isReserved %}
                        <span class="absolute bottom-1 left-1/2 -translate-x-1/2 text-[9px] text-green-500">Réservé</span>
                    {% endif %}
                </div>
            {% endfor %}
        </div>
    </div>

    {# Legend #}
    <div class="flex gap-4 text-xs text-gray-500 mb-8">
        <span class="flex items-center gap-1"><span class="w-3 h-3 rounded bg-green-100 inline-block"></span>Réservé</span>
        <span class="flex items-center gap-1"><span class="w-3 h-3 rounded bg-red-100 inline-block"></span>Bloqué manuellement</span>
        <span class="flex items-center gap-1"><span class="w-3 h-3 rounded bg-white border border-gray-200 inline-block"></span>Disponible</span>
    </div>

    {# Block / unblock form #}
    <div class="border border-gray-200 rounded-2xl p-6 mb-8">
        <h3 class="font-semibold text-gray-900 mb-4">Bloquer / débloquer une période</h3>
        <form method="POST" action="{{ path('app_host_block_dates', { id: property.id }) }}" class="flex flex-wrap gap-4 items-end">
            <div>
                <label class="block text-xs text-gray-500 mb-1">Date début</label>
                <input type="date" name="date_start" required
                       class="border border-gray-300 rounded-xl px-3 py-2 text-sm">
            </div>
            <div>
                <label class="block text-xs text-gray-500 mb-1">Date fin</label>
                <input type="date" name="date_end" required
                       class="border border-gray-300 rounded-xl px-3 py-2 text-sm">
            </div>
            <div>
                <label class="block text-xs text-gray-500 mb-1">Action</label>
                <select name="action" class="border border-gray-300 rounded-xl px-3 py-2 text-sm">
                    <option value="block">Bloquer</option>
                    <option value="unblock">Débloquer</option>
                </select>
            </div>
            <button type="submit" class="px-4 py-2 bg-brand hover:bg-brandHover text-white text-sm font-semibold rounded-xl">
                Appliquer
            </button>
        </form>
    </div>

    {# iCal export token #}
    <div class="border border-gray-200 rounded-2xl p-6">
        <h3 class="font-semibold text-gray-900 mb-2">Export iCal (Google Calendar, Outlook…)</h3>
        {% if property.icalExportToken %}
            <p class="text-xs text-gray-500 mb-2">Copiez cette URL dans votre application calendrier :</p>
            <code class="block bg-gray-50 border border-gray-200 rounded-lg px-3 py-2 text-xs break-all mb-3">
                {{ url('api_ical_export', { id: property.id }) }}?token={{ property.icalExportToken }}
            </code>
        {% else %}
            <p class="text-sm text-gray-500 mb-3">Aucun token iCal généré pour ce logement.</p>
        {% endif %}
        <form method="POST" action="{{ path('app_host_ical_token_regenerate', { id: property.id }) }}">
            <button type="submit" class="px-4 py-2 border border-gray-300 text-sm font-semibold rounded-xl hover:bg-gray-50">
                {{ property.icalExportToken ? 'Régénérer le token' : 'Générer un token iCal' }}
            </button>
        </form>
    </div>
</main>
{% endblock %}
