{% extends 'layout/app.html.twig' %}

{% block title %}Calendrier — {{ property.title }}{% endblock %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-5xl mx-auto w-full">
        <div class="flex items-center justify-between mb-6">
            <div>
                <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">Calendrier</h1>
                <p class="text-gray-500 mt-1">{{ property.title }}</p>
            </div>
            <a href="{{ path('app_account_properties') }}" class="text-brand hover:underline text-sm">
                <i class="fa-solid fa-arrow-left mr-1"></i> Mes propriétés
            </a>
        </div>

        {% for message in app.flashes('success') %}
            <div class="mb-4 p-3 bg-green-50 border border-green-200 text-green-800 rounded-lg text-sm">
                {{ message }}
            </div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="mb-4 p-3 bg-red-50 border border-red-200 text-red-800 rounded-lg text-sm">
                {{ message }}
            </div>
        {% endfor %}

        {% set prevMonth = month - 1 %}
        {% set prevYear = year %}
        {% if prevMonth < 1 %}
            {% set prevMonth = 12 %}
            {% set prevYear = year - 1 %}
        {% endif %}

        {% set nextMonth = month + 1 %}
        {% set nextYear = year %}
        {% if nextMonth > 12 %}
            {% set nextMonth = 1 %}
            {% set nextYear = year + 1 %}
        {% endif %}

        <div class="bg-white rounded-xl border border-gray-200 p-6 mb-8">
            <div class="flex items-center justify-between mb-6">
                <a href="{{ path('app_host_calendar', {id: property.id, year: prevYear, month: prevMonth}) }}"
                   class="px-3 py-2 rounded-lg border border-gray-200 hover:bg-gray-50 text-sm">
                    <i class="fa-solid fa-chevron-left"></i>
                </a>
                <h2 class="text-lg font-semibold text-gray-900">
                    {{ firstDay|date('F Y')|capitalize }}
                </h2>
                <a href="{{ path('app_host_calendar', {id: property.id, year: nextYear, month: nextMonth}) }}"
                   class="px-3 py-2 rounded-lg border border-gray-200 hover:bg-gray-50 text-sm">
                    <i class="fa-solid fa-chevron-right"></i>
                </a>
            </div>

            <div class="grid grid-cols-7 gap-1 text-center text-xs font-medium text-gray-500 mb-2">
                <div>Lun</div>
                <div>Mar</div>
                <div>Mer</div>
                <div>Jeu</div>
                <div>Ven</div>
                <div>Sam</div>
                <div>Dim</div>
            </div>

            <div class="grid grid-cols-7 gap-1">
                {% if firstDayOfWeek > 1 %}
                    {% for i in 1..(firstDayOfWeek - 1) %}
                        <div class="h-12"></div>
                    {% endfor %}
                {% endif %}

                {% for day in 1..daysInMonth %}
                    {% set dateStr = '%04d-%02d-%02d'|format(year, month, day) %}
                    {% set isBlocked = blockedDates[dateStr] is defined %}
                    {% set isReserved = reservedDates[dateStr] is defined %}

                    {% if isReserved %}
                        {% set bgClass = 'bg-blue-100 border-blue-300 text-blue-800' %}
                    {% elseif isBlocked %}
                        {% set bgClass = 'bg-red-100 border-red-300 text-red-800' %}
                    {% else %}
                        {% set bgClass = 'bg-green-50 border-green-200 text-green-800 hover:bg-green-100' %}
                    {% endif %}

                    <div class="h-12 flex items-center justify-center rounded-lg border text-sm font-medium cursor-default {{ bgClass }}"
                         title="{% if isReserved %}Réservé{% elseif isBlocked %}Bloqué{% else %}Disponible{% endif %}">
                        {{ day }}
                    </div>
                {% endfor %}
            </div>

            <div class="flex items-center gap-6 mt-4 text-xs text-gray-500">
                <div class="flex items-center gap-1">
                    <span class="w-3 h-3 rounded bg-green-100 border border-green-200"></span> Disponible
                </div>
                <div class="flex items-center gap-1">
                    <span class="w-3 h-3 rounded bg-red-100 border border-red-300"></span> Bloqué
                </div>
                <div class="flex items-center gap-1">
                    <span class="w-3 h-3 rounded bg-blue-100 border border-blue-300"></span> Réservé
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="bg-white rounded-xl border border-gray-200 p-6">
                <h3 class="font-semibold text-gray-900 mb-4">Bloquer des dates</h3>
                <form method="post" action="{{ path('app_host_calendar_block', {id: property.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('calendar_block' ~ property.id) }}">
                    <div class="space-y-3">
                        <div>
                            <label for="block_start" class="block text-sm text-gray-600 mb-1">Date de début</label>
                            <input type="date" id="block_start" name="date_start" required
                                   class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-brand focus:border-brand">
                        </div>
                        <div>
                            <label for="block_end" class="block text-sm text-gray-600 mb-1">Date de fin</label>
                            <input type="date" id="block_end" name="date_end" required
                                   class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-brand focus:border-brand">
                        </div>
                        <button type="submit"
                                class="w-full bg-red-500 hover:bg-red-600 text-white font-medium py-2 px-4 rounded-lg text-sm transition">
                            <i class="fa-solid fa-lock mr-1"></i> Bloquer
                        </button>
                    </div>
                </form>
            </div>

            <div class="bg-white rounded-xl border border-gray-200 p-6">
                <h3 class="font-semibold text-gray-900 mb-4">Débloquer des dates</h3>
                <form method="post" action="{{ path('app_host_calendar_unblock', {id: property.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('calendar_unblock' ~ property.id) }}">
                    <div class="space-y-3">
                        <div>
                            <label for="unblock_start" class="block text-sm text-gray-600 mb-1">Date de début</label>
                            <input type="date" id="unblock_start" name="date_start" required
                                   class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-brand focus:border-brand">
                        </div>
                        <div>
                            <label for="unblock_end" class="block text-sm text-gray-600 mb-1">Date de fin</label>
                            <input type="date" id="unblock_end" name="date_end" required
                                   class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-brand focus:border-brand">
                        </div>
                        <button type="submit"
                                class="w-full bg-green-500 hover:bg-green-600 text-white font-medium py-2 px-4 rounded-lg text-sm transition">
                            <i class="fa-solid fa-unlock mr-1"></i> Débloquer
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </main>
{% endblock %}
