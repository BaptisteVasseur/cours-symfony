{% extends 'layout/app.html.twig' %}

{% block title %}Paramètres - {{ property.title }}{% endblock %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-4xl mx-auto w-full">
        <a href="{{ path('app_account_properties') }}" class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-gray-900 mb-6">
            <i class="fa-solid fa-arrow-left"></i> Mes proprietes
        </a>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 px-4 py-3 rounded-xl text-sm {{ label == 'success' ? 'bg-emerald-50 text-emerald-800' : 'bg-red-50 text-red-800' }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}

        <div class="mb-8">
            <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">{{ property.title }}</h1>
            <p class="text-gray-500 mt-1">Gérez les paramètres de votre propriété</p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
            {# Navigation sidebar #}
            <aside class="lg:col-span-1">
                <nav class="space-y-2 border border-gray-200 rounded-xl p-4 bg-white h-fit">
                    <a href="{{ path('app_host_property_calendar', { id: property.id }) }}" class="block px-4 py-2 text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-50 rounded-lg">
                        <i class="fa-solid fa-calendar mr-2"></i> Calendrier
                    </a>
                    <a href="{{ path('app_host_property_settings', { id: property.id }) }}" class="block px-4 py-2 text-sm font-semibold text-brand bg-brand/10 rounded-lg">
                        <i class="fa-solid fa-gear mr-2"></i> Paramètres
                    </a>
                </nav>
            </aside>

            {# Main content #}
            <div class="lg:col-span-3">
                <div class="border border-gray-200 rounded-xl p-6 bg-white">
                    <h2 class="text-xl font-semibold text-gray-900 mb-6">Réservations</h2>
                    
                    {{ form_start(form) }}
                        <div class="space-y-6">
                        {# Instant Booking #}
                        <div class="border-b border-gray-100 pb-6">
                            <div class="flex items-start justify-between">
                                <div class="flex-1">
                                    <label class="flex items-center gap-3 cursor-pointer">
                                        {{ form_widget(form.instantBooking, { attr: { class: 'w-4 h-4 rounded' } }) }}
                                        <div>
                                            <h3 class="font-semibold text-gray-900">Réservation instantanée</h3>
                                            <p class="text-sm text-gray-500 mt-1">
                                                {% if property.instantBooking %}
                                                    <span class="text-emerald-700 font-medium">✓ Activée</span>
                                                    <br>
                                                    Les réservations sont automatiquement confirmées si les dates sont disponibles.
                                                {% else %}
                                                    <span class="text-amber-700 font-medium">⊘ Désactivée</span>
                                                    <br>
                                                    Les réservations nécessitent votre approbation manuelle.
                                                {% endif %}
                                            </p>
                                        </div>
                                    </label>
                                </div>
                            </div>
                        </div>

                        {# Check-in Time #}
                        <div class="border-b border-gray-100 pb-6">
                            <label class="block mb-2">
                                <span class="font-semibold text-gray-900">Heure d'arrivée</span>
                                <p class="text-sm text-gray-500 mt-1">À quelle heure les voyageurs peuvent-ils arriver ?</p>
                            </label>
                            <div class="mt-3">
                                {{ form_widget(form.checkinTime, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-brand focus:border-transparent' } }) }}
                                {% if form.checkinTime.vars.help %}
                                    <p class="text-xs text-gray-500 mt-2">{{ form.checkinTime.vars.help }}</p>
                                {% endif %}
                            </div>
                        </div>

                        {# Check-out Time #}
                        <div class="pb-6">
                            <label class="block mb-2">
                                <span class="font-semibold text-gray-900">Heure de départ</span>
                                <p class="text-sm text-gray-500 mt-1">À quelle heure les voyageurs doivent-ils partir ?</p>
                            </label>
                            <div class="mt-3">
                                {{ form_widget(form.checkoutTime, { attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-brand focus:border-transparent' } }) }}
                                {% if form.checkoutTime.vars.help %}
                                    <p class="text-xs text-gray-500 mt-2">{{ form.checkoutTime.vars.help }}</p>
                                {% endif %}
                            </div>
                        </div>

                        {# Form errors #}
                        {% if form_errors(form) %}
                            <div class="bg-red-50 border border-red-200 rounded-xl p-4 text-sm text-red-800">
                                {{ form_errors(form) }}
                            </div>
                        {% endif %}

                        {# Submit button #}
                        <div class="flex items-center gap-3 pt-4">
                            <button type="submit" class="px-6 py-3 bg-brand hover:bg-brandHover text-white font-semibold rounded-xl transition">
                                Enregistrer les modifications
                            </button>
                            <a href="{{ path('app_account_properties') }}" class="px-6 py-3 border border-gray-200 text-gray-700 font-semibold rounded-xl hover:bg-gray-50 transition">
                                Annuler
                            </a>
                        </div>
                        </div>
                    {{ form_end(form) }}
                </div>

                {# Information box #}
                <div class="mt-6 border border-blue-200 rounded-xl p-4 bg-blue-50">
                    <div class="flex gap-3">
                        <i class="fa-solid fa-circle-info text-blue-600 flex-shrink-0 mt-1"></i>
                        <div class="text-sm text-blue-800">
                            <p class="font-semibold mb-1">À propos de la réservation instantanée</p>
                            <ul class="list-disc list-inside space-y-1 text-blue-700">
                                <li><strong>Activée :</strong> Les voyageurs peuvent réserver immédiatement sans attendre votre confirmation. Les réservations conflictuelles sont rejetées automatiquement.</li>
                                <li><strong>Désactivée :</strong> Chaque réservation doit être examinée et confirmée manuellement.</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
{% endblock %}
