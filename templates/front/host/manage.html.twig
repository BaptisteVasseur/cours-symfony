{% extends 'layout/app.html.twig' %}

{% block title %}Gestion — {{ property.title }}{% endblock %}

{% set dayLabels = ['L', 'M', 'M', 'J', 'V', 'S', 'D'] %}

{% block content %}
<main class="flex-grow px-6 md:px-12 py-8 max-w-7xl mx-auto w-full">

    <a href="{{ path('app_account_properties') }}" class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-gray-900 mb-6">
        <i class="fa-solid fa-arrow-left"></i> Mes propriétés
    </a>

    <div class="flex flex-wrap items-start justify-between gap-4 mb-8">
        <div>
            <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">{{ property.title }}</h1>
            {% if property.address %}
                <p class="text-gray-500 mt-1">{{ property.address.city }}{% if property.address.country %}, {{ property.address.country }}{% endif %}</p>
            {% endif %}
        </div>
        <div class="flex items-center gap-2">
            {% if property.instantBooking %}
                <span class="text-xs font-semibold px-3 py-1 rounded-full bg-green-100 text-green-800">
                    <i class="fa-solid fa-bolt mr-1"></i>Réservation instantanée
                </span>
            {% else %}
                <span class="text-xs font-semibold px-3 py-1 rounded-full bg-gray-100 text-gray-700">
                    <i class="fa-solid fa-clock mr-1"></i>Sur demande
                </span>
            {% endif %}
        </div>
    </div>

    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div class="mb-4 px-4 py-3 rounded-lg text-sm font-medium
                {{ type == 'success' ? 'bg-green-50 text-green-800 border border-green-200' : 'bg-red-50 text-red-800 border border-red-200' }}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    <div class="grid grid-cols-1 xl:grid-cols-3 gap-8">

        <div class="xl:col-span-2 space-y-8">

            <section>
                <h2 class="text-lg font-semibold text-gray-900 mb-4">Calendrier des disponibilités</h2>
                <div class="flex items-center gap-4 mb-4 text-sm text-gray-600">
                    <span class="flex items-center gap-1.5">
                        <span class="w-3 h-3 rounded-full bg-brand inline-block"></span>Occupé
                    </span>
                    <span class="flex items-center gap-1.5">
                        <span class="w-3 h-3 rounded-full bg-gray-200 inline-block"></span>Disponible
                    </span>
                </div>
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                    {% for month in calendarMonths %}
                        <div class="bg-white border border-gray-200 rounded-xl p-4">
                            <h3 class="text-sm font-semibold text-gray-800 text-center mb-3">{{ month.label }}</h3>
                            <div class="grid grid-cols-7 mb-1">
                                {% for label in dayLabels %}
                                    <div class="text-center text-xs text-gray-400 font-medium py-1">{{ label }}</div>
                                {% endfor %}
                            </div>
                            {% for week in month.weeks %}
                                <div class="grid grid-cols-7">
                                    {% for day in week %}
                                        <div class="flex items-center justify-center p-0.5">
                                            <span class="w-7 h-7 flex items-center justify-center text-xs rounded-full
                                                {% if not day.isCurrentMonth %}
                                                    text-gray-200
                                                {% elseif day.isOccupied %}
                                                    bg-brand text-white font-semibold
                                                {% elseif day.isToday %}
                                                    ring-2 ring-brand text-brand font-semibold
                                                {% elseif day.isPast %}
                                                    text-gray-400
                                                {% else %}
                                                    text-gray-700
                                                {% endif %}
                                            ">
                                                {{ day.day }}
                                            </span>
                                        </div>
                                    {% endfor %}
                                </div>
                            {% endfor %}
                        </div>
                    {% endfor %}
                </div>
            </section>

            <section>
                <h2 class="text-lg font-semibold text-gray-900 mb-4">
                    Réservations en cours et à venir
                    {% if upcomingReservations|length > 0 %}
                        <span class="ml-2 text-sm font-normal text-gray-500">({{ upcomingReservations|length }})</span>
                    {% endif %}
                </h2>
                {% if upcomingReservations|length > 0 %}
                    <div class="space-y-3">
                        {% for reservation in upcomingReservations %}
                            {% set guestProfile = reservation.guest ? reservation.guest.profile : null %}
                            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 p-4 bg-white border border-gray-200 rounded-xl">
                                <div class="flex items-center gap-3 min-w-0">
                                    <div class="w-9 h-9 rounded-full bg-gray-100 flex items-center justify-center shrink-0">
                                        <i class="fa-solid fa-user text-gray-400 text-sm"></i>
                                    </div>
                                    <div class="min-w-0">
                                        <p class="text-sm font-semibold text-gray-900 truncate">
                                            {% if guestProfile %}
                                                {{ guestProfile.firstName }} {{ guestProfile.lastName }}
                                            {% else %}
                                                Voyageur
                                            {% endif %}
                                        </p>
                                        <p class="text-xs text-gray-500">
                                            {{ reservation.checkinDate|date('d/m/Y') }} → {{ reservation.checkoutDate|date('d/m/Y') }}
                                            · {{ reservation.guestsCount }} voyageur{{ reservation.guestsCount > 1 ? 's' : '' }}
                                        </p>
                                    </div>
                                </div>
                                <div class="flex items-center gap-3 shrink-0">
                                    <span class="text-sm font-semibold text-gray-900">
                                        {{ reservation.totalPrice|number_format(0, ',', ' ') }} {{ reservation.currency }}
                                    </span>
                                    <span class="text-xs font-semibold px-2.5 py-1 rounded-full bg-green-100 text-green-800">Confirmée</span>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="text-center py-10 border border-dashed border-gray-200 rounded-xl">
                        <i class="fa-regular fa-calendar text-3xl text-gray-300 mb-2"></i>
                        <p class="text-sm text-gray-500">Aucune réservation à venir.</p>
                    </div>
                {% endif %}
            </section>

            <section>
                <h2 class="text-lg font-semibold text-gray-900 mb-4">
                    Annulations
                    {% if cancelledReservations|length > 0 %}
                        <span class="ml-2 text-sm font-normal text-gray-500">({{ cancelledReservations|length }})</span>
                    {% endif %}
                </h2>
                {% if cancelledReservations|length > 0 %}
                    <div class="space-y-3">
                        {% for reservation in cancelledReservations %}
                            {% set guestProfile = reservation.guest ? reservation.guest.profile : null %}
                            {% set cancelledByHost = false %}
                            {% for entry in reservation.statusHistory %}
                                {% if entry.newStatus == 'cancelled' and entry.changedBy and entry.changedBy.id == property.host.id %}
                                    {% set cancelledByHost = true %}
                                {% endif %}
                            {% endfor %}
                            <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-3 p-4 bg-red-50 border border-red-200 rounded-xl">
                                <div class="flex items-start gap-3 min-w-0">
                                    <div class="w-9 h-9 rounded-full bg-red-100 flex items-center justify-center shrink-0 mt-0.5">
                                        <i class="fa-solid fa-xmark text-red-400 text-sm"></i>
                                    </div>
                                    <div class="min-w-0">
                                        <p class="text-sm font-semibold text-gray-900 truncate">
                                            {% if guestProfile %}
                                                {{ guestProfile.firstName }} {{ guestProfile.lastName }}
                                            {% else %}
                                                Voyageur
                                            {% endif %}
                                        </p>
                                        <p class="text-xs text-gray-500 mt-0.5">
                                            {{ reservation.checkinDate|date('d/m/Y') }} → {{ reservation.checkoutDate|date('d/m/Y') }}
                                            · {{ reservation.guestsCount }} voyageur{{ reservation.guestsCount > 1 ? 's' : '' }}
                                        </p>
                                        {% if reservation.cancellationReason %}
                                            <p class="text-xs text-red-700 mt-1.5 italic">
                                                "{{ reservation.cancellationReason }}"
                                            </p>
                                        {% endif %}
                                        <p class="text-xs text-gray-400 mt-1">
                                            Annulée par
                                            {% if cancelledByHost %}
                                                vous (l'hôte)
                                            {% else %}
                                                le voyageur
                                            {% endif %}
                                        </p>
                                    </div>
                                </div>
                                <span class="text-xs font-semibold px-2.5 py-1 rounded-full bg-red-100 text-red-700 shrink-0">
                                    {{ reservation.totalPrice|number_format(0, ',', ' ') }} {{ reservation.currency }}
                                </span>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="text-center py-10 border border-dashed border-gray-200 rounded-xl">
                        <i class="fa-regular fa-circle-check text-3xl text-gray-300 mb-2"></i>
                        <p class="text-sm text-gray-500">Aucune annulation.</p>
                    </div>
                {% endif %}
            </section>

        </div>

        <aside>
            <div class="sticky top-24 space-y-6">

                <section class="bg-white border border-gray-200 rounded-xl p-5">
                    <button type="button"
                        onclick="this.nextElementSibling.classList.toggle('hidden')"
                        class="flex items-center justify-between w-full text-left">
                        <h2 class="text-base font-semibold text-gray-900">
                            <i class="fa-solid fa-ban mr-2 text-gray-400"></i>Bloquer des dates
                        </h2>
                        <i class="fa-solid fa-chevron-down text-gray-400 text-sm"></i>
                    </button>
                    <div class="hidden mt-4">
                        <form method="post" action="{{ path('app_host_block', { id: property.id }) }}" class="space-y-3">
                            <input type="hidden" name="_token" value="{{ csrf_token('block_' ~ property.id) }}">
                            <div>
                                <label class="block text-xs font-medium text-gray-700 mb-1">Date de début <span class="text-red-500">*</span></label>
                                <input type="date" name="start_date" required
                                    class="w-full text-sm border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand">
                            </div>
                            <div>
                                <label class="block text-xs font-medium text-gray-700 mb-1">Date de fin <span class="text-red-500">*</span></label>
                                <input type="date" name="end_date" required
                                    class="w-full text-sm border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand">
                            </div>
                            <div>
                                <label class="block text-xs font-medium text-gray-700 mb-1">Motif <span class="text-gray-400">(optionnel)</span></label>
                                <textarea name="reason" rows="2"
                                    placeholder="Ex : Travaux, usage personnel…"
                                    class="w-full text-sm border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-brand resize-none"></textarea>
                            </div>
                            <button type="submit" class="w-full text-sm font-semibold py-2 rounded-lg bg-gray-900 text-white hover:bg-gray-700 transition">
                                Bloquer ces dates
                            </button>
                        </form>
                    </div>
                </section>

                {% if blocks|length > 0 %}
                <section>
                    <h2 class="text-base font-semibold text-gray-900 mb-3">
                        Dates bloquées
                        <span class="ml-1 text-sm font-normal text-gray-500">({{ blocks|length }})</span>
                    </h2>
                    <div class="space-y-2">
                        {% for block in blocks %}
                            <div class="bg-orange-50 border border-orange-200 rounded-xl p-3">
                                <div class="flex items-start gap-2">
                                    <i class="fa-solid fa-ban text-orange-400 text-xs mt-0.5 shrink-0"></i>
                                    <div class="min-w-0">
                                        <p class="text-sm font-medium text-gray-800">
                                            {{ block.checkinDate|date('d/m/Y') }} → {{ block.checkoutDate|date('d/m/Y') }}
                                        </p>
                                        {% if block.blockReason %}
                                            <p class="text-xs text-gray-500 mt-0.5 truncate">{{ block.blockReason }}</p>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </section>
                {% endif %}

                <section class="bg-white border border-gray-200 rounded-xl p-5">
                    <h2 class="text-base font-semibold text-gray-900 mb-4">
                        <i class="fa-solid fa-calendar-days mr-2 text-gray-400"></i>Synchronisation calendrier
                    </h2>
                    {% if property.calendarToken %}
                        <p class="text-xs text-gray-500 mb-3">Copiez ce lien dans Google Calendar, Outlook ou tout autre outil compatible iCal.</p>
                        <div class="flex items-center gap-2 mb-4">
                            <input type="text" readonly
                                value="{{ url('api_property_calendar', { id: property.id }) ~ '?token=' ~ property.calendarToken }}"
                                class="flex-1 text-xs border border-gray-300 rounded-lg px-3 py-2 bg-gray-50 text-gray-700 focus:outline-none"
                                onclick="this.select()">
                            <button type="button"
                                onclick="navigator.clipboard.writeText(this.previousElementSibling.value); this.textContent='Copié !';"
                                class="shrink-0 text-xs font-semibold px-3 py-2 rounded-lg border border-gray-300 text-gray-700 hover:bg-gray-50 transition">
                                Copier
                            </button>
                        </div>
                        <div class="flex gap-2">
                            <form method="post" action="{{ path('app_host_calendar_token_generate', { id: property.id }) }}" class="flex-1">
                                <input type="hidden" name="_token" value="{{ csrf_token('calendar_token_' ~ property.id) }}">
                                <button type="submit"
                                    onclick="return confirm('Regénérer le lien rendra l\'ancien inutilisable. Continuer ?')"
                                    class="w-full text-xs font-semibold py-2 rounded-lg border border-gray-300 text-gray-700 hover:bg-gray-50 transition">
                                    <i class="fa-solid fa-rotate mr-1"></i>Regénérer
                                </button>
                            </form>
                            <form method="post" action="{{ path('app_host_calendar_token_revoke', { id: property.id }) }}" class="flex-1">
                                <input type="hidden" name="_token" value="{{ csrf_token('calendar_token_' ~ property.id) }}">
                                <button type="submit"
                                    onclick="return confirm('Révoquer le lien le rendra inutilisable immédiatement. Continuer ?')"
                                    class="w-full text-xs font-semibold py-2 rounded-lg border border-red-200 text-red-600 hover:bg-red-50 transition">
                                    <i class="fa-solid fa-trash mr-1"></i>Révoquer
                                </button>
                            </form>
                        </div>
                    {% else %}
                        <p class="text-xs text-gray-500 mb-4">Générez un lien iCal pour synchroniser vos réservations avec votre calendrier personnel.</p>
                        <form method="post" action="{{ path('app_host_calendar_token_generate', { id: property.id }) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('calendar_token_' ~ property.id) }}">
                            <button type="submit" class="w-full text-sm font-semibold py-2 rounded-lg bg-gray-900 text-white hover:bg-gray-700 transition">
                                <i class="fa-solid fa-link mr-2"></i>Générer le lien iCal
                            </button>
                        </form>
                    {% endif %}
                </section>

                <div>
                <div class="flex items-center justify-between mb-4">
                    <h2 class="text-lg font-semibold text-gray-900">Demandes en attente</h2>
                    {% if pendingReservations|length > 0 %}
                        <span class="text-xs font-bold px-2 py-0.5 rounded-full bg-yellow-100 text-yellow-800">
                            {{ pendingReservations|length }}
                        </span>
                    {% endif %}
                </div>

                {% if pendingReservations|length > 0 %}
                    <div class="space-y-4">
                        {% for reservation in pendingReservations %}
                            {% set guestProfile = reservation.guest ? reservation.guest.profile : null %}
                            <div class="bg-white border border-gray-200 rounded-xl p-4">
                                <div class="flex items-center gap-3 mb-3">
                                    <div class="w-9 h-9 rounded-full bg-gray-100 flex items-center justify-center shrink-0">
                                        <i class="fa-solid fa-user text-gray-400 text-sm"></i>
                                    </div>
                                    <div class="min-w-0">
                                        <p class="text-sm font-semibold text-gray-900 truncate">
                                            {% if guestProfile %}
                                                {{ guestProfile.firstName }} {{ guestProfile.lastName }}
                                            {% else %}
                                                Voyageur
                                            {% endif %}
                                        </p>
                                        <p class="text-xs text-gray-400">Demande reçue le {{ reservation.createdAt|date('d/m/Y') }}</p>
                                    </div>
                                </div>
                                <dl class="text-xs text-gray-600 space-y-1 mb-3">
                                    <div class="flex justify-between">
                                        <dt class="text-gray-400">Arrivée</dt>
                                        <dd class="font-medium">{{ reservation.checkinDate|date('d/m/Y') }}</dd>
                                    </div>
                                    <div class="flex justify-between">
                                        <dt class="text-gray-400">Départ</dt>
                                        <dd class="font-medium">{{ reservation.checkoutDate|date('d/m/Y') }}</dd>
                                    </div>
                                    <div class="flex justify-between">
                                        <dt class="text-gray-400">Voyageurs</dt>
                                        <dd class="font-medium">{{ reservation.guestsCount }}</dd>
                                    </div>
                                    <div class="flex justify-between">
                                        <dt class="text-gray-400">Total</dt>
                                        <dd class="font-semibold text-gray-900">{{ reservation.totalPrice|number_format(0, ',', ' ') }} {{ reservation.currency }}</dd>
                                    </div>
                                </dl>

                                {% if not property.instantBooking %}
                                    <div class="flex gap-2">
                                        <form method="post" action="{{ path('app_host_reservation_accept', { id: reservation.id }) }}" class="flex-1">
                                            <input type="hidden" name="_token" value="{{ csrf_token('accept_' ~ reservation.id) }}">
                                            <button type="submit" class="w-full text-sm font-semibold py-2 rounded-lg bg-brand text-white hover:bg-brandHover transition">
                                                <i class="fa-solid fa-check mr-1"></i>Accepter
                                            </button>
                                        </form>
                                        <button type="button"
                                            onclick="this.closest('.bg-white').querySelector('.refuse-form').classList.toggle('hidden')"
                                            class="flex-1 text-sm font-semibold py-2 rounded-lg border border-gray-300 text-gray-700 hover:bg-gray-50 transition">
                                            <i class="fa-solid fa-xmark mr-1"></i>Refuser
                                        </button>
                                    </div>
                                    <div class="refuse-form hidden mt-3 pt-3 border-t border-gray-100">
                                        <form method="post" action="{{ path('app_host_reservation_refuse', { id: reservation.id }) }}">
                                            <input type="hidden" name="_token" value="{{ csrf_token('refuse_' ~ reservation.id) }}">
                                            <label class="block text-xs font-medium text-gray-700 mb-1">Motif du refus <span class="text-red-500">*</span></label>
                                            <textarea name="reason" required rows="3"
                                                placeholder="Expliquez la raison du refus au voyageur…"
                                                class="w-full text-sm border border-gray-300 rounded-lg p-2.5 focus:outline-none focus:ring-2 focus:ring-brand resize-none"></textarea>
                                            <button type="submit" class="mt-2 w-full text-sm font-semibold py-2 rounded-lg bg-red-600 text-white hover:bg-red-700 transition">
                                                Confirmer le refus
                                            </button>
                                        </form>
                                    </div>
                                {% else %}
                                    <p class="text-xs text-center text-gray-400 pt-2 border-t border-gray-100">Acceptée automatiquement (réservation instantanée)</p>
                                {% endif %}
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="text-center py-10 border border-dashed border-gray-200 rounded-xl">
                        <i class="fa-regular fa-bell text-3xl text-gray-300 mb-2"></i>
                        <p class="text-sm text-gray-500">Aucune demande en attente.</p>
                    </div>
                {% endif %}
                </div>

            </div>
        </aside>

    </div>
</main>
{% endblock %}
