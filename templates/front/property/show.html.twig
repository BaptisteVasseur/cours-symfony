{% extends 'layout/app.html.twig' %}

{% set cover = property.coverMedia %}
{% set averageRating = property.averageRating %}
{% set placeholderImage = 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=1200&q=80' %}
{% set hostProfile = property.host ? property.host.profile : null %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-6xl mx-auto w-full">
        <div class="mb-6">
            <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">{{ property.title }}</h1>
            <div class="flex flex-wrap items-center gap-2 mt-2 text-sm text-gray-600">
                {% if averageRating %}
                    <span class="flex items-center gap-1 font-semibold text-gray-900">
                        <i class="fa-solid fa-star text-xs"></i>
                        {{ averageRating|number_format(2, ',') }}
                    </span>
                    <span>·</span>
                    <span>{{ totalReviews|default(property.reviews|length) }} avis</span>
                    <span>·</span>
                {% endif %}
                {% if property.address %}
                    <span>{{ property.address.city }}, {{ property.address.country }}</span>
                {% endif %}
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-4 gap-2 rounded-xl overflow-hidden mb-10 h-[300px] md:h-[480px]">
            <div class="md:col-span-2 md:row-span-2 relative">
                <img
                    src="{{ cover ? cover.fileUrl : placeholderImage }}"
                    alt="{{ property.title }}"
                    class="w-full h-full object-cover"
                >
            </div>
            {% for medium in property.media|slice(1, 4) %}
                <div class="hidden md:block relative">
                    <img src="{{ medium.fileUrl }}" alt="{{ property.title }}" class="w-full h-full object-cover">
                </div>
            {% endfor %}
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
            <div class="lg:col-span-2 space-y-10">
                <section class="flex items-center justify-between pb-8 border-b border-gray-200">
                    <div>
                        <h2 class="text-xl font-semibold text-gray-900">
                            Logement proposé par {{ hostProfile ? hostProfile.firstName : 'un hôte' }}
                        </h2>
                        <p class="text-gray-500 mt-1">
                            {{ property.maxGuests }} voyageur{{ property.maxGuests > 1 ? 's' : '' }}
                            · {{ property.bedrooms }} chambre{{ property.bedrooms > 1 ? 's' : '' }}
                            · {{ property.beds }} lit{{ property.beds > 1 ? 's' : '' }}
                            · {{ property.bathrooms }} salle{{ property.bathrooms > 1 ? 's' : '' }} de bain
                        </p>
                    </div>
                    <div class="w-14 h-14 rounded-full bg-gray-200 overflow-hidden shrink-0">
                        {% if hostProfile and hostProfile.avatarUrl %}
                            <img src="{{ hostProfile.avatarUrl }}" alt="Hôte" class="w-full h-full object-cover">
                        {% else %}
                            <div class="w-full h-full flex items-center justify-center text-gray-500 font-bold">
                                {{ hostProfile and hostProfile.firstName ? hostProfile.firstName|first|upper : 'H' }}
                            </div>
                        {% endif %}
                    </div>
                </section>

                {% if property.description %}
                    <section class="pb-8 border-b border-gray-200">
                        <h2 class="text-xl font-semibold text-gray-900 mb-4">À propos de ce logement</h2>
                        <p class="text-gray-700 leading-relaxed whitespace-pre-line">{{ property.description }}</p>
                    </section>
                {% endif %}

                {% if property.propertyAmenities|length > 0 %}
                    <section class="pb-8 border-b border-gray-200">
                        <h2 class="text-xl font-semibold text-gray-900 mb-4">Équipements</h2>
                        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                            {% for propertyAmenity in property.propertyAmenities %}
                                {% if propertyAmenity.amenity %}
                                    <li class="flex items-center gap-3 text-gray-700">
                                        <i class="fa-solid fa-check text-gray-900"></i>
                                        {{ propertyAmenity.amenity.label }}
                                    </li>
                                {% endif %}
                            {% endfor %}
                        </ul>
                    </section>
                {% endif %}

                <section>
                    <h2 class="text-xl font-semibold text-gray-900 mb-6">
                        Avis ({{ totalReviews|default(property.reviews|length) }})
                    </h2>
                    {% set reviewCount = totalReviews|default(property.reviews|length) %}
                    {% if reviewCount > 0 %}
                        <div class="space-y-6">
                            {% for review in reviews|default(property.reviews) %}
                                {% include 'front/property/partials/review_item.html.twig' with { review: review } %}
                            {% endfor %}
                        </div>
                        {% if reviewCount > 5 %}
                            <a href="{{ path('app_logement_reviews', { id: property.id }) }}" class="inline-block mt-6 text-sm font-semibold underline text-gray-900 hover:text-brand">
                                Tout afficher ({{ reviewCount }} avis)
                            </a>
                        {% endif %}
                    {% else %}
                        <p class="text-gray-500 text-sm">Aucun avis pour le moment.</p>
                    {% endif %}
                </section>
            </div>

            <aside class="lg:col-span-1">
                <div class="sticky top-28 border border-gray-200 rounded-xl shadow-lg p-6 space-y-4">
                    <p class="text-2xl font-semibold">
                        <span class="font-bold">{{ property.pricePerNight|number_format(0, ',', ' ') }} €</span>
                        <span class="text-base font-normal text-gray-600"> / nuit</span>
                    </p>

                    {# Inputs dates + voyageurs #}
                    <div class="border border-gray-300 rounded-xl overflow-hidden text-sm">
                        <div class="grid grid-cols-2 divide-x divide-gray-300">
                            <div class="p-3">
                                <p class="text-[10px] font-bold uppercase text-gray-700 mb-1">Arrivée</p>
                                <input type="date" id="detail-checkin"
                                       value="{{ checkin }}"
                                       class="w-full text-sm text-gray-700 focus:outline-none bg-transparent cursor-pointer">
                            </div>
                            <div class="p-3">
                                <p class="text-[10px] font-bold uppercase text-gray-700 mb-1">Départ</p>
                                <input type="date" id="detail-checkout"
                                       value="{{ checkout }}"
                                       class="w-full text-sm text-gray-700 focus:outline-none bg-transparent cursor-pointer">
                            </div>
                        </div>
                        <div class="p-3 border-t border-gray-300">
                            <p class="text-[10px] font-bold uppercase text-gray-700 mb-1">Voyageurs</p>
                            <div class="flex items-center gap-2">
                                <button type="button" id="detail-guests-minus"
                                        class="w-6 h-6 rounded-full border border-gray-300 flex items-center justify-center text-gray-500 hover:border-gray-500 transition text-xs">
                                    <i class="fa-solid fa-minus"></i>
                                </button>
                                <span id="detail-guests-count" class="text-sm font-semibold text-gray-800 w-4 text-center">{{ guests }}</span>
                                <button type="button" id="detail-guests-plus"
                                        class="w-6 h-6 rounded-full border border-gray-300 flex items-center justify-center text-gray-500 hover:border-gray-500 transition text-xs">
                                    <i class="fa-solid fa-plus"></i>
                                </button>
                                <span class="text-xs text-gray-400">/ {{ property.maxGuests }} max</span>
                            </div>
                        </div>
                    </div>

                    {# Prix estimé #}
                    <div id="detail-price-box" class="hidden bg-gray-50 rounded-xl p-3 text-sm space-y-1.5">
                        <div class="flex justify-between text-gray-600">
                            <span id="detail-nights-label"></span>
                            <span id="detail-subtotal"></span>
                        </div>
                        {% if property.cleaningFee and property.cleaningFee > 0 %}
                            <div class="flex justify-between text-gray-600">
                                <span>Frais de ménage</span>
                                <span>{{ property.cleaningFee|number_format(0, ',', ' ') }} €</span>
                            </div>
                        {% endif %}
                        <div class="flex justify-between text-gray-600">
                            <span>Frais de service <span class="text-[11px] text-gray-400">(12 %)</span></span>
                            <span id="detail-service"></span>
                        </div>
                        <div class="flex justify-between font-bold text-gray-900 pt-1 border-t border-gray-200">
                            <span>Total estimé</span>
                            <span id="detail-total"></span>
                        </div>
                    </div>

                    <a id="detail-reserve-btn"
                       href="{{ path('app_booking_checkout', { id: property.id }) }}"
                       class="block w-full bg-brand hover:bg-brandHover text-white font-semibold py-3 rounded-lg transition text-center">
                        Réserver
                    </a>
                    {% if property.instantBooking %}
                        <p class="text-center text-xs text-gray-500">
                            <i class="fa-solid fa-bolt text-xs mr-1"></i>Réservation instantanée disponible
                        </p>
                    {% endif %}
                </div>
            </aside>
        </div>
    </main>

<script>
(function () {
    const BASE_URL    = {{ path('app_booking_checkout', { id: property.id })|json_encode|raw }};
    const PRICE       = {{ property.pricePerNight }};
    const CLEANING    = {{ property.cleaningFee ?? 0 }};
    const MAX_GUESTS  = {{ property.maxGuests }};
    const TODAY       = new Date().toISOString().split('T')[0];

    const ci     = document.getElementById('detail-checkin');
    const co     = document.getElementById('detail-checkout');
    const countEl = document.getElementById('detail-guests-count');
    const btn    = document.getElementById('detail-reserve-btn');
    const priceBox = document.getElementById('detail-price-box');

    ci.min = TODAY;
    let guestsVal = parseInt(countEl.textContent, 10) || 1;

    function fmt(n) { return Math.round(n).toLocaleString('fr-FR'); }

    function update() {
        const params = new URLSearchParams();
        if (ci.value)  params.set('checkin',  ci.value);
        if (co.value)  params.set('checkout', co.value);
        if (guestsVal > 1) params.set('guests', guestsVal);

        btn.href = params.toString() ? `${BASE_URL}?${params}` : BASE_URL;

        if (ci.value && co.value && ci.value < co.value) {
            const nights     = Math.round((new Date(co.value) - new Date(ci.value)) / 86400000);
            const subtotal   = PRICE * nights;
            const service    = Math.round(subtotal * 0.12 * 100) / 100;
            const total      = subtotal + CLEANING + service;

            document.getElementById('detail-nights-label').textContent = `${nights} nuit${nights > 1 ? 's' : ''} × ${fmt(PRICE)} €`;
            document.getElementById('detail-subtotal').textContent     = `${fmt(subtotal)} €`;
            document.getElementById('detail-service').textContent      = `${fmt(service)} €`;
            document.getElementById('detail-total').textContent        = `${fmt(total)} €`;
            priceBox.classList.remove('hidden');
        } else {
            priceBox.classList.add('hidden');
        }
    }

    ci.addEventListener('change', function () {
        if (ci.value) {
            const next = new Date(ci.value);
            next.setDate(next.getDate() + 1);
            co.min = next.toISOString().split('T')[0];
            if (co.value && co.value <= ci.value) co.value = '';
        }
        update();
    });
    co.addEventListener('change', update);

    document.getElementById('detail-guests-minus').addEventListener('click', function () {
        if (guestsVal > 1) { guestsVal--; countEl.textContent = guestsVal; update(); }
    });
    document.getElementById('detail-guests-plus').addEventListener('click', function () {
        if (guestsVal < MAX_GUESTS) { guestsVal++; countEl.textContent = guestsVal; update(); }
    });

    update();
})();
</script>
{% endblock %}
