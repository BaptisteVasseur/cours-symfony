{% extends 'layout/app.html.twig' %}

{% set cover = property.coverMedia %}
{% set averageRating = property.averageRating %}
{% set placeholderImage = 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=1200&q=80' %}
{% set hostProfile = property.host ? property.host.profile : null %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-6xl mx-auto w-full">
        <div class="mb-6">
            <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">{{ property.title }}</h1>
            <div class="flex flex-wrap items-center gap-2 mt-2 text-sm text-gray-600">
                {% if averageRating %}
                    <span class="flex items-center gap-1 font-semibold text-gray-900">
                        <i class="fa-solid fa-star text-xs"></i>
                        {{ averageRating|number_format(2, ',') }}
                    </span>
                    <span>·</span>
                    <span>{{ totalReviews|default(property.reviews|length) }} avis</span>
                    <span>·</span>
                {% endif %}
                {% if property.address %}
                    <span>{{ property.address.city }}, {{ property.address.country }}</span>
                {% endif %}
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-4 gap-2 rounded-xl overflow-hidden mb-10 h-[300px] md:h-[480px]">
            <div class="md:col-span-2 md:row-span-2 relative">
                <img
                    src="{{ cover ? cover.fileUrl : placeholderImage }}"
                    alt="{{ property.title }}"
                    class="w-full h-full object-cover"
                >
            </div>
            {% for medium in property.media|slice(1, 4) %}
                <div class="hidden md:block relative">
                    <img src="{{ medium.fileUrl }}" alt="{{ property.title }}" class="w-full h-full object-cover">
                </div>
            {% endfor %}
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
            <div class="lg:col-span-2 space-y-10">
                <section class="flex items-center justify-between pb-8 border-b border-gray-200">
                    <div>
                        <h2 class="text-xl font-semibold text-gray-900">
                            Logement proposé par {{ hostProfile ? hostProfile.firstName : 'un hôte' }}
                        </h2>
                        <p class="text-gray-500 mt-1">
                            {{ property.maxGuests }} voyageur{{ property.maxGuests > 1 ? 's' : '' }}
                            · {{ property.bedrooms }} chambre{{ property.bedrooms > 1 ? 's' : '' }}
                            · {{ property.beds }} lit{{ property.beds > 1 ? 's' : '' }}
                            · {{ property.bathrooms }} salle{{ property.bathrooms > 1 ? 's' : '' }} de bain
                        </p>
                    </div>
                    <div class="w-14 h-14 rounded-full bg-gray-200 overflow-hidden shrink-0">
                        {% if hostProfile and hostProfile.avatarUrl %}
                            <img src="{{ hostProfile.avatarUrl }}" alt="Hôte" class="w-full h-full object-cover">
                        {% else %}
                            <div class="w-full h-full flex items-center justify-center text-gray-500 font-bold">
                                {{ hostProfile and hostProfile.firstName ? hostProfile.firstName|first|upper : 'H' }}
                            </div>
                        {% endif %}
                    </div>
                </section>

                {% if property.description %}
                    <section class="pb-8 border-b border-gray-200">
                        <h2 class="text-xl font-semibold text-gray-900 mb-4">À propos de ce logement</h2>
                        <p class="text-gray-700 leading-relaxed whitespace-pre-line">{{ property.description }}</p>
                    </section>
                {% endif %}

                {% if property.propertyAmenities|length > 0 %}
                    <section class="pb-8 border-b border-gray-200">
                        <h2 class="text-xl font-semibold text-gray-900 mb-4">Équipements</h2>
                        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                            {% for propertyAmenity in property.propertyAmenities %}
                                {% if propertyAmenity.amenity %}
                                    <li class="flex items-center gap-3 text-gray-700">
                                        <i class="fa-solid fa-check text-gray-900"></i>
                                        {{ propertyAmenity.amenity.label }}
                                    </li>
                                {% endif %}
                            {% endfor %}
                        </ul>
                    </section>
                {% endif %}

                <section>
                    <h2 class="text-xl font-semibold text-gray-900 mb-6">
                        Avis ({{ totalReviews|default(property.reviews|length) }})
                    </h2>
                    {% set reviewCount = totalReviews|default(property.reviews|length) %}
                    {% if reviewCount > 0 %}
                        <div class="space-y-6">
                            {% for review in reviews|default(property.reviews) %}
                                {% include 'front/property/partials/review_item.html.twig' with { review: review } %}
                            {% endfor %}
                        </div>
                        {% if reviewCount > 5 %}
                            <a href="{{ path('app_logement_reviews', { id: property.id }) }}" class="inline-block mt-6 text-sm font-semibold underline text-gray-900 hover:text-brand">
                                Tout afficher ({{ reviewCount }} avis)
                            </a>
                        {% endif %}
                    {% else %}
                        <p class="text-gray-500 text-sm">Aucun avis pour le moment.</p>
                    {% endif %}
                </section>
            </div>

            <aside class="lg:col-span-1">
                <div class="sticky top-28 border border-gray-200 rounded-xl shadow-lg p-6">

                    {% for label, messages in app.flashes %}
                        {% for message in messages %}
                            <div class="mb-4 px-3 py-2 rounded-lg text-xs {{ label == 'success' ? 'bg-emerald-50 text-emerald-800' : 'bg-red-50 text-red-800' }}">{{ message }}</div>
                        {% endfor %}
                    {% endfor %}

                    {% if app.user and app.user.id == property.host.id %}

                        {# Vue hôte : bloquer des dates #}
                        <p class="text-sm font-semibold text-gray-800 mb-1">Bloquer une période</p>
                        <p class="text-xs text-gray-500 mb-4">Les dates bloquées ne seront pas réservables par les voyageurs.</p>

                        <form method="post" action="{{ path('app_host_block_dates', { id: property.id }) }}" class="space-y-3">
                            <input type="hidden" name="_token" value="{{ csrf_token('block_dates' ~ property.id) }}">
                            <div>
                                <label class="block text-xs font-medium text-gray-700 mb-1">Du</label>
                                <input type="date" name="startDate" required
                                    min="{{ 'today'|date('Y-m-d') }}"
                                    class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
                            </div>
                            <div>
                                <label class="block text-xs font-medium text-gray-700 mb-1">Au</label>
                                <input type="date" name="endDate" required
                                    min="{{ 'today'|date('Y-m-d') }}"
                                    class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm">
                            </div>
                            <button type="submit"
                                class="w-full bg-gray-900 hover:bg-gray-700 text-white font-semibold py-2.5 rounded-lg text-sm transition">
                                Bloquer ces dates
                            </button>
                        </form>

                        <div class="mt-4 pt-4 border-t border-gray-100 flex flex-col gap-2 text-xs">
                            <a href="{{ path('app_host_property_edit', { id: property.id }) }}"
                               class="text-center text-gray-600 hover:text-gray-900 underline">
                                Modifier l'annonce
                            </a>
                            <a href="{{ path('app_host_property_unavailability', { id: property.id }) }}"
                               class="text-center text-gray-600 hover:text-gray-900 underline">
                                Gérer toutes les indisponibilités
                            </a>
                        </div>

                    {% else %}

                        {# Vue voyageur : réserver #}
                        <p class="text-2xl font-semibold mb-4">
                            <span class="font-bold">{{ property.pricePerNight|number_format(0, ',', ' ') }} €</span>
                            <span class="text-base font-normal text-gray-600"> / nuit</span>
                        </p>
                        {% if property.cleaningFee %}
                            <p class="text-sm text-gray-500 mb-4">Frais de ménage : {{ property.cleaningFee|number_format(0, ',', ' ') }} €</p>
                        {% endif %}
                        <div class="border border-gray-300 rounded-lg mb-4">
                            <div class="grid grid-cols-2 divide-x divide-gray-300">
                                <div class="p-3">
                                    <p class="text-[10px] font-bold uppercase text-gray-800">Arrivée</p>
                                    <p class="text-sm text-gray-500">{{ property.checkinTime ? property.checkinTime|date('H:i') : '15:00' }}</p>
                                </div>
                                <div class="p-3">
                                    <p class="text-[10px] font-bold uppercase text-gray-800">Départ</p>
                                    <p class="text-sm text-gray-500">{{ property.checkoutTime ? property.checkoutTime|date('H:i') : '11:00' }}</p>
                                </div>
                            </div>
                            <div class="p-3 border-t border-gray-300">
                                <p class="text-[10px] font-bold uppercase text-gray-800">Voyageurs</p>
                                <p class="text-sm text-gray-500">Jusqu'à {{ property.maxGuests }} personnes</p>
                            </div>
                        </div>
                        <a href="{{ path('app_booking_checkout', { id: property.id }) }}"
                           class="block w-full bg-brand hover:bg-brandHover text-white font-semibold py-3 rounded-lg transition text-center">
                            Réserver
                        </a>
                        {% if property.instantBooking %}
                            <p class="text-center text-xs text-gray-500 mt-3">Réservation instantanée disponible</p>
                        {% endif %}

                    {% endif %}
                </div>
            </aside>
        </div>
    </main>
{% endblock %}
