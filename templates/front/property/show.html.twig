{% extends 'layout/app.html.twig' %}

{% set cover = property.coverMedia %}
{% set averageRating = property.averageRating %}
{% set placeholderImage = 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=1200&q=80' %}
{% set hostProfile = property.host ? property.host.profile : null %}

{% set allMedia = [] %}
{% if cover %}
    {% set allMedia = allMedia|merge([cover.fileUrl]) %}
{% else %}
    {% set allMedia = allMedia|merge([placeholderImage]) %}
{% endif %}
{% for medium in property.media %}
    {% if not cover or medium.id != cover.id %}
        {% set allMedia = allMedia|merge([medium.fileUrl]) %}
    {% endif %}
{% endfor %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-6xl mx-auto w-full">
        <a href="{{ path('app_home') }}" onclick="if(document.referrer && document.referrer.includes(window.location.host)) { history.back(); return false; }" class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-gray-900 mb-6">
            <i class="fa-solid fa-arrow-left"></i> Retour
        </a>
        <div class="mb-6 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
            <div>
                <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">{{ property.title }}</h1>
                <div class="flex flex-wrap items-center gap-2 mt-2 text-sm text-gray-600">
                    {% if averageRating %}
                        <span class="flex items-center gap-1 font-semibold text-gray-900">
                            <i class="fa-solid fa-star text-xs"></i>
                            {{ averageRating|number_format(2, ',') }}
                        </span>
                        <span>·</span>
                        <span>{{ totalReviews|default(property.reviews|length) }} avis</span>
                        <span>·</span>
                    {% endif %}
                    {% if property.address %}
                        <span>{{ property.address.city }}, {{ property.address.country }}</span>
                    {% endif %}
                </div>
            </div>
            {% if is_granted('PROPERTY_EDIT', property) %}
                <div class="shrink-0">
                    <a href="{{ path('app_host_property_edit', { id: property.id }) }}" class="inline-flex items-center gap-2 bg-white hover:bg-gray-50 text-gray-700 font-semibold px-4 py-2 border border-gray-300 rounded-lg shadow-sm transition text-sm">
                        <i class="fa-solid fa-pen text-xs"></i>
                        Modifier l'annonce
                    </a>
                </div>
            {% endif %}
        </div>

        <div class="grid grid-cols-1 md:grid-cols-4 gap-2 rounded-xl overflow-hidden mb-10 h-[300px] md:h-[480px]">
            <div class="md:col-span-2 md:row-span-2 relative cursor-pointer overflow-hidden group" onclick="openCarousel(0)">
                <img
                    src="{{ cover ? cover.fileUrl : placeholderImage }}"
                    alt="{{ property.title }}"
                    class="w-full h-full object-cover group-hover:scale-105 transition duration-300"
                >
                <div class="absolute inset-0 bg-black/10 opacity-0 group-hover:opacity-100 transition duration-300 flex items-center justify-center text-white font-semibold gap-2">
                    <i class="fa-solid fa-magnifying-glass-plus"></i>
                    Agrandir
                </div>
            </div>
            {% set imgIdx = 1 %}
            {% for medium in property.media %}
                {% if not cover or medium.id != cover.id %}
                    <div class="hidden md:block relative cursor-pointer overflow-hidden group" onclick="openCarousel({{ imgIdx }})">
                        <img src="{{ medium.fileUrl }}" alt="{{ property.title }}" class="w-full h-full object-cover group-hover:scale-105 transition duration-300">
                        <div class="absolute inset-0 bg-black/10 opacity-0 group-hover:opacity-100 transition duration-300 flex items-center justify-center text-white font-semibold gap-2">
                            <i class="fa-solid fa-magnifying-glass-plus"></i>
                            Agrandir
                        </div>
                    </div>
                    {% set imgIdx = imgIdx + 1 %}
                {% endif %}
            {% endfor %}
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
            <div class="lg:col-span-2 space-y-10">
                <section class="flex items-center justify-between pb-8 border-b border-gray-200">
                    <div>
                        <h2 class="text-xl font-semibold text-gray-900">
                            Logement proposé par {{ hostProfile ? hostProfile.firstName : 'un hôte' }}
                        </h2>
                        <p class="text-gray-500 mt-1">
                            {{ property.maxGuests }} voyageur{{ property.maxGuests > 1 ? 's' : '' }}
                            · {{ property.bedrooms }} chambre{{ property.bedrooms > 1 ? 's' : '' }}
                            · {{ property.beds }} lit{{ property.beds > 1 ? 's' : '' }}
                            · {{ property.bathrooms }} salle{{ property.bathrooms > 1 ? 's' : '' }} de bain
                        </p>
                    </div>
                    <div class="w-14 h-14 rounded-full bg-gray-200 overflow-hidden shrink-0">
                        {% if hostProfile and hostProfile.avatarUrl %}
                            <img src="{{ hostProfile.avatarUrl }}" alt="Hôte" class="w-full h-full object-cover">
                        {% else %}
                            <div class="w-full h-full flex items-center justify-center text-gray-500 font-bold">
                                {{ hostProfile and hostProfile.firstName ? hostProfile.firstName|first|upper : 'H' }}
                            </div>
                        {% endif %}
                    </div>
                </section>

                {% if property.description %}
                    <section class="pb-8 border-b border-gray-200">
                        <h2 class="text-xl font-semibold text-gray-900 mb-4">À propos de ce logement</h2>
                        <p class="text-gray-700 leading-relaxed whitespace-pre-line">{{ property.description }}</p>
                    </section>
                {% endif %}

                {% if property.propertyAmenities|length > 0 %}
                    <section class="pb-8 border-b border-gray-200">
                        <h2 class="text-xl font-semibold text-gray-900 mb-4">Équipements</h2>
                        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                            {% for propertyAmenity in property.propertyAmenities %}
                                {% if propertyAmenity.amenity %}
                                    <li class="flex items-center gap-3 text-gray-700">
                                        <i class="fa-solid fa-check text-gray-900"></i>
                                        {{ propertyAmenity.amenity.label }}
                                    </li>
                                {% endif %}
                            {% endfor %}
                        </ul>
                    </section>
                {% endif %}

                <section>
                    <h2 class="text-xl font-semibold text-gray-900 mb-6">
                        Avis ({{ totalReviews|default(property.reviews|length) }})
                    </h2>
                    {% set reviewCount = totalReviews|default(property.reviews|length) %}
                    {% if reviewCount > 0 %}
                        <div class="space-y-6">
                            {% for review in reviews|default(property.reviews) %}
                                {% include 'front/property/partials/review_item.html.twig' with { review: review } %}
                            {% endfor %}
                        </div>
                        {% if reviewCount > 5 %}
                            <a href="{{ path('app_logement_reviews', { id: property.id }) }}" class="inline-block mt-6 text-sm font-semibold underline text-gray-900 hover:text-brand">
                                Tout afficher ({{ reviewCount }} avis)
                            </a>
                        {% endif %}
                    {% else %}
                        <p class="text-gray-500 text-sm">Aucun avis pour le moment.</p>
                    {% endif %}
                </section>
            </div>

            <aside class="lg:col-span-1">
                <div class="sticky top-28 border border-gray-200 rounded-xl shadow-lg p-6">
                    <p class="text-2xl font-semibold mb-4">
                        <span class="font-bold">{{ property.pricePerNight|number_format(0, ',', ' ') }} €</span>
                        <span class="text-base font-normal text-gray-600"> / nuit</span>
                    </p>
                    {% if property.cleaningFee %}
                        <p class="text-sm text-gray-500 mb-4">Frais de ménage : {{ property.cleaningFee|number_format(0, ',', ' ') }} €</p>
                    {% endif %}
                    <div class="border border-gray-300 rounded-lg mb-4">
                        <div class="grid grid-cols-2 divide-x divide-gray-300">
                            <div class="p-3">
                                <p class="text-[10px] font-bold uppercase text-gray-800">Arrivée</p>
                                <p class="text-sm text-gray-500">{{ property.checkinTime ? property.checkinTime|date('H:i') : '15:00' }}</p>
                            </div>
                            <div class="p-3">
                                <p class="text-[10px] font-bold uppercase text-gray-800">Départ</p>
                                <p class="text-sm text-gray-500">{{ property.checkoutTime ? property.checkoutTime|date('H:i') : '11:00' }}</p>
                            </div>
                        </div>
                        <div class="p-3 border-t border-gray-300">
                            <p class="text-[10px] font-bold uppercase text-gray-800">Voyageurs</p>
                            <p class="text-sm text-gray-500">Jusqu'à {{ property.maxGuests }} personnes</p>
                        </div>
                    </div>
                    {% if is_granted('PROPERTY_EDIT', property) %}
                        <a href="{{ path('app_host_property_edit', { id: property.id }) }}" class="block w-full bg-brand hover:bg-brandHover text-white font-semibold py-3 rounded-lg transition text-center">
                            Modifier l'annonce
                        </a>
                    {% else %}
                        <a href="{{ path('app_booking_checkout', { id: property.id }) }}" class="block w-full bg-brand hover:bg-brandHover text-white font-semibold py-3 rounded-lg transition text-center">
                            Réserver
                        </a>
                    {% endif %}
                    {% if property.instantBooking %}
                        <p class="text-center text-xs text-gray-500 mt-3">Réservation instantanée disponible</p>
                    {% endif %}
                </div>
            </aside>
        </div>
    </main>

    <!-- Modale Carrousel d'images -->
    <div id="carouselModal" class="fixed inset-0 z-50 hidden bg-black/95 backdrop-blur-sm flex flex-col justify-center items-center select-none">
        <!-- Bouton fermer -->
        <button onclick="closeCarousel()" class="absolute top-6 right-6 text-white/75 hover:text-white text-3xl focus:outline-none transition z-50">
            <i class="fa-solid fa-xmark"></i>
        </button>

        <!-- Conteneur Image Principale -->
        <div class="relative w-full max-w-4xl px-4 flex justify-center items-center">
            <!-- Bouton Précédent -->
            <button onclick="prevImage(event)" class="absolute left-6 text-white/75 hover:text-white bg-black/45 hover:bg-black/75 rounded-full w-12 h-12 flex items-center justify-center text-xl transition focus:outline-none z-50">
                <i class="fa-solid fa-chevron-left"></i>
            </button>

            <!-- L'image -->
            <img id="carouselImage" src="" alt="Aperçu logement" class="max-h-[80vh] max-w-full object-contain rounded-lg shadow-2xl transition-all duration-300 transform scale-95 opacity-0">

            <!-- Bouton Suivant -->
            <button onclick="nextImage(event)" class="absolute right-6 text-white/75 hover:text-white bg-black/45 hover:bg-black/75 rounded-full w-12 h-12 flex items-center justify-center text-xl transition focus:outline-none z-50">
                <i class="fa-solid fa-chevron-right"></i>
            </button>
        </div>

        <!-- Indicateur de position (ex: 2 / 5) -->
        <div class="mt-4 text-white/80 font-medium text-sm" id="carouselCounter">
            1 / 1
        </div>
    </div>

    <script>
        const images = {{ allMedia|json_encode|raw }};
        let currentIndex = 0;

        const modal = document.getElementById('carouselModal');
        const carouselImg = document.getElementById('carouselImage');
        const counter = document.getElementById('carouselCounter');

        function openCarousel(index) {
            currentIndex = index;
            modal.classList.remove('hidden');
            updateCarouselImage();
            document.body.style.overflow = 'hidden';
        }

        function closeCarousel() {
            modal.classList.add('hidden');
            document.body.style.overflow = '';
        }

        function updateCarouselImage() {
            if (images.length === 0) return;
            
            carouselImg.classList.remove('scale-100', 'opacity-100');
            carouselImg.classList.add('scale-95', 'opacity-0');

            setTimeout(() => {
                carouselImg.src = images[currentIndex];
                carouselImg.onload = () => {
                    carouselImg.classList.remove('scale-95', 'opacity-0');
                    carouselImg.classList.add('scale-100', 'opacity-100');
                };
                counter.innerText = `${currentIndex + 1} / ${images.length}`;
            }, 150);
        }

        function nextImage(event) {
            if (event) event.stopPropagation();
            currentIndex = (currentIndex + 1) % images.length;
            updateCarouselImage();
        }

        function prevImage(event) {
            if (event) event.stopPropagation();
            currentIndex = (currentIndex - 1 + images.length) % images.length;
            updateCarouselImage();
        }

        modal.addEventListener('click', (e) => {
            if (e.target === modal) {
                closeCarousel();
            }
        });

        document.addEventListener('keydown', (e) => {
            if (modal.classList.contains('hidden')) return;
            if (e.key === 'ArrowRight') {
                nextImage();
            } else if (e.key === 'ArrowLeft') {
                prevImage();
            } else if (e.key === 'Escape') {
                closeCarousel();
            }
        });
    </script>
{% endblock %}
