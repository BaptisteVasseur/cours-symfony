{% extends 'layout/app.html.twig' %}

{% block title %}Réserver — {{ property.title }}{% endblock %}

{% set cover = property.coverMedia %}
{% set placeholderImage = 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=800&q=80' %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-5xl mx-auto w-full"
          data-realtime-view="booking-checkout"
          data-realtime-property-id="{{ property.id }}">
        <a href="{{ path('app_logement_detail', { id: property.id }) }}" class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-gray-900 mb-6">
            <i class="fa-solid fa-arrow-left"></i> Retour au logement
        </a>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8"
             data-controller="booking-price"
             data-booking-price-property-id-value="{{ property.id }}"
             data-booking-price-price-per-night-value="{{ property.pricePerNight }}"
             data-booking-price-cleaning-fee-value="{{ property.cleaningFee|default('0.00') }}">
            <div class="lg:col-span-2">
                <h1 class="text-2xl font-bold text-gray-900 mb-6">Finaliser votre réservation</h1>
                <div class="bg-white border border-gray-200 rounded-2xl p-6 shadow-sm">
                    {{ form_start(form, { attr: { class: 'space-y-5', 'data-action': 'submit->booking-price#disableSubmit' } }) }}
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            {{ form_row(form.checkinDate, { label: 'Arrivée', attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm', 'data-booking-price-target': 'checkin', 'data-action': 'change->booking-price#updatePrice input->booking-price#updatePrice' } }) }}
                            {{ form_row(form.checkoutDate, { label: 'Départ', attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm', 'data-booking-price-target': 'checkout', 'data-action': 'change->booking-price#updatePrice input->booking-price#updatePrice' } }) }}
                        </div>
                        {{ form_row(form.guestsCount, { label: 'Voyageurs', attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm', min: 1, max: property.maxGuests, 'data-booking-price-target': 'guests', 'data-action': 'change->booking-price#updatePrice input->booking-price#updatePrice' } }) }}
                        <button type="submit" data-booking-price-target="submitBtn" class="w-full bg-brand hover:bg-brandHover text-white font-semibold py-3 rounded-xl disabled:opacity-50 disabled:cursor-not-allowed">Confirmer la réservation</button>
                    {{ form_end(form) }}
                </div>
            </div>
            <aside>
                <div class="border border-gray-200 rounded-2xl overflow-hidden shadow-sm sticky top-28 bg-white">
                    <img src="{{ cover ? cover.fileUrl : placeholderImage }}" alt="{{ property.title }}" class="w-full h-48 object-cover">
                    <div class="p-5">
                        <h2 class="font-semibold text-gray-900">{{ property.title }}</h2>
                        <p class="text-lg font-bold mt-2 text-gray-900">
                            {{ property.pricePerNight|number_format(0, ',', ' ') }} € <span class="text-sm font-normal text-gray-500">/ nuit</span>
                        </p>
                        <div data-booking-price-target="error" class="mt-4 p-3 bg-rose-50 border border-rose-100 text-rose-800 rounded-xl text-xs hidden"></div>

                        <div data-booking-price-target="breakdown" class="mt-4 pt-4 border-t border-gray-200 hidden space-y-2">
                            <div class="flex justify-between text-sm text-gray-600">
                                <span data-booking-price-target="nightsLabel">{{ property.pricePerNight|number_format(0, ',', ' ') }} € x 1 nuit</span>
                                <span data-booking-price-target="subtotal">0,00 €</span>
                            </div>

                            {% if property.cleaningFee and property.cleaningFee > 0 %}
                                <div class="flex justify-between text-sm text-gray-600">
                                    <span>Frais de ménage</span>
                                    <span data-booking-price-target="cleaning">{{ property.cleaningFee|number_format(0, ',', ' ') }} €</span>
                                </div>
                            {% endif %}

                            <div class="flex justify-between text-sm text-gray-600">
                                <span>Frais de service</span>
                                <span data-booking-price-target="service">0,00 €</span>
                            </div>

                            <div class="flex justify-between text-base font-bold text-gray-900 border-t border-gray-200 pt-3 mt-2">
                                <span>Total</span>
                                <span data-booking-price-target="total">0,00 €</span>
                            </div>
                        </div>
                    </div>
                </div>
            </aside>
        </div>
    </main>
{% endblock %}
