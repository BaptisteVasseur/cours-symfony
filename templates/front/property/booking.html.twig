{% extends 'layout/app.html.twig' %}

{% block title %}Réserver — {{ property.title }}{% endblock %}

{% set cover = property.coverMedia %}
{% set placeholderImage = 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=800&q=80' %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-5xl mx-auto w-full">
        <a href="{{ path('app_logement_detail', { id: property.id }) }}" class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-gray-900 mb-6">
            <i class="fa-solid fa-arrow-left"></i> Retour au logement
        </a>
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 px-4 py-3 rounded-xl text-sm {{ label == 'success' ? 'bg-emerald-50 text-emerald-800' : 'bg-red-50 text-red-800' }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <div class="lg:col-span-2">
                <h1 class="text-2xl font-bold text-gray-900 mb-6">Finaliser votre réservation</h1>
                <div class="bg-white border border-gray-200 rounded-2xl p-6 shadow-sm">
                    {{ form_start(form, { attr: { class: 'space-y-5' } }) }}
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            {{ form_row(form.checkinDate, { label: 'Arrivée', attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm' } }) }}
                            {{ form_row(form.checkoutDate, { label: 'Départ', attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm' } }) }}
                        </div>
                        {{ form_row(form.guestsCount, { label: 'Voyageurs', attr: { class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm', min: 1, max: property.maxGuests } }) }}
                        <button type="submit" class="w-full bg-brand hover:bg-brandHover text-white font-semibold py-3 rounded-xl">Confirmer la réservation</button>
                    {{ form_end(form) }}
                </div>
            </div>
            <aside>
                <div class="border border-gray-200 rounded-2xl overflow-hidden shadow-sm sticky top-28">
                    <img src="{{ cover ? cover.fileUrl : placeholderImage }}" alt="{{ property.title }}" class="w-full h-48 object-cover">
                    <div class="p-5">
                        <h2 class="font-semibold">{{ property.title }}</h2>
                        <p class="text-lg font-bold mt-2">{{ property.pricePerNight|number_format(0, ',', ' ') }} € <span class="text-sm font-normal text-gray-500">/ nuit</span></p>
                    </div>
                </div>
            </aside>
        </div>
    </main>

{# Prépare les données JSON pour JS #}
{% set bookedJson = [] %}
{% for range in bookedRanges %}
    {% set bookedJson = bookedJson|merge([{
        start: range.checkinDate|date('Y-m-d'),
        end: range.checkoutDate|date('Y-m-d')
    }]) %}
{% endfor %}

<div class="mt-8 bg-white border border-gray-200 rounded-2xl p-6 shadow-sm">
    <h2 class="text-base font-semibold text-gray-800 mb-4">
        <i class="fa-solid fa-calendar-xmark text-red-400 mr-2"></i>
        Disponibilités du logement
    </h2>
    <div id="availability-calendar" class="overflow-x-auto"></div>
</div>

<script>
const bookedRanges = {{ bookedJson|json_encode|raw }};

function generateCalendar(year, month) {
    const monthNames = ['Janvier','Février','Mars','Avril','Mai','Juin',
                        'Juillet','Août','Septembre','Octobre','Novembre','Décembre'];
    const today = new Date();
    today.setHours(0,0,0,0);

    // Calcule tous les jours occupés
    const bookedDays = new Set();
    bookedRanges.forEach(range => {
        let current = new Date(range.start);
        const end = new Date(range.end);
        while (current < end) {
            bookedDays.add(current.toISOString().split('T')[0]);
            current.setDate(current.getDate() + 1);
        }
    });

    const firstDay = new Date(year, month, 1).getDay();
    const startOffset = (firstDay === 0 ? 6 : firstDay - 1); // lundi = 0
    const daysInMonth = new Date(year, month + 1, 0).getDate();

    let html = `
        <div class="min-w-[280px]">
            <div class="flex items-center justify-between mb-3">
                <button onclick="prevMonth()" class="p-1 hover:bg-gray-100 rounded-full text-gray-500">
                    <i class="fa-solid fa-chevron-left text-xs"></i>
                </button>
                <span class="text-sm font-semibold text-gray-700">${monthNames[month]} ${year}</span>
                <button onclick="nextMonth()" class="p-1 hover:bg-gray-100 rounded-full text-gray-500">
                    <i class="fa-solid fa-chevron-right text-xs"></i>
                </button>
            </div>
            <div class="grid grid-cols-7 gap-1 text-center text-xs text-gray-400 mb-1">
                <span>Lu</span><span>Ma</span><span>Me</span>
                <span>Je</span><span>Ve</span><span>Sa</span><span>Di</span>
            </div>
            <div class="grid grid-cols-7 gap-1 text-center text-sm">
    `;

    // Cases vides avant le 1er
    for (let i = 0; i < startOffset; i++) {
        html += `<span></span>`;
    }

    for (let day = 1; day <= daysInMonth; day++) {
        const dateStr = `${year}-${String(month + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
        const date = new Date(dateStr);
        const isBooked = bookedDays.has(dateStr);
        const isPast = date < today;

        let cls = 'rounded-full w-8 h-8 flex items-center justify-center mx-auto ';
        if (isBooked) {
            cls += 'bg-red-100 text-red-400 line-through cursor-not-allowed';
        } else if (isPast) {
            cls += 'text-gray-300 cursor-not-allowed';
        } else {
            cls += 'text-gray-700 hover:bg-gray-100';
        }

        html += `<div><span class="${cls}">${day}</span></div>`;
    }

    html += `</div></div>`;
    return html;
}

let currentYear = new Date().getFullYear();
let currentMonth = new Date().getMonth();

function renderCalendar() {
    document.getElementById('availability-calendar').innerHTML =
        generateCalendar(currentYear, currentMonth);
}

function prevMonth() {
    if (currentMonth === 0) { currentMonth = 11; currentYear--; }
    else currentMonth--;
    renderCalendar();
}

function nextMonth() {
    if (currentMonth === 11) { currentMonth = 0; currentYear++; }
    else currentMonth++;
    renderCalendar();
}

renderCalendar();
</script>
{% endblock %}
