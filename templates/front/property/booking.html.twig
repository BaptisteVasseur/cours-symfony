{% extends 'layout/app.html.twig' %}

{% block title %}Réserver — {{ property.title }}{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/fr.js"></script>
{% endblock %}

{% set cover = property.coverMedia %}
{% set placeholderImage = 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=800&q=80' %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-5xl mx-auto w-full">
        <a href="{{ path('app_logement_detail', { id: property.id }) }}" class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-gray-900 mb-6">
            <i class="fa-solid fa-arrow-left"></i> Retour au logement
        </a>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 px-4 py-3 rounded-xl text-sm {{ label == 'success' ? 'bg-emerald-50 text-emerald-800' : 'bg-red-50 text-red-800' }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <div class="lg:col-span-2">
                <h1 class="text-2xl font-bold text-gray-900 mb-6">Finaliser votre réservation</h1>

                <div class="bg-white border border-gray-200 rounded-2xl p-6 shadow-sm">
                    {{ form_start(form, { attr: { class: 'space-y-5', id: 'booking-form' } }) }}

                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <div>
                                {{ form_label(form.checkinDate, 'Arrivée', { label_attr: { class: 'block text-sm font-medium text-gray-700 mb-1' } }) }}
                                {{ form_widget(form.checkinDate, { attr: {
                                    class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm',
                                    autocomplete: 'off',
                                    placeholder: "Date d'arrivée",
                                    'data-booking': 'checkin'
                                } }) }}
                                {{ form_errors(form.checkinDate) }}
                            </div>
                            <div>
                                {{ form_label(form.checkoutDate, 'Départ', { label_attr: { class: 'block text-sm font-medium text-gray-700 mb-1' } }) }}
                                {{ form_widget(form.checkoutDate, { attr: {
                                    class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm',
                                    autocomplete: 'off',
                                    placeholder: 'Date de départ',
                                    'data-booking': 'checkout'
                                } }) }}
                                {{ form_errors(form.checkoutDate) }}
                            </div>
                        </div>

                        <div>
                            {{ form_label(form.guestsCount, 'Voyageurs', { label_attr: { class: 'block text-sm font-medium text-gray-700 mb-1' } }) }}
                            {{ form_widget(form.guestsCount, { attr: {
                                class: 'w-full border border-gray-300 rounded-xl px-4 py-3 text-sm',
                                min: 1,
                                max: property.maxGuests,
                                'data-booking': 'guests'
                            } }) }}
                            <p class="text-xs text-gray-400 mt-1">Maximum {{ property.maxGuests }} voyageur(s)</p>
                            <p id="guests-error" class="hidden text-xs text-red-500 mt-1">
                                Ce logement accepte au maximum {{ property.maxGuests }} voyageur(s).
                            </p>
                            {{ form_errors(form.guestsCount) }}
                        </div>

                        <div id="price-preview" class="hidden border border-gray-100 rounded-xl p-4 bg-gray-50 text-sm space-y-1">
                            <div class="flex justify-between text-gray-600">
                                <span id="price-nights-label"></span>
                                <span id="price-subtotal"></span>
                            </div>
                            {% if property.cleaningFee %}
                                <div class="flex justify-between text-gray-600">
                                    <span>Frais de ménage</span>
                                    <span>{{ property.cleaningFee|number_format(2, ',', ' ') }} €</span>
                                </div>
                            {% endif %}
                            <div class="flex justify-between text-gray-600">
                                <span>Frais de service (12 %)</span>
                                <span id="price-service"></span>
                            </div>
                            <div class="flex justify-between font-semibold text-gray-900 border-t border-gray-200 pt-2 mt-2">
                                <span>Total</span>
                                <span id="price-total"></span>
                            </div>
                        </div>

                        <button type="submit" id="submit-btn" disabled
                            class="w-full bg-brand hover:bg-brandHover text-white font-semibold py-3 rounded-xl disabled:opacity-50 disabled:cursor-not-allowed transition-opacity">
                            Confirmer la réservation
                        </button>

                    {{ form_end(form) }}
                </div>
            </div>

            <aside>
                <div class="border border-gray-200 rounded-2xl overflow-hidden shadow-sm sticky top-28">
                    <img src="{{ cover ? cover.fileUrl : placeholderImage }}" alt="{{ property.title }}" class="w-full h-48 object-cover">
                    <div class="p-5">
                        <h2 class="font-semibold">{{ property.title }}</h2>
                        <p class="text-lg font-bold mt-2">
                            {{ property.pricePerNight|number_format(0, ',', ' ') }} €
                            <span class="text-sm font-normal text-gray-500">/ nuit</span>
                        </p>
                        {% if property.instantBooking %}
                            <p class="mt-2 text-xs text-emerald-600 font-medium">
                                <i class="fa-solid fa-bolt"></i> Réservation instantanée
                            </p>
                        {% else %}
                            <p class="mt-2 text-xs text-yellow-600 font-medium">
                                <i class="fa-solid fa-clock"></i> Confirmation sous 24h
                            </p>
                        {% endif %}
                    </div>
                </div>
            </aside>
        </div>
    </main>

    <script>
    (function () {
        var disabledDates = {{ disabledDates|json_encode|raw }};
        var pricePerNight = {{ property.pricePerNight }};
        var cleaningFee   = parseFloat('{{ property.cleaningFee ?? 0 }}') || 0;
        var maxGuests     = {{ property.maxGuests }};

        function fmt(n) {
            return n.toFixed(2).replace('.', ',') + ' €';
        }

        function init() {
            var checkinInput  = document.querySelector('[data-booking="checkin"]');
            var checkoutInput = document.querySelector('[data-booking="checkout"]');
            if (!checkinInput || !checkoutInput) return;
            if (checkinInput._flatpickr) return;

            // Forcer type=text pour bloquer le picker natif du navigateur
            checkinInput.type  = 'text';
            checkoutInput.type = 'text';

            var guestsInput  = document.querySelector('[data-booking="guests"]');
            var guestsError  = document.getElementById('guests-error');
            var submitBtn    = document.getElementById('submit-btn');
            var pricePreview = document.getElementById('price-preview');

            var checkinPicker, checkoutPicker;

            function updatePricePreview() {
                if (!checkinPicker.selectedDates[0] || !checkoutPicker.selectedDates[0]) {
                    pricePreview.classList.add('hidden');
                    return;
                }
                var nights = Math.round(
                    (checkoutPicker.selectedDates[0] - checkinPicker.selectedDates[0]) / 86400000
                );
                if (nights <= 0) { pricePreview.classList.add('hidden'); return; }

                var subtotal = pricePerNight * nights;
                var service  = Math.round(subtotal * 0.12 * 100) / 100;
                var total    = subtotal + cleaningFee + service;

                document.getElementById('price-nights-label').textContent =
                    pricePerNight + ' € × ' + nights + ' nuit' + (nights > 1 ? 's' : '');
                document.getElementById('price-subtotal').textContent = fmt(subtotal);
                document.getElementById('price-service').textContent  = fmt(service);
                document.getElementById('price-total').textContent    = fmt(total);
                pricePreview.classList.remove('hidden');
            }

            function validateForm() {
                var hasCheckin  = checkinPicker.selectedDates.length > 0;
                var hasCheckout = checkoutPicker.selectedDates.length > 0;
                var guests      = parseInt(guestsInput.value, 10) || 0;
                submitBtn.disabled = !(hasCheckin && hasCheckout && guests >= 1 && guests <= maxGuests);
            }

            checkinPicker = flatpickr(checkinInput, {
                locale:     flatpickr.l10ns.fr,
                dateFormat: 'Y-m-d',
                altInput:   true,
                altFormat:  'j F Y',
                minDate:    'today',
                disable:    disabledDates,
                onChange: function (dates) {
                    if (dates.length > 0) {
                        var next = new Date(dates[0]);
                        next.setDate(next.getDate() + 1);
                        checkoutPicker.set('minDate', next);
                        checkoutPicker.clear();
                    }
                    updatePricePreview();
                    validateForm();
                }
            });

            checkoutPicker = flatpickr(checkoutInput, {
                locale:     flatpickr.l10ns.fr,
                dateFormat: 'Y-m-d',
                altInput:   true,
                altFormat:  'j F Y',
                minDate:    'today',
                disable:    disabledDates,
                onChange: function () {
                    updatePricePreview();
                    validateForm();
                }
            });

            guestsInput.addEventListener('input', function () {
                guestsError.classList.toggle('hidden', parseInt(this.value, 10) <= maxGuests);
                validateForm();
            });
        }

        document.addEventListener('turbo:load', init);
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', init);
        } else {
            init();
        }
    }());
    </script>
{% endblock %}
