{% extends 'layout/app.html.twig' %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-5xl mx-auto w-full">
        <div class="mb-8">
            <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">Réservations reçues</h1>
            <p class="text-gray-500 mt-1">Demandes voyageurs sur vos logements, avec modération des réservations en attente.</p>
        </div>
        {% if reservations|length > 0 %}
            <div class="space-y-4">
                {% for reservation in reservations %}
                    {% include 'components/reservation_row.html.twig' with { reservation: reservation } %}
                {% endfor %}
            </div>
        {% else %}
            <div class="text-center py-16 border border-dashed border-gray-200 rounded-xl">
                <p class="text-gray-500">Aucune réservation reçue pour le moment.</p>
            </div>
        {% endif %}
    </main>
{% endblock %}
