{% extends 'layout/app.html.twig' %}

{% set property    = reservation.property %}
{% set cover       = property ? property.coverMedia : null %}
{% set hostProfile = property and property.host ? property.host.profile : null %}
{% set placeholderImage = 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=800&q=80' %}
{% set isInstant   = reservation.status == 'confirmed' %}
{% set isPending   = reservation.status == 'pending' %}

{% block title %}Récapitulatif de réservation{% endblock %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-4xl mx-auto w-full">

        <a href="{{ path('app_reservation_index') }}"
           class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-gray-900 mb-8 transition-colors">
            <i class="fa-solid fa-arrow-left text-xs"></i> Mes réservations
        </a>

        {# ── En-tête statut ───────────────────────────────────────────────── #}
        <div class="mb-8">
            {% if isInstant %}
                <div class="flex items-center gap-3 mb-1">
                    <span class="flex items-center justify-center w-10 h-10 rounded-full bg-emerald-100 text-emerald-700 shrink-0">
                        <i class="fa-solid fa-check"></i>
                    </span>
                    <h1 class="text-2xl md:text-3xl font-bold text-gray-900">Réservation confirmée !</h1>
                </div>
                <p class="text-gray-500 ml-13 pl-1">Votre séjour est réservé. Vous recevrez une confirmation par email.</p>
            {% elseif isPending %}
                <div class="flex items-center gap-3 mb-1">
                    <span class="flex items-center justify-center w-10 h-10 rounded-full bg-amber-100 text-amber-600 shrink-0">
                        <i class="fa-solid fa-clock"></i>
                    </span>
                    <h1 class="text-2xl md:text-3xl font-bold text-gray-900">Demande envoyée</h1>
                </div>
                <p class="text-gray-500">En attente de la confirmation de l'hôte.</p>
            {% else %}
                <h1 class="text-2xl md:text-3xl font-bold text-gray-900">Récapitulatif de réservation</h1>
            {% endif %}
        </div>

        {# ── Bannière attente ─────────────────────────────────────────────── #}
        {% if isPending %}
            <div class="mb-8 flex gap-4 bg-amber-50 border border-amber-200 rounded-2xl p-5">
                <i class="fa-solid fa-circle-info text-amber-500 text-lg mt-0.5 shrink-0"></i>
                <div>
                    <p class="font-semibold text-amber-800 mb-1">Ce logement ne propose pas la réservation instantanée</p>
                    <p class="text-sm text-amber-700">
                        Votre demande de séjour a bien été transmise à l'hôte
                        {% if hostProfile and hostProfile.firstName %}{{ hostProfile.firstName }}{% endif %}.
                        Vous serez notifié par email dès qu'il aura accepté ou refusé votre demande.
                        L'hôte a généralement 24&nbsp;h pour répondre.
                    </p>
                </div>
            </div>
        {% endif %}

        <div class="grid grid-cols-1 lg:grid-cols-5 gap-10">

            {# ── Colonne principale ───────────────────────────────────────── #}
            <div class="lg:col-span-3 space-y-6">

                {# Logement #}
                {% if property %}
                    <section class="border border-gray-200 rounded-2xl overflow-hidden">
                        <div class="flex">
                            <div class="w-32 h-28 shrink-0">
                                <img src="{{ cover ? cover.fileUrl : placeholderImage }}"
                                     alt="{{ property.title }}"
                                     class="w-full h-full object-cover">
                            </div>
                            <div class="p-4 flex flex-col justify-center">
                                <p class="text-xs font-semibold uppercase text-gray-400 mb-0.5">Logement</p>
                                <h2 class="font-semibold text-gray-900">{{ property.title }}</h2>
                                {% if property.address %}
                                    <p class="text-sm text-gray-500 mt-0.5">
                                        {{ property.address.city }}, {{ property.address.country }}
                                    </p>
                                {% endif %}
                                <a href="{{ path('app_logement_detail', { id: property.id }) }}"
                                   class="text-sm font-semibold text-brand hover:underline mt-2 inline-block">
                                    Voir le logement
                                </a>
                            </div>
                        </div>
                    </section>
                {% endif %}

                {# Détails du séjour #}
                <section class="border border-gray-200 rounded-2xl p-6">
                    <h2 class="text-base font-semibold text-gray-900 mb-4">Détails du séjour</h2>
                    <div class="grid grid-cols-2 gap-y-4 text-sm">
                        <div>
                            <p class="text-gray-400 text-xs font-semibold uppercase mb-0.5">Arrivée</p>
                            <p class="font-semibold text-gray-900">{{ reservation.checkinDate|date('d/m/Y') }}</p>
                            {% if property and property.checkinTime %}
                                <p class="text-xs text-gray-400">à partir de {{ property.checkinTime|date('H:i') }}</p>
                            {% endif %}
                        </div>
                        <div>
                            <p class="text-gray-400 text-xs font-semibold uppercase mb-0.5">Départ</p>
                            <p class="font-semibold text-gray-900">{{ reservation.checkoutDate|date('d/m/Y') }}</p>
                            {% if property and property.checkoutTime %}
                                <p class="text-xs text-gray-400">avant {{ property.checkoutTime|date('H:i') }}</p>
                            {% endif %}
                        </div>
                        <div>
                            <p class="text-gray-400 text-xs font-semibold uppercase mb-0.5">Durée</p>
                            <p class="font-semibold text-gray-900">{{ nights }} nuit{{ nights > 1 ? 's' : '' }}</p>
                        </div>
                        <div>
                            <p class="text-gray-400 text-xs font-semibold uppercase mb-0.5">Voyageurs</p>
                            <p class="font-semibold text-gray-900">{{ reservation.guestsCount }} personne{{ reservation.guestsCount > 1 ? 's' : '' }}</p>
                        </div>
                    </div>
                </section>

                {# Référence #}
                <p class="text-xs text-gray-400 px-1">
                    Référence : <span class="font-mono font-medium text-gray-600">{{ reservation.id|slice(0, 8)|upper }}</span>
                    · Créée le {{ reservation.createdAt|date('d/m/Y à H:i') }}
                </p>

                {% if reservation.status == 'cancelled' and reservation.cancellationReason %}
                    <div class="flex gap-3 bg-red-50 border border-red-200 rounded-2xl p-4">
                        <i class="fa-solid fa-circle-xmark text-red-400 mt-0.5 shrink-0"></i>
                        <div>
                            <p class="text-sm font-semibold text-red-800 mb-0.5">Réservation annulée</p>
                            <p class="text-sm text-red-700">{{ reservation.cancellationReason }}</p>
                        </div>
                    </div>
                {% endif %}

                {% if canCancel %}
                    <div class="border border-gray-200 rounded-2xl p-5">
                        <button type="button"
                            onclick="this.nextElementSibling.classList.toggle('hidden')"
                            class="flex items-center gap-2 text-sm font-semibold text-red-600 hover:text-red-800 transition">
                            <i class="fa-solid fa-xmark"></i>Annuler cette réservation
                        </button>
                        <div class="hidden mt-4 space-y-3">
                            <p class="text-sm text-gray-600">
                                Merci d'indiquer le motif de votre annulation. L'hôte en sera informé.
                            </p>
                            <form method="post" action="{{ path('app_reservation_cancel', { id: reservation.id }) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('cancel_' ~ reservation.id) }}">
                                <label class="block text-xs font-medium text-gray-700 mb-1">
                                    Motif <span class="text-red-500">*</span>
                                </label>
                                <textarea name="reason" required rows="3"
                                    placeholder="Expliquez la raison de votre annulation…"
                                    class="w-full text-sm border border-gray-300 rounded-xl px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-brand resize-none"></textarea>
                                <button type="submit"
                                    class="mt-3 w-full text-sm font-semibold py-2.5 rounded-xl bg-red-600 text-white hover:bg-red-700 transition">
                                    Confirmer l'annulation
                                </button>
                            </form>
                        </div>
                    </div>
                {% endif %}

            </div>

            {# ── Sidebar prix ─────────────────────────────────────────────── #}
            <aside class="lg:col-span-2">
                <div class="sticky top-28 border border-gray-200 rounded-2xl p-6">
                    <h2 class="text-base font-semibold text-gray-900 mb-4">Récapitulatif du prix</h2>

                    <div class="space-y-3 text-sm">
                        <div class="flex justify-between text-gray-700">
                            <span>{{ nightlyRate|number_format(0, ',', ' ') }} € × {{ nights }} nuit{{ nights > 1 ? 's' : '' }}</span>
                            <span>{{ subtotal|number_format(0, ',', ' ') }} €</span>
                        </div>
                        {% if reservation.cleaningFee %}
                            <div class="flex justify-between text-gray-700">
                                <span>Frais de ménage</span>
                                <span>{{ reservation.cleaningFee|number_format(0, ',', ' ') }} €</span>
                            </div>
                        {% endif %}
                        {% if reservation.serviceFee %}
                            <div class="flex justify-between text-gray-700">
                                <span>Frais de service</span>
                                <span>{{ reservation.serviceFee|number_format(2, ',', ' ') }} €</span>
                            </div>
                        {% endif %}
                        <div class="flex justify-between font-bold text-gray-900 text-base pt-3 border-t border-gray-200">
                            <span>Total</span>
                            <span>{{ reservation.totalPrice|number_format(2, ',', ' ') }} {{ reservation.currency|default('EUR') }}</span>
                        </div>
                    </div>

                    <div class="mt-5 pt-5 border-t border-gray-100">
                        {% if isInstant %}
                            <div class="flex items-center gap-2 text-sm text-emerald-700 font-medium">
                                <i class="fa-solid fa-shield-halved"></i>
                                Paiement sécurisé et confirmé
                            </div>
                        {% else %}
                            <div class="flex items-center gap-2 text-sm text-amber-600 font-medium">
                                <i class="fa-solid fa-clock"></i>
                                Aucun montant prélevé pour l'instant
                            </div>
                            <p class="text-xs text-gray-400 mt-1">Le paiement sera effectué après confirmation de l'hôte.</p>
                        {% endif %}
                    </div>
                </div>
            </aside>

        </div>

    </main>
{% endblock %}
