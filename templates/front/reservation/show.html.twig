{% extends 'layout/app.html.twig' %}

{% set property = reservation.property %}
{% set cover = property ? property.coverMedia : null %}
{% set guestProfile = reservation.guest ? reservation.guest.profile : null %}
{% set hostProfile = property and property.host ? property.host.profile : null %}
{% set placeholderImage = 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=800&q=80' %}

{% set statusLabels = {
    'confirmed': 'Confirmée',
    'completed': 'Terminée',
    'pending': 'En attente',
    'cancelled': 'Annulée',
} %}
{% set statusColors = {
    'confirmed': 'bg-green-100 text-green-800',
    'completed': 'bg-blue-100 text-blue-800',
    'pending': 'bg-yellow-100 text-yellow-800',
    'cancelled': 'bg-red-100 text-red-800',
} %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-4xl mx-auto w-full">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 px-4 py-3 rounded-xl text-sm {{ label == 'success' ? 'bg-emerald-50 text-emerald-800 border border-emerald-200' : 'bg-red-50 text-red-800 border border-red-200' }}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}
        
        <a href="{{ path('app_reservation_index') }}" class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-gray-900 mb-6">
            <i class="fa-solid fa-arrow-left"></i> Retour aux réservations
        </a>
        
        <div class="mb-8">
            <div class="flex flex-wrap items-center gap-3 mb-2">
                <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">Confirmation de réservation</h1>
                <span class="text-sm font-semibold px-3 py-1 rounded-full {{ statusColors[reservation.status]|default('bg-gray-100 text-gray-800') }}">
                    {{ statusLabels[reservation.status]|default(reservation.status) }}
                </span>
                
                {% if reservation.status in ['pending', 'confirmed'] %}
                    <a href="{{ path('app_reservation_cancel', { id: reservation.id }) }}" 
                       class="ml-2 inline-flex items-center gap-2 text-sm text-red-600 hover:text-red-800 border border-red-300 hover:bg-red-50 px-3 py-1 rounded-full transition">
                        <i class="fa-solid fa-ban"></i> Annuler
                    </a>
                {% endif %}
            </div>
            <p class="text-gray-500">Réservation effectuée le {{ reservation.createdAt|date('d/m/Y à H:i') }}</p>
        </div>
        
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <div class="lg:col-span-2 space-y-6">
                {% if property %}
                    <section class="border border-gray-200 rounded-xl overflow-hidden">
                        <div class="flex flex-col sm:flex-row">
                            <div class="sm:w-48 h-40 sm:h-auto shrink-0">
                                <img src="{{ cover ? cover.fileUrl : placeholderImage }}" alt="{{ property.title }}" class="w-full h-full object-cover">
                            </div>
                            <div class="p-5">
                                <h2 class="text-lg font-semibold">{{ property.title }}</h2>
                                <a href="{{ path('app_logement_detail', { id: property.id }) }}" class="text-sm font-semibold text-brand hover:underline mt-2 inline-block">Voir le logement</a>
                            </div>
                        </div>
                    </section>
                {% endif %}
                
                <section class="border border-gray-200 rounded-xl p-6">
                    <h2 class="text-lg font-semibold mb-4">Détails du séjour</h2>
                    <dl class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
                        <div><dt class="text-gray-500">Arrivée</dt><dd class="font-semibold">{{ reservation.checkinDate|date('d/m/Y') }}</dd></div>
                        <div><dt class="text-gray-500">Départ</dt><dd class="font-semibold">{{ reservation.checkoutDate|date('d/m/Y') }}</dd></div>
                        <div><dt class="text-gray-500">Voyageurs</dt><dd class="font-semibold">{{ reservation.guestsCount }}</dd></div>
                    </dl>
                    
                    {% if reservation.status in ['confirmed', 'pending', 'completed'] %}
                        <div class="mt-4 pt-4 border-t border-gray-100">
                            <a href="{{ path('app_messages_conversation_start', { reservationId: reservation.id }) }}" 
                               class="inline-flex bg-red-500 items-center gap-2 p-3 px-4 rounded-md text-md text-white hover:bg-red-700">
                                <i class="fa-regular fa-envelope"></i> Contacter l'hôte
                            </a>
                        </div>
                    {% endif %}
                </section>

                {% if reservation.statusHistory|length > 0 %}
                    <section class="border border-gray-200 rounded-xl p-6">
                        <h2 class="text-lg font-semibold mb-4 flex items-center gap-2">
                            <i class="fa-solid fa-timeline text-gray-400"></i>
                            Historique du statut
                        </h2>
                        <div class="relative">
                            <div class="absolute left-[11px] top-0 bottom-0 w-0.5 bg-gray-200"></div>
                            
                            <div class="space-y-4">
                                {% for history in reservation.statusHistory|reverse %}
                                    <div class="relative flex gap-3">
                                        <div class="relative z-10 flex-shrink-0 w-6 h-6 rounded-full flex items-center justify-center
                                            {% if history.newStatus == 'confirmed' %}bg-green-100 text-green-600
                                            {% elseif history.newStatus == 'cancelled' %}bg-red-100 text-red-600
                                            {% elseif history.newStatus == 'completed' %}bg-blue-100 text-blue-600
                                            {% elseif history.newStatus == 'pending' %}bg-yellow-100 text-yellow-600
                                            {% else %}bg-gray-100 text-gray-600{% endif %}">
                                            {% if history.newStatus == 'confirmed' %}
                                                <i class="fa-solid fa-check text-xs"></i>
                                            {% elseif history.newStatus == 'cancelled' %}
                                                <i class="fa-solid fa-ban text-xs"></i>
                                            {% elseif history.newStatus == 'completed' %}
                                                <i class="fa-solid fa-check-double text-xs"></i>
                                            {% elseif history.newStatus == 'pending' %}
                                                <i class="fa-solid fa-clock text-xs"></i>
                                            {% else %}
                                                <i class="fa-solid fa-arrow-right text-xs"></i>
                                            {% endif %}
                                        </div>
                                        
                                        <div class="flex-1 pb-3">
                                            <div class="flex flex-wrap items-baseline justify-between gap-2">
                                                <div>
                                                    <span class="font-semibold text-gray-900">
                                                        {{ history.oldStatus|default('Création')|capitalize }}
                                                        <i class="fa-solid fa-arrow-right text-xs mx-1 text-gray-400"></i>
                                                        {{ history.newStatus|capitalize }}
                                                    </span>
                                                    <span class="text-xs text-gray-500 ml-2">
                                                        {{ history.createdAt|date('d/m/Y à H:i') }}
                                                    </span>
                                                </div>
                                                <span class="text-xs text-gray-400">
                                                    par {{ history.changedBy.profile.firstName ?? history.changedBy.email }}
                                                </span>
                                            </div>
                                            
                                            {% if history.newStatus == 'cancelled' and reservation.cancellationReason %}
                                                <div class="mt-1 text-xs text-red-600 bg-red-50 p-2 rounded">
                                                    <i class="fa-solid fa-circle-info mr-1"></i>
                                                    Motif : {{ reservation.cancellationReason }}
                                                </div>
                                            {% endif %}
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>
                    </section>
                {% endif %}
            </div>
            
            <aside>
                <div class="border border-gray-200 rounded-xl p-6 sticky top-28">
                    <h2 class="text-lg font-semibold mb-4">Récapitulatif</h2>
                    <p class="text-xl font-bold">{{ reservation.totalPrice|number_format(2, ',', ' ') }} {{ reservation.currency|default('EUR') }}</p>
                </div>
            </aside>
        </div>
    </main>
{% endblock %}