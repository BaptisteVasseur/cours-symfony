{% extends 'layout/app.html.twig' %}

{% set property = reservation.property %}
{% set cover = property ? property.coverMedia : null %}
{% set guestProfile = reservation.guest ? reservation.guest.profile : null %}
{% set hostProfile = property and property.host ? property.host.profile : null %}
{% set placeholderImage = 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=800&q=80' %}

{% set statusLabels = {
    'confirmed': 'Confirmée',
    'completed': 'Terminée',
    'pending': 'En attente',
    'cancelled': 'Annulée',
} %}
{% set statusColors = {
    'confirmed': 'bg-green-100 text-green-800',
    'completed': 'bg-blue-100 text-blue-800',
    'pending': 'bg-yellow-100 text-yellow-800',
    'cancelled': 'bg-red-100 text-red-800',
} %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-4xl mx-auto w-full">
        <a href="{{ path('app_reservation_index') }}" class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-gray-900 mb-6">
            <i class="fa-solid fa-arrow-left"></i> Retour aux réservations
        </a>
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 px-4 py-3 rounded-xl text-sm {{ label == 'success' ? 'bg-emerald-50 text-emerald-800' : 'bg-red-50 text-red-800' }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}
        {% if paymentDeadline is defined and paymentDeadline %}
            <div id="payment-countdown" data-deadline="{{ paymentDeadline|date('c') }}"
                 class="mb-4 px-4 py-3 rounded-xl text-sm bg-amber-50 text-amber-800 flex items-center gap-2">
                <i class="fa-regular fa-clock"></i>
                <span>Votre réservation est en attente de paiement : il vous reste <strong id="countdown-value">15:00</strong> avant l'annulation automatique et la libération des dates.</span>
            </div>
        {% endif %}
        <div class="mb-8">
            <div class="flex flex-wrap items-center gap-3 mb-2">
                <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">Confirmation de réservation</h1>
                <span class="text-sm font-semibold px-3 py-1 rounded-full {{ statusColors[reservation.status]|default('bg-gray-100 text-gray-800') }}">
                    {{ statusLabels[reservation.status]|default(reservation.status) }}
                </span>
            </div>
            <p class="text-gray-500">Réservation effectuée le {{ reservation.createdAt|date('d/m/Y à H:i') }}</p>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <div class="lg:col-span-2 space-y-6">
                {% if property %}
                    <section class="border border-gray-200 rounded-xl overflow-hidden">
                        <div class="flex flex-col sm:flex-row">
                            <div class="sm:w-48 h-40 sm:h-auto shrink-0">
                                <img src="{{ cover ? cover.fileUrl : placeholderImage }}" alt="{{ property.title }}" class="w-full h-full object-cover">
                            </div>
                            <div class="p-5">
                                <h2 class="text-lg font-semibold">{{ property.title }}</h2>
                                <a href="{{ path('app_logement_detail', { id: property.id }) }}" class="text-sm font-semibold text-brand hover:underline mt-2 inline-block">Voir le logement</a>
                            </div>
                        </div>
                    </section>
                {% endif %}
                <section class="border border-gray-200 rounded-xl p-6">
                    <h2 class="text-lg font-semibold mb-4">Détails du séjour</h2>
                    <dl class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
                        <div><dt class="text-gray-500">Arrivée</dt><dd class="font-semibold">{{ reservation.checkinDate|date('d/m/Y') }}</dd></div>
                        <div><dt class="text-gray-500">Départ</dt><dd class="font-semibold">{{ reservation.checkoutDate|date('d/m/Y') }}</dd></div>
                        <div><dt class="text-gray-500">Voyageurs</dt><dd class="font-semibold">{{ reservation.guestsCount }}</dd></div>
                    </dl>
                </section>
                {% if reservation.status == 'cancelled' and reservation.cancellationReason %}
                    <section class="border border-red-100 bg-red-50 rounded-xl p-6">
                        <h2 class="text-lg font-semibold mb-2 text-red-800">Motif de l'annulation</h2>
                        <p class="text-sm text-red-800">{{ reservation.cancellationReason }}</p>
                    </section>
                {% endif %}
            </div>
            <aside>
                <div class="border border-gray-200 rounded-xl p-6 sticky top-28">
                    <h2 class="text-lg font-semibold mb-4">Récapitulatif</h2>
                    {% set nights = reservation.checkinDate.diff(reservation.checkoutDate).days %}
                    <dl class="space-y-2 text-sm mb-4">
                        <div class="flex justify-between"><dt class="text-gray-600">{{ nights }} nuit{{ nights > 1 ? 's' }}</dt><dd></dd></div>
                        {% if reservation.cleaningFee %}
                            <div class="flex justify-between"><dt class="text-gray-600">Frais de ménage</dt><dd>{{ reservation.cleaningFee|number_format(2, ',', ' ') }} €</dd></div>
                        {% endif %}
                        {% if reservation.serviceFee %}
                            <div class="flex justify-between"><dt class="text-gray-600">Frais de service</dt><dd>{{ reservation.serviceFee|number_format(2, ',', ' ') }} €</dd></div>
                        {% endif %}
                    </dl>
                    <p class="text-xl font-bold border-t border-gray-100 pt-3">Total : {{ reservation.totalPrice|number_format(2, ',', ' ') }} {{ reservation.currency|default('EUR') }}</p>

                    {% set isGuest = app.user is same as(reservation.guest) %}

                    {# ----- Paiement voyageur : valide la réservation (B.1) ----- #}
                    {% if reservation.status == 'pending' and isGuest %}
                        <form method="post" action="{{ path('app_reservation_pay', { id: reservation.id }) }}" class="mt-4">
                            <input type="hidden" name="_token" value="{{ csrf_token('pay-' ~ reservation.id) }}">
                            <button type="submit" class="w-full bg-brand hover:bg-brandHover text-white font-semibold py-3 rounded-xl">
                                <i class="fa-regular fa-credit-card mr-1.5"></i>Procéder au paiement
                            </button>
                        </form>
                        <p class="text-xs text-gray-400 text-center mt-2">Le paiement confirme immédiatement votre réservation.</p>
                    {% endif %}

                    {# ----- Modération hôte d'une demande en attente (B.2) ----- #}
                    {% if reservation.status == 'pending' and isHost is defined and isHost %}
                        <form method="post" action="{{ path('app_reservation_accept', { id: reservation.id }) }}" class="mt-4">
                            <input type="hidden" name="_token" value="{{ csrf_token('accept-' ~ reservation.id) }}">
                            <button type="submit" class="w-full bg-emerald-600 hover:bg-emerald-700 text-white font-semibold py-3 rounded-xl">
                                <i class="fa-solid fa-check mr-1.5"></i>Accepter la demande
                            </button>
                        </form>
                        <form method="post" action="{{ path('app_reservation_refuse', { id: reservation.id }) }}" class="mt-2">
                            <input type="hidden" name="_token" value="{{ csrf_token('refuse-' ~ reservation.id) }}">
                            <input type="text" name="reason" required placeholder="Motif du refus..."
                                   class="w-full border border-gray-300 rounded-xl px-3 py-2 text-sm mb-2">
                            <button type="submit" class="w-full border border-red-300 text-red-700 hover:bg-red-50 font-semibold py-2.5 rounded-xl">
                                <i class="fa-solid fa-xmark mr-1.5"></i>Refuser
                            </button>
                        </form>
                    {% endif %}

                    {# ----- Annulation d'une réservation confirmée (B.3) ----- #}
                    {% if reservation.status == 'confirmed' and (isGuest or (isHost is defined and isHost)) %}
                        <form method="post" action="{{ path('app_reservation_cancel', { id: reservation.id }) }}" class="mt-4 border-t border-gray-100 pt-4"
                              onsubmit="return confirm('Annuler cette réservation ? Les dates seront libérées.');">
                            <input type="hidden" name="_token" value="{{ csrf_token('cancel-' ~ reservation.id) }}">
                            <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Motif de l'annulation</label>
                            <input type="text" name="reason" required placeholder="Motif..."
                                   class="w-full border border-gray-300 rounded-xl px-3 py-2 text-sm mb-2">
                            <button type="submit" class="w-full border border-red-300 text-red-700 hover:bg-red-50 font-semibold py-2.5 rounded-xl">
                                <i class="fa-solid fa-ban mr-1.5"></i>Annuler la réservation
                            </button>
                        </form>
                    {% endif %}
                </div>
            </aside>
        </div>
    </main>

    {% if paymentDeadline is defined and paymentDeadline %}
        <script>
            (function () {
                'use strict';
                const banner = document.getElementById('payment-countdown');
                const value = document.getElementById('countdown-value');
                const deadline = new Date(banner.dataset.deadline).getTime();

                function tick() {
                    const remaining = Math.floor((deadline - Date.now()) / 1000);
                    if (remaining <= 0) {
                        // Le rechargement déclenche l'annulation automatique côté serveur
                        window.location.reload();
                        return;
                    }
                    const m = Math.floor(remaining / 60);
                    const s = remaining % 60;
                    value.textContent = m + ':' + String(s).padStart(2, '0');
                    setTimeout(tick, 1000);
                }

                tick();
            })();
        </script>
    {% endif %}
{% endblock %}
