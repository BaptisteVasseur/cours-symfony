{% extends 'layout/app.html.twig' %}

{% set property = reservation.property %}
{% set cover = property ? property.coverMedia : null %}
{% set guestProfile = reservation.guest ? reservation.guest.profile : null %}
{% set hostProfile = property and property.host ? property.host.profile : null %}
{% set placeholderImage = 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=800&q=80' %}

{% set statusLabels = {
    'confirmed': 'Confirmee',
    'completed': 'Terminee',
    'pending': 'En attente',
    'cancelled': 'Annulee',
} %}
{% set statusColors = {
    'confirmed': 'bg-green-100 text-green-800',
    'completed': 'bg-blue-100 text-blue-800',
    'pending': 'bg-yellow-100 text-yellow-800',
    'cancelled': 'bg-red-100 text-red-800',
} %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-5xl mx-auto w-full">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 px-4 py-3 rounded-xl text-sm {{ label == 'success' ? 'bg-emerald-50 text-emerald-800' : 'bg-red-50 text-red-800' }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}

        <a href="{{ path(is_granted('RESERVATION_MANAGE', reservation) ? 'app_host_reservation_index' : 'app_reservation_index') }}" class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-gray-900 mb-6">
            <i class="fa-solid fa-arrow-left"></i> Retour aux reservations
        </a>

        <div class="mb-8">
            <div class="flex flex-wrap items-center gap-3 mb-2">
                <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">Confirmation de reservation</h1>
                <span class="text-sm font-semibold px-3 py-1 rounded-full {{ statusColors[reservation.status]|default('bg-gray-100 text-gray-800') }}">
                    {{ statusLabels[reservation.status]|default(reservation.status) }}
                </span>
            </div>
            <p class="text-gray-500">Reservation effectuee le {{ reservation.createdAt|date('d/m/Y à H:i') }}</p>
        </div>

        {% if reservation.status == 'cancelled' and reservation.cancellationReason %}
            <div class="mb-6 px-4 py-3 rounded-xl text-sm bg-red-50 text-red-800">
                Motif d'annulation : {{ reservation.cancellationReason }}
            </div>
        {% endif %}

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <div class="lg:col-span-2 space-y-6">
                {% if property %}
                    <section class="border border-gray-200 rounded-xl overflow-hidden">
                        <div class="flex flex-col sm:flex-row">
                            <div class="sm:w-48 h-40 sm:h-auto shrink-0">
                                <img src="{{ cover ? cover.fileUrl : placeholderImage }}" alt="{{ property.title }}" class="w-full h-full object-cover">
                            </div>
                            <div class="p-5">
                                <h2 class="text-lg font-semibold">{{ property.title }}</h2>
                                <a href="{{ path('app_logement_detail', { id: property.id }) }}" class="text-sm font-semibold text-brand hover:underline mt-2 inline-block">Voir le logement</a>
                            </div>
                        </div>
                    </section>
                {% endif %}

                {% if is_granted('RESERVATION_MANAGE', reservation) and reservation.status == 'pending' %}
                    <section class="border border-gray-200 rounded-xl p-6 bg-gray-50">
                        <h2 class="text-lg font-semibold mb-4">Moderation de la demande</h2>
                        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
                            <form method="post" action="{{ path('app_host_reservation_accept', { id: reservation.id }) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('host_reservation_accept_' ~ reservation.id) }}">
                                <button type="submit" class="w-full bg-emerald-600 hover:bg-emerald-700 text-white font-semibold py-3 rounded-xl transition">
                                    Accepter la demande
                                </button>
                            </form>
                            <form method="post" action="{{ path('app_host_reservation_reject', { id: reservation.id }) }}" class="space-y-3">
                                <input type="hidden" name="_token" value="{{ csrf_token('host_reservation_reject_' ~ reservation.id) }}">
                                <textarea name="reason" rows="3" class="w-full border border-gray-300 rounded-xl px-4 py-3 text-sm" placeholder="Motif du refus"></textarea>
                                <button type="submit" class="w-full border border-red-200 hover:bg-red-50 text-red-700 font-semibold py-3 rounded-xl transition">
                                    Refuser la demande
                                </button>
                            </form>
                        </div>
                    </section>
                {% endif %}

                <section class="border border-gray-200 rounded-xl p-6">
                    <h2 class="text-lg font-semibold mb-4">Details du sejour</h2>
                    <dl class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
                        <div><dt class="text-gray-500">Arrivee</dt><dd class="font-semibold">{{ reservation.checkinDate|date('d/m/Y') }}</dd></div>
                        <div><dt class="text-gray-500">Depart</dt><dd class="font-semibold">{{ reservation.checkoutDate|date('d/m/Y') }}</dd></div>
                        <div><dt class="text-gray-500">Voyageurs</dt><dd class="font-semibold">{{ reservation.guestsCount }}</dd></div>
                    </dl>
                </section>

                <section class="border border-gray-200 rounded-xl p-6">
                    <h2 class="text-lg font-semibold mb-4">Participants</h2>
                    <dl class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
                        <div>
                            <dt class="text-gray-500">Voyageur</dt>
                            <dd class="font-semibold">
                                {% if guestProfile and (guestProfile.firstName or guestProfile.lastName) %}
                                    {{ guestProfile.firstName }} {{ guestProfile.lastName }}
                                {% else %}
                                    {{ reservation.guest ? reservation.guest.email : '—' }}
                                {% endif %}
                            </dd>
                        </div>
                        <div>
                            <dt class="text-gray-500">Hote</dt>
                            <dd class="font-semibold">
                                {% if hostProfile and (hostProfile.firstName or hostProfile.lastName) %}
                                    {{ hostProfile.firstName }} {{ hostProfile.lastName }}
                                {% else %}
                                    {{ property and property.host ? property.host.email : '—' }}
                                {% endif %}
                            </dd>
                        </div>
                    </dl>
                </section>

                {% if reservation.statusHistory|length > 0 %}
                    <section class="border border-gray-200 rounded-xl p-6">
                        <h2 class="text-lg font-semibold mb-4">Historique des statuts</h2>
                        <div class="space-y-3">
                            {% for history in reservation.statusHistory %}
                                <div class="flex items-center justify-between gap-4 text-sm border-b border-gray-100 pb-3 last:border-0 last:pb-0">
                                    <div>
                                        <span class="font-medium text-gray-900">
                                            {{ history.oldStatus ? statusLabels[history.oldStatus]|default(history.oldStatus) ~ ' → ' : '' }}
                                            {{ statusLabels[history.newStatus]|default(history.newStatus) }}
                                        </span>
                                        {% if history.changedBy %}
                                            <p class="text-xs text-gray-400 mt-0.5">Par {{ history.changedBy.email }}</p>
                                        {% endif %}
                                    </div>
                                    <span class="text-xs text-gray-400">{{ history.createdAt|date('d/m/Y H:i') }}</span>
                                </div>
                            {% endfor %}
                        </div>
                    </section>
                {% endif %}
            </div>

            <aside>
                <div class="border border-gray-200 rounded-xl p-6 sticky top-28">
                    <h2 class="text-lg font-semibold mb-4">Recapitulatif</h2>
                    <p class="text-xl font-bold">{{ reservation.totalPrice|number_format(2, ',', ' ') }} {{ reservation.currency|default('EUR') }}</p>
                </div>
            </aside>
        </div>
    </main>
{% endblock %}
