{% extends 'layout/app.html.twig' %}

{% set property = reservation.property %}
{% set cover = property ? property.coverMedia : null %}
{% set guestProfile = reservation.guest ? reservation.guest.profile : null %}
{% set hostProfile = property and property.host ? property.host.profile : null %}
{% set placeholderImage = 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=800&q=80' %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-4xl mx-auto w-full">
        <a href="{{ path('app_reservation_index') }}" class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-gray-900 mb-6">
            <i class="fa-solid fa-arrow-left"></i> Retour aux réservations
        </a>
        <div class="mb-8">
            <div class="flex flex-wrap items-center gap-3 mb-2">
                <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">Confirmation de réservation</h1>
                {% include 'components/status_badge.html.twig' with { status: reservation.status } %}
            </div>
            <p class="text-gray-500">Réservation effectuée le {{ reservation.createdAt|date('d/m/Y à H:i') }}</p>
        </div>
        
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <div class="lg:col-span-2 space-y-6">
                {% if property %}
                    <section class="border border-gray-200 rounded-xl overflow-hidden">
                        <div class="flex flex-col sm:flex-row">
                            <div class="sm:w-48 h-40 sm:h-auto shrink-0">
                                <img src="{{ cover ? cover.fileUrl : placeholderImage }}" alt="{{ property.title }}" class="w-full h-full object-cover">
                            </div>
                            <div class="p-5">
                                <h2 class="text-lg font-semibold">{{ property.title }}</h2>
                                <a href="{{ path('app_logement_detail', { id: property.id }) }}" class="text-sm font-semibold text-brand hover:underline mt-2 inline-block">Voir le logement</a>
                            </div>
                        </div>
                    </section>
                {% endif %}
                <section class="border border-gray-200 rounded-xl p-6">
                    <h2 class="text-lg font-semibold mb-4">Détails du séjour</h2>
                    <dl class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
                        <div><dt class="text-gray-500">Arrivée</dt><dd class="font-semibold">{{ reservation.checkinDate|date('d/m/Y') }}</dd></div>
                        <div><dt class="text-gray-500">Départ</dt><dd class="font-semibold">{{ reservation.checkoutDate|date('d/m/Y') }}</dd></div>
                        <div><dt class="text-gray-500">Voyageurs</dt><dd class="font-semibold">{{ reservation.guestsCount }}</dd></div>
                    </dl>
                </section>
            </div>
            <aside>
                <div class="border border-gray-200 rounded-xl p-6 sticky top-28">
                    <h2 class="text-lg font-semibold mb-4">Récapitulatif</h2>
                    <p class="text-xl font-bold">{{ reservation.totalPrice|number_format(2, ',', ' ') }} {{ reservation.currency|default('EUR') }}</p>
                </div>
            </aside>
        </div>
        {% if reservation.status in ['pending', 'confirmed'] %}
            <form method="post" action="{{ path('app_reservation_cancel', { id: reservation.id }) }}" class="mt-6 border-t border-gray-200 pt-5">
                <h3 class="font-semibold text-gray-900 mb-2">Annuler la réservation</h3>
                <input type="hidden" name="_token" value="{{ csrf_token('cancel' ~ reservation.id) }}">
                <div class="flex flex-col sm:flex-row gap-2">
                    <input type="text" name="reason" placeholder="Motif de l'annulation" required
                        class="flex-1 border border-gray-300 rounded-xl px-3 py-2 text-sm">
                    <button class="bg-red-600 hover:bg-red-700 text-white text-sm font-semibold px-4 py-2 rounded-xl">
                        Annuler
                    </button>
                </div>
            </form>
        {% endif %}
        {% if reservation.statusHistory|length > 0 %}
                    <section class="mt-8 pt-6 border-t border-gray-200">
                        <h2 class="text-lg font-semibold text-gray-900 mb-5">Historique de la réservation</h2>
                        <ol class="relative border-l border-gray-200 ml-2">
                            {% for entry in reservation.statusHistory %}
                                <li class="mb-6 ml-6">
                                    <span class="absolute -left-1.5 w-3 h-3 rounded-full bg-gray-300 ring-4 ring-white"></span>
                                    {% include 'components/status_badge.html.twig' with { status: entry.newStatus } %}
                                    <time class="block text-xs text-gray-500 mt-1.5">
                                        {{ entry.createdAt|date('d/m/Y à H:i') }}
                                    </time>
                                    {% if entry.changedBy %}
                                        <p class="text-xs text-gray-400">
                                            Par {{ entry.changedBy.profile ? entry.changedBy.profile.firstName : entry.changedBy.email }}
                                        </p>
                                    {% endif %}
                                </li>
                            {% endfor %}
                        </ol>
                    </section>
                {% endif %}
    </main>
{% endblock %}
