{% extends 'layout/app.html.twig' %}

{% set property = reservation.property %}
{% set cover = property ? property.coverMedia : null %}
{% set guestProfile = reservation.guest ? reservation.guest.profile : null %}
{% set hostProfile = property and property.host ? property.host.profile : null %}
{% set placeholderImage = 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=800&q=80' %}

{% set statusLabels = {
    'confirmed': 'Confirmée',
    'completed': 'Terminée',
    'pending': 'En attente',
    'cancelled': 'Annulée',
} %}
{% set statusColors = {
    'confirmed': 'bg-green-100 text-green-800',
    'completed': 'bg-blue-100 text-blue-800',
    'pending': 'bg-yellow-100 text-yellow-800',
    'cancelled': 'bg-red-100 text-red-800',
} %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-4xl mx-auto w-full">
        <a href="{{ path('app_reservation_index') }}" class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-gray-900 mb-6">
            <i class="fa-solid fa-arrow-left"></i> Retour aux réservations
        </a>
        <div class="mb-8">
            <div class="flex flex-wrap items-center gap-3 mb-2">
                <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">Confirmation de réservation</h1>
                <span class="text-sm font-semibold px-3 py-1 rounded-full {{ statusColors[reservation.status]|default('bg-gray-100 text-gray-800') }}">
                    {{ statusLabels[reservation.status]|default(reservation.status) }}
                </span>
            </div>
            <p class="text-gray-500">Réservation effectuée le {{ reservation.createdAt|date('d/m/Y à H:i') }}</p>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <div class="lg:col-span-2 space-y-6">
                {% if property %}
                    <section class="border border-gray-200 rounded-xl overflow-hidden">
                        <div class="flex flex-col sm:flex-row">
                            <div class="sm:w-48 h-40 sm:h-auto shrink-0">
                                <img src="{{ cover ? cover.fileUrl : placeholderImage }}" alt="{{ property.title }}" class="w-full h-full object-cover">
                            </div>
                            <div class="p-5">
                                <h2 class="text-lg font-semibold">{{ property.title }}</h2>
                                <a href="{{ path('app_logement_detail', { id: property.id }) }}" class="text-sm font-semibold text-brand hover:underline mt-2 inline-block">Voir le logement</a>
                            </div>
                        </div>
                    </section>
                {% endif %}
                <section class="border border-gray-200 rounded-xl p-6">
                    <h2 class="text-lg font-semibold mb-4">Détails du séjour</h2>
                    <dl class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
                        <div><dt class="text-gray-500">Arrivée</dt><dd class="font-semibold">{{ reservation.checkinDate|date('d/m/Y') }}</dd></div>
                        <div><dt class="text-gray-500">Départ</dt><dd class="font-semibold">{{ reservation.checkoutDate|date('d/m/Y') }}</dd></div>
                        <div><dt class="text-gray-500">Voyageurs</dt><dd class="font-semibold">{{ reservation.guestsCount }}</dd></div>
                    </dl>
                </section>
            </div>
            <aside>
                <div class="space-y-4">
                    <div class="border border-gray-200 rounded-xl p-6 sticky top-28">
                        <h2 class="text-lg font-semibold mb-4">Récapitulatif</h2>
                        <p class="text-xl font-bold">{{ reservation.totalPrice|number_format(2, ',', ' ') }} {{ reservation.currency|default('EUR') }}</p>
                    </div>

                    {% if reservation.status in ['confirmed', 'completed'] %}
                    <div class="border border-gray-200 rounded-xl p-5">
                        <h3 class="font-semibold text-gray-900 mb-2 text-sm">
                            <i class="fa-solid fa-calendar-plus text-brand mr-1"></i> Ajouter à mon calendrier
                        </h3>
                        <p class="text-xs text-gray-500 mb-3">
                            Téléchargez ce séjour en format .ics compatible Google Calendar, Apple Calendar, Outlook…
                        </p>
                        <a href="{{ path('app_reservation_ical', { id: reservation.id }) }}"
                           class="inline-flex items-center gap-2 border border-brand text-brand rounded-xl px-4 py-2 text-sm font-semibold hover:bg-brand/5 transition">
                            <i class="fa-solid fa-download text-xs"></i> Télécharger .ics
                        </a>
                        {% if reservation.property and reservation.property.calendarToken and reservation.property.host and reservation.property.host.id == app.user.id %}
                        <div class="mt-3 pt-3 border-t border-gray-100">
                            <p class="text-xs text-gray-500 mb-2">Abonnement calendrier (hôte) — se synchronise automatiquement</p>
                            <button type="button"
                                onclick="navigator.clipboard.writeText('{{ url('api_property_ical', { id: reservation.property.id }) }}?token={{ reservation.property.calendarToken }}').then(()=>{this.innerHTML='<i class=\'fa-solid fa-check\'></i> Copié !';}).catch(()=>{})"
                                class="inline-flex items-center gap-2 border border-gray-300 text-gray-600 rounded-xl px-4 py-2 text-sm font-medium hover:bg-gray-50 transition">
                                <i class="fa-solid fa-link text-xs"></i> Copier URL webcal
                            </button>
                        </div>
                        {% endif %}
                    </div>
                    {% endif %}

                    {% if reservation.status == 'completed' and reservation.guest and reservation.guest.id == app.user.id %}
                    {% set hasReview = reservation.property and reservation.property.reviews|filter(r => r.reviewer and r.reviewer.id == app.user.id and r.reservation and r.reservation.id == reservation.id)|length > 0 %}
                    {% if not hasReview %}
                    <div class="border border-gray-200 rounded-xl p-5">
                        <h3 class="font-semibold text-gray-900 mb-2 text-sm">Votre avis</h3>
                        <p class="text-xs text-gray-500 mb-3">Votre séjour est terminé. Partagez votre expérience !</p>
                        <a href="{{ path('app_reservation_review', { id: reservation.id }) }}"
                           class="inline-flex items-center gap-2 bg-brand hover:bg-brandHover text-white text-sm font-semibold px-5 py-2.5 rounded-xl transition">
                            <i class="fa-solid fa-star"></i> Laisser un avis
                        </a>
                    </div>
                    {% else %}
                    <div class="border border-green-100 rounded-xl p-4 bg-green-50 text-sm text-green-800">
                        <i class="fa-solid fa-circle-check mr-1"></i> Vous avez déjà laissé un avis pour ce séjour.
                    </div>
                    {% endif %}
                    {% endif %}

                    {% if reservation.status in ['pending', 'confirmed'] %}
                    <div class="border border-red-100 rounded-xl p-5">
                        <h3 class="font-semibold text-gray-900 mb-3 text-sm">Annuler cette réservation</h3>
                        <form method="post" action="{{ path('app_reservation_cancel', {id: reservation.id}) }}"
                              onsubmit="return confirm('Confirmer l\'annulation ?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('cancel_' ~ reservation.id) }}">
                            <textarea name="reason" required rows="2" placeholder="Motif d'annulation (obligatoire)"
                                      class="w-full border border-gray-300 rounded-xl px-3 py-2 text-sm focus:outline-none focus:border-gray-900 mb-3 resize-none"></textarea>
                            <button type="submit" class="w-full border border-red-300 text-red-600 rounded-xl py-2 text-sm font-semibold hover:bg-red-50 transition">
                                <i class="fa-solid fa-xmark mr-1"></i> Annuler la réservation
                            </button>
                        </form>
                    </div>
                    {% endif %}
                </div>
            </aside>
        </div>

        {% if reservation.statusHistory is not empty %}
        <div class="mt-8 border border-gray-200 rounded-xl p-6">
            <h2 class="text-lg font-semibold mb-4">Historique</h2>
            <ol class="relative border-l border-gray-200 ml-2 space-y-4">
                {% for entry in reservation.statusHistory %}
                <li class="ml-4">
                    <span class="absolute -left-1.5 w-3 h-3 rounded-full bg-brand border-2 border-white"></span>
                    <p class="text-sm font-semibold text-gray-900">
                        {{ entry.oldStatus ? entry.oldStatus ~ ' → ' : '' }}{{ entry.newStatus }}
                    </p>
                    <p class="text-xs text-gray-500">{{ entry.createdAt|date('d/m/Y à H:i') }} — {{ entry.changedBy.email }}</p>
                </li>
                {% endfor %}
            </ol>
        </div>
        {% endif %}

    </main>
{% endblock %}
