{% extends 'layout/app.html.twig' %}

{% block title %}Demandes de réservation{% endblock %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-5xl mx-auto w-full">
        <div class="mb-8">
            <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">Demandes de réservation</h1>
            <p class="text-gray-500 mt-1">Les demandes en attente sur vos logements</p>
        </div>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 px-4 py-3 rounded-xl text-sm {{ label == 'success' ? 'bg-emerald-50 text-emerald-800' : 'bg-red-50 text-red-800' }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}

        {% if reservations|length > 0 %}
            <div class="overflow-hidden border border-gray-200 rounded-2xl">
                <table class="w-full text-sm">
                    <thead class="bg-gray-50 text-left text-xs font-semibold text-gray-500 uppercase">
                        <tr>
                            <th class="px-4 py-3">Logement</th>
                            <th class="px-4 py-3">Voyageur</th>
                            <th class="px-4 py-3">Dates</th>
                            <th class="px-4 py-3">Voyageurs</th>
                            <th class="px-4 py-3">Total</th>
                            <th class="px-4 py-3 text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100">
                        {% for reservation in reservations %}
                            {% set guestProfile = reservation.guest ? reservation.guest.profile : null %}
                            {% set guestName = guestProfile and (guestProfile.firstName or guestProfile.lastName) ? (guestProfile.firstName ~ ' ' ~ guestProfile.lastName)|trim : (reservation.guest ? reservation.guest.email : '—') %}
                            {% set nights = reservation.checkinDate.diff(reservation.checkoutDate).days %}
                            <tr class="hover:bg-gray-50">
                                <td class="px-4 py-3">
                                    <a href="{{ path('app_reservation_show', { id: reservation.id }) }}" class="font-medium text-gray-900 hover:text-brand">{{ reservation.property.title }}</a>
                                </td>
                                <td class="px-4 py-3">
                                    <p class="text-gray-900">{{ guestName }}</p>
                                    {% if reservation.guest %}<p class="text-xs text-gray-500">{{ reservation.guest.email }}</p>{% endif %}
                                </td>
                                <td class="px-4 py-3 text-gray-700">
                                    {{ reservation.checkinDate|date('d/m/Y') }} → {{ reservation.checkoutDate|date('d/m/Y') }}
                                    <span class="text-xs text-gray-400 block">{{ nights }} nuit{{ nights > 1 ? 's' }}</span>
                                </td>
                                <td class="px-4 py-3 text-gray-700">{{ reservation.guestsCount }}</td>
                                <td class="px-4 py-3 font-semibold text-gray-900">{{ reservation.totalPrice|number_format(2, ',', ' ') }} {{ reservation.currency|default('EUR') }}</td>
                                <td class="px-4 py-3">
                                    <div class="flex items-center justify-end gap-2">
                                        <form method="post" action="{{ path('app_reservation_accept', { id: reservation.id }) }}">
                                            <input type="hidden" name="_token" value="{{ csrf_token('accept-' ~ reservation.id) }}">
                                            <button type="submit" class="px-3 py-1.5 rounded-lg bg-emerald-600 hover:bg-emerald-700 text-white text-xs font-semibold">
                                                <i class="fa-solid fa-check mr-1"></i>Accepter
                                            </button>
                                        </form>
                                        <button type="button" class="px-3 py-1.5 rounded-lg border border-red-300 text-red-700 hover:bg-red-50 text-xs font-semibold"
                                                onclick="document.getElementById('refuse-{{ reservation.id }}').classList.toggle('hidden')">
                                            <i class="fa-solid fa-xmark mr-1"></i>Refuser
                                        </button>
                                    </div>
                                    <form method="post" action="{{ path('app_reservation_refuse', { id: reservation.id }) }}" id="refuse-{{ reservation.id }}" class="hidden mt-2">
                                        <input type="hidden" name="_token" value="{{ csrf_token('refuse-' ~ reservation.id) }}">
                                        <input type="text" name="reason" required placeholder="Motif du refus..."
                                               class="w-full border border-gray-300 rounded-lg px-2 py-1.5 text-xs mb-1">
                                        <button type="submit" class="w-full px-3 py-1.5 rounded-lg bg-red-600 hover:bg-red-700 text-white text-xs font-semibold">Confirmer le refus</button>
                                    </form>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% else %}
            <div class="text-center py-16 border border-dashed border-gray-200 rounded-xl">
                <i class="fa-regular fa-bell text-4xl text-gray-300 mb-4"></i>
                <p class="text-gray-500">Aucune demande en attente.</p>
            </div>
        {% endif %}
    </main>
{% endblock %}
