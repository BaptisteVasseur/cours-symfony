{% extends 'layout/app.html.twig' %}

{% block title %}Annuler la réservation{% endblock %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-2xl mx-auto w-full">
        <a href="{{ path('app_reservation_show', { id: reservation.id }) }}" class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-gray-900 mb-6">
            <i class="fa-solid fa-arrow-left"></i> Retour à la réservation
        </a>

        {% set property = reservation.property %}

        <h1 class="text-2xl font-bold text-gray-900 mb-2">Annuler la réservation</h1>
        <p class="text-gray-500 text-sm mb-6">
            <strong>{{ property.title }}</strong> —
            du {{ reservation.checkinDate|date('d/m/Y') }} au {{ reservation.checkoutDate|date('d/m/Y') }}.
        </p>

        <div class="bg-amber-50 border border-amber-200 text-amber-800 rounded-xl px-4 py-3 text-sm mb-6">
            Cette action est irréversible. Le logement sera à nouveau disponible pour ces dates.
            Les deux parties seront notifiées par e-mail.
        </div>

        <div class="bg-white border border-gray-200 rounded-2xl p-6 shadow-sm">
            {{ form_start(form, { attr: { class: 'space-y-5' } }) }}
                {{ form_errors(form) }}
                {{ form_row(form.reason) }}
                <div class="flex gap-3 pt-2">
                    <button type="submit" class="px-6 py-3 bg-red-600 hover:bg-red-700 text-white font-semibold rounded-xl transition">
                        Confirmer l'annulation
                    </button>
                    <a href="{{ path('app_reservation_show', { id: reservation.id }) }}" class="px-6 py-3 border border-gray-300 text-gray-700 hover:bg-gray-50 font-semibold rounded-xl transition">
                        Retour
                    </a>
                </div>
            {{ form_end(form) }}
        </div>
    </main>
{% endblock %}
