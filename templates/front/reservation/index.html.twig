{% extends 'layout/app.html.twig' %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-5xl mx-auto w-full" data-realtime-view="reservation-index">
        <a href="{{ path('app_home') }}" class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-gray-900 mb-6">
            <i class="fa-solid fa-arrow-left"></i> Retour à l'accueil
        </a>
        <div class="mb-8">
            <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">Mes réservations</h1>
            <p class="text-gray-500 mt-1">Historique de toutes vos réservations</p>
        </div>
        {% if reservations|length > 0 %}
            <div class="space-y-4">
                {% for reservation in reservations %}
                    {% include 'components/reservation_row.html.twig' with { reservation: reservation } %}
                {% endfor %}
            </div>
        {% else %}
            <div class="text-center py-16 border border-dashed border-gray-200 rounded-xl">
                <p class="text-gray-500">Aucune réservation pour le moment.</p>
                <a href="{{ path('app_home') }}" class="inline-block mt-4 text-brand font-semibold hover:underline">Découvrir des logements</a>
            </div>
        {% endif %}
    </main>
{% endblock %}
