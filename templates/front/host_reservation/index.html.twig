{% extends 'layout/app.html.twig' %}

{% block title %}Demandes de reservation{% endblock %}

{% set statusLabels = {
    'confirmed': 'Confirmee',
    'completed': 'Terminee',
    'pending': 'En attente',
    'cancelled': 'Annulee',
} %}
{% set statusColors = {
    'confirmed': 'bg-green-100 text-green-800',
    'completed': 'bg-blue-100 text-blue-800',
    'pending': 'bg-yellow-100 text-yellow-800',
    'cancelled': 'bg-red-100 text-red-800',
} %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8 max-w-6xl mx-auto w-full">
        <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-8">
            <div>
                <h1 class="text-2xl md:text-3xl font-semibold text-gray-900">Demandes de reservation</h1>
                <p class="text-gray-500 mt-1">Demandes en attente sur vos logements</p>
            </div>
            <a href="{{ path('app_account_properties') }}" class="inline-flex items-center gap-2 text-sm font-semibold text-brand hover:underline">
                <i class="fa-solid fa-house"></i>
                Mes proprietes
            </a>
        </div>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 px-4 py-3 rounded-xl text-sm {{ label == 'success' ? 'bg-emerald-50 text-emerald-800' : 'bg-red-50 text-red-800' }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}

        {% if reservations|length > 0 %}
            <div class="space-y-6">
                {% for reservation in reservations %}
                    {% set property = reservation.property %}
                    {% set cover = property ? property.coverMedia : null %}
                    {% set guestProfile = reservation.guest ? reservation.guest.profile : null %}
                    {% set placeholderImage = 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=600&q=80' %}

                    <section class="bg-white border border-gray-200 rounded-2xl shadow-sm overflow-hidden">
                        <div class="grid grid-cols-1 lg:grid-cols-[1.7fr_1fr]">
                            <div class="p-6">
                                <div class="flex flex-col md:flex-row gap-5">
                                    <div class="w-full md:w-44 h-32 rounded-xl overflow-hidden shrink-0">
                                        <img src="{{ cover ? cover.fileUrl : placeholderImage }}" alt="{{ property ? property.title : 'Logement' }}" class="w-full h-full object-cover">
                                    </div>

                                    <div class="min-w-0 flex-grow">
                                        <div class="flex flex-wrap items-center gap-3 mb-2">
                                            <h2 class="text-lg font-semibold text-gray-900">{{ property ? property.title : 'Logement indisponible' }}</h2>
                                            <span class="text-xs font-semibold px-2.5 py-1 rounded-full {{ statusColors[reservation.status]|default('bg-gray-100 text-gray-800') }}">
                                                {{ statusLabels[reservation.status]|default(reservation.status) }}
                                            </span>
                                        </div>

                                        {% if property and property.address %}
                                            <p class="text-sm text-gray-500 mb-3">{{ property.address.city }}, {{ property.address.country }}</p>
                                        {% endif %}

                                        <dl class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm text-gray-700">
                                            <div>
                                                <dt class="text-gray-400 text-xs uppercase mb-1">Voyageur</dt>
                                                <dd class="font-medium">
                                                    {% if guestProfile and (guestProfile.firstName or guestProfile.lastName) %}
                                                        {{ guestProfile.firstName }} {{ guestProfile.lastName }}
                                                    {% else %}
                                                        {{ reservation.guest ? reservation.guest.email : '—' }}
                                                    {% endif %}
                                                </dd>
                                            </div>
                                            <div>
                                                <dt class="text-gray-400 text-xs uppercase mb-1">Montant</dt>
                                                <dd class="font-medium">{{ reservation.totalPrice|number_format(2, ',', ' ') }} {{ reservation.currency|default('EUR') }}</dd>
                                            </div>
                                            <div>
                                                <dt class="text-gray-400 text-xs uppercase mb-1">Sejour</dt>
                                                <dd class="font-medium">{{ reservation.checkinDate|date('d/m/Y') }} → {{ reservation.checkoutDate|date('d/m/Y') }}</dd>
                                            </div>
                                            <div>
                                                <dt class="text-gray-400 text-xs uppercase mb-1">Voyageurs</dt>
                                                <dd class="font-medium">{{ reservation.guestsCount }}</dd>
                                            </div>
                                        </dl>

                                        <a href="{{ path('app_reservation_show', { id: reservation.id }) }}" class="inline-flex items-center gap-2 text-sm font-semibold text-brand hover:underline mt-4">
                                            Voir le detail
                                            <i class="fa-solid fa-arrow-right text-xs"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>

                            <aside class="border-t lg:border-t-0 lg:border-l border-gray-200 bg-gray-50 p-6 space-y-4">
                                <form method="post" action="{{ path('app_host_reservation_accept', { id: reservation.id }) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('host_reservation_accept_' ~ reservation.id) }}">
                                    <button type="submit" class="w-full bg-emerald-600 hover:bg-emerald-700 text-white font-semibold py-3 rounded-xl transition">
                                        Accepter la demande
                                    </button>
                                </form>

                                <form method="post" action="{{ path('app_host_reservation_reject', { id: reservation.id }) }}" class="space-y-3">
                                    <input type="hidden" name="_token" value="{{ csrf_token('host_reservation_reject_' ~ reservation.id) }}">
                                    <div>
                                        <label for="reason-{{ reservation.id }}" class="block text-sm font-medium text-gray-700 mb-2">Motif du refus</label>
                                        <textarea id="reason-{{ reservation.id }}" name="reason" rows="3" class="w-full border border-gray-300 rounded-xl px-4 py-3 text-sm" placeholder="Expliquez brievement le refus."></textarea>
                                    </div>
                                    <button type="submit" class="w-full border border-red-200 hover:bg-red-50 text-red-700 font-semibold py-3 rounded-xl transition">
                                        Refuser la demande
                                    </button>
                                </form>
                            </aside>
                        </div>
                    </section>
                {% endfor %}
            </div>
        {% else %}
            <div class="text-center py-16 border border-dashed border-gray-200 rounded-xl">
                <i class="fa-solid fa-calendar-check text-4xl text-gray-300 mb-4"></i>
                <p class="text-gray-600 font-medium">Aucune demande en attente.</p>
                <p class="text-gray-500 text-sm mt-2">Les nouvelles demandes de reservation apparaitront ici.</p>
            </div>
        {% endif %}
    </main>
{% endblock %}
