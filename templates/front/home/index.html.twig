{% extends 'layout/app.html.twig' %}

{% block title %}StayNest — Logements de charme en France{% endblock %}

{% block content %}

{# Hero   #}
<section class="relative bg-gray-950 overflow-hidden">
    <img
        src="https://images.unsplash.com/photo-1499793983690-e29da59ef1c2?auto=format&fit=crop&w=1800&q=80"
        alt="Hero"
        class="absolute inset-0 w-full h-full object-cover opacity-60"
    >
    <div class="relative max-w-screen-xl mx-auto px-6 md:px-8 py-20 md:py-32 flex flex-col items-center text-center">
        <p class="text-brand font-semibold text-sm uppercase tracking-widest mb-3">Séjours d'exception</p>
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-white leading-tight mb-4 max-w-2xl">
            Des logements uniques,<br>des souvenirs inoubliables
        </h1>
        <p class="text-white/70 text-base md:text-lg mb-10 max-w-lg">
            Villas, chalets, appartements — trouvez l'endroit parfait pour votre prochain séjour.
        </p>

        {# Search bar inside hero   #}
        <div class="w-full max-w-3xl">
            <form action="{{ path('app_search') }}" method="get">
                <div class="bg-white rounded-2xl shadow-popup p-2 flex flex-col sm:flex-row gap-2">
                    <div class="flex-1 px-4 py-2.5">
                        <p class="text-[10px] font-bold uppercase text-gray-500 mb-1">Destination</p>
                        <input type="text" name="destination" placeholder="Où souhaitez-vous aller ?"
                            class="w-full text-sm text-gray-800 placeholder-gray-400 focus:outline-none font-medium">
                    </div>
                    <div class="hidden sm:block w-px bg-gray-100 my-2"></div>
                    <div class="sm:w-36 px-4 py-2.5">
                        <p class="text-[10px] font-bold uppercase text-gray-500 mb-1">Arrivée</p>
                        <input type="date" name="checkin" class="w-full text-sm text-gray-600 focus:outline-none bg-transparent">
                    </div>
                    <div class="hidden sm:block w-px bg-gray-100 my-2"></div>
                    <div class="sm:w-36 px-4 py-2.5">
                        <p class="text-[10px] font-bold uppercase text-gray-500 mb-1">Départ</p>
                        <input type="date" name="checkout" class="w-full text-sm text-gray-600 focus:outline-none bg-transparent">
                    </div>
                    <button type="submit"
                        class="flex items-center justify-center gap-2 bg-brand hover:bg-brandHover text-white font-semibold text-sm px-7 py-3 rounded-xl transition sm:self-center shrink-0">
                        <i class="fa-solid fa-magnifying-glass"></i>
                        <span>Rechercher</span>
                    </button>
                </div>
            </form>
        </div>

        {# Stats   #}
        <div class="flex flex-wrap justify-center gap-8 mt-10 text-white/80 text-sm">
            <span><strong class="text-white font-bold">{{ properties|length }}+</strong> logements</span>
            <span>·</span>
            <span><strong class="text-white font-bold">Toute la France</strong></span>
            <span>·</span>
            <span><strong class="text-white font-bold">Réservation sécurisée</strong></span>
        </div>
    </div>
</section>

{# Category pills   #}
<div class="border-b border-gray-100 bg-white sticky top-16 z-30">
    <div class="max-w-screen-xl mx-auto px-6 md:px-8">
        <div class="flex items-center gap-6 overflow-x-auto no-scrollbar py-4">
            {% set categories = [
                { icon: 'fa-umbrella-beach', label: 'Bord de mer' },
                { icon: 'fa-mountain', label: 'Montagne' },
                { icon: 'fa-city', label: 'Villes' },
                { icon: 'fa-water', label: 'Lac' },
                { icon: 'fa-tree', label: 'Forêt' },
                { icon: 'fa-fire', label: 'Tendances' },
                { icon: 'fa-star', label: 'Top noté' },
                { icon: 'fa-key', label: 'Instant' },
            ] %}
            {% for cat in categories %}
                <button class="flex flex-col items-center gap-1.5 min-w-max text-gray-400 hover:text-gray-800 transition group pb-1 border-b-2 border-transparent hover:border-gray-800">
                    <i class="fa-solid {{ cat.icon }} text-xl"></i>
                    <span class="text-[11px] font-semibold whitespace-nowrap">{{ cat.label }}</span>
                </button>
            {% endfor %}
        </div>
    </div>
</div>

{# Listings grid   #}
<main class="max-w-screen-xl mx-auto px-6 md:px-8 py-10 flex-grow">
    <div class="flex items-center justify-between mb-6">
        <h2 class="text-lg font-bold text-gray-900">
            {{ properties|length }} logement{{ properties|length > 1 ? 's' : '' }} disponible{{ properties|length > 1 ? 's' : '' }}
        </h2>
    </div>

    {% if properties is empty %}
        <div class="py-24 flex flex-col items-center text-center">
            <div class="w-20 h-20 bg-surface rounded-full flex items-center justify-center mb-6">
                <i class="fa-solid fa-house-circle-xmark text-3xl text-gray-300"></i>
            </div>
            <h3 class="text-xl font-bold text-gray-800 mb-2">Aucun logement disponible</h3>
            <p class="text-gray-500 text-sm max-w-xs">Revenez bientôt, de nouveaux logements sont ajoutés régulièrement.</p>
        </div>
    {% else %}
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 xl:grid-cols-4 gap-x-6 gap-y-10">
            {% for property in properties %}
                {% include 'components/card.html.twig' with { property: property } %}
            {% endfor %}
        </div>
    {% endif %}
</main>

{% endblock %}
