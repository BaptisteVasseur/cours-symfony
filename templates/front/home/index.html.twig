{% extends 'layout/app.html.twig' %}

{% block title %}Airbnb — Locations de vacances, maisons, appartements{% endblock %}

{% block content %}

{# ── Hero ── #}
<section class="relative overflow-hidden" style="min-height: 92vh;">
    <img
        src="https://images.unsplash.com/photo-1506905925346-21bda4d32df4?auto=format&fit=crop&w=1800&q=85"
        alt="Hero"
        class="absolute inset-0 w-full h-full object-cover"
        style="transform: scale(1.04);"
    >
    {# Layered overlays for editorial depth #}
    <div class="absolute inset-0" style="background: linear-gradient(160deg, rgba(13,17,23,0.72) 0%, rgba(13,17,23,0.35) 50%, rgba(13,17,23,0.65) 100%);"></div>
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at 20% 50%, rgba(230,57,70,0.08) 0%, transparent 60%);"></div>

    {# Decorative vertical rule #}
    <div class="absolute left-8 md:left-16 top-1/2 -translate-y-1/2 hidden lg:flex flex-col items-center gap-3 opacity-40">
        <div class="w-px h-16 bg-gradient-to-b from-transparent to-gold"></div>
        <span class="text-gold text-[9px] font-semibold uppercase tracking-[0.25em] rotate-90 whitespace-nowrap" style="transform: rotate(90deg); margin: 2rem 0;">France · 2026</span>
        <div class="w-px h-16 bg-gradient-to-b from-gold to-transparent"></div>
    </div>

    <div class="relative max-w-screen-xl mx-auto px-6 md:px-8 flex flex-col justify-center" style="min-height: 92vh; padding-top: 5rem; padding-bottom: 5rem;">

        {# Eyebrow #}
        <div class="flex items-center gap-3 mb-6">
            <div class="h-px w-10 bg-gold opacity-70"></div>
            <p class="text-gold text-xs font-semibold uppercase tracking-[0.25em]">Séjours d'exception</p>
        </div>

        {# Headline — editorial split layout #}
        <div class="max-w-2xl mb-4">
            <h1 class="font-display text-5xl sm:text-6xl md:text-7xl font-600 text-white leading-[1.05] tracking-tight">
                Des lieux<br>
                <span class="italic font-400" style="color: #FCA5A5;">uniques</span>,<br>
                des instants<br>inoubliables.
            </h1>
        </div>

        <p class="text-white/60 text-base md:text-lg mb-12 max-w-sm font-300 leading-relaxed">
            Villas, chalets, mas provençaux — trouvez l'adresse parfaite pour votre prochain séjour en France.
        </p>

        {# Search bar #}
        {% include 'components/search_bar.html.twig' with { variant: 'hero' } %}

        {# Stats row #}
        <div class="flex flex-wrap gap-8 text-sm mt-4">
            <div class="flex items-center gap-2 text-white/50">
                <div class="w-1 h-1 rounded-full bg-gold"></div>
                <span><strong class="text-white font-medium">{{ properties|length }}+</strong> logements</span>
            </div>
            <div class="flex items-center gap-2 text-white/50">
                <div class="w-1 h-1 rounded-full bg-gold"></div>
                <span><strong class="text-white font-medium">Toute la France</strong></span>
            </div>
            <div class="flex items-center gap-2 text-white/50">
                <div class="w-1 h-1 rounded-full bg-gold"></div>
                <span><strong class="text-white font-medium">Réservation sécurisée</strong></span>
            </div>
        </div>

    </div>

    {# Bottom fade into bg #}
    <div class="absolute bottom-0 left-0 right-0 h-32 pointer-events-none" style="background: linear-gradient(to bottom, transparent, #F5F3EE);"></div>
</section>

{# ── Category pills ── #}
<div class="bg-surface border-b border-black/[0.06] sticky top-16 z-30">
    <div class="max-w-screen-xl mx-auto px-6 md:px-8">
        <div class="flex items-center gap-1 overflow-x-auto no-scrollbar py-4">
            {% set categories = [
                { icon: 'fa-umbrella-beach', label: 'Bord de mer' },
                { icon: 'fa-mountain',        label: 'Montagne' },
                { icon: 'fa-city',            label: 'Villes' },
                { icon: 'fa-water',           label: 'Lac' },
                { icon: 'fa-tree',            label: 'Forêt' },
                { icon: 'fa-fire',            label: 'Tendances' },
                { icon: 'fa-star',            label: 'Top noté' },
                { icon: 'fa-key',             label: 'Instant' },
            ] %}
            {% for cat in categories %}
                <button class="cat-pill flex items-center gap-2 min-w-max text-ink/50 hover:text-gold border border-transparent hover:border-gold/30 transition-all px-4 py-2 rounded-full text-xs font-medium whitespace-nowrap hover:bg-gold/5">
                    <i class="fa-solid {{ cat.icon }} text-sm"></i>
                    <span>{{ cat.label }}</span>
                </button>
            {% endfor %}
        </div>
    </div>
</div>

{# ── Listings grid ── #}
<main class="max-w-screen-xl mx-auto px-6 md:px-8 py-12 flex-grow">

    <div class="flex items-end justify-between mb-10">
        <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-gold mb-1">Nos adresses</p>
            <h2 class="font-display text-2xl md:text-3xl font-600 text-ink">
                {{ properties|length }} logement{{ properties|length > 1 ? 's' : '' }} disponible{{ properties|length > 1 ? 's' : '' }}
            </h2>
        </div>
        <div class="gold-rule hidden md:block flex-1 mx-8 mt-6"></div>
        <a href="{{ path('app_search') }}" class="hidden md:inline-flex items-center gap-2 text-sm font-medium text-gold hover:text-brandHover transition shrink-0">
            Voir tout <i class="fa-solid fa-arrow-right text-xs"></i>
        </a>
    </div>

    {% if properties is empty %}
        <div class="py-24 flex flex-col items-center text-center">
            <div class="w-20 h-20 bg-white rounded-full flex items-center justify-center mb-6 shadow-card">
                <i class="fa-solid fa-house-circle-xmark text-3xl text-ink/20"></i>
            </div>
            <h3 class="font-display text-xl font-semibold text-ink mb-2">Aucun logement disponible</h3>
            <p class="text-ink/50 text-sm max-w-xs">Revenez bientôt, de nouveaux logements sont ajoutés régulièrement.</p>
        </div>
    {% else %}
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 xl:grid-cols-4 gap-x-6 gap-y-10">
            {% for property in properties %}
                {% include 'components/card.html.twig' with { property: property } %}
            {% endfor %}
        </div>
    {% endif %}
</main>

{# ── Editorial banner ── #}
<section class="relative overflow-hidden my-8 mx-6 md:mx-8 max-w-screen-xl xl:mx-auto rounded-3xl" style="height: 320px;">
    <img src="https://images.unsplash.com/photo-1571896349842-33c89424de2d?auto=format&fit=crop&w=1400&q=80"
         alt="Banner" class="absolute inset-0 w-full h-full object-cover">
    <div class="absolute inset-0" style="background: linear-gradient(90deg, rgba(13,17,23,0.85) 0%, rgba(13,17,23,0.3) 100%);"></div>
    <div class="relative h-full flex flex-col justify-center px-10 md:px-16 max-w-lg">
        <p class="text-gold text-xs font-semibold uppercase tracking-widest mb-3">Devenir hôte</p>
        <h3 class="font-display text-3xl md:text-4xl font-600 text-white leading-tight mb-4">
            Partagez votre adresse avec le monde.
        </h3>
        <a href="{{ path('app_register') }}" class="inline-flex items-center gap-2 text-sm font-semibold text-ink rounded-full px-6 py-3 w-fit transition hover:opacity-90"
           style="background: linear-gradient(135deg, #E63946, #FCA5A5); color: #FFFFFF;">
            Proposer un logement <i class="fa-solid fa-arrow-right text-xs"></i>
        </a>
    </div>
</section>

{% endblock %}
