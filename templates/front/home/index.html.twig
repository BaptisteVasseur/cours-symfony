{% extends 'layout/app.html.twig' %}

{% block content %}
    <main class="flex-grow px-6 md:px-12 py-8">
        {% include 'components/search_bar.html.twig' %}

        {# Catégories filtrantes #}
        <div class="flex items-center space-x-8 overflow-x-auto pb-4 mb-8 no-scrollbar border-b border-gray-100">
            <button type="button" data-filter="all"
                class="category-btn flex flex-col items-center space-y-2 border-b-2 border-black text-black pb-2 cursor-pointer min-w-[56px] bg-transparent transition"
                aria-pressed="true">
                <i class="fa-solid fa-globe text-xl"></i>
                <span class="text-xs font-semibold whitespace-nowrap">Tous</span>
            </button>
            <button type="button" data-filter="villa,house"
                class="category-btn flex flex-col items-center space-y-2 text-gray-500 hover:text-black border-b-2 border-transparent hover:border-black pb-2 cursor-pointer min-w-[56px] bg-transparent transition">
                <i class="fa-solid fa-umbrella-beach text-xl"></i>
                <span class="text-xs font-semibold whitespace-nowrap">Bord de mer</span>
            </button>
            <button type="button" data-filter="loft"
                class="category-btn flex flex-col items-center space-y-2 text-gray-500 hover:text-black border-b-2 border-transparent hover:border-black pb-2 cursor-pointer min-w-[56px] bg-transparent transition">
                <i class="fa-solid fa-mountain-city text-xl"></i>
                <span class="text-xs font-semibold whitespace-nowrap">Iconiques</span>
            </button>
            <button type="button" data-filter="apartment"
                class="category-btn flex flex-col items-center space-y-2 text-gray-500 hover:text-black border-b-2 border-transparent hover:border-black pb-2 cursor-pointer min-w-[56px] bg-transparent transition">
                <i class="fa-solid fa-fire text-xl"></i>
                <span class="text-xs font-semibold whitespace-nowrap">Tendances</span>
            </button>
            <button type="button" data-filter="chalet"
                class="category-btn flex flex-col items-center space-y-2 text-gray-500 hover:text-black border-b-2 border-transparent hover:border-black pb-2 cursor-pointer min-w-[56px] bg-transparent transition">
                <i class="fa-solid fa-campground text-xl"></i>
                <span class="text-xs font-semibold whitespace-nowrap">Campings</span>
            </button>
        </div>

        <div id="property-grid" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-6 gap-y-10">
            {% for property in properties %}
                {% include 'components/card.html.twig' with { property: property, favoriteIds: favoriteIds|default([]) } %}
            {% else %}
                <p class="col-span-full text-gray-500 text-sm">Aucun logement disponible.</p>
            {% endfor %}
        </div>

        <p id="no-results" class="hidden text-gray-500 text-sm mt-8">Aucun logement dans cette catégorie.</p>
    </main>

    <script>
    (function () {
        const buttons = document.querySelectorAll('.category-btn');
        const cards   = document.querySelectorAll('#property-grid [data-property-type]');
        const noRes   = document.getElementById('no-results');

        buttons.forEach(function (btn) {
            btn.addEventListener('click', function () {
                // Style actif
                buttons.forEach(function (b) {
                    b.classList.remove('border-black', 'text-black');
                    b.classList.add('border-transparent', 'text-gray-500');
                });
                btn.classList.remove('border-transparent', 'text-gray-500');
                btn.classList.add('border-black', 'text-black');

                var filter = btn.dataset.filter;
                var types  = filter === 'all' ? [] : filter.split(',');
                var visible = 0;

                cards.forEach(function (card) {
                    var type = card.dataset.propertyType;
                    var show = types.length === 0 || types.indexOf(type) !== -1;
                    card.style.display = show ? '' : 'none';
                    if (show) visible++;
                });

                noRes.classList.toggle('hidden', visible > 0);
            });
        });
    })();
    </script>
{% endblock %}
