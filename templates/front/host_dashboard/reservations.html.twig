{% extends 'layout/app.html.twig' %}

{% block title %}Réservations reçues - Airbnb Clone{% endblock %}

{% block content %}
    <div class="flex-grow bg-gray-50/50">
        <main class="px-6 md:px-12 py-10 max-w-6xl mx-auto w-full">
            <a href="{{ path('app_home') }}" class="inline-flex items-center gap-2 text-sm text-gray-600 hover:text-gray-900 mb-6">
                <i class="fa-solid fa-arrow-left"></i> Retour à l'accueil
            </a>

            {# Host Navigation Tabs #}
            <div class="flex items-center gap-6 border-b border-gray-200 mb-8 pb-1">
                <a href="{{ path('app_host_dashboard') }}" class="text-sm font-medium pb-4 border-b-2 border-transparent text-gray-500 hover:text-gray-900 transition">
                    Tableau de bord
                </a>
                <a href="{{ path('app_host_reservations') }}" class="text-sm font-semibold pb-4 border-b-2 border-brand text-gray-900">
                    Réservations reçues
                </a>
                <a href="{{ path('app_account_properties') }}" class="text-sm font-medium pb-4 border-b-2 border-transparent text-gray-500 hover:text-gray-900 transition">
                    Mes propriétés
                </a>
            </div>

            <div class="mb-8">
                <h1 class="text-2xl md:text-3xl font-bold text-gray-950 tracking-tight">Réservations reçues</h1>
                <p class="text-gray-500 text-sm mt-1">Gérez les demandes de séjour de vos voyageurs.</p>
            </div>

            {# Status Filters #}
            <div class="flex flex-wrap items-center gap-2 mb-8 bg-gray-100 p-1 rounded-xl w-fit">
                <a href="{{ path('app_host_reservations', { status: 'all' }) }}" class="px-4 py-2 rounded-lg text-xs font-semibold transition {% if currentStatus == 'all' %}bg-white text-gray-950 shadow-sm{% else %}text-gray-500 hover:text-gray-900{% endif %}">
                    Toutes
                </a>
                <a href="{{ path('app_host_reservations', { status: 'pending' }) }}" class="px-4 py-2 rounded-lg text-xs font-semibold transition {% if currentStatus == 'pending' %}bg-white text-gray-950 shadow-sm{% else %}text-gray-500 hover:text-gray-900{% endif %}">
                    En attente
                </a>
                <a href="{{ path('app_host_reservations', { status: 'confirmed' }) }}" class="px-4 py-2 rounded-lg text-xs font-semibold transition {% if currentStatus == 'confirmed' %}bg-white text-gray-950 shadow-sm{% else %}text-gray-500 hover:text-gray-900{% endif %}">
                    Confirmées
                </a>
                <a href="{{ path('app_host_reservations', { status: 'completed' }) }}" class="px-4 py-2 rounded-lg text-xs font-semibold transition {% if currentStatus == 'completed' %}bg-white text-gray-950 shadow-sm{% else %}text-gray-500 hover:text-gray-900{% endif %}">
                    Terminées
                </a>
                <a href="{{ path('app_host_reservations', { status: 'cancelled' }) }}" class="px-4 py-2 rounded-lg text-xs font-semibold transition {% if currentStatus == 'cancelled' %}bg-white text-gray-950 shadow-sm{% else %}text-gray-500 hover:text-gray-900{% endif %}">
                    Annulées
                </a>
            </div>

            {# Bookings List #}
            {% if reservations|length > 0 %}
                <div class="space-y-6">
                    {% for res in reservations %}
                        {% set property = res.property %}
                        {% set cover = property ? property.coverMedia : null %}
                        {% set guestProfile = res.guest ? res.guest.profile : null %}
                        {% set placeholderImage = 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=400&q=80' %}

                        <div class="bg-white border border-gray-200 rounded-2xl p-5 shadow-sm hover:shadow-md transition">
                            <div class="flex flex-col md:flex-row gap-6">
                                {# Cover Image #}
                                <div class="w-full md:w-48 h-36 rounded-xl overflow-hidden shrink-0 bg-gray-100">
                                    <img src="{{ cover ? cover.fileUrl : placeholderImage }}" alt="" class="w-full h-full object-cover">
                                </div>

                                {# Booking Details #}
                                <div class="flex-grow min-w-0 flex flex-col justify-between">
                                    <div>
                                        <div class="flex flex-wrap items-start justify-between gap-2 mb-2">
                                            <h2 class="font-bold text-gray-950 text-lg truncate">
                                                {{ property.title|default('Logement') }}
                                            </h2>
                                            <span class="text-xs font-semibold px-2.5 py-1 rounded-full 
                                                {% if res.status == 'confirmed' %}bg-green-50 text-green-700 border border-green-200/50
                                                {% elseif res.status == 'completed' %}bg-blue-50 text-blue-700 border border-blue-200/50
                                                {% elseif res.status == 'pending' %}bg-yellow-50 text-yellow-700 border border-yellow-200/50
                                                {% else %}bg-red-50 text-red-700 border border-red-200/50{% endif %}">
                                                {% if res.status == 'confirmed' %}Confirmée
                                                {% elseif res.status == 'completed' %}Terminée
                                                {% elseif res.status == 'pending' %}En attente de réponse
                                                {% else %}Annulée{% endif %}
                                            </span>
                                        </div>

                                        {% if property.address %}
                                            <p class="text-xs text-gray-400 mb-3">
                                                <i class="fa-solid fa-location-dot"></i> {{ property.address.city }}, {{ property.address.country }}
                                            </p>
                                        {% endif %}

                                        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4 bg-gray-50 p-3 rounded-xl text-xs mb-4">
                                            <div>
                                                <span class="text-gray-400 block mb-0.5">Dates du séjour</span>
                                                <span class="font-semibold text-gray-800">
                                                    {{ res.checkinDate|date('d/m/Y') }} → {{ res.checkoutDate|date('d/m/Y') }}
                                                </span>
                                            </div>
                                            <div>
                                                <span class="text-gray-400 block mb-0.5">Voyageurs</span>
                                                <span class="font-semibold text-gray-800">
                                                    {{ res.guestsCount }} voyageur{{ res.guestsCount > 1 ? 's' : '' }}
                                                </span>
                                            </div>
                                            <div>
                                                <span class="text-gray-400 block mb-0.5">Prix total</span>
                                                <span class="font-bold text-gray-900">
                                                    {{ res.totalPrice }} €
                                                </span>
                                            </div>
                                        </div>
                                        
                                        {% if res.cancellationReason %}
                                            <div class="mb-4 p-3 bg-red-50/50 border border-red-100 rounded-xl text-xs">
                                                <span class="text-red-700 font-semibold block mb-0.5">Motif d'annulation/refus :</span>
                                                <span class="text-red-600 italic">"{{ res.cancellationReason }}"</span>
                                            </div>
                                        {% endif %}
                                    </div>

                                    {# Traveler and Management Actions #}
                                    <div class="flex flex-wrap items-center justify-between gap-4 border-t border-gray-100 pt-4 mt-auto">
                                        <div class="flex items-center gap-3">
                                            <div class="w-9 h-9 bg-gray-100 rounded-full flex items-center justify-center font-bold text-gray-700 text-xs overflow-hidden">
                                                {% if guestProfile.avatarUrl %}
                                                    <img src="{{ guestProfile.avatarUrl }}" alt="" class="w-full h-full object-cover">
                                                {% else %}
                                                    {{ res.guest.profile.firstName|default(res.guest.email)|first|upper }}
                                                {% endif %}
                                            </div>
                                            <div>
                                                <p class="text-xs font-semibold text-gray-800">
                                                    {{ guestProfile.firstName|default('') }} {{ guestProfile.lastName|default('') }}
                                                </p>
                                                <p class="text-[10px] text-gray-400">
                                                    Inscrit en {{ res.guest.createdAt|date('Y') }}
                                                </p>
                                            </div>
                                        </div>

                                        <div class="flex items-center gap-2">
                                            <a href="{{ path('app_reservation_contact', { id: res.id }) }}" class="inline-flex items-center gap-1.5 px-3 py-1.5 border border-gray-200 hover:bg-gray-50 text-gray-600 font-semibold text-xs rounded-lg transition">
                                                <i class="fa-solid fa-comment"></i> Contacter
                                            </a>
                                            <a href="{{ path('app_reservation_show', { id: res.id }) }}" class="inline-flex items-center gap-1.5 px-3 py-1.5 border border-gray-200 hover:bg-gray-50 text-gray-600 font-semibold text-xs rounded-lg transition">
                                                <i class="fa-solid fa-eye"></i> Détails
                                            </a>

                                            {% if res.status == 'pending' %}
                                                <form action="{{ path('app_host_reservation_accept', { id: res.id }) }}" method="POST" class="inline">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('accept' ~ res.id) }}">
                                                    <button type="submit" class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-green-600 hover:bg-green-700 text-white font-semibold text-xs rounded-lg transition shadow-sm">
                                                        Accepter
                                                    </button>
                                                </form>
                                                <button type="button" onclick="toggleForm('decline-{{ res.id }}')" class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-red-50 border border-red-200 text-red-600 hover:bg-red-100 font-semibold text-xs rounded-lg transition">
                                                    Refuser
                                                </button>
                                            {% elseif res.status == 'confirmed' %}
                                                <button type="button" onclick="toggleForm('cancel-{{ res.id }}')" class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-red-50 border border-red-200 text-red-600 hover:bg-red-100 font-semibold text-xs rounded-lg transition">
                                                    Annuler
                                                </button>
                                            {% endif %}
                                        </div>
                                    </div>

                                    {# Decline reason form (initially hidden) #}
                                    <div id="decline-{{ res.id }}" class="hidden mt-4 pt-4 border-t border-gray-100">
                                        <form action="{{ path('app_host_reservation_decline', { id: res.id }) }}" method="POST" class="bg-gray-50 p-4 rounded-xl border border-gray-150">
                                            <input type="hidden" name="_token" value="{{ csrf_token('decline' ~ res.id) }}">
                                            <label for="decline_reason_{{ res.id }}" class="block text-xs font-semibold text-gray-700 mb-2">Motif du refus de la demande :</label>
                                            <textarea id="decline_reason_{{ res.id }}" name="cancellation_reason" rows="2" required placeholder="Veuillez expliquer la raison du refus (ex: indisponibilité de dernière minute)..." class="w-full text-xs p-2.5 border border-gray-200 rounded-lg focus:ring-1 focus:ring-brand focus:border-brand bg-white mb-3"></textarea>
                                            <div class="flex justify-end gap-2">
                                                <button type="button" onclick="toggleForm('decline-{{ res.id }}')" class="px-3 py-1.5 border border-gray-200 hover:bg-gray-100 text-gray-600 font-semibold text-xs rounded-lg transition">Annuler</button>
                                                <button type="submit" class="px-3 py-1.5 bg-red-600 hover:bg-red-700 text-white font-semibold text-xs rounded-lg transition shadow-sm">Confirmer le refus</button>
                                            </div>
                                        </form>
                                    </div>

                                    {# Cancel reason form (initially hidden) #}
                                    <div id="cancel-{{ res.id }}" class="hidden mt-4 pt-4 border-t border-gray-100">
                                        <form action="{{ path('app_host_reservation_cancel', { id: res.id }) }}" method="POST" class="bg-gray-50 p-4 rounded-xl border border-gray-150">
                                            <input type="hidden" name="_token" value="{{ csrf_token('cancel' ~ res.id) }}">
                                            <label for="cancel_reason_{{ res.id }}" class="block text-xs font-semibold text-gray-700 mb-2">Motif de l'annulation de la réservation :</label>
                                            <textarea id="cancel_reason_{{ res.id }}" name="cancellation_reason" rows="2" required placeholder="Veuillez indiquer la raison de cette annulation..." class="w-full text-xs p-2.5 border border-gray-200 rounded-lg focus:ring-1 focus:ring-brand focus:border-brand bg-white mb-3"></textarea>
                                            <div class="flex justify-end gap-2">
                                                <button type="button" onclick="toggleForm('cancel-{{ res.id }}')" class="px-3 py-1.5 border border-gray-200 hover:bg-gray-100 text-gray-600 font-semibold text-xs rounded-lg transition">Annuler</button>
                                                <button type="submit" class="px-3 py-1.5 bg-red-600 hover:bg-red-700 text-white font-semibold text-xs rounded-lg transition shadow-sm">Confirmer l'annulation</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="bg-white border border-gray-200 rounded-2xl py-16 px-4 text-center shadow-sm">
                    <i class="fa-solid fa-suitcase text-4xl text-gray-300 mb-4 block"></i>
                    <h3 class="font-bold text-gray-900 text-base mb-1">Aucune réservation</h3>
                    <p class="text-gray-500 text-sm">Il n'y a aucune réservation correspondant à ce statut pour le moment.</p>
                </div>
            {% endif %}
        </main>
    </div>

    <script>
        function toggleForm(id) {
            const formDiv = document.getElementById(id);
            if (formDiv) {
                formDiv.classList.toggle('hidden');
            }
        }
    </script>
{% endblock %}
