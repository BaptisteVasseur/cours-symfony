# Copy this file to .env.local and update values

# Doctrine & Database
DATABASE_URL="mysql://user:password@127.0.0.1:3306/airbnb_clone?serverVersion=8.0"

# Symfony Messenger - Async notifications
# Using database as transport (reliable, simple to set up)
MESSENGER_TRANSPORT_DSN="doctrine://default"

# Alternative: Using RabbitMQ (more scalable)
# MESSENGER_TRANSPORT_DSN="amqp://guest:guest@127.0.0.1:5672/%2f/messages"

# Mailer Configuration
# For development with Mailpit
MAILER_DSN="smtp://127.0.0.1:1025"

# For production with SMTP
# MAILER_DSN="smtp://user:password@smtp.example.com:587?encryption=tls"

# Optional: Email address for system notifications
MAILER_FROM_ADDRESS="noreply@airbnb-clone.local"
MAILER_FROM_NAME="Airbnb Clone"

# Session Configuration
SESSION_SAVE_PATH="%kernel.project_dir%/var/sessions/%kernel.environment%"
